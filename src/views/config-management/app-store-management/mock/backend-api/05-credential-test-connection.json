{
  "_comment": "应用商店凭据管理 - 单条凭据测试连接（测试/续期动作）。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "凭据 ID。" }
    },
    "response": {
      "success": { "type": "boolean", "required": true, "description": "连接测试是否成功。" },
      "platform": { "type": "string", "required": true, "description": "广告平台。" },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "durationMs": { "type": "number", "required": true, "description": "测试耗时（毫秒）。" },
      "statusAfterTest": {
        "type": "string",
        "required": true,
        "enum": ["正常", "即将过期", "连接异常"],
        "description": "测试后状态。"
      },
      "checks": {
        "type": "ConnectionCheckItem[]",
        "required": true,
        "description": "成功场景的检查项列表；失败场景可返回空数组。"
      },
      "errorCode": { "type": "string", "required": false, "description": "失败错误码。" },
      "errorMessage": { "type": "string", "required": false, "description": "失败错误信息。" },
      "invalidAt": {
        "type": "string",
        "required": false,
        "description": "失效时间，格式 YYYY-MM-DD HH:mm:ss。"
      },
      "suggestions": {
        "type": "string[]",
        "required": false,
        "description": "失败场景建议操作列表。"
      }
    },
    "ConnectionCheckItem": {
      "label": { "type": "string", "required": true, "description": "检查项名称。" },
      "value": { "type": "string", "required": true, "description": "检查项结果。" },
      "passed": { "type": "boolean", "required": true, "description": "检查项是否通过。" }
    }
  },
  "sampleRequest": {
    "id": "credential-gp-001"
  },
  "sampleResponse": {
    "success": true,
    "platform": "Google Play",
    "appName": "Vegoo Keyboard",
    "durationMs": 1200,
    "statusAfterTest": "正常",
    "checks": [
      { "label": "认证方式", "value": "Service Account", "passed": true },
      { "label": "应用访问权限", "value": "已授权", "passed": true },
      { "label": "订阅数据访问", "value": "可访问", "passed": true },
      { "label": "评论回复权限", "value": "可访问", "passed": true }
    ],
    "errorCode": "",
    "errorMessage": "",
    "invalidAt": "",
    "suggestions": []
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/test-connection",
    "method": "POST",
    "priority": "P0",
    "requestBody": "id",
    "responseBody": "CredentialConnectionTestResult"
  },
  "apiSuggestion": {
    "notes": [
      "失败时 success=false，checks 可为空数组，同时返回 errorCode、errorMessage、suggestions。",
      "前端按 success 决定显示成功弹窗或失败弹窗。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "点击列表行“测试”或“续期”触发。"
      }
    ],
    "defaultSelection": "由当前行 id 触发。",
    "dedupe": "同一行测试未完成前不建议重复触发。"
  }
}
