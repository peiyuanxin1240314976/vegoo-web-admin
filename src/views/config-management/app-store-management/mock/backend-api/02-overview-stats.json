{
  "_comment": "应用商店凭据管理 - 顶部统计卡片。",
  "fieldDescription": {
    "request": {
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["", "Google Play", "App Store", "Huawei AppGallery", "Samsung Galaxy Store"],
        "description": "广告平台筛选；空字符串表示全部。"
      },
      "status": {
        "type": "string",
        "required": false,
        "enum": ["", "正常", "即将过期", "连接异常"],
        "description": "状态筛选；空字符串表示全部。"
      }
    },
    "response": {
      "configured": { "type": "number", "required": true, "description": "已配置凭据组数。" },
      "normal": { "type": "number", "required": true, "description": "连接正常组数。" },
      "error": { "type": "number", "required": true, "description": "连接异常组数。" },
      "expiring": { "type": "number", "required": true, "description": "30 天内即将过期组数。" }
    }
  },
  "sampleRequest": {
    "platform": "",
    "status": ""
  },
  "sampleResponse": {
    "configured": 8,
    "normal": 5,
    "error": 2,
    "expiring": 1
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/overview-stats",
    "method": "POST",
    "priority": "P0",
    "requestBody": "platform?, status?",
    "responseBody": "AppStoreCredentialOverviewStats"
  },
  "apiSuggestion": {
    "notes": ["空数据时四个字段均返回 0，保持结构稳定。", "统计口径需与当前筛选后的列表总量一致。"]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "进入页面时加载统计卡片。",
        "prerequisite": "无"
      },
      {
        "moment": "用户操作",
        "detail": "平台/状态筛选变化后刷新统计；新增/编辑/重试成功后可刷新。"
      }
    ],
    "defaultSelection": "platform/status 默认为空字符串，表示全部。",
    "dedupe": "可与列表接口并行调用。"
  }
}
