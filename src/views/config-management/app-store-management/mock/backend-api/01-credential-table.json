{
  "_comment": "应用商店凭据管理 - 凭据表格列表。对应页面 index.vue 的 filteredCredentials。",
  "fieldDescription": {
    "request": {
      "current": { "type": "number", "required": true, "description": "当前页，从 1 开始。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["", "Google Play", "App Store", "Huawei AppGallery", "Samsung Galaxy Store"],
        "description": "广告平台筛选；空字符串表示全部。"
      },
      "status": {
        "type": "string",
        "required": false,
        "enum": ["", "正常", "即将过期", "连接异常"],
        "description": "状态筛选；空字符串表示全部。"
      }
    },
    "response": {
      "records": {
        "type": "AppStoreCredentialRow[]",
        "required": true,
        "description": "当前页凭据列表；无数据时返回空数组。"
      },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" },
      "total": { "type": "number", "required": true, "description": "符合筛选条件的总条数。" }
    },
    "AppStoreCredentialRow": {
      "id": { "type": "string", "required": true, "description": "凭据 ID。" },
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["Google Play", "App Store", "Huawei AppGallery", "Samsung Galaxy Store"],
        "description": "广告平台。"
      },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "credType": {
        "type": "string",
        "required": true,
        "enum": ["Service Account JSON", "API Key (P8)", "OAuth Client", "API Token"],
        "description": "凭据类型。"
      },
      "account": {
        "type": "string",
        "required": true,
        "description": "账号、Key 或 Token 展示值。"
      },
      "expiry": {
        "type": "string",
        "required": true,
        "description": "过期时间；永久凭据可返回“永久”。"
      },
      "lastVerify": { "type": "string", "required": true, "description": "最后验证时间文案。" },
      "verifyOk": { "type": "boolean", "required": true, "description": "最近一次验证是否成功。" },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["正常", "即将过期", "连接异常"],
        "description": "连接状态。"
      }
    }
  },
  "sampleRequest": {
    "current": 1,
    "size": 20,
    "platform": "",
    "status": ""
  },
  "sampleResponse": {
    "records": [
      {
        "id": "credential-gp-001",
        "platform": "Google Play",
        "appName": "Vegoo Keyboard",
        "credType": "Service Account JSON",
        "account": "vegoo-sa@project.iam.gserviceaccount.com",
        "expiry": "永久",
        "lastVerify": "2026-04-13 09:50:11",
        "verifyOk": true,
        "status": "正常"
      },
      {
        "id": "credential-as-002",
        "platform": "App Store",
        "appName": "Vegoo Notes",
        "credType": "API Key (P8)",
        "account": "Key ID: XYZ789GHI",
        "expiry": "2026-05-10",
        "lastVerify": "2026-04-13 08:42:05",
        "verifyOk": true,
        "status": "即将过期"
      },
      {
        "id": "credential-hw-003",
        "platform": "Huawei AppGallery",
        "appName": "Vegoo Cleaner",
        "credType": "OAuth Client",
        "account": "Client ID: hw_vegoo_cleaner",
        "expiry": "2026-11-30",
        "lastVerify": "2026-04-12 21:12:30",
        "verifyOk": false,
        "status": "连接异常"
      },
      {
        "id": "credential-ss-004",
        "platform": "Samsung Galaxy Store",
        "appName": "Vegoo Launcher",
        "credType": "API Token",
        "account": "Token: sgst_*****8f2a",
        "expiry": "永久",
        "lastVerify": "2026-04-11 17:33:40",
        "verifyOk": false,
        "status": "连接异常"
      }
    ],
    "current": 1,
    "size": 20,
    "total": 4
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "current, size, platform?, status?",
    "responseBody": "Api.Common.PaginatedResponse<AppStoreCredentialRow>"
  },
  "apiSuggestion": {
    "notes": [
      "空数据时返回 records: []、current/size 保持请求值、total=0。",
      "列表行状态决定前端按钮文案：正常=测试、即将过期=续期、连接异常=重试。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "页面进入时加载列表数据。",
        "prerequisite": "无"
      },
      {
        "moment": "用户操作",
        "detail": "平台或状态筛选变化时重载列表。"
      }
    ],
    "defaultSelection": "platform/status 默认为空字符串，表示全部。",
    "dedupe": "筛选快速切换时以最后一次请求结果为准。"
  }
}
