{
  "_comment": "应用商店凭据管理 - 新增凭据。",
  "fieldDescription": {
    "request": {
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["Google Play", "App Store", "Huawei AppGallery", "Samsung Galaxy Store"],
        "description": "广告平台。"
      },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "credInputType": {
        "type": "string",
        "required": true,
        "enum": ["file", "paste"],
        "description": "凭据输入方式：上传文件或粘贴内容。"
      },
      "credentialContent": {
        "type": "string",
        "required": true,
        "description": "凭据 JSON 文本内容。"
      },
      "fileName": {
        "type": "string",
        "required": false,
        "description": "上传文件名，credInputType=file 时建议传入。"
      },
      "expiryDate": {
        "type": "string",
        "required": false,
        "description": "过期日期，格式 YYYY-MM-DD；永久凭据可空。"
      },
      "remark": { "type": "string", "required": false, "description": "备注信息。" }
    },
    "response": {
      "id": { "type": "string", "required": true, "description": "新建凭据 ID。" },
      "created": { "type": "boolean", "required": true, "description": "是否创建成功。" }
    }
  },
  "sampleRequest": {
    "platform": "Google Play",
    "appName": "Vegoo Keyboard",
    "credInputType": "file",
    "credentialContent": "{ \"type\": \"service_account\", \"project_id\": \"vegoo-prod\" }",
    "fileName": "google-play-service-account.json",
    "expiryDate": "",
    "remark": "主账号凭据"
  },
  "sampleResponse": {
    "id": "credential-gp-101",
    "created": true
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/create",
    "method": "POST",
    "priority": "P0",
    "requestBody": "platform, appName, credInputType, credentialContent, fileName?, expiryDate?, remark?",
    "responseBody": "CreateCredentialResult"
  },
  "apiSuggestion": {
    "notes": [
      "新增成功后前端会继续调用单条测试连接接口，展示“连接成功/失败”弹窗。",
      "后端应对 credentialContent 做格式校验并返回明确错误信息。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "新增弹窗点击“保存并测试”先调用本接口；成功后再调测试接口。"
      }
    ],
    "defaultSelection": "弹窗默认 platform=Google Play、credInputType=file。",
    "dedupe": "保存按钮建议做提交中禁用，避免重复创建。"
  }
}
