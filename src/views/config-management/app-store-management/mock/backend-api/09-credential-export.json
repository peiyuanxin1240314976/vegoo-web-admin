    "response": {
      "fileId": { "type": "string", "required": true, "description": "导出文件 ID。" },
      "downloadUrl": { "type": "string", "required": true, "description": "下载地址。" },
      "expireAt": {
        "type": "string",
        "required": true,
        "description": "下载地址失效时间，ISO 8601 字符串。"
      }
    }
  },
  "sampleRequest": {
    "platform": "",
    "status": ""
