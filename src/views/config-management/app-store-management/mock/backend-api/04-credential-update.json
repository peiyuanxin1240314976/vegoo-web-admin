{
  "_comment": "应用商店凭据管理 - 编辑凭据。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "凭据 ID。" },
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["Google Play", "App Store", "Huawei AppGallery", "Samsung Galaxy Store"],
        "description": "广告平台。"
      },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "credInputType": {
        "type": "string",
        "required": true,
        "enum": ["file", "paste"],
        "description": "凭据输入方式。"
      },
      "credentialContent": {
        "type": "string",
        "required": false,
        "description": "凭据 JSON 文本；不修改时可空。"
      },
      "fileName": { "type": "string", "required": false, "description": "上传文件名。" },
      "expiryDate": {
        "type": "string",
        "required": false,
        "description": "过期日期，格式 YYYY-MM-DD；永久凭据可空。"
      },
      "remark": { "type": "string", "required": false, "description": "备注信息。" }
    },
    "response": {
      "updated": { "type": "boolean", "required": true, "description": "是否更新成功。" },
      "updatedAt": {
        "type": "string",
        "required": true,
        "description": "更新时间，ISO 8601 字符串。"
      }
    }
  },
  "sampleRequest": {
    "id": "credential-as-002",
    "platform": "App Store",
    "appName": "Vegoo Notes",
    "credInputType": "paste",
    "credentialContent": "{ \"keyId\": \"XYZ789GHI\", \"issuerId\": \"9f7aa-...\" }",
    "fileName": "",
    "expiryDate": "2026-12-31",
    "remark": "更新续期后的 P8 凭据"
  },
  "sampleResponse": {
    "updated": true,
    "updatedAt": "2026-04-13T09:58:22.000Z"
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/update",
    "method": "POST",
    "priority": "P0",
    "requestBody": "id, platform, appName, credInputType, credentialContent?, fileName?, expiryDate?, remark?",
    "responseBody": "UpdateCredentialResult"
  },
  "apiSuggestion": {
    "notes": [
      "更新成功后前端刷新列表与统计卡片。",
      "若 credentialContent 为空，后端可按“不更新密钥内容”处理。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "编辑弹窗点击“保存”触发。"
      }
    ],
    "defaultSelection": "编辑弹窗由行数据回填平台、应用、过期时间。",
    "dedupe": "保存中需禁止重复提交。"
  }
}
