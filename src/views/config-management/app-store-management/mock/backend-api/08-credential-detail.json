{
  "_comment": "应用商店凭据管理 - 查看凭据详情（查看按钮与告警详情）。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "凭据 ID。" }
    },
    "response": {
      "detail": {
        "type": "AppStoreCredentialDetail",
        "required": true,
        "description": "详情主体对象。"
      }
    },
    "AppStoreCredentialDetail": {
      "id": { "type": "string", "required": true, "description": "凭据 ID。" },
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["Google Play", "App Store", "Huawei AppGallery", "Samsung Galaxy Store"],
        "description": "广告平台。"
      },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "credType": { "type": "string", "required": true, "description": "凭据类型。" },
      "account": { "type": "string", "required": true, "description": "账号或 key 展示。" },
      "expiryDate": {
        "type": "string",
        "required": false,
        "description": "过期日期，永久凭据可空。"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["正常", "即将过期", "连接异常"],
        "description": "当前状态。"
      },
      "lastVerifyAt": {
        "type": "string",
        "required": true,
        "description": "最后验证时间，格式 YYYY-MM-DD HH:mm:ss。"
      },
      "errorMessage": {
        "type": "string",
        "required": false,
        "description": "异常信息；正常状态可为空。"
      },
      "suggestions": {
        "type": "string[]",
        "required": true,
        "description": "建议操作列表；无建议时返回空数组。"
      },
      "remark": { "type": "string", "required": false, "description": "备注信息。" }
    }
  },
  "sampleRequest": {
    "id": "credential-hw-003"
  },
  "sampleResponse": {
    "detail": {
      "id": "credential-hw-003",
      "platform": "Huawei AppGallery",
      "appName": "Vegoo Cleaner",
      "credType": "OAuth Client",
      "account": "Client ID: hw_vegoo_cleaner",
      "expiryDate": "2026-11-30",
      "status": "连接异常",
      "lastVerifyAt": "2026-04-12 21:12:30",
      "errorMessage": "Invalid credentials - Token expired",
      "suggestions": [
        "检查 OAuth Client Secret 是否更新",
        "确认应用权限是否已授予",
        "检查项目 ID 与回调配置是否一致"
      ],
      "remark": "华为市场备用凭据"
    }
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/detail",
    "method": "POST",
    "priority": "P1",
    "requestBody": "id",
    "responseBody": "AppStoreCredentialDetailResponse"
  },
  "apiSuggestion": {
    "notes": [
      "无详情时仍返回 detail 对象结构，字段以空值或默认值填充，避免前端判空分支过多。",
      "建议保留 errorMessage 与 suggestions 供异常弹窗、详情抽屉复用。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "点击列表“查看”按钮或底部告警“查看详情”触发。"
      }
    ],
    "defaultSelection": "按当前用户点击行的 id 查询详情。",
    "dedupe": "同一 id 详情可短时缓存。"
  }
}
