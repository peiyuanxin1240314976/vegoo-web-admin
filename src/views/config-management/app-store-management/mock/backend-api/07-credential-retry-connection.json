{
  "_comment": "应用商店凭据管理 - 异常凭据重试连接。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "凭据 ID。" }
    },
    "response": {
      "retried": { "type": "boolean", "required": true, "description": "是否成功发起重试。" },
      "success": { "type": "boolean", "required": true, "description": "重试后是否连接成功。" },
      "statusAfterRetry": {
        "type": "string",
        "required": true,
        "enum": ["正常", "即将过期", "连接异常"],
        "description": "重试后的连接状态。"
      },
      "message": { "type": "string", "required": true, "description": "重试结果消息。" },
      "durationMs": { "type": "number", "required": true, "description": "重试耗时（毫秒）。" }
    }
  },
  "sampleRequest": {
    "id": "credential-hw-003"
  },
  "sampleResponse": {
    "retried": true,
    "success": true,
    "statusAfterRetry": "正常",
    "message": "重试成功，连接已恢复",
    "durationMs": 980
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/retry-connection",
    "method": "POST",
    "priority": "P1",
    "requestBody": "id",
    "responseBody": "RetryConnectionResult"
  },
  "apiSuggestion": {
    "notes": [
      "失败时 success=false 且 statusAfterRetry=连接异常，并返回明确 message。",
      "前端重试后会刷新列表与统计。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "连接异常弹窗点击“重试连接”触发。"
      }
    ],
    "defaultSelection": "仅对当前异常凭据生效。",
    "dedupe": "弹窗内可在一次重试结束后再允许二次重试。"
  }
}
