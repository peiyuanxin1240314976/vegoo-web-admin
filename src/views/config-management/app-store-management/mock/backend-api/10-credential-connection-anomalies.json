{
  "_comment": "应用商店凭据管理 - 全页级连接异常列表（底部告警条与连接异常弹窗下拉的用途）。业务唯一性：platform + appName + account。",
  "fieldDescription": {
    "request": {},
    "response": {
      "items": {
        "type": "AppStoreConnectionAnomalyItem[]",
        "required": true,
        "description": "当前连接异常的凭据列表；无异常时为空数组。"
      }
    },
    "AppStoreConnectionAnomalyItem": {
      "id": {
        "type": "string",
        "required": true,
        "description": "凭据 ID，与列表行、详情、重试接口一致。"
      },
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["Google Play", "App Store", "Huawei AppGallery", "Samsung Galaxy Store"],
        "description": "应用商店平台，与列表「平台」列一致。"
      },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "account": {
        "type": "string",
        "required": true,
        "description": "帐号/Key 展示，与列表「帐号/Key」列一致。"
      },
      "credType": { "type": "string", "required": true, "description": "凭据类型。" },
      "errorMessage": {
        "type": "string",
        "required": true,
        "description": "异常信息，用于弹窗「错误信息」展示。"
      },
      "expiredAt": {
        "type": "string",
        "required": true,
        "description": "失效时间等展示文案；推荐 `YYYY-MM-DD HH:mm:ss`；无则可用 `—`。"
      },
      "suggestions": {
        "type": "string[]",
        "required": true,
        "description": "建议操作列表；无则返回空数组。"
      }
    }
  },
  "sampleRequest": {},
  "sampleResponse": {
    "items": [
      {
        "id": "5",
        "platform": "Huawei AppGallery",
        "appName": "Vegoo Cleaner",
        "account": "Client ID: hw_vegoo_cleaner",
        "credType": "OAuth Client",
        "errorMessage": "Invalid credentials - Token expired",
        "expiredAt": "2024-01-30 22:15:32",
        "suggestions": [
          "检查 OAuth Client Secret 是否更新",
          "确认应用权限是否已授予",
          "检查项目 ID 与回调配置是否一致"
        ]
      },
      {
        "id": "6",
        "platform": "Samsung Galaxy Store",
        "appName": "Vegoo Launcher",
        "account": "Token: sgst_*****8f2a",
        "credType": "API Token",
        "errorMessage": "Gateway timeout - upstream not reachable",
        "expiredAt": "2026-04-10 09:00:00",
        "suggestions": [
          "检查 API Token 是否被吊销或轮换",
          "确认三星开发者控制台网络策略",
          "稍后重试或联系应用商店支持"
        ]
      }
    ]
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/connection-anomalies",
    "method": "POST",
    "priority": "P1",
    "requestBody": "无",
    "responseBody": "AppStoreConnectionAnomaliesData"
  },
  "apiSuggestion": {
    "notes": [
      "唯一性：同一接口内以 platform + appName + account 三元组区分一条异常连接；id 为持久凭据主键。",
      "无异常时 items 为 []，前端隐藏底部告警条。",
      "失败或超时时前端可降级为空列表并保持页面可操作。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "首屏与重拉",
        "detail": "进入页面 onMounted 请求一次；列表/测试后若需刷新可由页面再次调用。"
      },
      {
        "moment": "用户操作",
        "detail": "底部告警「查看详情」打开连接异常弹窗，下拉项与本接口 items 一致。"
      }
    ]
  }
}
