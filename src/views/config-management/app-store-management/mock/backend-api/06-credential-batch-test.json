{
  "_comment": "应用商店凭据管理 - 批量测试连接（页头按钮）。",
  "fieldDescription": {
    "request": {
      "ids": {
        "type": "string[]",
        "required": false,
        "description": "指定测试 ID 列表；空数组表示按当前筛选全量测试。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["", "Google Play", "App Store", "Huawei AppGallery", "Samsung Galaxy Store"],
        "description": "当前平台筛选；空字符串表示全部。"
      },
      "status": {
        "type": "string",
        "required": false,
        "enum": ["", "正常", "即将过期", "连接异常"],
        "description": "当前状态筛选；空字符串表示全部。"
      }
    },
    "response": {
      "taskId": { "type": "string", "required": true, "description": "批量任务 ID。" },
      "summary": {
        "type": "BatchTestSummary",
        "required": true,
        "description": "批量测试汇总信息。"
      },
      "results": {
        "type": "BatchTestResultItem[]",
        "required": true,
        "description": "批量测试结果明细；无结果时返回空数组。"
      }
    },
    "BatchTestSummary": {
      "total": { "type": "number", "required": true, "description": "总测试条数。" },
      "success": { "type": "number", "required": true, "description": "成功条数。" },
      "failed": { "type": "number", "required": true, "description": "失败条数。" },
      "durationMs": { "type": "number", "required": true, "description": "任务总耗时（毫秒）。" }
    },
    "BatchTestResultItem": {
      "id": { "type": "string", "required": true, "description": "凭据 ID。" },
      "platform": { "type": "string", "required": true, "description": "广告平台。" },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "success": { "type": "boolean", "required": true, "description": "单条测试结果。" },
      "statusAfterTest": {
        "type": "string",
        "required": true,
        "enum": ["正常", "即将过期", "连接异常"],
        "description": "测试后状态。"
      },
      "message": { "type": "string", "required": true, "description": "结果消息。" }
    }
  },
  "sampleRequest": {
    "ids": [],
    "platform": "",
    "status": ""
  },
  "sampleResponse": {
    "taskId": "batch-test-20260413-001",
    "summary": {
      "total": 4,
      "success": 2,
      "failed": 2,
      "durationMs": 3860
    },
    "results": [
      {
        "id": "credential-gp-001",
        "platform": "Google Play",
        "appName": "Vegoo Keyboard",
        "success": true,
        "statusAfterTest": "正常",
        "message": "连接成功"
      },
      {
        "id": "credential-as-002",
        "platform": "App Store",
        "appName": "Vegoo Notes",
        "success": true,
        "statusAfterTest": "即将过期",
        "message": "连接成功，证书 30 天内到期"
      },
      {
        "id": "credential-hw-003",
        "platform": "Huawei AppGallery",
        "appName": "Vegoo Cleaner",
        "success": false,
        "statusAfterTest": "连接异常",
        "message": "OAuth token 已失效"
      },
      {
        "id": "credential-ss-004",
        "platform": "Samsung Galaxy Store",
        "appName": "Vegoo Launcher",
        "success": false,
        "statusAfterTest": "连接异常",
        "message": "API Token 权限不足"
      }
    ]
  },
  "api": {
    "url": "POST /api/config-management/app-store-management/credential/test-connection-batch",
    "method": "POST",
    "priority": "P1",
    "requestBody": "ids?, platform?, status?",
    "responseBody": "BatchCredentialTestResult"
  },
  "apiSuggestion": {
    "notes": [
      "空结果时返回 summary.total=0 且 results=[]。",
      "批量结果中的 statusAfterTest 会用于刷新表格状态。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "点击页头“测试连接”按钮触发。"
      }
    ],
    "defaultSelection": "不传 ids 时按当前筛选结果全量测试。",
    "dedupe": "批量任务进行中不建议重复发起。"
  }
}
