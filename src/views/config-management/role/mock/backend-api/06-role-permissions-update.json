{
  "_comment": "角色管理 - 保存指定角色的权限配置（功能与数据合并提交，对应中间面板底部的统一保存按钮）",
  "fieldDescription": {
    "request": {
      "roleId": {
        "type": "number",
        "required": true,
        "description": "角色 ID，标识本次更新的宿主"
      },
      "permissionIds": {
        "type": "string[]",
        "required": true,
        "description": "用户在 Tab1 勾选的所有功能权限点 ID 列表"
      },
      "moduleDataScopes": {
        "type": "ModuleDataScope[]",
        "required": true,
        "description": "用户在 Tab2 配置的各模块数据权限范围"
      }
    },
    "ModuleDataScope": {
      "moduleId": { "type": "string", "required": true, "description": "模块唯一标识" },
      "dataScope": {
        "type": "string",
        "required": true,
        "description": "数据权限范围枚举标识",
        "enum": ["all", "personal", "readonly", "none"]
      }
    },
    "response": {
      "success": {
        "type": "boolean",
        "required": true,
        "description": "是否保存成功"
      }
    }
  },
  "sampleRequest": {
    "roleId": 3,
    "permissionIds": [
      "cockpit:view:kpi",
      "cockpit:op:export",
      "delivery:view:list",
      "delivery:op:create",
      "revenue:view:data",
      "revenue:op:export"
    ],
    "moduleDataScopes": [
      {
        "moduleId": "cockpit",
        "dataScope": "all"
      },
      {
        "moduleId": "delivery",
        "dataScope": "personal"
      },
      {
        "moduleId": "revenue",
        "dataScope": "readonly"
      },
      {
        "moduleId": "material",
        "dataScope": "none"
      }
    ]
  },
  "sampleResponse": {
    "success": true
  },
  "api": {
    "url": "POST /api/config-management/role/permissions-update",
    "method": "POST",
    "priority": "P0",
    "requestBody": "roleId (必填), permissionIds[], moduleDataScopes[]",
    "responseBody": "success"
  },
  "apiSuggestion": {
    "notes": [
      "保存操作属于汇总行为。尽管展示拆分了 func 和 data，由于 UI 上是同一组保存按钮，提交时应当合并为一次网络请求，以保证数据一致性（或者后端设计为分开保存亦可，由后端接口决定，当前契约以统一合并保存为准）。"
    ]
  }
}
