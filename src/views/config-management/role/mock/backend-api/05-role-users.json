{
  "_comment": "角色管理 - 右侧角色成员列表。",
  "fieldDescription": {
    "request": {
      "roleId": { "type": "number", "required": true, "description": "当前选中的角色 ID。" }
    },
    "response": {
      "items": {
        "type": "RoleUserItem[]",
        "required": true,
        "description": "角色下的成员列表，空数据时返回 []。"
      }
    },
    "RoleUserItem": {
      "id": { "type": "string", "required": true, "description": "用户 ID。" },
      "userName": { "type": "string", "required": true, "description": "用户名。" },
      "userEmail": { "type": "string", "required": true, "description": "用户邮箱。" },
      "avatarText": { "type": "string", "required": true, "description": "头像占位缩写。" },
      "statusText": { "type": "string", "required": true, "description": "状态文案。" },
      "statusClass": {
        "type": "string",
        "required": true,
        "description": "前端状态样式 class。",
        "enum": ["status-dot--active", "status-dot--offline"]
      },
      "lastActive": {
        "type": "string",
        "required": true,
        "description": "最近活跃日期，格式 YYYY-MM-DD。"
      }
    }
  },
  "sampleRequest": {
    "roleId": 3
  },
  "sampleResponse": {
    "items": [
      {
        "id": "4",
        "userName": "zhangsan",
        "userEmail": "zhangsan@vegoo.com",
        "avatarText": "ZS",
        "statusText": "活跃",
        "statusClass": "status-dot--active",
        "lastActive": "2026-04-16"
      },
      {
        "id": "5",
        "userName": "lisi",
        "userEmail": "lisi@vegoo.com",
        "avatarText": "LS",
        "statusText": "活跃",
        "statusClass": "status-dot--active",
        "lastActive": "2026-04-15"
      },
      {
        "id": "6",
        "userName": "wangwu",
        "userEmail": "wangwu@vegoo.com",
        "avatarText": "WW",
        "statusText": "离线",
        "statusClass": "status-dot--offline",
        "lastActive": "2026-04-13"
      }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/config-management/role/users",
    "method": "POST",
    "priority": "P1",
    "requestBody": "roleId",
    "responseBody": "items"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "切换左侧角色",
        "detail": "右侧成员卡片列表立即刷新。"
      }
    ],
    "defaultSelection": "成员列表只展示，不在当前页面做真正的成员编辑提交。",
    "dedupe": "与摘要接口并行请求即可。"
  },
  "apiSuggestion": {
    "notes": [
      "如需支持分页，可后续扩展 page、pageSize、total，但当前列表成员不多可先不分页。",
      "statusClass 是前端展示型字段，后续也可改为 status 枚举再由前端映射。"
    ]
  }
}
