{
  "_comment": "配置管理 - 导出用户列表。与 exportUserList、UserEndpoint.Export、user-api-mock.mockExportUserList 对齐。",
  "fieldDescription": {
    "request": {
      "keyword": { "type": "string", "required": false, "description": "与列表筛选一致。" },
      "role": { "type": "string", "required": false, "description": "角色。" },
      "status": { "type": "string", "required": false, "description": "状态。" }
    },
    "response": {
      "downloadUrl": {
        "type": "string",
        "required": false,
        "description": "异步导出时返回下载地址；若为文件流则见 apiSuggestion。"
      },
      "fileName": {
        "type": "string",
        "required": false,
        "description": "建议文件名。"
      }
    }
  },
  "sampleRequest": { "keyword": "", "role": "", "status": "" },
  "sampleResponse": {
    "downloadUrl": "https://example.com/exports/users-20260327.xlsx",
    "fileName": "users-20260327.xlsx"
  },
  "api": {
    "url": "POST /api/config-management/user/export",
    "method": "POST",
    "priority": "P2",
    "requestBody": "与列表筛选字段对齐的 JSON",
    "responseBody": "downloadUrl + fileName，或二进制流（Content-Disposition）"
  },
  "apiSuggestion": {
    "notes": [
      "若返回文件流，需在 request 层设置 responseType: blob，与本项目其他 export* 一致。",
      "页面可无「导出」按钮；需要时调用 exportUserList，与当前列表筛选字段一致。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "页面若提供「导出」按钮则触发；当前 UI 无导出按钮，为预留契约。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "导出条件默认与当前筛选一致。",
    "dedupe": "导出任务防重复提交。"
  }
}
