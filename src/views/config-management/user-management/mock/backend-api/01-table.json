{
  "_comment": "配置管理 - 用户管理分页列表。对应 types.ts: UserTableQuery、UserItem；fetch*: fetchUserTable。响应为网关 unwrap 后的业务体（与 Api.Common.PaginatedResponse 一致）。",
  "fieldDescription": {
    "request": {
      "current": { "type": "number", "required": true, "description": "当前页，从 1 开始。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" },
      "keyword": {
        "type": "string",
        "required": false,
        "description": "用户名或邮箱模糊搜索。"
      },
      "role": {
        "type": "string",
        "required": false,
        "description": "角色筛选，与 UserItem.role 文案一致（如管理层/老板）。"
      },
      "status": {
        "type": "string",
        "required": false,
        "description": "状态筛选：活跃 / 待激活 / 已禁用。"
      }
    },
    "response": {
      "records": { "type": "UserItem[]", "required": true, "description": "当前页用户行。" },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" },
      "total": { "type": "number", "required": true, "description": "总条数。" }
    },
    "UserItem": {
      "id": { "type": "string", "required": true, "description": "用户 ID。" },
      "userName": { "type": "string", "required": true, "description": "显示名/用户名。" },
      "email": { "type": "string", "required": true, "description": "邮箱。" },
      "avatarColor": {
        "type": "string",
        "required": true,
        "description": "头像底色 HEX，前端根据邮箱等派生。"
      },
      "role": {
        "type": "string",
        "required": true,
        "description": "角色，枚举见 types.ts UserRole。"
      },
      "status": {
        "type": "string",
        "required": true,
        "description": "活跃 | 待激活 | 已禁用。"
      },
      "lastLogin": { "type": "string", "required": true, "description": "最近登录展示文案。" },
      "joinTime": { "type": "string", "required": true, "description": "加入日期 YYYY-MM-DD。" },
      "accessibleApps": {
        "type": "string[]",
        "required": true,
        "description": "可访问应用名称列表。"
      },
      "remark": { "type": "string", "required": true, "description": "备注。" }
    }
  },
  "sampleRequest": {
    "current": 1,
    "size": 20,
    "keyword": "",
    "role": "",
    "status": ""
  },
  "sampleResponse": {
    "records": [
      {
        "id": "u001",
        "userName": "张三",
        "email": "zhangsan@vegoo.com",
        "avatarColor": "#F97316",
        "role": "管理层/老板",
        "status": "活跃",
        "lastLogin": "2小时前",
        "joinTime": "2024-01-15",
        "accessibleApps": ["Weather1", "Weather2", "Finance Pro"],
        "remark": ""
      }
    ],
    "current": 1,
    "size": 20,
    "total": 1
  },
  "api": {
    "url": "POST /api/config-management/user/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "current, size, keyword?, role?, status?",
    "responseBody": "PaginatedResponse<UserItem>"
  },
  "apiSuggestion": {
    "notes": [
      "与 src/api/config-management.ts 中 fetchUserTable 一致；若网关统一包装，业务体为 data 内层结构与 sampleResponse 一致。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化（接入远程后）",
        "detail": "index.vue onMounted 拉取第一页；当前页面为本地 mock 列表时可跳过。",
        "prerequisite": "登录态；筛选默认值见 defaultSelection。"
      },
      {
        "moment": "筛选与分页",
        "detail": "关键词/角色/状态变更或分页组件切换时重新请求 current、size 与筛选字段。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "keyword、role、status 缺省为空表示不过滤；current=1、size 与页签选择一致（如 20）。",
    "dedupe": "建议列表请求 cancel 上次或 debounce 关键词输入（由前端实现决定）。"
  }
}
