{
  "_comment": "配置管理 - 用户管理 - 分页用户列表。对应 Api.SystemManage.UserSearchParams / UserList / UserListItem。",
  "fieldDescription": {
    "request": {
      "current": { "type": "number", "required": true, "description": "当前页，从 1 开始。" },
      "size": { "type": "number", "required": true, "description": "每页条数，页面固定最大 10。" },
      "userName": {
        "type": "string",
        "required": false,
        "description": "用户名/昵称/邮箱关键字模糊查询。"
      },
      "status": {
        "type": "string",
        "required": false,
        "enum": ["", "待激活", "活跃", "禁用"],
        "description": "状态筛选：空字符串=全部；其余与列表行 status 文案一致（待激活、活跃、禁用）。"
      },
      "role": {
        "type": "number",
        "required": false,
        "description": "角色主键筛选（RoleListItem.roleId）：空值=全部。"
      },
      "userGender": {
        "type": "string",
        "required": false,
        "description": "性别筛选，页面当前未暴露此筛选。"
      },
      "userPhone": {
        "type": "string",
        "required": false,
        "description": "手机号筛选，支持局部匹配。"
      },
      "userEmail": {
        "type": "string",
        "required": false,
        "description": "邮箱筛选，支持局部匹配。"
      },
      "id": { "type": "number", "required": false, "description": "按用户主键精准查询。" }
    },
    "response": {
      "records": {
        "type": "UserListItem[]",
        "required": true,
        "description": "当前页用户列表。无数据时返回空数组 []。"
      },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" },
      "total": {
        "type": "number",
        "required": true,
        "description": "符合筛选条件的总条数。无数据时返回 0。"
      }
    },
    "UserListItem": {
      "id": { "type": "number", "required": true, "description": "用户主键。" },
      "avatar": {
        "type": "string",
        "required": false,
        "description": "头像 URL；空字符串或缺失时前端显示占位图。"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["待激活", "活跃", "禁用"],
        "description": "状态文案，由后端直接返回（待激活、活跃、禁用）。"
      },
      "userName": { "type": "string", "required": true, "description": "用户名（登录名）。" },
      "nickName": { "type": "string", "required": true, "description": "昵称，可为空字符串。" },
      "userGender": {
        "type": "string",
        "required": true,
        "enum": ["男", "女"],
        "description": "性别展示文案。"
      },
      "userPhone": { "type": "string", "required": true, "description": "手机号。" },
      "userEmail": { "type": "string", "required": true, "description": "邮箱。" },
      "userRoles": {
        "type": "string[]",
        "required": true,
        "description": "角色编码数组，与 roleCode 一致。"
      },
      "accessibleApps": {
        "type": "string[]",
        "required": false,
        "description": "可访问应用标识列表（应用 ID 或包名）。"
      },
      "remark": { "type": "string", "required": false, "description": "备注。" },
      "createBy": { "type": "string", "required": true, "description": "创建人。" },
      "createTime": {
        "type": "string",
        "required": true,
        "description": "创建时间，格式 yyyy-MM-dd HH:mm:ss。"
      },
      "updateBy": { "type": "string", "required": true, "description": "最后更新人。" },
      "updateTime": {
        "type": "string",
        "required": true,
        "description": "最后更新时间，格式 yyyy-MM-dd HH:mm:ss。"
      }
    }
  },
