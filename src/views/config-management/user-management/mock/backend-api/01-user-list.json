      },
      {
        "moment": "用户操作",
        "detail": "搜索输入回车/清空、角色筛选、状态筛选、分页切换、点击刷新均触发重新请求。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "current=1，size=10，status=''，role=''，userName=''。",
    "dedupe": "列表请求应支持后发覆盖前发，避免快速筛选时旧响应回写。"
  }
