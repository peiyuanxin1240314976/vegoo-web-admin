{
  "_comment": "配置管理 - 用户管理 - 表格操作「重置密码」。返回仅表示是否成功，不回传明文密码。",
  "fieldDescription": {
    "request": {
      "id": { "type": "number", "required": true, "description": "用户主键（列表行 id）。" },
      "operator": {
        "type": "string",
        "required": false,
        "description": "操作人标识（可选）；用于审计。"
      }
    },
    "response": {
      "success": { "type": "boolean", "required": true, "description": "是否重置成功。" },
      "id": { "type": "number", "required": true, "description": "用户主键。" },
      "resetAt": {
        "type": "string",
        "required": true,
        "description": "重置时间，格式 yyyy-MM-dd HH:mm:ss。"
      }
    }
  },
  "sampleRequest": { "id": 101, "operator": "current_user" },
  "sampleResponse": { "success": true, "id": 101, "resetAt": "2026-04-26 22:55:00" },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/config-management/user/{id}/reset-password",
    "method": "POST",
    "priority": "P0",
    "requestBody": "{ id(path), operator?(body) }",
    "responseBody": "{ success, id, resetAt }"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "列表操作列点击「重置密码」，二次确认后调用。",
        "prerequisite": "目标用户未被禁用（或由后端自行校验）"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "操作中禁用按钮，避免重复点击。"
  }
}
