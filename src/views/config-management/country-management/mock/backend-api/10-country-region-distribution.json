{
  "_comment": "国家管理 - 地区分布图表。按与列表同筛选条件返回全量国家的地区聚合（非当前页）。",
  "fieldDescription": {
    "request": {
      "keyword": { "type": "string", "required": false, "description": "关键词筛选，同 table。" },
      "region": { "type": "string", "required": false, "description": "地区筛选，同 table。" },
      "currency": { "type": "string", "required": false, "description": "货币筛选，同 table。" }
    },
    "response": {
      "items": {
        "type": "CountryRegionDistributionItem[]",
        "required": true,
        "description": "地区分布聚合数组。"
      }
    },
    "CountryRegionDistributionItem": {
      "region": { "type": "string", "required": true, "description": "地区名称，如 `亚太`。" },
      "count": { "type": "number", "required": true, "description": "该地区国家条数。" },
      "percent": { "type": "number", "required": true, "description": "占比百分比（0-100）。" }
    }
  },
  "sampleRequest": {
    "keyword": "",
    "region": "",
    "currency": ""
  },
  "sampleResponse": {
    "code": 200,
    "data": {
      "items": [
        { "region": "亚太", "count": 6, "percent": 40 },
        { "region": "欧洲", "count": 4, "percent": 26.67 },
        { "region": "北美", "count": 3, "percent": 20 },
        { "region": "其他", "count": 2, "percent": 13.33 }
      ]
    }
  },
  "api": {
    "url": "POST /api/config-management/country/charts/region-distribution",
    "method": "POST",
    "priority": "P0",
    "requestBody": "keyword?, region?, currency?",
    "responseBody": "{ items: CountryRegionDistributionItem[] }"
  },
  "apiSuggestion": {
    "notes": [
      "图表数据必须基于筛选后的全量国家聚合，不受分页影响。",
      "返回地区顺序可固定为 `亚太/欧洲/北美/其他`，缺失地区返回 count=0。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面初始化 / 点击查询 / 数据变更后",
        "detail": "`index.vue` 调用 `fetchCountryRegionDistribution` 更新右侧地区分布图。"
      }
    ],
    "defaultSelection": "与当前筛选条件一致。"
  }
}
