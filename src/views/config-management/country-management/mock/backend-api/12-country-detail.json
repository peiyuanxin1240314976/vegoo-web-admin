    "code": 200,
    "data": {
      "code": "US",
      "code3": "840",
      "criteriaId": "2840",
      "flagIconUrl": "",
      "nameCn": "美国",
      "nameEn": "United States",
      "aliases": ["USA", "America", "United States of America", "US"],
      "timezone": "GMT-5",
      "phoneCode": "1",
      "currency": "USD - 美元",
      "currencySymbol": "$",
      "region": "北美",
      "isMainMarket": true,
      "createdBy": "admin",
      "createdTime": "2024-01-10 09:00:00",
      "updatedBy": "admin",
      "updatedTime": "2024-06-15 14:30:00"
    }
  },
  "api": {
    "url": "POST /api/config-management/country/detail",
    "method": "POST",
    "priority": "P1",
    "requestBody": "{ code }",
    "responseBody": "CountryItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
