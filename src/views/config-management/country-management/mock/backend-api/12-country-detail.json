{
  "_comment": "国家管理 - 国家详情。按 code 获取完整国家信息，供右侧“查看”抽屉展示。",
  "fieldDescription": {
    "request": {
      "code": {
        "type": "string",
        "required": true,
        "description": "国家代码（ISO alpha-2）。"
      }
    },
    "response": {
      "data": {
        "type": "CountryItem",
        "required": true,
        "description": "国家完整详情对象。字段同 `01-country-table` 中 `CountryItem`。"
      }
    }
  },
  "sampleRequest": {
    "code": "US"
  },
