{
  "_comment": "国家管理 - 删除国家。按国家代码删除。",
  "fieldDescription": {
    "request": {
      "path.code": {
        "type": "string",
        "required": true,
        "description": "国家代码（ISO alpha-2）。"
      }
    },
    "response": {
      "code": { "type": "number", "required": true, "description": "状态码，200 表示成功。" },
      "message": { "type": "string", "required": true, "description": "删除结果提示。" }
    }
  },
  "sampleRequest": {
    "path": { "code": "BR" }
  },
  "sampleResponse": {
    "code": 200,
    "message": "删除成功"
  },
  "api": {
    "url": "DELETE /api/config-management/country/:code",
    "method": "DELETE",
    "priority": "P0",
    "requestBody": "N/A",
    "responseBody": "{ code, message }"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "删除确认后 `deleteCountry(code)`。",
        "prerequisite": "当前实现为 DELETE；联调以 `src/api` 为准，后续可迁移 POST `/country/delete` + body。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "无"
  }
}
