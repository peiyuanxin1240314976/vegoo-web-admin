{
  "_comment": "应用管理 - 新增。对应 types.ts: ApplicationFormPayload / ApplicationAppItem。",
  "fieldDescription": {
    "request": {
      "id": {
        "type": "string | null",
        "required": false,
        "description": "新增时可不传或传 null，由后端生成业务 ID。"
      },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "platform": {
        "type": "string",
        "required": true,
        "description": "平台：Android / iOS / Web。"
      },
      "category": { "type": "string", "required": true, "description": "应用类别。" },
      "bundleId": { "type": "string", "required": true, "description": "Bundle ID。" },
      "packageId": { "type": "string", "required": false, "description": "软件包 ID。" },
      "iconFileKey": {
        "type": "string",
        "required": false,
        "description": "图标上传后的文件标识或 URL。"
      },
      "creator": { "type": "string", "required": false, "description": "创建人。" },
      "body": {
        "type": "ApplicationFormPayload",
        "required": true,
        "description": "完整表单提交体（含图标上传字段，不要求传 iconColor）。"
      }
    },
    "response": {
      "data": {
        "type": "ApplicationAppItem",
        "required": true,
        "description": "新建后的完整记录（网关若包裹则取 data）。"
      }
    }
  },
  "sampleRequest": {
    "id": null,
    "appName": "Demo",
    "platform": "Android",
    "category": "Weather",
    "bundleId": "com.demo.app",
    "packageId": "com.demo.app",
    "iconFileKey": "oss://app-icons/demo.png",
    "creator": "系统"
  },
  "sampleResponse": {
    "id": "APP1711524600000",
    "appName": "Demo",
    "iconColor": "hsl(200 42% 46%)",
    "iconUrl": "https://cdn.example.com/app-icons/demo.png",
    "platform": "Android",
    "bundleId": "com.demo.app",
    "packageId": "com.demo.app",
    "shortName": "",
    "category": "Weather",
    "timezone": "PST",
    "priority": 1,
    "status": "正常",
    "creator": "系统",
    "createTime": "2026-03-27",
    "lastModifier": "系统",
    "lastModifyTime": "2026-03-27 10:00:00"
  },
  "api": {
    "url": "POST /api/config-management/application",
    "method": "POST",
    "priority": "P0",
    "requestBody": "ApplicationFormPayload",
    "responseBody": "ApplicationAppItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户点击「新增应用」提交表单",
        "detail": "createApplication；成功后 loadStats + loadTable。",
        "prerequisite": "表单校验通过"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "提交中禁用确认按钮（由弹窗实现）。"
  }
}
