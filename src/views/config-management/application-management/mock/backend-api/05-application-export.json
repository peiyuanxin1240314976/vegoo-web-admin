{
  "_comment": "应用管理 - 服务端导出（与列表筛选对齐）；前端可并行生成本地 CSV 兜底。",
  "fieldDescription": {
    "request": {
      "current": {
        "type": "number",
        "required": false,
        "description": "当前页（同步任务可选用）。"
      },
      "size": { "type": "number", "required": false, "description": "每页条数。" },
      "keyword": { "type": "string", "required": false, "description": "与列表一致。" },
      "category": { "type": "string", "required": false, "description": "类别。" },
      "platform": { "type": "string", "required": false, "description": "终端平台。" },
      "status": { "type": "string", "required": false, "description": "状态。" },
      "creator": { "type": "string", "required": false, "description": "创建人。" }
    },
    "response": {
      "downloadUrl": { "type": "string", "required": false, "description": "异步导出下载地址。" },
      "fileName": { "type": "string", "required": false, "description": "建议文件名。" }
    }
  },
  "sampleRequest": {
    "current": 1,
    "size": 20,
    "keyword": "",
    "category": "",
    "platform": "",
    "status": "",
    "creator": ""
  },
  "sampleResponse": {
    "downloadUrl": "https://example.com/exports/applications-20260327.xlsx",
    "fileName": "applications-20260327.xlsx"
  },
  "api": {
    "url": "POST /api/config-management/application/export",
    "method": "POST",
    "priority": "P1",
    "requestBody": "与列表筛选字段一致",
    "responseBody": "downloadUrl + fileName，或二进制流"
  },
  "apiSuggestion": {
    "notes": ["若返回文件流，需在 request 层设置 responseType: blob。"]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户点击「导出」",
        "detail": "先 fetchApplicationTable(current=1,size=10000,筛选) 生成 CSV；再调用 exportApplicationList 联调远端。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "导出条件与当前筛选一致。",
    "dedupe": "导出中可禁用按钮（可选）。"
  }
}
