{
  "_comment": "应用管理 - 分页列表。对应 types.ts: ApplicationTableQuery / ApplicationAppItem。",
  "fieldDescription": {
    "request": {
      "current": { "type": "number", "required": true, "description": "当前页，从 1 开始。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" },
      "keyword": {
        "type": "string",
        "required": false,
        "description": "应用名称或业务 ID 模糊搜索。"
      },
      "category": { "type": "string", "required": false, "description": "类别。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：Android / iOS。"
      },
      "status": { "type": "string", "required": false, "description": "状态，如 正常 / 禁用。" },
      "creator": { "type": "string", "required": false, "description": "创建人。" }
    },
    "response": {
      "records": {
        "type": "ApplicationAppItem[]",
        "required": true,
        "description": "当前页数据。"
      },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" },
      "total": { "type": "number", "required": true, "description": "总条数（与筛选条件一致）。" }
    },
    "ApplicationAppItem": {
      "id": { "type": "string", "required": true, "description": "应用业务 ID。" },
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "iconColor": { "type": "string", "required": true, "description": "列表色块。" },
      "platform": { "type": "string", "required": true, "description": "终端平台。" },
      "bundleId": { "type": "string", "required": true, "description": "Bundle ID。" },
      "packageId": { "type": "string", "required": true, "description": "软件包 ID。" },
      "shortName": { "type": "string", "required": true, "description": "简称。" },
      "category": { "type": "string", "required": true, "description": "类别。" },
      "timezone": { "type": "string", "required": true, "description": "报表时区。" },
      "priority": { "type": "number", "required": true, "description": "优先级。" },
      "status": { "type": "string", "required": true, "description": "状态。" },
      "creator": { "type": "string", "required": true, "description": "创建人。" },
      "createTime": { "type": "string", "required": true, "description": "创建日期。" }
    }
  },
  "sampleRequest": { "current": 1, "size": 20, "keyword": "" },
  "sampleResponse": {
    "records": [
      {
        "id": "Weather5A",
        "appName": "Weather5",
        "iconColor": "#2dd4bf",
        "platform": "Android",
        "bundleId": "com.accurate.weather.forecast.live",
        "packageId": "com.accurate.weather.forecast.live",
        "shortName": "W5",
        "category": "Weather",
        "timezone": "PST",
        "priority": 12,
        "status": "正常",
        "creator": "张三",
        "createTime": "2024-01-15"
      }
    ],
    "current": 1,
    "size": 20,
    "total": 8
  },
  "api": {
    "url": "POST /api/config-management/application/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "current, size, keyword?, category?, platform?, status?, creator?",
    "responseBody": "Api.Common.PaginatedResponse<ApplicationAppItem>"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "进入页面 / 筛选变更 / 翻页 / 每页条数变更",
        "detail": "调用 fetchApplicationTable；页头 KPI 另请求 current=1,size=10000 且无筛选以聚合全量（与 user-management 一致）。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "分页 current=1,size=20；筛选为空表示不限。",
    "dedupe": "同一时刻仅一个列表请求；导出可先拉取大页再本地 CSV。"
  }
}
