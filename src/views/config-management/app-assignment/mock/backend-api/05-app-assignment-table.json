            "evalMethod": "ROI",
            "evalDays": 3,
            "targetRate": "53%",
            "minRate": "50%",
            "difficulty": 1.2,
            "minProfit": "-",
            "extraCondition": "-"
          },
          {
            "id": "v2",
            "version": "v2",
            "status": "已发布",
            "isActive": false,
            "date": "2024-03-10",
