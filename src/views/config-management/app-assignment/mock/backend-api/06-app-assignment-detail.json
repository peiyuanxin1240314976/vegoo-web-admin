  "api": {
    "url": "POST /api/config-management/app-assignment/detail",
    "method": "POST",
    "priority": "P1",
    "requestBody": "id",
    "responseBody": "AppAssignmentItem | null"
  },
  "apiSuggestion": {
    "notes": [
      "`fieldDescription.response.data` 命名与 unwrap 冲突时，以实际网关 `data` 内单对象为准；前端 `request.post<AppAssignmentItem | null>`。"
