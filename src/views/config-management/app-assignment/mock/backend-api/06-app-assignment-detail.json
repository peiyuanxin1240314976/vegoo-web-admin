{
  "_comment": "应用分配 - 单条详情（抽屉/变更记录数据源）。对应 types.ts: AppAssignmentItem。",
  "interaction": {
    "triggers": [
      {
        "moment": "用户点击表格行打开抽屉",
        "detail": "`index.vue` `handleRowClick`：若 table 行已含完整嵌套可直接展示，否则用 `id` 请求本接口。",
        "prerequisite": "已知分配 `id`。"
      },
      {
        "moment": "抽屉内点「变更记录」",
        "detail": "`change-log-dialog` 可走行内 `changeLogs` 或依赖本接口刷新。",
        "prerequisite": "同 id。"
      }
    ],
    "defaultSelection": "无。",
    "dedupe": "重复打开同一行可复用缓存。"
  },
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "分配记录 id。" }
    },
    "response": {
      "_item": {
        "type": "AppAssignmentItem | null",
        "required": true,
        "description": "单条完整对象，字段见 05-app-assignment-table.json 的 AppAssignmentItem；无记录时后端可 404 或返回 null（与网关约定）。"
      }
    }
  },
  "sampleRequest": { "id": "asgn-001" },
  "sampleResponse": {
    "id": "asgn-001",
    "appName": "Weather8",
