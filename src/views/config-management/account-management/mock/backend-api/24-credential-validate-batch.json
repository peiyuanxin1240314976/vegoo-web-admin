{
  "_comment": "凭据管理 - 批量验证凭据。",
  "fieldDescription": {
    "request": {
      "ids": {
        "type": "string[]",
        "required": true,
        "description": "待验证凭据 ID 列表；空数组表示全部。"
      }
    },
    "response": {
      "taskId": { "type": "string", "required": true, "description": "批量验证任务 ID。" }
    }
  },
  "sampleRequest": { "ids": ["CRED-001", "CRED-002"] },
  "sampleResponse": {
    "code": 200,
    "message": "success",
    "data": { "taskId": "validate_batch_20260324_001" }
  },
  "api": {
    "url": "POST /api/config-management/credential/validate-batch",
    "method": "POST",
    "priority": "P1",
    "requestBody": "{ ids }",
    "responseBody": "{ taskId } | 同步结果列表"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "凭据 Tab 批量验证按钮 `validateCredentialBatch`。",
        "prerequisite": "`AccountApiSource.validateCredentialBatch`。"
      }
    ],
    "defaultSelection": "ids 空数组可约定为「全部待验证」（与后端确认）。",
    "dedupe": "无"
  }
}
