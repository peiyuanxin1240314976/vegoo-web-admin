{
  "_comment": "凭据管理 - 分页列表。支持关键词、广告平台、凭据类型、验证状态筛选。",
  "fieldDescription": {
    "request": {
      "current": { "type": "number", "required": true, "description": "当前页码，从 1 开始。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" },
      "keyword": {
        "type": "string",
        "required": false,
        "description": "关键词，模糊匹配凭据名称或ID。"
      },
      "source": { "type": "string", "required": false, "description": "广告平台筛选。" },
      "credentialType": {
        "type": "string",
        "required": false,
        "description": "凭据类型：客户端Token | 服务号 | 证书文件。"
      },
      "status": {
        "type": "string",
        "required": false,
        "description": "验证状态：验证正常 | 验证失败 | 待验证。"
      }
    },
    "response": {
      "data": {
        "records": {
          "type": "CredentialItem[]",
          "description": "当前页凭据列表。config 字段中敏感内容由后端脱敏后返回。"
        },
        "total": { "type": "number" },
        "current": { "type": "number" },
        "size": { "type": "number" }
      }
    }
  },
  "sampleRequest": {
    "current": 1,
    "size": 20,
    "keyword": "",
    "source": "",
    "credentialType": "",
    "status": ""
  },
  "sampleResponse": {
    "data": {
      "records": [
        {
          "id": "CRED-001",
          "name": "Facebook1",
          "source": "Meta Ads",
          "group": "Google",
          "credentialType": "客户端Token",
          "remark": "获取Meta广告成效",
          "apps": ["BloodSugar2", "HealthTracker2"],
          "accountCount": 8,
          "accountIds": ["ACC-012", "ACC-034"],
          "status": "验证正常",
          "lastValidateTime": "2026-03-13 08:00",
          "config": {
            "account": "fb_app@vegoo.com",
            "clientId": "1234567890",
            "clientSecret": "***",
            "accessToken": "***",
            "refreshToken": "***"
          },
          "validateHistory": [
            { "time": "2026-03-13 08:00", "status": "验证成功", "trigger": "自动定时" }
          ]
        }
      ],
      "total": 9,
      "current": 1,
      "size": 20
    }
  },
  "api": {
    "url": "POST /api/config-management/credential/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "CredentialTableQuery",
    "responseBody": "PaginatedResponse<CredentialItem>"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "「凭据管理」Tab `credential-tab.vue` onMounted。",
        "prerequisite": "`AccountApiSource.credentialTable`。"
      }
    ],
    "defaultSelection": "current=1，size=20。",
    "dedupe": "无"
  }
}
