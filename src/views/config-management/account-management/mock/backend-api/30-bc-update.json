{
  "_comment": "BC/BM 管理 — 编辑。请求体含 id 与 Partial<BcFormModel>；广告平台与 bmId 编辑态前端只读，可不传或由后端忽略。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "BC 业务 ID，如 BM-001。" },
      "source": { "type": "string", "required": false, "description": "广告平台，通常与创建时一致。" },
      "bmId": { "type": "string", "required": false, "description": "BM 平台 ID，通常不可改。" },
      "bmName": { "type": "string", "required": false, "description": "BM 名称。" },
      "group": { "type": "string", "required": false, "description": "归属组。" },
      "status": { "type": "string", "required": false, "description": "状态。" },
      "ownerType": { "type": "string", "required": false, "description": "开户主体。" },
      "manager": { "type": "string", "required": false, "description": "管理员。" },
      "banRecord": { "type": "string", "required": false, "description": "有 | 无。" },
      "banDesc": { "type": "string", "required": false, "description": "封户说明。" },
      "remark": { "type": "string", "required": false, "description": "备注。" }
    },
    "response": {
      "data": {
        "type": "BcItem",
        "required": true,
        "description": "更新后的完整 BC 对象。"
      }
    }
  },
  "sampleRequest": {
    "id": "BM-001",
    "bmName": "Vegoo主务BC（更新）",
    "group": "Google组",
    "status": "健康",
    "ownerType": "企业户",
    "manager": "李四",
    "banRecord": "无",
    "banDesc": "",
    "remark": "联调示例备注"
  },
  "sampleResponse": {
    "data": {
      "id": "BM-001",
      "bmId": "123456789012345",
      "bmName": "Vegoo主务BC（更新）",
      "source": "Meta Ads",
      "group": "Google组",
      "status": "健康",
      "ownerType": "企业户",
      "manager": "李四",
      "banRecord": "无",
      "banDesc": "",
      "createTime": "2022-06-15",
      "remark": "联调示例备注",
      "linkedAccounts": 45,
      "activeAccounts": 40,
      "inactiveAccounts": 5,
      "monthSpend": 128450.35,
      "monthOpenCount": 8
    }
  },
  "api": {
    "url": "POST /api/config-management/bc/update",
    "method": "POST",
    "priority": "P0",
    "requestBody": "{ id, ...Partial<BcFormModel> }",
    "responseBody": "BcItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "编辑弹窗提交。`handleFormSuccess` 在非 mock 时调用 `updateBc(id, data)`。",
        "prerequisite": "`AccountApiSource.updateBc` 为 false 时走网关。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "无"
  }
}
