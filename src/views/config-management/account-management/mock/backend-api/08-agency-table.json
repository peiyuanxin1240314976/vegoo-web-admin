{
  "_comment": "代理商管理 - 分页列表。支持关键词、广告平台、合作模式、合作状态筛选。",
  "fieldDescription": {
    "request": {
      "current":   { "type": "number",  "required": true,  "description": "当前页码，从 1 开始。" },
      "size":      { "type": "number",  "required": true,  "description": "每页条数。" },
      "keyword":   { "type": "string",  "required": false, "description": "关键词，模糊匹配代理商名称或ID。" },
      "source":    { "type": "string",  "required": false, "description": "广告平台筛选，如 Meta Ads。" },
      "coopMode":  { "type": "string",  "required": false, "description": "合作模式筛选：授权代理 | 直接开户。" },
      "status":    { "type": "string",  "required": false, "description": "合作状态筛选：已合作 | 洽谈中 | 已终止。" }
    },
    "response": {
      "data": {
        "records":  { "type": "AgencyItem[]", "description": "当前页代理商列表。" },
        "total":    { "type": "number",       "description": "符合条件的总条数。" },
        "current":  { "type": "number",       "description": "当前页码。" },
        "size":     { "type": "number",       "description": "每页条数。" }
      }
    }
  },
  "sampleRequest": {
    "current": 1,
