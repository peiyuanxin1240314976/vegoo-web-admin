{
  "_comment": "账户管理 · 开户管理 — 开户记录分页列表。对应 types.ts: OpenAccountTableQuery / OpenAccountItem。请求字段与 `fetchOpenAccountTable` 一致：current、size（非 page/pageSize）。",
  "fieldDescription": {
    "request": {
      "current": {
        "type": "number",
        "required": true,
        "description": "当前页码，从 1 开始。",
        "default": 1
      },
      "size": { "type": "number", "required": true, "description": "每页条数。", "default": 20 },
      "keyword": { "type": "string", "required": false, "default": "", "description": "关键词。" },
      "source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台筛选。"
      },
      "status": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "状态：待分配 / 已激活 / 开户失败。"
      },
      "agency": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "代理商筛选。"
      },
      "app": { "type": "string", "required": false, "default": "", "description": "应用筛选。" }
    },
    "response": {
      "records": { "type": "OpenAccountItem[]", "required": true, "description": "当前页记录。" },
      "total": { "type": "number", "required": true, "description": "总条数。" },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" }
    }
  },
