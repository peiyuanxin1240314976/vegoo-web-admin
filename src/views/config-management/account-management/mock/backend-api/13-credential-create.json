{
  "_comment": "凭据管理 - 新建凭据。保存后服务端自动触发接口连通性验证，验证结果由 14-credential-validate 接口获取或在 response 中直接返回。",
  "fieldDescription": {
    "request": {
      "name": { "type": "string", "required": true, "description": "凭据名称。" },
      "source": { "type": "string", "required": true, "description": "广告平台。" },
      "group": { "type": "string", "required": true, "description": "分组。" },
      "credentialType": {
        "type": "string",
        "required": true,
        "description": "凭据类型：客户端Token | 服务号 | 证书文件。"
      },
      "remark": { "type": "string", "required": false, "description": "备注。" },
      "apps": { "type": "string[]", "required": false, "description": "关联应用列表。" },
      "config": {
        "type": "object",
        "required": true,
        "description": "凭据配置，包含 account/clientId/clientSecret/accessToken/refreshToken 等字段。"
      }
    },
    "response": {
      "data": { "type": "CredentialItem", "description": "新建后的凭据对象，id 由服务端生成。" }
    }
  },
  "sampleRequest": {
    "name": "TikTok2",
    "source": "TikTok Ads",
    "group": "Google",
    "credentialType": "客户端Token",
    "remark": "获取TikTok广告成效",
    "apps": ["WeatherApp"],
    "config": {
      "account": "tiktok_app@vegoo.com",
      "clientId": "7123456789012345678",
      "clientSecret": "***",
      "accessToken": "***"
    }
  },
  "sampleResponse": {
    "data": {
      "id": "CRED-010",
      "name": "TikTok2",
      "source": "TikTok Ads",
      "group": "Google",
      "credentialType": "客户端Token",
      "remark": "获取TikTok广告成效",
      "apps": ["WeatherApp"],
      "accountCount": 0,
      "accountIds": [],
      "status": "待验证",
      "lastValidateTime": "",
      "config": {
        "account": "tiktok_app@vegoo.com",
        "clientId": "7123456789012345678",
        "clientSecret": "***",
        "accessToken": "***",
        "refreshToken": ""
      },
      "validateHistory": []
    }
  },
  "api": {
    "url": "POST /api/config-management/credential",
    "method": "POST",
    "priority": "P0",
    "requestBody": "CredentialFormModel",
    "responseBody": "CredentialItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "新建凭据弹窗提交 `createCredential`。",
        "prerequisite": "`AccountApiSource.createCredential`。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "无"
  }
}
