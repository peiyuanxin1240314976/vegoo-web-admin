{
  "_comment": "代理商管理 - 新增代理商。",
  "fieldDescription": {
    "request": {
      "agencyName": { "type": "string", "required": true, "description": "代理商名称。" },
      "source": { "type": "string", "required": true, "description": "广告平台，如 Meta Ads。" },
      "coopMode": {
        "type": "string",
        "required": true,
        "description": "合作模式：授权代理 | 直接开户。"
      },
      "contact": { "type": "string", "required": true, "description": "联系人姓名。" },
      "email": { "type": "string", "required": true, "description": "联系邮箱。" },
      "phone": { "type": "string", "required": true, "description": "联系电话。" },
      "startDate": {
        "type": "string",
        "required": false,
        "description": "合作开始日期，格式 YYYY-MM-DD。"
      },
      "expireDate": {
        "type": "string",
        "required": false,
        "description": "合作到期日期，格式 YYYY-MM-DD。"
      },
      "remark": { "type": "string", "required": false, "description": "备注信息。" }
    },
    "response": {
      "data": {
        "type": "AgencyItem",
        "description": "新建后的完整代理商对象，包含服务端生成的 id。"
      }
    }
  },
  "sampleRequest": {
    "agencyName": "新合作传媒",
    "source": "TikTok Ads",
    "coopMode": "授权代理",
    "contact": "李四",
    "email": "li4@example.com",
    "phone": "+86 139-0000-5678",
    "startDate": "2025-03-01",
    "expireDate": "2026-03-01",
    "remark": ""
  },
  "sampleResponse": {
    "data": {
      "id": "AGY-009",
      "agencyName": "新合作传媒",
      "source": "TikTok Ads",
      "coopMode": "授权代理",
      "managedAccounts": 0,
      "monthSpend": 0,
      "expireDate": "2026-03-01",
      "status": "已合作",
      "contact": "李四",
      "email": "li4@example.com",
      "phone": "+86 139-0000-5678",
      "startDate": "2025-03-01",
      "remark": "",
      "activeAccounts": 0,
      "pausedAccounts": 0,
      "monthRevenue": 0,
      "bcBmList": []
    }
  },
  "api": {
    "url": "POST /api/config-management/agency",
    "method": "POST",
    "priority": "P0",
    "requestBody": "AgencyFormModel",
    "responseBody": "AgencyItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "代理商新建弹窗提交 `createAgency`。",
        "prerequisite": "`AccountApiSource.createAgency` 为 false 时走网关。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "无"
  }
}
