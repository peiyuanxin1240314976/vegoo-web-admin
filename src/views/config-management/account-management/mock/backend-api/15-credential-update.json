{
  "_comment": "凭据管理 - 更新凭据配置。id 放入请求体，使用 POST。更新后服务端自动重新验证。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "凭据ID，如 CRED-001。" },
      "name": { "type": "string", "required": false, "description": "凭据名称。" },
      "group": { "type": "string", "required": false, "description": "分组。" },
      "remark": { "type": "string", "required": false, "description": "备注。" },
      "apps": { "type": "string[]", "required": false, "description": "关联应用列表。" },
      "config": {
        "type": "object",
        "required": false,
        "description": "更新的凭据配置字段（仅传有变更的字段）。"
      }
    },
    "response": {
      "data": { "type": "CredentialItem", "description": "更新后的凭据对象。" }
    }
  },
  "sampleRequest": { "id": "CRED-001", "config": { "accessToken": "new_token_here" } },
  "sampleResponse": {
    "data": {
      "id": "CRED-001",
      "name": "Facebook1",
      "source": "Meta Ads",
      "group": "Google",
      "credentialType": "客户端Token",
      "remark": "获取Meta广告成效",
      "apps": ["BloodSugar2"],
      "accountCount": 8,
      "accountIds": ["ACC-012"],
      "status": "待验证",
      "lastValidateTime": "2026-03-13 14:32:05",
      "config": {
        "account": "fb_app@vegoo.com",
        "clientId": "1234567890",
        "clientSecret": "***",
        "accessToken": "new_token_here",
        "refreshToken": "***"
      },
      "validateHistory": []
    }
  },
  "api": {
    "url": "POST /api/config-management/credential/update",
    "method": "POST",
    "priority": "P0",
    "requestBody": "{ id, ...Partial<CredentialFormModel> }",
    "responseBody": "CredentialItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "编辑凭据提交 `updateCredential`。",
        "prerequisite": "`AccountApiSource.updateCredential`。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "无"
  }
}
