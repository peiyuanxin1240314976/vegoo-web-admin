{
  "_comment": "代理商管理 - 编辑代理商信息。id 放入请求体，使用 POST。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "代理商ID，如 AGY-001。" },
      "agencyName": { "type": "string", "required": false, "description": "代理商名称。" },
      "coopMode": {
        "type": "string",
        "required": false,
        "description": "合作模式：授权代理 | 直接开户。"
      },
      "contact": { "type": "string", "required": false, "description": "联系人姓名。" },
      "email": { "type": "string", "required": false, "description": "联系邮箱。" },
      "phone": { "type": "string", "required": false, "description": "联系电话。" },
      "startDate": {
        "type": "string",
        "required": false,
        "description": "合作开始日期，格式 YYYY-MM-DD。"
      },
      "expireDate": {
        "type": "string",
        "required": false,
        "description": "合作到期日期，格式 YYYY-MM-DD。"
      },
      "remark": { "type": "string", "required": false, "description": "备注信息。" }
    },
    "response": {
      "data": { "type": "AgencyItem", "description": "更新后的完整代理商对象。" }
    }
  },
  "sampleRequest": {
    "id": "AGY-001",
    "agencyName": "星达传媒（更新）",
    "contact": "张三",
    "email": "zhang3@xingda.com",
    "phone": "+86 138-0000-1234",
    "expireDate": "2026-01-14",
    "remark": "主要负责Meta平台开户"
  },
  "sampleResponse": {
    "data": {
      "id": "AGY-001",
      "agencyName": "星达传媒（更新）",
      "source": "Meta Ads",
      "coopMode": "授权代理",
      "managedAccounts": 32,
      "monthSpend": 128450,
      "expireDate": "2026-01-14",
      "status": "已合作",
      "contact": "张三",
      "email": "zhang3@xingda.com",
      "phone": "+86 138-0000-1234",
      "startDate": "2023-01-15",
      "remark": "主要负责Meta平台开户",
      "activeAccounts": 28,
      "pausedAccounts": 4,
      "monthRevenue": 8991,
      "bcBmList": [
        {
          "name": "Vegoo主务BC",
          "source": "Meta Ads",
          "type": "BC",
          "accountCount": 45,
          "status": "正常"
        }
      ]
    }
  },
  "api": {
    "url": "POST /api/config-management/agency/update",
    "method": "POST",
    "priority": "P0",
    "requestBody": "{ id, ...Partial<AgencyFormModel> }",
    "responseBody": "AgencyItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "代理商编辑弹窗提交 `updateAgency`。",
        "prerequisite": "`AccountApiSource.updateAgency`。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "无"
  }
}
