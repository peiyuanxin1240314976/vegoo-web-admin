{
  "_comment": "凭据管理 - 手动触发接口验证。id 放入请求体，使用 POST。后端调用对应平台 API 并返回验证结果。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "凭据ID，如 CRED-001。" }
    },
    "response": {
      "data": {
        "success": { "type": "boolean", "description": "验证是否成功。" },
        "validateTime": { "type": "string", "description": "验证时间，格式 YYYY-MM-DD HH:mm:ss。" },
        "responseTime": { "type": "number", "description": "响应耗时，单位 ms。" },
        "apiVersion": { "type": "string", "description": "接口版本，如 v18.0。" },
        "permissions": {
          "type": "array",
          "description": "账户权限列表，每项含 label(string) 和 granted(boolean)。"
        },
        "accessibleAccounts": { "type": "string[]", "description": "可访问账户ID列表（前3个）。" },
        "totalAccountCount": { "type": "number", "description": "可访问账户总数。" }
      }
    }
  },
  "sampleRequest": { "id": "CRED-001" },
  "sampleResponse": {
    "data": {
      "success": true,
      "validateTime": "2026-03-13 14:32:05",
      "responseTime": 238,
      "apiVersion": "v18.0",
      "permissions": [
        { "label": "广告账户管理员", "granted": true },
        { "label": "广告主", "granted": true },
        { "label": "公共页面管理员", "granted": true },
        { "label": "广告创意上传", "granted": false }
      ],
      "accessibleAccounts": ["ACC-012", "ACC-034", "ACC-056"],
      "totalAccountCount": 5
    }
  },
  "api": {
    "url": "POST /api/config-management/credential/validate",
    "method": "POST",
    "priority": "P0",
    "requestBody": "{ id }",
    "responseBody": "CredentialValidateResult"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "凭据行「验证」或详情内手动验证，`credential-validate-dialog` → `validateCredential`。",
        "prerequisite": "`AccountApiSource.validateCredential`。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "同一 id 验证中可禁用按钮防抖。"
  }
}
