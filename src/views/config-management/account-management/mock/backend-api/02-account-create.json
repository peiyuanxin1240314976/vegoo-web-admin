{
  "_comment": "账户管理 - 新建广告账户（提交开户申请）。",
  "fieldDescription": {
    "request": {
      "source": {
        "type": "string",
        "required": true,
        "description": "广告平台，如 Google Ads / Meta Ads。"
      },
      "accountName": { "type": "string", "required": true, "description": "账户名称。" },
      "accountType": {
        "type": "string",
        "required": true,
        "enum": ["直投", "代投"],
        "description": "账户类型。"
      },
      "openAmount": { "type": "number", "required": false, "description": "开户金额（美元）。" },
      "agency": { "type": "string", "required": false, "description": "归属代理商，代投时必填。" },
      "bcBm": { "type": "string", "required": false, "description": "归属BC/BM。" },
      "apps": { "type": "string[]", "required": false, "description": "投放应用列表。" },
      "platform": {
        "type": "string[]",
        "required": false,
        "description": "投放平台，如 ['安卓','iOS']。"
      },
      "purposes": {
        "type": "string[]",
        "required": false,
        "description": "账户用途，如 ['广告投放','用户获取']。"
      },
      "credential": { "type": "string", "required": false, "description": "关联凭据名称。" },
      "remark": { "type": "string", "required": false, "description": "备注。" }
    },
    "response": {
      "data": {
        "type": "AdAccountItem",
        "required": true,
        "description": "创建完成后的完整账户信息。"
      }
    }
  },
  "sampleRequest": {
    "source": "Meta Ads",
    "accountName": "FB-Agency-B-03",
    "accountType": "直投",
    "openAmount": 500,
    "agency": "",
    "bcBm": "Vegoo主客BC",
    "apps": ["BloodSugar2"],
    "platform": ["安卓"],
    "purposes": ["广告投放", "用户获取"],
    "credential": "Facebook1",
    "remark": ""
  },
  "sampleResponse": {
    "data": {
      "id": "ACC-099",
      "accountName": "FB-Agency-B-03",
      "source": "Meta Ads",
      "agency": "",
      "accountType": "直投",
      "balance": 500,
      "monthSpend": 0,
      "status": "正常",
      "bcBm": "Vegoo主客BC",
      "apps": ["BloodSugar2"],
      "platform": ["安卓"],
      "purposes": ["广告投放", "用户获取"],
      "credential": "Facebook1",
      "spendLimit": 0,
      "spendProgress": 0,
      "currency": "USD",
      "lastRechargeTime": "",
      "lastRechargeAmount": 0,
      "createTime": "2026-03-23",
      "remark": ""
    }
  },
  "api": {
    "url": "POST /api/config-management/account",
    "method": "POST",
    "priority": "P0",
    "requestBody": "AccountFormModel",
    "responseBody": "AdAccountItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "「广告账户」Tab 新建/编辑弹窗提交新建分支，`index.vue` 调用 `createAccount`。",
        "prerequisite": "`AccountApiSource.createAccount === false` 时走网关；否则本地模拟成功。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "提交防重复。"
  }
}
