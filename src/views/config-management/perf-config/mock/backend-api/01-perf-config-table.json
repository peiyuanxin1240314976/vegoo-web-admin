  "api": {
    "url": "POST /api/config-management/perf-config/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "page, pageSize, keyword?, appId?, platform?, source?, status?",
    "responseBody": "PaginatedResponse<PerfConfigItem>（推荐）或 { total, list } 待映射"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`/config-management/perf-config` `loadPerfTable`；`PerfConfigApiSource.perfTable === true` 时跳过远程。",
        "prerequisite": "登录态。"
      },
      {
        "moment": "用户操作",
        "detail": "顶部筛选变更后可重新拉取（与前端 filteredList 并行时注意是否仍需远程分页）。"
      }
    ],
    "defaultSelection": "page=1，pageSize=20，筛选项默认空。",
    "dedupe": "无"
  }
}
