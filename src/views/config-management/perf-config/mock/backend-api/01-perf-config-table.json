{
  "_comment": "绩效配置 — 分页列表。请求与 `fetchPerfTable` 一致：page、pageSize。响应建议与 `Api.Common.PaginatedResponse<PerfConfigItem>` 对齐：records、total、current、size；若网关暂为 { total, list }，联调时在网关层映射或与前端约定后更新本契约。对应 types.ts: PerfConfigItem / PerfVersion。",
  "fieldDescription": {
    "request": {
      "page": { "type": "number", "required": true, "description": "页码。", "default": 1 },
      "pageSize": {
        "type": "number",
        "required": true,
        "description": "每页条数。",
        "default": 20
      },
      "keyword": { "type": "string", "required": false, "description": "应用关键词。" },
      "appPlatform": {
        "type": "string",
        "required": false,
        "description": "应用平台：android | ios。"
      },
      "adPlatform": { "type": "string", "required": false, "description": "广告平台筛选。" },
      "status": { "type": "string", "required": false, "description": "配置/运行状态筛选。" }
    },
    "response": {
      "records": { "type": "PerfConfigItem[]", "required": true, "description": "列表行。" },
      "total": { "type": "number", "required": true, "description": "总数。" },
      "current": {
        "type": "number",
        "required": true,
        "description": "当前页码（与请求 page 一致）。"
      },
      "size": {
        "type": "number",
        "required": true,
        "description": "每页条数（与请求 pageSize 一致）。"
      }
    }
  },
