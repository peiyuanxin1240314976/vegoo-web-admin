{
  "_comment": "绩效配置 — 分页列表。请求与 `fetchPerfTable` 一致。应用/终端平台/广告平台维度与公用 `GET .../cockpit/meta-filter-options` 的 `value` 对齐（`appId`、`platform`、`source`）；不在本目录重复 meta 契约。对应 types.ts: PerfConfigItem / PerfVersion。",
  "fieldDescription": {
    "request": {
      "page": { "type": "number", "required": true, "description": "页码。", "default": 1 },
      "pageSize": {
        "type": "number",
        "required": true,
        "description": "每页条数。",
        "default": 20
      },
      "keyword": {
        "type": "string",
        "required": false,
        "description": "应用展示名或 appId 关键词。"
      },
      "appId": {
        "type": "string",
        "required": false,
        "description": "应用筛选；cockpit appOptions[].value；空字符串表示全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台筛选；cockpit platformOptions[].value；空字符串表示全部。"
      },
      "source": {
        "type": "string",
        "required": false,
        "description": "广告平台筛选；cockpit sourceOptions[].value；匹配行 `source` 或 `sourceList` 任一项；空字符串表示全部。"
      },
      "status": {
        "type": "string",
        "required": false,
        "description": "配置版本状态筛选（如 published/draft/archived）。"
      }
    },
    "response": {
      "records": { "type": "PerfConfigItem[]", "required": true, "description": "列表行。" },
      "total": { "type": "number", "required": true, "description": "总数。" },
      "current": {
        "type": "number",
        "required": true,
        "description": "当前页码（与请求 page 一致）。"
      },
      "size": {
        "type": "number",
        "required": true,
        "description": "每页条数（与请求 pageSize 一致）。"
      }
    },
    "PerfConfigItem": {
      "id": { "type": "string", "required": true, "description": "配置 ID。" },
      "appId": {
        "type": "string",
        "required": true,
        "description": "应用 ID，与 cockpit appOptions[].value 一致。"
      },
      "appName": { "type": "string", "required": true, "description": "应用展示名。" },
      "appIcon": { "type": "string", "required": true, "description": "列表图标色（CSS 颜色）。" },
      "platform": { "type": "string", "required": true, "description": "终端平台 value。" },
      "source": {
        "type": "string",
        "required": true,
        "description": "主广告平台 value，与 sourceList[0] 一致。"
      },
      "sourceList": {
        "type": "string[]",
        "required": true,
        "description": "已选广告平台枚举值列表。"
      },
      "runStatus": {
        "type": "string",
        "required": true,
        "enum": ["running", "paused", "stopped"],
        "description": "投放状态。"
      },
      "allowMulti": { "type": "boolean", "required": true, "description": "是否允许多投。" },
      "activeVersion": { "type": "PerfVersion", "required": true, "description": "当前激活版本。" },
      "versions": { "type": "PerfVersion[]", "required": true, "description": "版本历史。" }
    },
    "PerfVersion": {
      "version": { "type": "number", "required": true, "description": "版本号。" },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["published", "draft", "archived"],
        "description": "版本状态。"
      },
      "publishedAt": { "type": "string", "required": true, "description": "发布时间。" },
      "publishedBy": { "type": "string", "required": true, "description": "发布人。" },
      "evalMethod": {
        "type": "string",
        "required": true,
        "enum": ["ROI", "CPA"],
        "description": "评估方式。"
      },
      "evalDays": { "type": "number", "required": true, "description": "评估天数。" },
      "targetRate": { "type": "number", "required": true, "description": "达标要求。" },
      "minRate": { "type": "number", "required": true, "description": "最低要求。" },
      "difficultyFactor": { "type": "number", "required": true, "description": "难度系数。" },
      "minProfit": { "type": "number|null", "required": true, "description": "最低利润。" },
      "extraCondition": { "type": "string", "required": true, "description": "附加条件。" },
      "isActive": { "type": "boolean", "required": true, "description": "是否为当前激活版本。" }
    }
  },
  "sampleRequest": {
    "page": 1,
    "pageSize": 20,
    "keyword": "",
