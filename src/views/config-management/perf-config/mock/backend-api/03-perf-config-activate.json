{
  "_comment": "激活指定版本。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "配置 ID（路径参数）。" },
      "version": { "type": "number", "required": true, "description": "版本号。" }
    },
    "response": {
      "activeVersion": { "type": "number", "required": true, "description": "激活版本号。" }
    }
  },
  "sampleRequest": { "id": "PF-001", "version": 2 },
  "sampleResponse": { "data": { "activeVersion": 2 } },
  "api": {
    "url": "POST /api/config-management/perf-config/:id/activate",
    "method": "POST",
    "priority": "P1",
    "requestBody": "version",
    "responseBody": "PerfConfigItem | { activeVersion }"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "详情抽屉中将某历史版本设为激活 `activatePerfConfig`（index.vue 行内操作）。",
        "prerequisite": "`PerfConfigApiSource.perfActivate` 为 false 时调用 `activatePerfConfig`。"
      }
    ],
    "defaultSelection": "version 为目标激活版本号。",
    "dedupe": "无"
  }
}
