{
  "_comment": "编辑绩效配置。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "配置 ID（路径参数）。" },
      "step1": { "type": "Partial<PerfStep1Form>", "required": false, "description": "可选基础信息。" },
      "step2": { "type": "PerfStep2Form", "required": true, "description": "绩效指标。" },
      "saveMode": { "type": "string", "required": true, "enum": ["draft", "publish"], "description": "保存方式。" }
    },
    "response": {
      "updated": { "type": "boolean", "required": true, "description": "更新结果。" }
    }
  },
  "sampleRequest": { "id": "PF-001", "step2": { "evalMethod": "ROI", "evalDays": 7, "targetRate": 58, "minRate": 46, "difficultyFactor": 1.3, "minProfit": 120, "extraCondition": "" }, "saveMode": "draft" },
  "sampleResponse": { "data": { "updated": true } },
  "api": {
    "url": "PUT /api/config-management/perf-config/:id",
    "method": "PUT",
    "priority": "P0",
    "requestBody": "step1?, step2, saveMode",
    "responseBody": "{ updated }"
  }
}
