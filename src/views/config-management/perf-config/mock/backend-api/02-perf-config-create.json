{
  "_comment": "新建绩效配置。step1 维度与 cockpit meta-filter-options 的 value 对齐。",
  "fieldDescription": {
    "request": {
      "step1": { "type": "PerfStep1Form", "required": true, "description": "基础信息。" },
      "step2": { "type": "PerfStep2Form", "required": true, "description": "绩效指标。" },
      "saveMode": {
        "type": "string",
        "required": true,
        "enum": ["draft", "publish"],
        "description": "保存方式。"
      }
    },
    "PerfStep1Form": {
      "appId": {
        "type": "string",
        "required": true,
        "description": "应用；cockpit appOptions[].value。"
      },
      "appName": { "type": "string", "required": true, "description": "应用展示名。" },
      "platform": {
        "type": "string",
        "required": true,
        "description": "终端平台；cockpit platformOptions[].value。"
      },
      "sourceList": {
        "type": "string[]",
        "required": true,
        "description": "广告平台多选；元素为 cockpit sourceOptions[].value；至少 1 项。"
      },
      "runStatus": {
        "type": "string",
        "required": true,
        "enum": ["running", "paused", "stopped"],
        "description": "投放状态。"
      },
      "allowMulti": { "type": "boolean", "required": true, "description": "是否允许多投。" }
    },
    "PerfStep2Form": {
      "evalMethod": {
        "type": "string",
        "required": true,
        "enum": ["ROI", "CPA"],
        "description": "评估方式。"
      },
      "evalDays": { "type": "number", "required": true, "description": "评估天数。" },
      "targetRate": { "type": "number", "required": true, "description": "达标要求。" },
      "minRate": { "type": "number", "required": true, "description": "最低要求。" },
      "difficultyFactor": { "type": "number", "required": true, "description": "难度系数。" },
      "minProfit": { "type": "number|null", "required": true, "description": "最低利润。" },
      "extraCondition": { "type": "string", "required": true, "description": "附加条件。" }
    },
    "response": {
      "id": { "type": "string", "required": true, "description": "新增配置 ID。" }
    }
  },
  "sampleRequest": {
    "step1": {
      "appId": "com.blood.sugar.monitor",
      "appName": "BloodSugar2",
      "platform": "0",
      "sourceList": ["1"],
      "runStatus": "running",
      "allowMulti": true
    },
    "step2": {
      "evalMethod": "ROI",
      "evalDays": 7,
      "targetRate": 55,
      "minRate": 45,
      "difficultyFactor": 1.2,
      "minProfit": 100,
      "extraCondition": ""
    },
    "saveMode": "publish"
  },
  "sampleResponse": {
    "data": {
      "id": "PF-009",
      "appId": "com.blood.sugar.monitor",
      "appName": "BloodSugar2",
      "appIcon": "#3B82F6",
      "platform": "0",
      "source": "1",
      "sourceList": ["1"],
      "runStatus": "running",
      "allowMulti": true,
      "activeVersion": {
        "version": 1,
        "status": "published",
        "publishedAt": "2026-03-27 10:00:00",
        "publishedBy": "admin",
        "evalMethod": "ROI",
        "evalDays": 7,
        "targetRate": 55,
        "minRate": 45,
        "difficultyFactor": 1.2,
        "minProfit": 100,
        "extraCondition": "",
        "isActive": true
      },
      "versions": [
        {
          "version": 1,
          "status": "published",
          "publishedAt": "2026-03-27 10:00:00",
          "publishedBy": "admin",
          "evalMethod": "ROI",
          "evalDays": 7,
          "targetRate": 55,
          "minRate": 45,
          "difficultyFactor": 1.2,
          "minProfit": 100,
          "extraCondition": "",
          "isActive": true
        }
      ]
    }
  },
  "api": {
    "url": "POST /api/config-management/perf-config",
    "method": "POST",
    "priority": "P0",
    "requestBody": "step1, step2, saveMode",
    "responseBody": "PerfConfigItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "新建向导最后一步提交 `createPerfConfig`；saveMode 为 draft 或 publish。",
        "prerequisite": "`PerfConfigApiSource.perfCreate`。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "提交防重复。"
  }
}
