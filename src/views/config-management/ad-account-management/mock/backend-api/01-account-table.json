{
  "_comment": "Ad account management - paginated table query. Used by search, filters, pagination and table rendering.",
  "fieldDescription": {
    "request": {
      "current": {
        "type": "number",
        "required": true,
        "description": "Current page number, starts from 1."
      },
      "size": { "type": "number", "required": true, "description": "Page size." },
      "keyword": {
        "type": "string",
        "required": false,
        "description": "Fuzzy keyword for appName and managerAccount. Empty string means no keyword filter."
      },
      "appName": {
        "type": "string",
        "required": false,
        "enum": ["", "Weather5", "Weather6", "Weather8", "Weather9"],
        "description": "App filter. Empty string means all."
      },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["", "Android", "iOS"],
        "description": "Platform filter. Empty string means all."
      },
      "adPlatform": {
        "type": "string",
        "required": false,
        "enum": ["", "Google", "TikTok", "Mintegral", "NewsBreak"],
        "description": "Ad platform filter. Empty string means all."
      },
      "status": {
        "type": "string",
        "required": false,
        "enum": ["", "enabled", "disabled"],
        "description": "Status filter. Empty string means all."
      }
    },
    "response": {
      "records": {
        "type": "AdAccountRow[]",
        "required": true,
        "description": "Current page records. Return [] when no data."
      },
      "current": { "type": "number", "required": true, "description": "Current page number." },
      "size": { "type": "number", "required": true, "description": "Page size." },
      "total": { "type": "number", "required": true, "description": "Total matched rows." }
    },
    "AdAccountRow": {
      "id": { "type": "number", "required": true, "description": "Primary key ID." },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["enabled", "disabled"],
        "description": "Account status."
      },
      "appName": {
        "type": "string",
        "required": true,
        "enum": ["Weather5", "Weather6", "Weather8", "Weather9"],
        "description": "App name."
      },
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["Android", "iOS"],
        "description": "OS platform."
      },
      "adPlatform": {
        "type": "string",
        "required": true,
        "enum": ["Google", "TikTok", "Mintegral", "NewsBreak"],
        "description": "Ad platform."
      },
      "managerAccount": {
        "type": "string",
        "required": true,
        "description": "Manager account ID or name."
      },
      "adAccounts": {
        "type": "string[]",
        "required": true,
        "description": "Ad account ID list. Return [] when not configured."
      },
      "credential": {
        "type": "string",
        "required": true,
        "description": "Credential name. Empty string is allowed."
      },
      "token": {
        "type": "string|null",
        "required": true,
        "description": "Raw token value or null. Frontend masks it by itself."
      }
    }
  },
  "sampleRequest": {
    "current": 1,
    "size": 10,
    "keyword": "",
    "appName": "",
    "platform": "",
    "adPlatform": "",
    "status": ""
  },
