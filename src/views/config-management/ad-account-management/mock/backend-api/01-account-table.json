  "api": {
    "url": "POST /api/config-management/ad-account-management/account/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "current, size, keyword?, appName?, platform?, adPlatform?, status?",
    "responseBody": "Api.Common.PaginatedResponse<AdAccountRow>"
  },
  "apiSuggestion": {
    "notes": [
      "Return records: [] and total: 0 when there is no data.",
      "Do server-side pagination by current and size.",
      "Token can be returned as raw value or null because masking is handled on the frontend."
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "page init",
        "detail": "Load table data when /config-management/ad-account-management is opened.",
        "prerequisite": "none"
      },
      {
        "moment": "user action",
        "detail": "Reload when keyword, appName, platform, adPlatform, status, current or size changes."
      }
    ],
    "defaultSelection": "keyword, appName, platform, adPlatform and status default to empty string. current defaults to 1 and size defaults to 10.",
    "dedupe": "Use the latest request result when filters change quickly."
  }
