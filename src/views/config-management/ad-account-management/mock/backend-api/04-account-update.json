  "apiSuggestion": {
    "notes": [
      "Return the full row to keep frontend merge logic simple.",
      "Passing adAccounts as [] means clearing all ad account IDs.",
      "appId/platform/source must stay aligned with cockpit meta option values."
    ]
  },
  "interaction": {
    "triggers": [
      {
