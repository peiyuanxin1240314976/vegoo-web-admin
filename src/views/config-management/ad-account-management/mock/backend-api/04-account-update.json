{
  "_comment": "Ad account management - update account.",
  "fieldDescription": {
    "request": {
      "id": { "type": "number", "required": true, "description": "Target account ID." },
      "appId": {
        "type": "string",
        "required": true,
        "description": "Application id; cockpit appOptions[].value."
      },
      "appName": {
        "type": "string",
        "required": true,
        "description": "Application display name for list and detail."
      },
      "platform": {
        "type": "string",
        "required": true,
        "description": "Terminal platform; cockpit platformOptions[].value."
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "Ad platform; cockpit sourceOptions[].value."
      },
      "managerAccount": {
        "type": "string",
        "required": true,
        "description": "Manager account ID or name."
      },
      "credential": {
        "type": "string",
        "required": false,
        "description": "Credential name. Empty string is allowed."
      },
      "adAccounts": {
        "type": "string[]",
        "required": true,
        "description": "Ad account ID list. [] is allowed."
      },
      "token": {
        "type": "string",
        "required": false,
        "description": "API token. Empty string is allowed."
      }
    },
    "response": {
      "updated": { "type": "boolean", "required": true, "description": "Update result." },
      "record": {
        "type": "AdAccountRow",
        "required": true,
        "description": "Complete updated row for immediate frontend replacement."
      }
    },
    "AdAccountRow": {
      "id": { "type": "number", "required": true, "description": "Primary key ID." },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["enabled", "disabled"],
        "description": "Account status."
      },
      "appId": { "type": "string", "required": true, "description": "Application id." },
      "appName": { "type": "string", "required": true, "description": "Application display name." },
      "platform": {
        "type": "string",
        "required": true,
        "description": "Terminal platform value."
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "Ad platform value."
      },
      "managerAccount": {
        "type": "string",
        "required": true,
        "description": "Manager account ID or name."
      },
      "adAccounts": { "type": "string[]", "required": true, "description": "Ad account ID list." },
      "credential": { "type": "string", "required": true, "description": "Credential name." },
      "token": {
        "type": "string|null",
        "required": true,
        "description": "Raw token value or null."
      }
    }
  },
