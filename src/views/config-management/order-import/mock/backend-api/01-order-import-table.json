          "remark": "文件格式异常"
        }
      ]
    }
  },
  "api": {
    "url": "POST /api/config-management/order-import/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "分页+筛选参数",
    "responseBody": "{ total, records, current, size }"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`/config-management/order-import` `index.vue` 拉取任务表与 KPI；`OrderImportListApiSource.importTable`。",
        "prerequisite": "登录态。"
      },
      {
        "moment": "用户操作",
        "detail": "筛选数据源/状态、分页变更后重新请求。"
      }
    ],
    "defaultSelection": "page=1，pageSize=10。",
    "dedupe": "无"
  }
}
