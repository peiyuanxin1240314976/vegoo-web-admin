{
  "_comment": "成本系数管理 KPI 四卡概览，对应 CostCoefficientOverviewKpi。",
  "fieldDescription": {
    "request": {
      "nSource": {
        "type": "number",
        "required": false,
        "description": "广告平台 n_source 筛选。"
      },
      "tStartYear": {
        "type": "string",
        "required": false,
        "description": "生效年份筛选，格式 YYYY。"
      },
      "keyword": {
        "type": "string",
        "required": false,
        "description": "关键字筛选（平台名称/日期/操作人）。"
      }
    },
    "response": {
      "total": { "type": "number", "required": true, "description": "配置总条数。" },
      "active": {
        "type": "number",
        "required": true,
        "description": "已启用条数（tstart 小于等于今天）。"
      },
      "platforms": {
        "type": "number",
        "required": true,
        "description": "平台覆盖数量（按 nSource 去重）。"
      },
      "monthChanges": {
        "type": "number",
        "required": true,
        "description": "本月变更次数（updatedAt 所在月份等于当前月）。"
      }
    }
  },
  "sampleRequest": { "nSource": 1, "tStartYear": "2026", "keyword": "" },
  "sampleResponse": {
    "data": { "total": 18, "active": 12, "platforms": 6, "monthChanges": 9 }
  },
  "api": {
    "url": "POST /api/config-management/cost-coefficient/overview/kpi",
    "method": "POST",
    "priority": "P0",
    "requestBody": "nSource?, tStartYear?, keyword?",
    "responseBody": "{ total, active, platforms, monthChanges }"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`/config-management/cost-coefficient` 进入后加载 KPI 卡片。"
      },
      {
        "moment": "用户操作",
        "detail": "筛选条件变更后刷新 KPI。"
      }
    ],
    "defaultSelection": "按当前筛选条件聚合，不受表格分页影响。",
    "dedupe": "同筛选条件可短时复用。"
  }
}
