{
  "_comment": "成本系数列表，对应 CostCoefficientQuery。",
  "fieldDescription": {
    "request": {
      "nSource": { "type": "number", "required": false, "description": "广告平台 n_source。" },
      "tStartYear": { "type": "string", "required": false, "description": "生效年份。" },
      "keyword": { "type": "string", "required": false, "description": "关键词。" },
      "page": { "type": "number", "required": true, "description": "页码。", "default": 1 },
      "pageSize": { "type": "number", "required": true, "description": "每页条数。", "default": 10 }
    },
    "response": {
      "records": {
        "type": "CostCoefficientItem[]",
        "required": true,
        "description": "当前页列表。"
      },
      "total": { "type": "number", "required": true, "description": "符合筛选条件的总条数。" },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" }
    },
    "CostCoefficientItem": {
      "id": { "type": "string", "required": true, "description": "记录 ID。" },
      "nSource": { "type": "number", "required": true, "description": "广告平台 n_source。" },
      "platformName": { "type": "string", "required": true, "description": "广告平台名称。" },
      "tStart": { "type": "string", "required": true, "description": "生效起始日期 YYYY-MM-DD。" },
      "dCostRatio": {
        "type": "number",
        "required": true,
        "description": "折算比例 d_cost_ratio（展示保留 3 位小数）。"
      },
      "dInstallCost": {
        "type": "number",
        "required": true,
        "description": "安装成本 d_install_cost（展示保留 5 位小数）。"
      },
      "updatedAt": {
        "type": "string",
        "required": true,
        "description": "最后修改时间 YYYY-MM-DD HH:mm。"
      },
      "updatedBy": { "type": "string", "required": true, "description": "操作人。" },
      "remark": { "type": "string", "required": true, "description": "备注。" },
      "isDeleted": { "type": "boolean", "required": true, "description": "逻辑删除标记。" }
    }
  },
