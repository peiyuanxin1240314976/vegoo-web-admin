{
  "_comment": "批量同步汇率。",
  "fieldDescription": {
    "request": {
      "pairs": { "type": "string[]", "required": true, "description": "同步货币对。" },
      "source": {
        "type": "string",
        "required": true,
        "enum": ["openexchange", "fixer", "custom"],
        "description": "数据源。"
      }
    },
    "response": {
      "total": { "type": "number", "required": true, "description": "总同步数。" },
      "success": { "type": "number", "required": true, "description": "成功数。" },
      "overrideManual": { "type": "number", "required": true, "description": "覆盖手动数。" },
      "failed": { "type": "number", "required": true, "description": "失败数。" }
    }
  },
  "sampleRequest": { "pairs": ["USD/EUR", "USD/JPY"], "source": "openexchange" },
  "sampleResponse": {
    "data": { "total": 2, "success": 2, "overrideManual": 0, "failed": 0, "syncTime": "2026-03-24 09:32:00" }
  },
  "api": {
    "url": "POST /api/config-management/exchange-rate/sync",
    "method": "POST",
    "priority": "P0",
    "requestBody": "pairs, source",
    "responseBody": "SyncResult"
  }
}
