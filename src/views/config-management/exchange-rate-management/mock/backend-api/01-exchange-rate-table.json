{
  "_comment": "汇率列表，对应 ExchangeRateQuery。",
  "fieldDescription": {
    "request": {
      "pair": { "type": "string", "required": false, "description": "货币对筛选。" },
      "date": { "type": "string", "required": false, "description": "日期筛选 YYYY-MM-DD。" },
      "page": { "type": "number", "required": true, "description": "页码。", "default": 1 },
      "pageSize": { "type": "number", "required": true, "description": "每页条数。", "default": 10 }
    },
    "response": {
      "records": {
        "type": "ExchangeRateItem[]",
        "required": true,
        "description": "当前页汇率记录。"
      },
      "total": { "type": "number", "required": true, "description": "符合筛选条件的总条数。" },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "当前每页条数。" }
    },
    "ExchangeRateItem": {
      "id": { "type": "string", "required": true, "description": "汇率记录唯一 ID。" },
      "pair": { "type": "string", "required": true, "description": "货币对，如 USD/EUR。" },
      "baseCurrency": { "type": "string", "required": true, "description": "来源货币代码。" },
      "quoteCurrency": { "type": "string", "required": true, "description": "目标货币代码。" },
      "currentRate": { "type": "number", "required": true, "description": "当前汇率值。" },
      "yesterdayRate": { "type": "number", "required": true, "description": "昨日汇率值。" },
      "changePercent": {
        "type": "number",
        "required": true,
        "description": "变动幅度百分比（可正可负）。"
      },
      "lastUpdated": {
        "type": "string",
        "required": true,
        "description": "最后更新时间，格式 HH:mm。"
      },
      "dataSource": {
        "type": "string",
        "required": true,
        "enum": ["auto", "manual"],
        "description": "数据来源，auto=自动同步，manual=手动录入。"
      },
      "isEnabled": { "type": "boolean", "required": true, "description": "是否启用。" },
      "isPinned": { "type": "boolean", "required": true, "description": "是否置顶。" },
      "overrideAuto": {
        "type": "boolean",
        "required": true,
        "description": "是否覆盖自动同步（对应表格“覆盖/已覆盖”按钮状态）。"
      },
      "remark": { "type": "string", "required": false, "description": "备注（可为空）。" },
      "effectiveDate": {
        "type": "string",
        "required": false,
        "description": "手动设置生效日期 YYYY-MM-DD（可为空）。"
      },
      "effectiveTime": {
        "type": "string",
        "required": false,
        "description": "手动设置生效时间 HH:mm（可为空）。"
      }
    }
  },
  "sampleRequest": { "pair": "", "date": "", "page": 1, "pageSize": 10 },
  "sampleResponse": {
    "data": {
      "records": [
        {
          "id": "ER-001",
          "pair": "USD/EUR",
          "baseCurrency": "USD",
          "quoteCurrency": "EUR",
          "currentRate": 0.9234,
          "yesterdayRate": 0.9198,
          "changePercent": 0.39,
          "lastUpdated": "10:32",
          "dataSource": "auto",
          "isEnabled": true,
          "isPinned": true,
          "overrideAuto": false,
          "remark": "",
          "effectiveDate": "",
          "effectiveTime": ""
        },
        {
          "id": "ER-002",
          "pair": "USD/JPY",
          "baseCurrency": "USD",
          "quoteCurrency": "JPY",
          "currentRate": 154.23,
          "yesterdayRate": 153.98,
          "changePercent": 0.16,
          "lastUpdated": "10:31",
          "dataSource": "manual",
          "isEnabled": true,
          "isPinned": false,
          "overrideAuto": true,
          "remark": "财务确认后手动覆盖",
          "effectiveDate": "2026-04-15",
          "effectiveTime": "10:30"
        },
        {
          "id": "ER-003",
          "pair": "USD/GBP",
          "baseCurrency": "USD",
          "quoteCurrency": "GBP",
          "currentRate": 0.7812,
          "yesterdayRate": 0.7854,
          "changePercent": -0.53,
          "lastUpdated": "10:30",
          "dataSource": "auto",
          "isEnabled": true,
          "isPinned": false,
          "overrideAuto": false,
          "remark": "",
          "effectiveDate": "",
          "effectiveTime": ""
        }
      ],
      "total": 12,
      "current": 1,
      "size": 10
    }
  },
  "api": {
    "url": "POST /api/config-management/exchange-rate/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "pair?, date?, page, pageSize",
    "responseBody": "{ records, total, current, size }"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`/config-management/exchange-rate-management` 进入后加载表格；`ExchangeRateApiSource.rateTable` 控制 mock。",
        "prerequisite": "登录态。"
      },
      {
        "moment": "用户操作",
        "detail": "筛选货币对、日期、分页变更后重新请求。"
      }
    ],
    "defaultSelection": "page=1，pageSize=10。",
    "dedupe": "无"
  }
}
