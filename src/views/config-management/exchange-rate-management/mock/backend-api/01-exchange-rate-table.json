{
  "_comment": "汇率列表，对应 ExchangeRateQuery。",
  "fieldDescription": {
    "request": {
      "pair": { "type": "string", "required": false, "description": "货币对筛选。" },
      "date": { "type": "string", "required": false, "description": "日期筛选 YYYY-MM-DD。" },
      "page": { "type": "number", "required": true, "description": "页码。", "default": 1 },
      "pageSize": { "type": "number", "required": true, "description": "每页条数。", "default": 10 }
    },
    "response": {
      "total": { "type": "number", "required": true, "description": "总数。" },
      "list": { "type": "ExchangeRateItem[]", "required": true, "description": "汇率列表。" }
    }
  },
  "sampleRequest": { "pair": "", "date": "", "page": 1, "pageSize": 10 },
  "sampleResponse": { "data": { "total": 2, "list": [{ "id": "ER-001", "pair": "USD/EUR" }] } },
  "api": {
    "url": "POST /api/config-management/exchange-rate/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "pair?, date?, page, pageSize",
    "responseBody": "{ total, list }"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`/config-management/exchange-rate-management` 进入后加载表格；`ExchangeRateApiSource.rateTable` 控制 mock。",
        "prerequisite": "登录态。"
      },
      {
        "moment": "用户操作",
        "detail": "筛选货币对、日期、分页变更后重新请求。"
      }
    ],
    "defaultSelection": "page=1，pageSize=10。",
    "dedupe": "无"
  }
}
