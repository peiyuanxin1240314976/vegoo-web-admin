{
  "_comment": "优化师管理 - 更新。路径参数 id + body 与 FormPayload 一致（含 id 也可仅在路径）。",
  "fieldDescription": {
    "request": {
      "id": { "type": "string", "required": true, "description": "路径 :id，优化师主键。" },
      "userId": {
        "type": "string",
        "required": true,
        "description": "关联用户（通常不可改，可与原值一致）。"
      },
      "version": { "type": "number", "required": true, "description": "版本号。" },
      "sCode": { "type": "string", "required": true, "description": "代号。" },
      "sCode2": { "type": "string", "required": false, "description": "副代号。" },
      "minConsumption": {
        "type": "number",
        "required": true,
        "description": "最低消耗要求（美元）。"
      },
      "checkCode": { "type": "string", "required": true, "description": "检验码。" },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["在职", "离职"],
        "description": "状态。"
      }
    },
    "response": {
      "data": { "type": "ListItem", "required": true, "description": "更新后的完整行。" }
    }
  },
  "sampleRequest": {
    "userId": "u001",
    "version": 2,
    "sCode": "FB-OPT-001",
    "sCode2": "FB-001",
    "minConsumption": 900,
    "checkCode": "CHK-UPDATED",
    "status": "在职"
  },
  "sampleResponse": {
    "data": {
      "id": "opt001",
      "no": 1,
      "userId": "u001",
      "userName": "张三",
      "email": "zhang@example.com",
      "avatarColor": "#2dd4bf",
      "version": 2,
      "sCode": "FB-OPT-001",
      "minConsumption": 900,
      "checkCode": "CHK-UPDATED",
      "status": "在职",
      "apps": [],
      "recentLogs": [],
      "createTime": "2024-01-15",
      "lastModifyTime": "2026-03-21 12:00"
    }
  },
  "api": {
    "url": "PUT /api/config-management/optimizer/:id",
    "method": "PUT",
    "priority": "P0",
    "requestBody": "FormPayload + id（id 以路径为准）",
    "responseBody": "ListItem"
  }
}
