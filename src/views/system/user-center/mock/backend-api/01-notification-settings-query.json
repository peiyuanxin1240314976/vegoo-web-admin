{
  "_comment": "系统 - 个人中心 - 查询当前登录用户的通知设置。仅覆盖页面上线模块：飞书通知（预警/日报两行）、预警级别（高优先级 + 飞书卡片）、推送时间；与 index.vue 当前可见表单一致。",
  "fieldDescription": {
    "request": {},
    "response": {
      "data": {
        "type": "UserNotificationSettings",
        "required": true,
        "description": "当前用户的通知偏好；无记录时后端返回与默认 UI 一致的结构。"
      }
    },
    "UserNotificationSettings": {
      "feishu": {
        "type": "FeishuNotifySwitches",
        "required": true,
        "description": "飞书渠道通知开关；键与当前表格两行（预警通知、日报推送）一致。"
      },
      "alertChannels": {
        "type": "AlertChannelsConfig",
        "required": true,
        "description": "预警级别触达渠道；当前页面仅展示高优先级一块，仅支持飞书卡片勾选。"
      },
      "pushInWorkTime": {
        "type": "boolean",
        "required": true,
        "description": "是否仅在工作时间内推送（与页面「工作时间内推送」单选项绑定）。"
      },
      "pushStartTime": {
        "type": "string",
        "required": true,
        "description": "允许推送的开始时间，格式 HH:mm（24 小时制）。"
      },
      "pushEndTime": {
        "type": "string",
        "required": true,
        "description": "允许推送的结束时间，格式 HH:mm（24 小时制）。"
      },
      "pushWeekdays": {
        "type": "number[]",
        "required": true,
        "description": "推送日，1–7 表示周一至周日；无数据时返回 []，前端可回退为默认工作日。"
      }
    },
    "FeishuNotifySwitches": {
      "alert": {
        "type": "boolean",
        "required": true,
        "description": "预警通知。"
      },
      "daily": {
        "type": "boolean",
        "required": true,
        "description": "日报推送。"
      }
    },
    "AlertChannelsConfig": {
      "high": {
        "type": "string[]",
        "required": true,
        "description": "高优先级预警触达渠道；当前 UI 仅提供飞书卡片。",
        "enum": ["feishu"]
      }
    }
  },
  "sampleRequest": {},
  "sampleResponse": {
    "data": {
      "feishu": {
        "alert": true,
        "daily": true
      },
      "alertChannels": {
        "high": ["feishu"]
      },
      "pushInWorkTime": true,
      "pushStartTime": "08:00",
      "pushEndTime": "22:00",
      "pushWeekdays": [1, 2, 3, 4, 5]
    }
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/system/user-center/notification-settings/query",
    "method": "POST",
    "priority": "P0",
    "requestBody": "无业务字段；依赖请求头 Authorization 识别当前用户",
    "responseBody": "{ data: UserNotificationSettings }"
  },
  "apiSuggestion": {
    "notes": [
      "首次无配置时建议仍返回完整 UserNotificationSettings，布尔与数组勿用 null 替代，数组用 []。",
      "若与网关统一结构不一致，可将业务体置于网关 data 内，字段名与类型保持不变。"
    ]
  }
}
