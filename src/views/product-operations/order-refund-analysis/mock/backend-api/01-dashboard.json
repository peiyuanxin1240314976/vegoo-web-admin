  },
  "api": {
    "url": "POST /api/product-operations/order-refund-analysis/overview/dashboard",
    "method": "POST",
    "priority": "P0",
    "requestBody": "OrderRefundDashboardParams",
    "responseBody": "DashboardPayload（网关包裹于 data）"
  },
  "apiSuggestion": {
    "notes": [
      "成功响应需符合项目 BaseResponse：`{ code, data, msg }`，`request` 拦截器返回解包后的业务体。",
      "筛选「全部」维度统一传空字符串 \"\"，与 backend-fields「接口请求 · 筛选「全部」」一致。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "进入页面 onMounted",
        "detail": "使用当前已应用筛选调用 overview/dashboard，填充 KPI、四图、订单表与预警条。",
        "prerequisite": "appliedFilters 已由默认值或上次查询确定。"
      },
      {
        "moment": "点击「查询」",
        "detail": "将草稿筛选同步为已应用筛选后重新请求 dashboard。",
        "prerequisite": "日期范围合法。"
      },
      {
        "moment": "点击「刷新」",
        "detail": "在不清改筛选的前提下用当前已应用条件重新请求 dashboard。"
      }
    ],
    "defaultSelection": "应用/国家/支付平台默认「全部」对应请求体空串；对比期默认 last_month。",
    "dedupe": "单页单聚合接口；无并行重复拉取同一 endpoint 的必要。"
  }
}
