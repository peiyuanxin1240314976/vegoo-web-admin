{
  "_comment": "订单退款分析 - 看板聚合。对应 types.ts: DashboardPayload、OrderRefundDashboardParams；实现 @/api/product-operations/order-refund-analysis.ts: getDashboard。",
  "fieldDescription": {
    "request": {
      "appId": {
        "type": "string",
        "required": true,
        "description": "应用筛选；自有应用 ID。选「全部」时传空字符串 \"\"（勿传字面量 all）。"
      },
      "startDate": {
        "type": "string",
        "required": true,
        "description": "开始日期，YYYY-MM-DD（含）。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "结束日期，YYYY-MM-DD（含）。"
      },
      "compareType": {
        "type": "string",
        "required": true,
        "enum": ["last_month", "last_week", "last_year"],
        "description": "对比期间类型。"
      },
      "countryCode": {
        "type": "string",
        "required": true,
        "description": "国家 ISO 3166-1 alpha-2 小写；不限国家时传 \"\"（与 UI「全部」映射一致）。"
      },
      "paymentPlatform": {
        "type": "string",
        "required": true,
        "description": "支付平台筛选项（如 google_play、app_store、stripe）；「全部」传 \"\"。"
      }
    },
    "response": {
      "data": {
        "type": "DashboardPayload",
        "required": true,
        "description": "网关包裹时为 data 内业务体。"
      }
    },
    "DashboardPayload": {
      "kpi": { "type": "OrderRefundKpiBlock", "required": true, "description": "KPI 数值块。" },
      "trend": {
        "type": "TrendPoint[]",
        "required": true,
        "description": "退款趋势点（通常约 30 天，与日期范围对齐）。"
      },
      "reasonData": {
        "type": "{ name: string; value: number }[]",
        "required": true,
        "description": "退款原因占比（饼图；value 为百分比或相对权重，与产品口径一致）。"
      },
      "countryData": {
        "type": "CountryRate[]",
        "required": true,
        "description": "国家退款率对比。"
      },
      "orderData": {
        "type": "OrderRecord[]",
        "required": true,
        "description": "退款订单明细表主数据。"
      },
      "alertMessage": {
        "type": "string",
        "required": true,
        "description": "底部预警条文案；空字符串表示不展示。"
      }
    },
    "CountryRate": {
      "countryCode": {
        "type": "string",
        "required": true,
        "description": "国家代码，ISO 3166-1 alpha-2 小写。"
      },
      "rate": {
        "type": "number",
        "required": true,
        "description": "退款率等指标（百分比数值，口径见产品）。"
      },
      "level": {
        "type": "string",
        "required": true,
        "enum": ["good", "warning", "danger", "critical"],
        "description": "与条形图色阶一致。"
      },
      "badge": { "type": "string", "required": false, "description": "可选角标文案。" }
    },
    "OrderRecord": {
      "orderId": { "type": "string", "required": true, "description": "订单号。" },
      "user": { "type": "string", "required": true, "description": "用户标识（脱敏展示）。" },
      "amount": {
        "type": "number",
        "required": true,
        "description": "金额（USD 等，与产品一致）。"
      },
      "reason": { "type": "string", "required": true, "description": "退款原因文案。" },
      "platform": { "type": "string", "required": true, "description": "支付渠道/商店展示名。" },
      "date": { "type": "string", "required": true, "description": "日期 YYYY-MM-DD。" },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["refunded", "processing", "pending"],
        "description": "订单退款状态。"
      }
    }
  },
  "sampleRequest": {
