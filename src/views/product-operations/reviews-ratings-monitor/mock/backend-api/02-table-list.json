        "starRating": 3,
        "content": "还可以，无功无过，期待后续优化",
        "date": "2026-03-03",
        "platform": "google_play",
        "appName": "Weather5",
        "appVersion": "1.2.0",
        "countryCode": "es",
        "language": "zh",
        "sentiment": "neutral",
        "replied": false,
        "autoReplied": false
      }
    ]
  },
  "api": {
    "url": "POST /api/product-operations/reviews-ratings-monitor/table/list",
    "method": "POST",
    "priority": "P0",
    "requestBody": "appIds[], platform?, startDate?, endDate?, language?, starRating?, reviewType?, replied?, autoReplied?, keyword?, sortBy?, page, pageSize",
    "responseBody": "ReviewListData"
  },
  "apiSuggestion": {
    "notes": [
      "分页从 1 开始；keyword 支持模糊匹配评论 content。",
      "筛选 reviewType 与行内展示字段的映射由后端约定；示例 list 中 sentiment 覆盖 positive / negative / neutral，platform 覆盖 google_play 与 app_store。"
    ]
  }
}
