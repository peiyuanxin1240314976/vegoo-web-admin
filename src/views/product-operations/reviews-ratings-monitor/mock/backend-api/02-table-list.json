        "date": "2026-03-04",
        "platform": "app_store",
        "appName": "ClapFinder",
        "appVersion": "2.0.8",
        "countryCode": "us",
        "language": "en",
        "sentiment": "positive",
        "replied": true,
        "autoReplied": true,
        "replyContent": "Thank you for your support!"
      },
      {
        "id": "9",
