{
  "_comment": "商品运营 - 三方商店管理：概览仪表盘（平台卡、摘要 KPI、应用商店表、渠道表、图表）。对应 types.ts: ThirdPartyStoresDashboardPayload。",
  "fieldDescription": {
    "request": {
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台筛选：空为全部；android / ios。"
      },
      "appStore": {
        "type": "string",
        "required": false,
        "description": "应用商店维度，空为全部。"
      },
      "appId": {
        "type": "string",
        "required": false,
        "description": "应用筛选 ID（或与页面下拉 value 一致的应用标识）；空为全部。"
      },
      "source": {
        "type": "string",
        "required": false,
        "description": "广告平台（与数据字典 n_source 语义一致），空为全部。"
      },
      "channel": {
        "type": "string",
        "required": false,
        "description": "推广渠道，空为全部。"
      },
      "startDate": {
        "type": "string",
        "required": false,
        "description": "查询开始日期（含），YYYY-MM-DD。"
      },
      "endDate": {
        "type": "string",
        "required": false,
        "description": "查询结束日期（含），YYYY-MM-DD。"
      },
      "currency": {
        "type": "string",
        "required": false,
        "description": "展示货币代码，如 USD。"
      }
    },
    "response": {
      "data": {
        "type": "ThirdPartyStoresDashboardPayload",
        "required": true,
        "description": "网关包裹时位于 data 内；与前端类型一致。"
      }
    },
    "ThirdPartyStoresDashboardPayload": {
      "platformCards": {
        "type": "PlatformCard[]",
        "required": true,
        "description": "各应用商店平台接入状态卡片。"
      },
      "statusSummary": {
        "type": "ThirdPartyStoresStatusSummary",
        "required": true,
        "description": "顶部四张摘要统计。"
      },
      "summary": {
        "type": "ThirdPartyStoresSummaryMetrics",
        "required": true,
        "description": "中部 KPI 数值（原始数，前端格式化）。"
      },
      "appStoreData": {
        "type": "AppStoreRecord[]",
        "required": true,
        "description": "应用商店数据明细树形表。"
      },
      "channelData": {
        "type": "ChannelRecord[]",
        "required": true,
        "description": "推广渠道数据明细树形表。"
      },
      "donut": {
        "type": "object",
        "required": true,
        "description": "广告平台收入占比环形图数据。"
      },
      "bar": {
        "type": "object",
        "required": true,
        "description": "推广渠道应用收入分布条形图数据。"
      }
    },
    "PlatformCard": {
      "id": { "type": "string", "required": true, "description": "平台唯一 id。" },
      "name": { "type": "string", "required": true, "description": "平台名称。" },
      "icon": { "type": "string", "required": true, "description": "平台图标 key（前端占位）。" },
      "iconBg": {
        "type": "string",
        "required": true,
        "description": "平台图标背景色（CSS 颜色字符串）。"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["connected", "warning", "pending"],
        "description": "接入状态：connected 已接入、warning 异常、pending 未配置。"
      },
      "appCount": { "type": "number", "required": true, "description": "该平台覆盖应用数。" },
      "lastSync": { "type": "string", "required": true, "description": "最近同步时间或异常描述。" }
    },
    "ThirdPartyStoresStatusSummary": {
      "connectedPlatforms": { "type": "number", "required": true, "description": "已接入平台数。" },
      "totalApps": { "type": "number", "required": true, "description": "总应用数。" },
      "pendingSync": { "type": "number", "required": true, "description": "待同步数量。" },
      "newPlatformsThisMonth": {
        "type": "number",
        "required": true,
        "description": "本月新增平台数。"
      },
      "newPlatformName": { "type": "string", "required": true, "description": "本月新增平台名称。" }
    },
    "ThirdPartyStoresSummaryMetrics": {
      "newUsers": { "type": "number", "required": true, "description": "总新用户数（计数）。" },
      "totalRevenue": {
        "type": "number",
        "required": true,
        "description": "总收入（金额；单位与 currency 一致）。"
      },
      "adRevenue": {
        "type": "number",
        "required": true,
        "description": "广告收入（金额；单位与 currency 一致）。"
      },
      "paidRevenue": {
        "type": "number",
        "required": true,
        "description": "付费收入（金额；单位与 currency 一致）。"
      },
      "arpu": {
        "type": "number",
        "required": true,
        "description": "平均每用户收入（金额；单位与 currency 一致）。"
      }
    },
    "AppStoreRecord": {
      "key": { "type": "string", "required": true, "description": "树表行唯一 key。" },
      "app": {
        "type": "string",
        "required": true,
        "description": "应用展示名称；分组行用于显示组名。"
      },
      "platform": {
        "type": "string",
        "required": true,
        "description": "平台展示值（如 安卓 / iOS）。"
      },
      "adStore": { "type": "string", "required": true, "description": "应用商店展示值。" },
      "adPlatform": { "type": "string", "required": true, "description": "广告平台/来源展示值。" },
      "newUsers": { "type": "number", "required": true, "description": "新用户数（计数）。" },
      "totalRevenue": { "type": "number", "required": true, "description": "总收入（金额）。" },
      "adRevenue": { "type": "number", "required": true, "description": "广告收入（金额）。" },
      "paidRevenue": { "type": "number", "required": true, "description": "付费收入（金额）。" },
      "adRatio": { "type": "number", "required": true, "description": "广告收入占比（0-100）。" },
      "isGroup": { "type": "boolean", "required": false, "description": "是否分组行（可展开）。" },
      "expanded": {
        "type": "boolean",
        "required": false,
        "description": "分组是否展开（仅前端使用）。"
      },
      "children": {
        "type": "AppStoreRecord[]",
        "required": false,
        "description": "子行数组（树表）。"
      }
    },
    "ChannelRecord": {
      "key": { "type": "string", "required": true, "description": "树表行唯一 key。" },
      "app": {
        "type": "string",
        "required": true,
        "description": "应用展示名称；分组行用于显示组名。"
      },
      "platform": {
        "type": "string",
        "required": true,
        "description": "平台展示值（如 安卓 / iOS）。"
      },
      "channel": { "type": "string", "required": true, "description": "推广渠道展示值。" },
      "adCampaign": { "type": "string", "required": true, "description": "广告系列展示值。" },
      "newUsers": { "type": "number", "required": true, "description": "新用户数（计数）。" },
      "totalRevenue": { "type": "number", "required": true, "description": "总收入（金额）。" },
      "adRevenue": { "type": "number", "required": true, "description": "广告收入（金额）。" },
      "paidRevenue": { "type": "number", "required": true, "description": "付费收入（金额）。" },
      "channelRatio": { "type": "number", "required": true, "description": "渠道占比（0-100）。" },
      "isGroup": { "type": "boolean", "required": false, "description": "是否分组行（可展开）。" },
      "expanded": {
        "type": "boolean",
        "required": false,
        "description": "分组是否展开（仅前端使用）。"
      },
      "children": {
        "type": "ChannelRecord[]",
        "required": false,
        "description": "子行数组（树表）。"
      }
    }
  },
