  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "路由 `/product-operations/third-party-stores` 进入后，在 `index.vue` 的 onMounted 调用 `thirdPartyStoresApi.getOverviewDashboard()` 拉取整页仪表盘数据。"
      },
      {
        "moment": "用户操作",
        "detail": "点击「查询」或「重置」后重新请求；请求体来自筛选栏：platform/appStore/appId/source/channel + startDate/endDate + currency。"
      }
    ],
    "defaultSelection": "默认日期为最近 7 天（含今日 0 点），currency 默认 USD；其它筛选为空字符串代表全部，提交时可省略字段或传空字符串。"
  },
  "api": {
    "url": "POST /api/product-operations/third-party-stores/overview/dashboard",
    "method": "POST",
    "priority": "P0",
    "requestBody": "platform?, appStore?, appId?, source?, channel?, startDate?, endDate?, currency?",
    "responseBody": "ThirdPartyStoresDashboardPayload（或网关包裹于 data）"
  },
  "apiSuggestion": {
    "notes": [
      "完整示例数据见 mocks/third-party-stores-default-payload.ts 与页面加载逻辑。",
      "列表筛选与聚合规则需与后端一致后再对齐字段。"
    ]
  }
}
