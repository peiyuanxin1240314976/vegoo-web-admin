{
  "_comment": "自动填充/预演框架 - 服务端导出译文文件。",
  "fieldDescription": {
    "request": {
      "format": {
        "type": "string",
        "required": true,
        "enum": ["xlsx", "csv", "json"],
        "description": "导出格式。"
      },
      "scope": {
        "type": "string",
        "required": true,
        "enum": ["completed", "selected", "custom"],
