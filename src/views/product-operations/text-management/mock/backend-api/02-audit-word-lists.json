        "required": true,
        "description": "词库配置。"
      }
    },
    "AuditWordLists": {
      "bannedWords": {
        "type": "string[]",
        "required": true,
        "description": "违禁词列表，匹配时不区分大小写（由服务端或前端统一约定）。"
      },
      "brandWords": {
        "type": "string[]",
        "required": true,
        "description": "品牌/竞品敏感词列表，用于高亮提示。"
      },
      "version": {
        "type": "string",
        "required": false,
        "description": "词库版本号，便于缓存失效。"
      }
    }
  },
