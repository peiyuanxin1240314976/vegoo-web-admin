{
  "_comment": "文本管理 - 商店列表文案草稿。对应 types.ts: AppContent、Translation；步骤完成状态用于恢复顶部步骤条。",
  "fieldDescription": {
    "request": {
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用 ID（自有）。空表示当前上下文默认应用。"
      }
    },
    "response": {
      "data": {
        "type": "StoreListingDraft",
        "required": true,
        "description": "草稿主体。"
      }
    },
