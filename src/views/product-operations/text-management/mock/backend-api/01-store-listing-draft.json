      "appContent": {
        "type": "AppContent",
        "required": true,
        "description": "主语言应用名、短描述、完整描述。"
      },
      "translations": {
        "type": "Translation[]",
        "required": true,
        "description": "各语种译文与状态。"
      },
      "step1Done": {
        "type": "boolean",
        "required": true,
        "description": "步骤一（文本审核）是否已完成。"
      },
      "step2Done": {
        "type": "boolean",
        "required": true,
        "description": "步骤二（自动填充）是否已完成。"
      },
      "updatedAt": {
        "type": "string",
        "required": false,
        "description": "服务端最后保存时间，ISO 8601。"
      }
    },
    "AppContent": {
      "appName": { "type": "string", "required": true, "description": "应用名称。" },
      "shortDesc": { "type": "string", "required": true, "description": "简短描述。" },
      "fullDesc": { "type": "string", "required": true, "description": "完整描述，可含换行。" }
    },
    "Translation": {
      "id": { "type": "string", "required": true, "description": "译文行唯一 id。" },
      "lang": { "type": "string", "required": true, "description": "语言展示名。" },
      "langCode": {
        "type": "string",
        "required": true,
        "description": "BCP 47 语言码，如 zh-CN、pt-BR。"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["completed", "over_limit", "translating", "pending"],
