      },
      "appName": { "type": "string", "required": true, "description": "该语种应用名。" },
      "shortDesc": { "type": "string", "required": true, "description": "该语种短描述。" },
      "fullDesc": { "type": "string", "required": true, "description": "该语种完整描述。" },
      "appNameCount": {
        "type": "number",
        "required": true,
        "description": "应用名字符数（可与客户端一致）。"
      },
      "shortDescCount": { "type": "number", "required": true, "description": "短描述字符数。" },
      "fullDescCount": { "type": "number", "required": true, "description": "完整描述字符数。" },
      "appNameLimit": {
        "type": "number",
        "required": true,
        "description": "应用名上限（如 30）。"
      },
      "shortDescLimit": { "type": "number", "required": true, "description": "短描述上限。" },
      "fullDescLimit": { "type": "number", "required": true, "description": "完整描述上限。" },
      "selected": { "type": "boolean", "required": true, "description": "列表多选状态。" },
      "aiSuggestion": {
        "type": "string",
        "required": false,
        "description": "可选的 AI 优化建议文案。"
      }
    }
  },
