{
  "_comment": "预估收入偏差 — 广告平台偏差对比表。对应 types.ts: RevenueDeviationPlatformTable。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "source": { "type": "string", "required": false, "description": "广告平台，空为全部。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，空为全部。" },
      "matrix_source": {
        "type": "string",
        "required": false,
        "description": "右上角「平台」筛选（广告平台编码），空为全部；当前作为全局筛选参数透传。"
      },
      "row_dim": {
        "type": "string",
        "required": false,
        "enum": ["app", "platform", "date"],
        "default": "app",
        "description": "右上角维度切换：行维度（默认 app）；当前作为全局筛选参数透传。"
      },
      "col_dim": {
        "type": "string",
        "required": false,
        "enum": ["platform", "date"],
        "default": "platform",
        "description": "右上角维度切换：列维度（默认 platform）；当前作为全局筛选参数透传。"
      }
    },
    "response": {
      "rows": {
        "type": "RevenueDeviationPlatformRow[]",
        "required": true,
        "description": "各广告平台行。"
      },
      "total": {
        "type": "RevenueDeviationPlatformRow",
        "required": true,
        "description": "合计行；s_source_label 可为「合计」。"
      }
    },
    "RevenueDeviationPlatformRow": {
      "s_source_label": { "type": "string", "required": true, "description": "广告平台展示名。" },
      "d_estimated_usd": {
        "type": "number",
        "required": true,
        "description": "预估收入（美元）。"
      },
      "d_real_usd": { "type": "number", "required": true, "description": "真实收入（美元）。" },
      "d_deviation_rate_pct": {
        "type": "number",
        "required": true,
        "description": "偏差率（百分比数值，可正可负）。"
      }
    }
  },
  "sampleRequest": {
    "t_start_date": "2024-05-01",
    "t_end_date": "2024-05-31",
    "source": "",
    "s_app_id": "",
    "matrix_source": "",
    "row_dim": "app",
    "col_dim": "platform"
  },
  "sampleResponse": {
    "rows": [
      {
        "s_source_label": "Admob",
        "d_estimated_usd": 2768.58,
        "d_real_usd": 1861.23,
        "d_deviation_rate_pct": 8.5
      },
      {
        "s_source_label": "Facebook",
        "d_estimated_usd": 1778.58,
        "d_real_usd": 1861.23,
        "d_deviation_rate_pct": 8.5
      },
      {
        "s_source_label": "Applovin",
        "d_estimated_usd": 888.53,
        "d_real_usd": 876.86,
        "d_deviation_rate_pct": 5.2
      },
      {
        "s_source_label": "Vungle",
        "d_estimated_usd": 338.8,
        "d_real_usd": 297.22,
        "d_deviation_rate_pct": -0.3
      },
      {
        "s_source_label": "Pangle",
        "d_estimated_usd": 722.5,
        "d_real_usd": 399.81,
        "d_deviation_rate_pct": -0.9
      }
    ],
    "total": {
      "s_source_label": "合计",
      "d_estimated_usd": 2798.58,
      "d_real_usd": 1861.23,
      "d_deviation_rate_pct": 8.5
    }
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "用于「平台偏差对比」表格（含合计行）；与其他区块并行加载。",
        "prerequisite": "无。"
      },
      {
        "moment": "筛选变化触发刷新",
        "detail": "日期范围/广告平台/应用变化后重新请求并刷新表格。",
        "prerequisite": "无。"
      }
    ],
    "defaultSelection": "source 为空表示全部广告平台；表格行按后端默认排序或按 d_deviation_rate_pct 排序（若需要前端排序需约定）。",
    "dedupe": "同入参可缓存；前端短时间内连续变更筛选可考虑防抖。"
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/revenue-deviation/table/platform",
    "method": "POST",
    "priority": "P0",
    "requestBody": "t_start_date, t_end_date, source?, s_app_id?, matrix_source?, row_dim?, col_dim?",
    "responseBody": "RevenueDeviationPlatformTable"
  },
  "apiSuggestion": {
    "notes": ["s_source_label 与 n_source 枚举映射由网关或字典统一。"]
  }
}
