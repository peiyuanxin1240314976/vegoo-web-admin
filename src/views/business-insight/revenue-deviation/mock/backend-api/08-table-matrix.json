{
  "_comment": "预估收入偏差 — 四维度偏差明细矩阵（应用 × 广告平台）。对应 types.ts: RevenueDeviationMatrixTable、mock/data.ts: MOCK_TABLE_MATRIX。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "source": { "type": "string", "required": false, "description": "广告平台，空为全部。" },
      "appIds": {
        "type": "string[]",
        "required": true,
        "description": "应用筛选；不限为 []，单选为 [\"应用ID\"]。"
      },
      "matrix_source": {
        "type": "string",
        "required": false,
        "description": "右上角「平台」筛选（广告平台编码），空为全部；当前作为全局筛选参数透传。"
      },
      "row_dim": {
        "type": "string",
        "required": false,
        "enum": ["app", "platform", "date"],
        "default": "app",
        "description": "右上角维度切换：行维度（默认 app）；当前作为全局筛选参数透传。"
      },
      "col_dim": {
        "type": "string",
        "required": false,
        "enum": ["platform", "date"],
        "default": "platform",
        "description": "右上角维度切换：列维度（默认 platform）；当前作为全局筛选参数透传。"
      }
    },
    "response": {
      "cols": {
        "type": "RevenueDeviationMatrixCol[]",
        "required": true,
        "description": "列：各广告平台 + 列合计（预估/真实/偏差率展示串）。"
      },
      "rows": {
        "type": "RevenueDeviationMatrixRow[]",
        "required": true,
        "description": "行：各应用一行多格。"
      }
    },
    "RevenueDeviationMatrixCol": {
      "name": { "type": "string", "required": true, "description": "列头展示名。" },
      "key": {
        "type": "string",
        "required": true,
        "enum": ["admob", "facebook", "applovin", "vungle"],
        "description": "列键，与 cells 字段名对应。"
      },
      "total": {
        "type": "RevenueDeviationMatrixCell",
        "required": true,
        "description": "该列合计格展示。"
      }
    },
    "RevenueDeviationMatrixRow": {
      "s_app_name": { "type": "string", "required": true, "description": "应用名。" },
      "s_app_icon_emoji": {
        "type": "string",
        "required": true,
        "description": "列表图标占位符（可为 emoji）；若改产品规范可换为 s_app_id + 静态资源。"
      },
      "s_icon_color": { "type": "string", "required": true, "description": "图标底色。" },
      "admob": {
        "type": "RevenueDeviationMatrixCell",
        "required": true,
        "description": "Admob 格。"
      },
      "facebook": {
        "type": "RevenueDeviationMatrixCell",
        "required": true,
        "description": "Facebook 格。"
      },
      "applovin": {
        "type": "RevenueDeviationMatrixCell",
        "required": true,
        "description": "Applovin 格。"
      },
      "vungle": {
        "type": "RevenueDeviationMatrixCell",
        "required": true,
        "description": "Vungle 格。"
      }
    },
    "RevenueDeviationMatrixCell": {
      "estimated": { "type": "string", "required": true, "description": "预估展示（已格式化）。" },
      "real": { "type": "string", "required": true, "description": "真实展示（已格式化）。" },
      "deviation": {
        "type": "string",
        "required": true,
        "description": "偏差率或区间文案，如 >15%、8–15%。"
      }
    }
  },
  "sampleRequest": {
    "t_start_date": "2024-05-01",
    "t_end_date": "2024-05-31",
    "source": "",
    "appIds": [],
    "matrix_source": "",
    "row_dim": "app",
    "col_dim": "platform"
  },
  "sampleResponse": {
    "cols": [
      {
        "name": "Admob",
        "key": "admob",
        "total": { "estimated": "$9.88", "real": "$3.77", "deviation": ">15%" }
      },
      {
        "name": "Facebook",
        "key": "facebook",
        "total": { "estimated": "$6.28", "real": "$0.00", "deviation": ">15%" }
      },
      {
        "name": "Applovin",
        "key": "applovin",
        "total": { "estimated": "$3.75", "real": "$3.99", "deviation": ">15%" }
      },
      {
        "name": "Vungle",
        "key": "vungle",
        "total": { "estimated": "$0.23", "real": "$9.78", "deviation": "<8%" }
      }
    ],
    "rows": [
      {
        "s_app_name": "WeatherRadar",
        "s_app_icon_emoji": "🌤",
        "s_icon_color": "#1e3a5f",
        "admob": { "estimated": "$9.33", "real": "$2.79", "deviation": ">15%" },
        "facebook": { "estimated": "$1.90", "real": "$1.18", "deviation": ">15%" },
        "applovin": { "estimated": "$3.96", "real": "$2.98", "deviation": ">15%" },
        "vungle": { "estimated": "$3.92", "real": "$2.21", "deviation": ">15%" }
      }
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "用于「四维度偏差明细分析表」矩阵区块；与其他区块并行加载。",
        "prerequisite": "无。"
      },
      {
        "moment": "筛选变化触发刷新",
        "detail": "日期范围/广告平台/应用变化后重新请求并刷新矩阵；矩阵右上角「平台」筛选与行/列维度切换同样会触发本接口刷新。",
        "prerequisite": "无。"
      }
    ],
    "defaultSelection": "默认 row_dim=app、col_dim=platform；matrix_source 为空表示全平台。",
    "dedupe": "无。"
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/revenue-deviation/table/matrix",
    "method": "POST",
    "priority": "P0",
    "requestBody": "t_start_date, t_end_date, source?, appIds, matrix_source?, row_dim?, col_dim?",
    "responseBody": "RevenueDeviationMatrixTable"
  },
  "apiSuggestion": {
    "notes": [
      "矩阵格为强展示形态，允许后端直接给格式化串；若需统一切换货币单位可改为数值 + 单位枚举。"
    ]
  }
}
