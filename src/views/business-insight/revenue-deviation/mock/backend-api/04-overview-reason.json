{
  "_comment": "预估收入偏差 — 偏差原因分析（饼图）。对应 types.ts: RevenueDeviationReasonSegment[]。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "source": { "type": "string", "required": false, "description": "广告平台，空为全部。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，空为全部。" },
      "matrix_source": {
        "type": "string",
        "required": false,
        "description": "右上角「平台」筛选（广告平台编码），空为全部；当前作为全局筛选参数透传。"
      },
      "row_dim": {
        "type": "string",
        "required": false,
        "enum": ["app", "platform", "date"],
        "default": "app",
        "description": "右上角维度切换：行维度（默认 app）；当前作为全局筛选参数透传。"
      },
      "col_dim": {
        "type": "string",
        "required": false,
        "enum": ["platform", "date"],
        "default": "platform",
        "description": "右上角维度切换：列维度（默认 platform）；当前作为全局筛选参数透传。"
      }
    },
    "response": {
      "data": {
        "type": "RevenueDeviationReasonSegment[]",
        "required": true,
        "description": "饼图扇区列表；本接口在前端为「直接返回数组」形态（与 fetchRevenueDeviationOverviewReason 的返回类型一致），n_pct 合计建议为 100。"
      }
    },
    "RevenueDeviationReasonSegment": {
      "s_label": { "type": "string", "required": true, "description": "原因名称。" },
      "n_pct": {
        "type": "number",
        "required": true,
        "description": "占比（百分比数值，如 45 表示 45%）。"
      },
      "s_color": { "type": "string", "required": true, "description": "扇区颜色（HEX）。" }
    }
  },
  "sampleRequest": {
    "t_start_date": "2024-05-01",
    "t_end_date": "2024-05-31",
    "source": "",
    "s_app_id": "",
    "matrix_source": "",
    "row_dim": "app",
    "col_dim": "platform"
  },
  "sampleResponse": [
    { "s_label": "预估收入", "n_pct": 45, "s_color": "#4ade80" },
    { "s_label": "美国偏差", "n_pct": 28, "s_color": "#f59e0b" },
    { "s_label": "中沪偏点贡献", "n_pct": 18, "s_color": "#60a5fa" },
    { "s_label": "真实原因", "n_pct": 9, "s_color": "#f87171" }
  ],
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "用于「偏差原因分析」饼图；页面拿到数组后映射为 {name,value,color} 渲染。",
        "prerequisite": "无。"
      },
      {
        "moment": "筛选变化触发刷新",
        "detail": "日期范围/广告平台/应用变化后重新请求并重绘饼图。",
        "prerequisite": "无。"
      }
    ],
    "defaultSelection": "默认筛选项同页面 state；source/s_app_id 为空表示全量汇总。",
    "dedupe": "无强依赖去重；建议后端对同入参做缓存。"
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/revenue-deviation/overview/reason",
    "method": "POST",
    "priority": "P0",
    "requestBody": "t_start_date, t_end_date, source?, s_app_id?, matrix_source?, row_dim?, col_dim?",
    "responseBody": "RevenueDeviationReasonSegment[]"
  },
  "apiSuggestion": {
    "notes": ["若网关统一包一层 { data: [] }，前端 unwrap 后与数组契约一致。"]
  }
}
