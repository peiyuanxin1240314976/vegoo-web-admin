{
  "_comment": "预估收入偏差 — 30 日收入偏差趋势。对应 types.ts: RevenueDeviationOverviewTrend。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "source": { "type": "string", "required": false, "description": "广告平台 slug，空为全部。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，空为全部。" }
    },
    "response": {
      "t_day_labels": {
        "type": "string[]",
        "required": true,
        "description": "横轴刻度，与序列等长（如当月日序 01–30）。"
      },
      "n_estimated_series": {
        "type": "number[]",
        "required": true,
        "description": "预估收入序列（与图表纵轴单位一致，如万美元或归一化标度）。"
      },
      "n_real_series": {
        "type": "number[]",
        "required": true,
        "description": "真实收入序列，与预估等长。"
      }
    }
  },
