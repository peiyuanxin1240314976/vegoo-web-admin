{
  "_comment": "预估收入偏差 — 30 日收入偏差趋势。对应 types.ts: RevenueDeviationOverviewTrend。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "source": { "type": "string", "required": false, "description": "广告平台 slug，空为全部。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，空为全部。" },
      "matrix_source": {
        "type": "string",
        "required": false,
        "description": "右上角「平台」筛选（广告平台编码），空为全部；当前作为全局筛选参数透传。"
      },
      "row_dim": {
        "type": "string",
        "required": false,
        "enum": ["app", "platform", "date"],
        "default": "app",
        "description": "右上角维度切换：行维度（默认 app）；当前作为全局筛选参数透传。"
      },
      "col_dim": {
        "type": "string",
        "required": false,
        "enum": ["platform", "date"],
        "default": "platform",
        "description": "右上角维度切换：列维度（默认 platform）；当前作为全局筛选参数透传。"
      }
    },
    "response": {
      "t_day_labels": {
        "type": "string[]",
        "required": true,
        "description": "横轴刻度，与序列等长（如当月日序 01–30）。"
      },
      "n_estimated_series": {
        "type": "number[]",
        "required": true,
        "description": "预估收入序列（与图表纵轴单位一致，如万美元或归一化标度）。"
      },
      "n_real_series": {
        "type": "number[]",
        "required": true,
        "description": "真实收入序列，与预估等长。"
      }
    }
  },
  "sampleRequest": {
    "t_start_date": "2024-05-01",
    "t_end_date": "2024-05-31",
    "source": "",
    "s_app_id": "",
    "matrix_source": "",
    "row_dim": "app",
    "col_dim": "platform"
  },
