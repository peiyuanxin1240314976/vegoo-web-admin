{
  "_comment": "预估收入偏差 — 偏差历史记录（按月）。对应 types.ts: RevenueDeviationHistoryRow[]。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "source": { "type": "string", "required": false, "description": "广告平台，空为全部。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，空为全部。" }
    },
    "response": {
      "rows": {
        "type": "RevenueDeviationHistoryRow[]",
        "required": true,
        "description": "历史月份列表，按时间倒序或正序由产品约定。"
      }
    },
    "RevenueDeviationHistoryRow": {
      "t_month": { "type": "string", "required": true, "description": "月份展示，如 2024–05。" },
      "d_estimated_usd": {
        "type": "number",
        "required": true,
        "description": "预估收入（美元）。"
      },
      "d_real_usd": { "type": "number", "required": true, "description": "真实收入（美元）。" },
      "d_deviation_rate_pct": {
        "type": "number",
        "required": true,
        "description": "偏差率（百分比数值，可正可负）。"
      }
    }
  },
