{
  "_comment": "预估收入偏差 — 国家偏差 Top10（两套指标供 Tab 切换）。对应 types.ts: RevenueDeviationCountryTop10。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "source": { "type": "string", "required": false, "description": "广告平台，空为全部。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，空为全部。" }
    },
    "response": {
      "tab_amount": {
        "type": "RevenueDeviationCountryItem[]",
        "required": true,
        "description": "偏差金额 Tab：横条长度用 n_value；国家顺序建议按 n_value 升序或降序与 UI 一致。"
      },
      "tab_rate": {
        "type": "RevenueDeviationCountryItem[]",
        "required": true,
        "description": "偏差率 Tab：n_value 为偏差率相关标度（与图表轴一致）。"
      }
    },
    "RevenueDeviationCountryItem": {
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "ISO 3166-1 alpha-2，小写；前端映射 flag-icons。"
      },
      "label_display": { "type": "string", "required": true, "description": "国家中文展示名。" },
      "n_value": {
        "type": "number",
        "required": true,
        "description": "条形图数值（金额或比率标度）。"
      }
    }
  },
