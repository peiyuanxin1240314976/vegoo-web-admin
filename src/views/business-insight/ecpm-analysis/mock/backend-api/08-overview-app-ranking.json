{
  "_comment": "ECPM 分析 — 应用 ECPM 排行。对应 mock.ts: MOCK_ECPM_APP_RANK。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "platform": { "type": "string", "required": true, "description": "终端平台。" },
      "source": { "type": "string", "required": false, "description": "广告平台。" },
      "appIds": {
        "type": "string[]",
        "required": true,
        "description": "应用筛选；不限为 []，单选为 [\"应用ID\"]。"
      },
      "s_country_code": { "type": "string", "required": false, "description": "国家码。" }
    },
    "response": {
      "rows": {
        "type": "EcpmAppRankRow[]",
        "required": true,
        "description": "应用维度排行。"
      }
    },
    "EcpmAppRankRow": {
      "s_app_name": { "type": "string", "required": true, "description": "应用名称。" },
      "icon_text": {
        "type": "string",
        "required": false,
        "description": "列表占位图标（演示用）；生产可改为空由前端默认图标。"
      },
      "d_ecpm_estimated": { "type": "number", "required": true, "description": "预估 ECPM。" },
      "d_ecpm_real": { "type": "number", "required": true, "description": "真实 ECPM。" },
      "revenue_display": {
        "type": "string",
        "required": true,
        "description": "广告收入预格式化文案。"
      },
      "mom_change_pct": {
        "type": "number",
        "required": true,
        "description": "环比变化百分比（可负）。"
      }
    }
  },
  "sampleRequest": {
    "t_start_date": "2024-05-01",
    "t_end_date": "2024-05-31",
    "platform": "all",
