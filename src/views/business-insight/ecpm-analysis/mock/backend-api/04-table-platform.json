{
  "_comment": "ECPM 分析 — 广告平台对比表。对应 mock.ts: MOCK_ECPM_PLATFORMS、MOCK_ECPM_PLATFORM_SUBTOTAL。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "platform": { "type": "string", "required": true, "description": "终端平台。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID。" },
      "s_country_code": { "type": "string", "required": false, "description": "国家码。" }
    },
    "response": {
      "rows": {
        "type": "EcpmPlatformRow[]",
        "required": true,
        "description": "按广告平台聚合的行。"
      },
      "subtotal": {
        "type": "EcpmPlatformSubtotal",
        "required": true,
        "description": "表尾小计。"
      }
    },
    "EcpmPlatformRow": {
      "name": { "type": "string", "required": true, "description": "广告平台展示名。" },
      "d_ecpm_estimated": { "type": "number", "required": true, "description": "预估 ECPM。" },
      "d_ecpm_real": { "type": "number", "required": true, "description": "真实 ECPM。" },
      "revenue_display": {
        "type": "string",
        "required": true,
        "description": "广告收入预格式化文案。"
      },
      "share_display": { "type": "string", "required": true, "description": "占比展示文案。" },
      "trend": {
        "type": "string",
        "required": true,
        "enum": ["up", "down", "flat"],
        "description": "迷你趋势方向。"
      },
      "spark_series": {
        "type": "number[]",
        "required": true,
        "description": "迷你折线 7 点。"
      }
    },
    "EcpmPlatformSubtotal": {
      "d_ecpm_estimated": { "type": "number", "required": true, "description": "预估 ECPM 小计。" },
      "d_ecpm_real": { "type": "number", "required": true, "description": "真实 ECPM 小计。" },
      "revenue_display": { "type": "string", "required": true, "description": "收入小计文案。" },
      "share_display": { "type": "string", "required": true, "description": "占比展示文案。" }
    }
  },
