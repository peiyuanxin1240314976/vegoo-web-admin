{
  "_comment": "ECPM 分析 — 广告位 ECPM 排行。对应 mock.ts: MOCK_ECPM_AD_SLOTS（页面字段 name/value/color）。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "platform": { "type": "string", "required": true, "description": "终端平台。" },
      "source": { "type": "string", "required": false, "description": "广告平台。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID。" },
      "s_country_code": { "type": "string", "required": false, "description": "国家码。" }
    },
    "response": {
      "rows": {
        "type": "EcpmAdSlotRow[]",
        "required": true,
        "description": "广告位维度；可与收入表 s_ad_unit_id 对齐。"
      }
    },
    "EcpmAdSlotRow": {
      "s_ad_unit_label": {
        "type": "string",
        "required": true,
        "description": "广告位展示名（或关联 ad unit 名称）。"
      },
      "d_ecpm": { "type": "number", "required": true, "description": "ECPM 数值。" },
      "bar_color": {
        "type": "string",
        "required": true,
        "description": "柱条颜色 HEX，可选由前端按序着色。"
      }
    }
  },
  "sampleRequest": {
    "t_start_date": "2024-05-01",
    "t_end_date": "2024-05-31",
    "platform": "all",
    "source": "",
    "s_app_id": "",
    "s_country_code": ""
  },
  "sampleResponse": {
    "rows": [
      { "s_ad_unit_label": "WeatherRadar", "d_ecpm": 19.16, "bar_color": "#00d4aa" },
      { "s_ad_unit_label": "HomeResume", "d_ecpm": 14.35, "bar_color": "#00d4aa" },
      { "s_ad_unit_label": "Splash", "d_ecpm": 13.63, "bar_color": "#00d4aa" },
      { "s_ad_unit_label": "HourlyForecast", "d_ecpm": 14.03, "bar_color": "#00cfaa" },
      { "s_ad_unit_label": "Reovu", "d_ecpm": 12.35, "bar_color": "#4db6e8" },
      { "s_ad_unit_label": "DailyDetail", "d_ecpm": 12.32, "bar_color": "#4db6e8" },
      { "s_ad_unit_label": "Monost", "d_ecpm": 9.83, "bar_color": "#52c41a" },
      { "s_ad_unit_label": "Amesus", "d_ecpm": 8.04, "bar_color": "#fadb14" },
      { "s_ad_unit_label": "South", "d_ecpm": 5.68, "bar_color": "#ff6b6b" }
    ]
  },
  "api": {
    "url": "POST /api/business-insight/ecpm-analysis/overview/ad-slot-ranking",
    "method": "POST",
    "priority": "P0",
    "requestBody": "日期范围 + 维度筛选",
    "responseBody": "{ rows: EcpmAdSlotRow[] }"
  },
  "apiSuggestion": {
    "notes": ["若后端返回 s_ad_unit_id，前端再映射展示名。"]
  }
}
