{
  "_comment": "ECPM 分析 — 30 日趋势（预估/真实/广告收入）。对应 mock.ts: MOCK_ECPM_TREND。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "platform": { "type": "string", "required": true, "description": "终端平台。" },
      "source": { "type": "string", "required": false, "description": "广告平台。" },
      "appIds": {
        "type": "string[]",
        "required": true,
        "description": "应用筛选；不限为 []，单选为 [\"应用ID\"]。"
      },
      "s_country_code": { "type": "string", "required": false, "description": "国家码。" }
    },
    "response": {
      "x_labels": {
        "type": "string[]",
        "required": true,
        "description": "横轴标签，与序列等长（如日序号 01-30）。"
      },
      "series_estimated": {
        "type": "number[]",
        "required": true,
        "description": "预估 ECPM 序列（美元）。"
      },
      "series_real": {
        "type": "number[]",
        "required": true,
        "description": "真实 ECPM 序列（美元）。"
      },
      "series_revenue": {
        "type": "number[]",
        "required": true,
        "description": "广告收入序列（与 UI 第三 Tab 一致，单位与后端约定，如 USD）。"
      }
    }
  },
