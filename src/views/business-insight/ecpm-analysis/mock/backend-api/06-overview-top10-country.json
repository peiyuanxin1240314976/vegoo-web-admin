{
  "_comment": "ECPM 分析 — Top 10 国家横向条。对应 mock.ts: MOCK_ECPM_TOP_COUNTRIES。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "platform": { "type": "string", "required": true, "description": "终端平台。" },
      "source": { "type": "string", "required": false, "description": "广告平台。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID。" },
      "metric": {
        "type": "string",
        "required": true,
        "enum": ["estimated", "real"],
        "description": "排序用预估或真实 ECPM。"
      }
    },
    "response": {
      "rows": {
        "type": "EcpmTopCountryRow[]",
        "required": true,
        "description": "按 ECPM 升序排列（图表自下而上递增时与前端一致）。"
      }
    },
    "EcpmTopCountryRow": {
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "ISO 3166-1 alpha-2。"
      },
      "label_zh": { "type": "string", "required": true, "description": "中文展示名。" },
      "d_ecpm": { "type": "number", "required": true, "description": "ECPM 数值。" },
      "bar_color": {
        "type": "string",
        "required": true,
        "description": "柱条颜色 HEX，可选由前端按序着色。"
      }
    }
  },
  "sampleRequest": {
    "t_start_date": "2024-05-01",
    "t_end_date": "2024-05-31",
    "platform": "all",
    "source": "",
    "s_app_id": "",
    "metric": "estimated"
  },
