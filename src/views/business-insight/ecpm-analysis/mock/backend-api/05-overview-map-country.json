{
  "_comment": "ECPM 分析 — 世界地图国家 ECPM。对应 mock.ts: MOCK_ECPM_MAP_COUNTRIES。",
  "fieldDescription": {
    "request": {
      "t_start_date": { "type": "string", "required": true, "description": "开始日 YYYY-MM-DD。" },
      "t_end_date": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD。" },
      "platform": { "type": "string", "required": true, "description": "终端平台。" },
      "source": { "type": "string", "required": false, "description": "广告平台。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID。" },
      "map_metric": {
        "type": "string",
        "required": true,
        "enum": ["estimated", "real"],
        "description": "地图展示预估或真实 ECPM。"
      }
    },
    "response": {
      "items": {
        "type": "EcpmMapCountryPoint[]",
        "required": true,
        "description": "国家点位；前端用 geo_name 绑定 ECharts map。"
      }
    },
    "EcpmMapCountryPoint": {
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "ISO 3166-1 alpha-2。"
      },
      "geo_name": {
        "type": "string",
        "required": true,
        "description": "与 ECharts geoJson 中名称一致，用于 series.data.name。"
      },
      "d_ecpm_estimated": { "type": "number", "required": true, "description": "预估 ECPM。" },
      "d_ecpm_real": { "type": "number", "required": true, "description": "真实 ECPM。" }
    }
  },
  "sampleRequest": {
    "t_start_date": "2024-05-01",
    "t_end_date": "2024-05-31",
    "platform": "all",
    "source": "",
    "s_app_id": "",
    "map_metric": "estimated"
  },
