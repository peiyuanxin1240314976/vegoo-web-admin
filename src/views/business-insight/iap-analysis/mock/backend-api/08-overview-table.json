{
  "_comment": "IAP Overview - 应用总览表格数据（树形结构）。对应 types.ts: IapOverviewRow[], IapOverviewSummary。",
  "fieldDescription": {
    "request": {
      "timeRange": {
        "type": "string",
        "required": true,
        "description": "时间范围，如 '30'、'7'、'90'。"
      },
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用 ID，'all' 表示全部。"
      },
      "productType": {
        "type": "string",
        "required": false,
        "description": "产品类型，'all' 表示全部。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，'all' 表示全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台，'all' 表示全部。"
      }
    },
    "response": {
      "list": {
        "type": "IapOverviewRow[]",
        "required": true,
        "description": "应用列表（树形），含顶级行与子行（children）。"
      },
      "summary": {
        "type": "IapOverviewSummary",
        "required": true,
        "description": "底部合计/均值行。"
      }
    }
  },
  "fieldDict": {
    "IapOverviewRow": {
      "id": "唯一标识",
      "name": "应用名称",
      "platform": "终端平台，如 '安卓'",
      "adPlatform": "广告平台标识: 'google' | 'facebook' | 'all'",
      "evalDays": "评估天数，如 '3天'",
      "targetReq": "达标要求，如 '53%'",
      "minReq": "最低要求，如 '50%'",
      "difficulty": "难度系数，如 '1.2'",
      "minProfit": "最低利润，如 '$45,000'，无要求时为 '—'",
      "adSpend": "广告支出（USD字符串），如 '$12,450'",
      "calcCost": "预算（USD字符串），如 '$11,800'",
      "roi": "ROI百分比字符串，如 '91%'",
      "proxyCost": "代投消耗（USD字符串），如 '$2,100'",
      "estProfit": "预估利润（有符号USD字符串），如 '+$3,240' 或 '-$120'",
      "cpa": "CPA（USD字符串），如 '$2.21'",
      "score": "绩效分数（整数，0表示无效/零分）",
      "status": "当前状态文本，如 '投放中'",
      "statusNote": "状态备注，如变更日期",
      "statusBadge": "状态徽章，如 'CPA≤$25'",
      "icon": "图标组件名（Element Plus 图标名）",
      "iconBg": "图标背景CSS（渐变字符串）",
      "isChild": "是否子行",
      "children": "子行列表（仅顶级行含有）",
      "hasChildren": "是否有子行（配合 ElTable tree-props）"
    },
    "IapOverviewSummary": {
      "adSpend": "合计广告支出",
      "calcCost": "合计预算",
      "avgRoi": "平均ROI",
      "proxyCost": "合计代投消耗",
      "estProfit": "合计预估利润",
      "avgCpa": "平均CPA",
      "score": "综合绩效分数"
    }
  },
