{
  "_comment": "IAP Detail - 产品统计 Tab 数据。对应 types.ts: IapDetailProduct。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": true, "description": "应用 ID。" },
      "timeRange": { "type": "string", "required": true, "description": "时间范围。" },
      "s_country_code": { "type": "string", "required": false, "description": "国家代码。" },
      "platform": { "type": "string", "required": false, "description": "终端平台。" }
    },
    "response": {
      "skuList": { "type": "IapSkuRow[]", "required": true, "description": "SKU 订单表。" },
      "userSegments": {
        "type": "IapUserSegment[]",
        "required": true,
        "description": "用户分层分布。"
      },
      "subscriptionDonut": {
        "type": "IapSubscriptionDonutItem[]",
        "required": true,
        "description": "订阅周期分布。"
      },
      "subscriptionTotal": { "type": "string", "required": false, "description": "订阅人数汇总。" },
      "renewChart": { "type": "IapRenewChart", "required": true, "description": "续费周期分析。" }
    },
    "IapSkuRow": {
      "name": { "type": "string", "required": true, "description": "SKU 产品名称。" },
      "type": { "type": "string", "required": true, "description": "产品类型（内购/订阅等）。" },
      "orders": { "type": "number", "required": true, "description": "订单数。" },
      "revenue": { "type": "string", "required": true, "description": "收入展示（USD）。" },
      "ratio": { "type": "string", "required": true, "description": "占比展示（如 34.3%）。" },
      "arpu": { "type": "string", "required": true, "description": "ARPU 展示。" },
      "conversion": { "type": "string", "required": true, "description": "转化率展示。" },
      "retention": {
        "type": "string",
        "required": true,
        "description": "续费率展示（可为 N/A）。"
      },
      "churn": { "type": "string", "required": true, "description": "退款率/流失率展示。" },
      "trend": { "type": "string", "required": true, "description": "趋势文案（如 ↑/↓）。" },
      "trendUp": { "type": "boolean", "required": true, "description": "趋势方向（true=上升）。" },
      "sparklineValues": {
        "type": "number[]",
        "required": false,
        "description": "迷你图折线数据，可选。"
      }
    },
    "IapUserSegment": {
      "label": { "type": "string", "required": true, "description": "用户分层名称。" },
      "count": { "type": "string", "required": true, "description": "用户数展示。" },
      "pct": { "type": "string", "required": true, "description": "占比展示（如 78%）。" },
      "arpu": { "type": "string", "required": true, "description": "该分层 ARPU 展示。" },
      "color": {
        "type": "string",
        "required": true,
        "description": "该分层颜色，用于进度条/标记。"
      }
    },
    "IapSubscriptionDonutItem": {
      "name": {
        "type": "string",
        "required": true,
        "description": "订阅周期名称（周/月/季/年）。"
      },
      "pct": { "type": "string", "required": true, "description": "占比展示（如 15%）。" },
      "value": { "type": "number", "required": false, "description": "甜甜圈数值（可选）。" },
      "color": { "type": "string", "required": false, "description": "颜色（可选）。" }
    },
    "IapRenewChart": {
      "categories": { "type": "string[]", "required": true, "description": "续费次数/周期标签。" },
      "counts": { "type": "number[]", "required": true, "description": "各周期续费人数/数量。" },
      "rates": {
        "type": "number[]",
        "required": false,
        "description": "各周期续费率（可选，0-100）。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "phonetracker",
