{
  "_comment": "IAP Dashboard - 三块趋势图数据。对应 types.ts: IapOverviewTrend。",
  "fieldDescription": {
    "request": {
      "timeRange": { "type": "string", "required": true, "description": "时间范围。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID。" },
      "productType": { "type": "string", "required": false, "description": "产品类型。" },
      "s_country_code": { "type": "string", "required": false, "description": "国家代码。" },
      "platform": { "type": "string", "required": false, "description": "终端平台。" }
    },
    "response": {
      "ordersRevenue": {
        "type": "IapTrendOrdersRevenue",
        "required": true,
        "description": "订单数 vs 收入趋势。"
      },
      "conversion": { "type": "IapTrendSingle", "required": true, "description": "转化率趋势。" },
      "arpu": { "type": "IapTrendSingle", "required": true, "description": "ARPU 趋势。" }
    },
    "IapTrendOrdersRevenue": {
      "dates": { "type": "string[]", "required": true, "description": "日期轴，如 M/D。" },
      "orders": { "type": "number[]", "required": true, "description": "订单数。" },
      "revenue": { "type": "number[]", "required": true, "description": "收入数值。" }
    },
    "IapTrendSingle": {
      "dates": { "type": "string[]", "required": true, "description": "日期轴。" },
      "values": { "type": "number[]", "required": true, "description": "指标值。" }
    }
  },
  "sampleRequest": {
    "timeRange": "30",
    "s_app_id": "all",
    "productType": "all",
    "s_country_code": "all",
    "platform": "all"
  },
  "sampleResponse": {
    "ordersRevenue": {
      "dates": ["2/4", "2/5", "2/6", "2/7", "2/8", "2/9", "2/10"],
      "orders": [3200, 3500, 3800, 3600, 4100, 3900, 4200],
      "revenue": [620000, 680000, 710000, 690000, 750000, 730000, 780000]
    },
    "conversion": {
      "dates": ["2/4", "2/5", "2/6", "2/7", "2/8", "2/9", "2/10"],
      "values": [2.8, 3.0, 3.2, 3.1, 3.4, 3.3, 3.5]
    },
    "arpu": {
      "dates": ["2/4", "2/5", "2/6", "2/7", "2/8", "2/9", "2/10"],
      "values": [11.2, 11.8, 12.0, 11.9, 12.2, 12.1, 12.5]
    }
  },
  "api": {
    "url": "POST /api/business-insight/iap-analysis/overview/trend",
    "method": "POST",
    "priority": "P0",
    "requestBody": "timeRange, s_app_id?, productType?, s_country_code?, platform",
    "responseBody": "ordersRevenue, conversion, arpu"
  }
}
