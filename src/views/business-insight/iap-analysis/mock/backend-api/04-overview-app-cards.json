{
  "_comment": "IAP Dashboard - 应用分析卡片列表。对应 types.ts: IapAppCard[]。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "开始日期，格式 YYYY-MM-DD。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "结束日期，格式 YYYY-MM-DD。"
      },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID。" },
      "s_country_code": { "type": "string", "required": false, "description": "国家代码。" },
      "platform": { "type": "string", "required": false, "description": "终端平台。" }
    },
    "response": {
      "list": {
        "type": "IapAppCard[]",
        "required": true,
        "description": "应用卡片列表，按收入排序。"
      }
    },
    "IapAppCard": {
      "name": { "type": "string", "required": true, "description": "应用名称。" },
      "platform": { "type": "string", "required": true, "description": "终端平台 Android/iOS。" },
      "orders": { "type": "string", "required": true, "description": "订单数展示。" },
      "revenue": { "type": "string", "required": true, "description": "收入展示。" },
      "arpu": { "type": "string", "required": true, "description": "ARPU 展示。" },
      "change": { "type": "string", "required": true, "description": "环比。" },
      "up": { "type": "boolean", "required": true, "description": "是否上升。" },
      "icon": { "type": "string", "required": true, "description": "图标组件名。" },
      "iconBg": { "type": "string", "required": true, "description": "图标背景样式。" }
    }
  },
  "sampleRequest": {
    "startDate": "2024-01-01",
    "endDate": "2024-01-31",
    "s_app_id": "all",
    "s_country_code": "all",
    "platform": "all"
  },
