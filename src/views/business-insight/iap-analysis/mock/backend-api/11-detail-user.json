  },
  "api": {
    "url": "POST /api/business-insight/iap-analysis/detail/user",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id, startDate, endDate, s_country_code?, platform?",
    "responseBody": "IapDetailUser"
  }
}
