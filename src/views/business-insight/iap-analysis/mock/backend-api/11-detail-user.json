    },
    "userCompareData": {
      "categories": ["新用户", "老用户", "回归用户"],
      "conversion": [2.1, 5.8, 4.2],
      "arpu": [6.5, 15.2, 11.8]
    },
    "firstPayData": {
      "categories": ["安装当天", "D1-03", "D4-07", "D8-14", "D15-030", "D30+"],
      "values": [28, 15, 22, 18, 12, 5]
