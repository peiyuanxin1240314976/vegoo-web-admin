        "arpu": "$18.50",
        "conversion": "5.2%",
        "retention": "55.2%",
        "churn": "1.2%"
      },
      {
        "segment": "中低价值(30-60%)",
        "count": "2,685",
        "ratio": "30%",
        "arpu": "$8.80",
        "conversion": "3.1%",
        "retention": "38.5%",
        "churn": "1.8%"
      },
      {
        "segment": "低价值(Bottom40%)",
        "count": "3,580",
