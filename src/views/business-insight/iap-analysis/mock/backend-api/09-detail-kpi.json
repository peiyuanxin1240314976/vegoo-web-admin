{
  "_comment": "IAP Detail - 详情页顶部 6 个 KPI。对应 types.ts: IapKpiCard[]。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": true, "description": "应用 ID 或应用标识。" },
      "startDate": {
        "type": "string",
        "required": true,
        "description": "开始日期，格式 YYYY-MM-DD。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "结束日期，格式 YYYY-MM-DD。"
      },
      "s_country_code": { "type": "string", "required": false, "description": "国家代码。" },
      "platform": { "type": "string", "required": false, "description": "终端平台。" }
    },
    "response": {
      "kpis": { "type": "IapKpiCard[]", "required": true, "description": "6 个 KPI 卡片。" }
    },
    "IapKpiCard": {
      "label": { "type": "string", "required": true, "description": "卡片标题。" },
      "value": { "type": "string", "required": true, "description": "主数值展示。" },
      "change": { "type": "string", "required": true, "description": "环比变化，如 8.3%。" },
      "up": { "type": "boolean", "required": true, "description": "是否上升。" },
      "warn": { "type": "boolean", "required": false, "description": "是否预警（如退款率）。" },
      "borderColor": { "type": "string", "required": true, "description": "卡片上边框色。" },
      "sparkColor": { "type": "string", "required": false, "description": "迷你图颜色。" },
      "sparklineValues": {
        "type": "number[]",
        "required": false,
        "description": "迷你图折线数据，可选。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "phonetracker",
    "startDate": "2024-01-01",
    "endDate": "2024-01-31",
    "s_country_code": "all",
    "platform": "all"
  },
  "sampleResponse": {
