{
  "_comment": "IAP 分析 - Overview 表格（树形）+ 合计行。对应 types.ts: IapOverviewRow / IapOverviewSummary。",
  "fieldDescription": {
    "request": {
      "timeRange": { "type": "string", "required": true, "description": "时间范围，如 7/30/90。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "productType": {
        "type": "string",
        "required": false,
        "description": "产品类型（内购/订阅），全部传 all。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      }
    },
    "response": {
      "list": {
        "type": "IapOverviewRow[]",
        "required": true,
        "description": "表格树形数据（根节点集合）。"
      },
      "summary": {
        "type": "IapOverviewSummary",
        "required": true,
        "description": "合计/均值汇总行数据。"
      }
    },
    "IapOverviewRow": {
      "id": { "type": "string", "required": true, "description": "行 id（树形 key 用）。" },
      "name": { "type": "string", "required": true, "description": "应用/实体名称。" },
      "platform": {
        "type": "string",
        "required": true,
        "description": "终端平台（如 安卓/ iOS）。"
      },
      "adPlatform": {
        "type": "string",
        "required": true,
        "description": "广告平台（如 google/facebook/all）。"
      },
      "evalDays": { "type": "string", "required": false, "description": "评估天数。" },
      "targetReq": {
        "type": "string",
        "required": false,
        "description": "达标要求（占比/阈值展示）。"
      },
      "minReq": {
        "type": "string",
        "required": false,
        "description": "最低要求（占比/阈值展示）。"
      },
      "difficulty": { "type": "string", "required": false, "description": "难度系数。" },
      "minProfit": {
        "type": "string",
        "required": false,
        "description": "最低利润（展示值，可能为 —）。"
      },
      "adSpend": { "type": "string", "required": true, "description": "广告支出。" },
      "calcCost": { "type": "string", "required": true, "description": "预算（计算消耗）展示值。" },
      "roi": { "type": "string", "required": false, "description": "ROI 展示（如 91%）。" },
      "proxyCost": { "type": "string", "required": true, "description": "代投消耗。" },
      "estProfit": {
        "type": "string",
        "required": true,
        "description": "预估利润（可能为 + / -）。"
      },
      "cpa": { "type": "string", "required": false, "description": "CPA 展示值。" },
      "score": {
        "type": "number|null",
        "required": false,
        "description": "绩效分数（可为 null）。"
      },
      "status": { "type": "string", "required": false, "description": "当前状态（如 投放中）。" },
      "statusNote": { "type": "string", "required": false, "description": "状态备注/变更说明。" },
      "statusBadge": { "type": "string", "required": false, "description": "状态徽标文案。" },
      "icon": {
        "type": "string",
        "required": true,
        "description": "图标组件名（前端通过 component 动态渲染）。"
      },
      "iconBg": {
        "type": "string",
        "required": true,
        "description": "图标背景样式（gradient 等）。"
      },
      "isChild": {
        "type": "boolean",
        "required": false,
        "description": "是否为子节点（树形层级样式）。"
      },
      "children": { "type": "IapOverviewRow[]", "required": false, "description": "子节点集合。" },
      "hasChildren": {
        "type": "boolean",
        "required": false,
        "description": "是否有子节点（tree-props: hasChildren）。"
      }
    },
    "IapOverviewSummary": {
      "adSpend": { "type": "string", "required": true, "description": "广告支出合计。" },
      "calcCost": { "type": "string", "required": true, "description": "预算合计。" },
      "avgRoi": { "type": "string", "required": true, "description": "平均 ROI（如 88%）。" },
      "proxyCost": { "type": "string", "required": true, "description": "代投消耗合计。" },
      "estProfit": { "type": "string", "required": true, "description": "预估利润合计。" },
      "avgCpa": { "type": "string", "required": true, "description": "平均 CPA。" },
      "score": {
        "type": "string",
        "required": true,
        "description": "绩效分数（展示值，如 92分）。"
      }
    }
  },
  "sampleRequest": {
    "timeRange": "30",
