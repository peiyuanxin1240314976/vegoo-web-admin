{
  "_comment": "经营报告 - 分国家汇总表。对应 types.ts: ByCountryResponse。三周期结构相同，数值按 period 聚合。",
  "api": {
    "url": "GET /api/v1/datacenter/analysis/report/by-country",
    "method": "GET",
    "priority": "P0",
    "queryParams": "period, appId?, date?"
  },
  "fieldDescription": {
    "request": {
      "period": {
        "type": "'daily' | 'weekly' | 'monthly'",
        "required": true,
        "description": "报告周期"
      },
      "appId": {
        "type": "string",
        "required": false,
        "description": "应用 ID，不传返回整体"
      },
      "date": {
        "type": "string",
        "required": false,
        "description": "ISO 日期，不传取最新"
      }
    },
    "response": {
      "rows": {
        "type": "CountryRow[]",
        "required": true,
        "description": "主要国家行列表（按收入降序，Top N）"
      },
      "othersRow": {
        "type": "CountryRow",
        "required": true,
        "description": "合并的「其他 N 个国家」行，flag 固定为 🌐"
      },
      "appList": {
        "type": "AppListItem[]",
        "required": true,
        "description": "左侧应用列表"
      }
    },
    "CountryRow": {
      "flag": {
        "type": "string",
        "required": true,
        "description": "国家旗帜 emoji，如 🇺🇸；合并行为 🌐"
      },
      "name": {
        "type": "string",
        "required": true,
        "description": "国家名称；合并行为 其他 N 个国家"
      },
      "subLabel": {
        "type": "string",
        "required": false,
        "description": "仅合并行使用，如 12个国家"
      },
      "avgDau": {
        "type": "string",
        "required": true,
        "description": "均DAU（预格式化）"
      },
      "revenue": {
        "type": "string",
        "required": true,
        "description": "总收入"
      },
      "paidRevenue": {
        "type": "string",
        "required": true,
        "description": "买量用户收入"
      },
      "profit": {
        "type": "string",
        "required": true,
        "description": "预估利润"
      },
      "calcProfit": {
        "type": "string",
        "required": true,
        "description": "计算利润（收入 - 广告支出）"
      },
      "newUsers": {
        "type": "string",
        "required": true,
        "description": "新增用户"
      },
      "organic": {
        "type": "string",
        "required": true,
        "description": "自然新增用户"
      },
      "organicRate": {
        "type": "string",
        "required": true,
        "description": "自然占比，如 38.2%"
      },
      "dauShare": {
        "type": "number",
        "required": true,
        "description": "DAU 占比 0~100，用于进度条"
      },
      "ecpm": {
        "type": "string",
        "required": true,
        "description": "有效千次展示收入"
      },
      "arpdau": {
        "type": "string",
        "required": true,
        "description": "每日活跃用户平均收入"
      },
      "adSpend": {
        "type": "string",
        "required": true,
        "description": "广告支出"
      },
      "cpi": {
        "type": "string",
        "required": true,
        "description": "单次安装成本"
      },
      "cpm": {
        "type": "string",
        "required": true,
        "description": "千次展示成本"
      },
      "cpc": {
        "type": "string",
        "required": true,
        "description": "单次点击成本"
      },
      "acquisitions": {
        "type": "string",
        "required": true,
        "description": "买量用户数"
      },
      "campaigns": {
        "type": "number",
        "required": true,
        "description": "在投广告系列数"
      },
      "roi1d": {
        "type": "string",
        "required": true,
        "description": "首日 ROI"
      },
      "roi7d": {
        "type": "string",
        "required": true,
        "description": "7 日 ROI"
      }
    }
  },
