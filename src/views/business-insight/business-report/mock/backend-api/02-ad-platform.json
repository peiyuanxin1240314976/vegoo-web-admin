        "acquisitions": "130万",
        "cpi": "$1.24",
        "cpm": "$8.70",
        "cpc": "$0.34",
        "campaigns": 37,
        "roi1d": "35%",
        "roi7d": "91%",
        "profit": "$4,500",
        "sharePercent": 30.5
      },
      {
        "id": "unity",
