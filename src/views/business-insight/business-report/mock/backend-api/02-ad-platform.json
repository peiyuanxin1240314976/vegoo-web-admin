{
  "_comment": "经营报告 - 广告平台卡片列表。对应 types.ts: AdPlatformResponse。",
  "api": {
    "url": "GET /api/v1/report/ad-platform",
    "method": "GET",
    "priority": "P0",
    "queryParams": "period, appId?, date?"
  },
  "fieldDescription": {
    "request": {
      "period": {
        "type": "'daily' | 'weekly' | 'monthly'",
        "required": true,
        "description": "报告周期"
      },
      "appId": { "type": "string", "required": false, "description": "应用 ID，不传返回整体" },
      "date": { "type": "string", "required": false, "description": "ISO 日期，不传取最新" }
    },
    "response": {
      "platforms": {
        "type": "AdPlatformCard[]",
        "required": true,
        "description": "广告平台卡片列表"
      },
      "appList": { "type": "AppListItem[]", "required": true, "description": "左侧应用列表" }
    },
    "AdPlatformCard": {
      "id": {
        "type": "string",
        "required": true,
        "description": "平台唯一标识，如 google / facebook"
      },
      "name": { "type": "string", "required": true, "description": "平台名称" },
      "logo": {
        "type": "string",
        "required": true,
        "description": "文字缩写或 emoji，如 G / f / ♪"
      },
      "color": { "type": "string", "required": true, "description": "主色（CSS 颜色）" },
      "adSpend": {
        "type": "string",
        "required": true,
        "description": "广告支出（预格式化），如 $15,200"
      },
      "adSpendChange": {
        "type": "number",
        "required": true,
        "description": "广告支出环比变化率，8.1 代表 +8.1%"
      },
      "acquisitions": {
        "type": "string",
        "required": true,
        "description": "买量用户（预格式化），如 9.5万"
      },
      "cpi": { "type": "string", "required": true, "description": "单次安装成本" },
      "cpm": { "type": "string", "required": true, "description": "千次展示成本" },
      "cpc": { "type": "string", "required": true, "description": "单次点击成本" },
      "campaigns": { "type": "number", "required": true, "description": "在投广告系列数" },
      "roi1d": { "type": "string", "required": true, "description": "首日 ROI，如 38%" },
      "roi7d": { "type": "string", "required": true, "description": "7 日 ROI" },
      "roi14d": { "type": "string", "required": false, "description": "14 日 ROI（可选）" },
      "profit": { "type": "string", "required": true, "description": "预估利润（预格式化）" },
      "sharePercent": {
        "type": "number",
        "required": true,
        "description": "广告支出占比 0~100，用于进度条"
      }
    }
  },
  "sampleRequest": {
    "period": "daily",
    "date": "2026-03-23"
  },
  "sampleResponse": {
    "platforms": [
      {
        "id": "google",
        "name": "Google",
        "logo": "G",
