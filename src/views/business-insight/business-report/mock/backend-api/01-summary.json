{
  "_comment": "经营报告 - 汇总表。对应 types.ts: SummaryResponse。日报/周报/月报通用，月报额外返回 feeDeductions。",
  "api": {
    "url": "GET /api/v1/report/summary",
    "method": "GET",
    "priority": "P0",
    "queryParams": "period, appId?, date?"
  },
  "fieldDescription": {
    "request": {
      "period": {
        "type": "'daily' | 'weekly' | 'monthly'",
        "required": true,
        "description": "报告周期"
      },
      "appId": {
        "type": "string",
        "required": false,
        "description": "应用 ID，不传返回所有应用整体数据"
      },
      "date": {
        "type": "string",
        "required": false,
        "description": "ISO 日期（2026-03-23），不传取最新可用日期"
      }
    },
    "response": {
      "kpis": {
        "type": "KpiMetric[]",
        "required": true,
        "description": "顶部 KPI 卡片，日报 6 个，周/月报同"
      },
      "userMetrics": {
        "type": "UserMetricRow[]",
        "required": true,
        "description": "用户指标表格行"
      },
      "revenueMetrics": {
        "type": "RevenueRow[]",
        "required": true,
        "description": "收缴指标表格行"
      },
      "roiMetrics": { "type": "RoiRow[]", "required": true, "description": "ROI 跟踪表格行" },
      "retentionMetrics": {
        "type": "RetentionRow[]",
        "required": true,
        "description": "留存率表格行"
      },
      "feeDeductions": {
        "type": "FeeItem[]",
        "required": false,
        "description": "费用抄扣明细，仅 period=monthly 时返回"
      },
      "appList": { "type": "AppListItem[]", "required": true, "description": "左侧应用列表" }
    },
    "KpiMetric": {
      "key": {
        "type": "string",
        "required": true,
        "description": "唯一标识，如 revenue / dau / newUsers"
      },
      "label": { "type": "string", "required": true, "description": "卡片标题" },
      "value": {
        "type": "string",
        "required": true,
        "description": "预格式化显示值，如 $152,300 / 78.3万"
      },
      "change": { "type": "number", "required": true, "description": "环比变化率，8.4 代表 +8.4%" },
      "changeLabel": {
        "type": "string",
        "required": true,
        "description": "含前缀展示文本，如 环比昨日 ↑ 8.4%"
      },
      "color": { "type": "string", "required": true, "description": "主色（CSS 颜色）" },
      "bg": { "type": "string", "required": true, "description": "背景渐变（CSS gradient）" },
      "sparkline": { "type": "number[]", "required": true, "description": "8 个点的迷你图数据" },
      "badge": { "type": "string", "required": false, "description": "徽标文字，如 MONTHLY ONLY" }
    },
    "UserMetricRow": {
      "name": { "type": "string", "required": true, "description": "指标名称" },
      "current": { "type": "string", "required": true, "description": "本期值（预格式化）" },
      "previous": { "type": "string", "required": true, "description": "上期值（预格式化）" },
      "change": { "type": "string", "required": true, "description": "变化，如 +8.4% / +1" },
      "changeType": {
        "type": "'positive' | 'negative' | 'neutral'",
        "required": true,
        "description": "变化类型，决定颜色"
      }
    },
    "RoiRow": {
      "type": {
        "type": "string",
        "required": true,
        "description": "ROI 类型，如 首日ROI / 7日ROI"
      },
      "current": { "type": "string", "required": true, "description": "本期值，如 98%" },
      "previous": { "type": "string", "required": true, "description": "上期值" },
      "change": { "type": "string", "required": true, "description": "变化，如 +2pp / 0pp" },
      "changeType": {
        "type": "'positive' | 'negative' | 'neutral'",
        "required": false,
        "description": "变化类型"
      },
      "isHighlighted": {
        "type": "boolean",
        "required": false,
        "description": "ROI >= 101% 时绿色高亮"
      }
    },
    "FeeItem": {
      "name": { "type": "string", "required": true, "description": "费用项目名称" },
      "amount": {
        "type": "string",
        "required": true,
        "description": "金额（带符号），如 +$6,737.28 / -$2,400.00"
      },
      "isPositive": { "type": "boolean", "required": true, "description": "是否为正向（收入）" }
    }
  },
