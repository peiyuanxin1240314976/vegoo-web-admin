{
  "_comment": "收入概览-AI 洞察建议：用于右下「AI 洞察建议」模块数据源。",
  "fieldDescription": {
    "request": {
      "t_date": { "type": "string", "required": true, "description": "日期（YYYY-MM-DD）。" },
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用。\"all\" 表示全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["all", "android", "ios"],
        "description": "终端平台。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码。\"all\" 表示全部。"
      },
      "app_version": {
        "type": "string",
        "required": false,
        "description": "应用版本。\"all\" 表示全部。"
      }
    },
    "response": {
      "ai_insight": {
        "type": "RevenueOverviewAiInsight",
        "required": true,
        "description": "AI 洞察建议。"
      }
    },
    "RevenueOverviewAiInsight": {
      "s_title": { "type": "string", "required": true, "description": "标题。" },
      "s_bullets_list": {
        "type": "string[]",
        "required": true,
        "description": "要点列表（字符串数组）。"
      }
    }
  },
  "sampleRequest": {
    "t_date": "2026-03-05",
    "s_app_id": "weather5",
    "platform": "all",
    "s_country_code": "all",
    "app_version": "all"
  },
  "sampleResponse": {
    "ai_insight": {
      "s_title": "AI 洞察建议",
      "s_bullets_list": [
        "IAA：插屏广告占比 72.8%，Admob 占比 71.7%，建议优先优化 Admob 插屏的填充与竞价策略。",
        "IAP：年度订阅贡献最高，建议增加年度订阅的展示曝光与价格锚点（$89.99）。"
      ]
    }
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/revenue-overview/ai-insight",
    "method": "POST",
    "priority": "P1",
    "requestBody": "t_date, s_app_id, platform, s_country_code, app_version（均为 body 字段）",
    "responseBody": "ai_insight (RevenueOverviewAiInsight)"
  },
  "apiSuggestion": {
    "notes": ["建议 bullets 控制在 3-6 条，每条不超过 60 字，保证卡片可读性。"]
  }
}
