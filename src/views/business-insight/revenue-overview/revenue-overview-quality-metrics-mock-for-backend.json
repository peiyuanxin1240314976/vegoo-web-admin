{
  "_comment": "收入概览-收入质量指标卡片：用于右下「收入质量指标」模块数据源。",
  "fieldDescription": {
    "request": {
      "t_date": { "type": "string", "required": true, "description": "日期（YYYY-MM-DD）。" },
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用。\"all\" 表示全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["all", "android", "ios"],
        "description": "终端平台。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码。\"all\" 表示全部。"
      },
      "app_version": {
        "type": "string",
        "required": false,
        "description": "应用版本。\"all\" 表示全部。"
      }
    },
    "response": {
      "quality_metric_list": {
        "type": "RevenueOverviewQualityMetricItem[]",
        "required": true,
        "description": "质量指标卡片列表。"
      }
    },
    "RevenueOverviewQualityMetricItem": {
      "s_title": { "type": "string", "required": true, "description": "指标名称。" },
      "s_value_text": {
        "type": "string",
        "required": true,
        "description": "指标值（格式化字符串）。"
      },
      "s_sub_text": { "type": "string", "required": true, "description": "副标题/说明。" },
      "s_trend_text": { "type": "string", "required": true, "description": "趋势/等级文案。" },
      "b_trend_up": { "type": "boolean", "required": true, "description": "趋势是否上升。" },
      "s_accent": {
        "type": "string",
        "required": true,
        "enum": ["green", "blue", "amber"],
        "description": "配色。"
      }
    }
  },
  "sampleRequest": {
    "t_date": "2026-03-05",
    "s_app_id": "weather5",
    "platform": "all",
    "s_country_code": "all",
    "app_version": "all"
  },
  "sampleResponse": {
    "quality_metric_list": [
      {
        "s_title": "广告充率",
        "s_value_text": "94.2%",
        "s_sub_text": "广告填充率",
        "s_trend_text": "稳定",
        "b_trend_up": true,
        "s_accent": "green"
      }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/revenue-overview/quality-metrics",
    "method": "POST",
    "priority": "P1",
    "requestBody": "t_date, s_app_id, platform, s_country_code, app_version（均为 body 字段）",
    "responseBody": "quality_metric_list (RevenueOverviewQualityMetricItem[])"
  },
  "apiSuggestion": {
    "notes": ["指标建议稳定返回固定 4 项（顺序固定），便于前端布局不抖动。"]
  }
}
