{
  "_comment": "收入概览-IAP 付费收入分析：商品构成表 + 订阅/一次性汇总 + 底部小指标。用于中间「IAP 付费收入分析」模块数据源。",
  "fieldDescription": {
    "request": {
      "t_date": { "type": "string", "required": true, "description": "日期（YYYY-MM-DD）。" },
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用。\"all\" 表示全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["all", "android", "ios"],
        "description": "终端平台。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码。\"all\" 表示全部。"
      },
      "app_version": {
        "type": "string",
        "required": false,
        "description": "应用版本。\"all\" 表示全部。"
      },
      "s_tab_key": {
        "type": "string",
        "required": false,
        "enum": ["product", "channel", "trend"],
        "description": "当前 tab key。"
      }
    },
    "response": {
      "iap_summary": {
        "type": "RevenueOverviewIapSummary",
        "required": true,
        "description": "订阅 vs 一次性汇总。"
      },
      "iap_breakdown_list": {
        "type": "RevenueOverviewIapBreakdownItem[]",
        "required": true,
        "description": "IAP 商品构成行列表。"
      },
      "iap_footer_metrics": {
        "type": "RevenueOverviewIapFooterMetrics",
        "required": true,
        "description": "底部指标。"
      }
    },
    "RevenueOverviewIapSummary": {
      "money_subscription_revenue": {
        "type": "number",
        "required": true,
        "description": "订阅收入（金额）。"
      },
      "d_subscription_percent": {
        "type": "number",
        "required": true,
        "description": "订阅占比（百分数）。"
      },
      "money_one_time_revenue": {
        "type": "number",
        "required": true,
        "description": "一次性收入（金额）。"
      },
      "d_one_time_percent": {
        "type": "number",
        "required": true,
        "description": "一次性占比（百分数）。"
      }
    },
    "RevenueOverviewIapBreakdownItem": {
      "s_product": { "type": "string", "required": true, "description": "商品/订阅项。" },
      "s_type": {
        "type": "string",
        "required": true,
        "enum": ["订阅", "一次性"],
        "description": "类型。"
      },
      "money_revenue": { "type": "number", "required": true, "description": "收入（金额）。" },
      "d_percent": { "type": "number", "required": true, "description": "占比（百分数）。" },
      "n_buy_times": { "type": "number", "required": true, "description": "购买次数。" },
      "n_users": { "type": "number", "required": true, "description": "购买用户数。" },
      "money_price": { "type": "number", "required": true, "description": "价格（金额）。" },
      "d_purchase_rate": {
        "type": "number",
        "required": true,
        "description": "续费率/购买率（百分数）。"
      }
    },
    "RevenueOverviewIapFooterMetrics": {
      "d_purchase_rate": {
        "type": "number",
        "required": true,
        "description": "付费转化率（百分数）。"
      },
      "money_arppu": { "type": "number", "required": true, "description": "ARPPU（金额）。" },
      "d_subscription_renew_rate": {
        "type": "number",
        "required": true,
        "description": "订阅续费率（百分数）。"
      }
    }
  },
  "sampleRequest": {
    "t_date": "2026-03-05",
    "s_app_id": "weather5",
    "platform": "all",
    "s_country_code": "all",
    "app_version": "all",
    "s_tab_key": "product"
  },
  "sampleResponse": {
    "iap_summary": {
      "money_subscription_revenue": 52.3,
      "d_subscription_percent": 60.5,
      "money_one_time_revenue": 34.17,
      "d_one_time_percent": 39.5
    },
    "iap_breakdown_list": [
      {
        "s_product": "月度订阅",
        "s_type": "订阅",
        "money_revenue": 18.02,
        "d_percent": 21.8,
        "n_buy_times": 1842,
        "n_users": 684,
        "money_price": 9.99,
        "d_purchase_rate": 78.4
      }
    ],
    "iap_footer_metrics": {
      "d_purchase_rate": 2.1,
      "money_arppu": 9.99,
      "d_subscription_renew_rate": 78.4
    }
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/revenue-overview/iap-breakdown",
    "method": "POST",
    "priority": "P0",
    "requestBody": "t_date, s_app_id, platform, s_country_code, app_version, s_tab_key（均为 body 字段）",
    "responseBody": "iap_summary, iap_breakdown_list, iap_footer_metrics"
  },
  "apiSuggestion": {
    "notes": ["money_price 建议直接返回 number，避免前端根据 SKU 再查价。"]
  }
}
