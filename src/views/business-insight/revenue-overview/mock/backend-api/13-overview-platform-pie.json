{
  "_comment": "收入总览 — 广告平台占比环形/饼图。对应 mock.ts: MOCK_REVENUE_OVERVIEW_PLATFORM_PIE。value 为占比 0-100。",
  "fieldDescription": {
    "request": {
      "appIds": { "type": "string[]", "required": true, "description": "应用多选，不限为 []。" },
      "platform": {
        "type": "string",
        "required": true,
        "description": "终端平台；收入概览页固定空串。"
      },
      "s_country_code": { "type": "string", "required": true, "description": "国家码。" },
      "app_version": { "type": "string", "required": true, "description": "版本。" },
      "t_date": { "type": "string", "required": true, "description": "统计日。" }
    },
    "response": {
      "slices": {
        "type": "RevenueOverviewPieSlice[]",
        "required": true,
        "description": "饼图扇区。"
      }
    },
    "RevenueOverviewPieSlice": {
      "name": { "type": "string", "required": true, "description": "广告平台名称。" },
      "value": {
        "type": "number",
        "required": true,
        "description": "占比数值（与图例一致，0-100）。"
      },
      "percentText": { "type": "string", "required": true, "description": "占比展示文案。" },
      "color": { "type": "string", "required": true, "description": "色值。" },
      "moneyText": { "type": "string", "required": true, "description": "金额展示文案 USD。" }
    }
  },
