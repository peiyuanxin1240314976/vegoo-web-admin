      "startDate": {
        "type": "string",
        "required": true,
        "description": "统计区间开始日 YYYY-MM-DD。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "统计区间结束日 YYYY-MM-DD。"
      }
    },
    "response": {
      "header": {
        "type": "object",
