{
  "_comment": "收入总览 — 收入质量指标卡片。对应 mock.ts: MOCK_REVENUE_OVERVIEW_QUALITY_METRICS。",
  "fieldDescription": {
    "request": {
      "appIds": { "type": "string[]", "required": true, "description": "应用多选，不限为 []。" },
      "platform": {
        "type": "string",
        "required": true,
        "description": "终端平台；收入概览页固定空串。"
      },
      "s_country_code": { "type": "string", "required": true, "description": "国家码。" },
      "app_version": { "type": "string", "required": true, "description": "版本。" },
      "startDate": {
        "type": "string",
        "required": true,
        "description": "统计区间开始日 YYYY-MM-DD。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "统计区间结束日 YYYY-MM-DD。"
      }
    },
    "response": {
      "metrics": {
        "type": "RevenueOverviewQualityMetric[]",
        "required": true,
        "description": "质量指标卡片。"
      }
    },
    "RevenueOverviewQualityMetric": {
      "title": { "type": "string", "required": true, "description": "指标名。" },
      "valueText": { "type": "string", "required": true, "description": "主值（预格式化）。" },
      "subText": { "type": "string", "required": true, "description": "说明。" },
      "trendText": { "type": "string", "required": true, "description": "趋势/评价文案。" },
      "trendUp": { "type": "boolean", "required": true, "description": "用于样式正负。" },
      "accent": {
        "type": "string",
        "required": true,
        "enum": ["green", "blue", "amber"],
        "description": "主题色键。"
      }
    }
  },
