{
  "_comment": "收入总览 — 顶部 KPI 卡片。对应 mock.ts: RevenueOverviewKpiCard[]、MOCK_REVENUE_OVERVIEW_KPIS。",
  "fieldDescription": {
    "request": {
      "appIds": { "type": "string[]", "required": true, "description": "应用多选，不限为 []。" },
      "platform": {
        "type": "string",
        "required": true,
        "description": "终端平台；收入概览页固定空串。"
      },
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "国家码；空字符串表示不按国家筛选（不限）。"
      },
      "app_version": { "type": "string", "required": true, "description": "版本，all 表示全部。" },
      "startDate": {
        "type": "string",
        "required": true,
        "description": "统计区间开始日 YYYY-MM-DD。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "统计区间结束日 YYYY-MM-DD。"
      }
    },
    "response": {
      "kpis": {
        "type": "RevenueOverviewKpiCard[]",
        "required": true,
        "description": "KPI 卡片列表；primaryValue/sub 等为预格式化展示文案。"
      }
    },
    "RevenueOverviewKpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片唯一 id。" },
      "title": { "type": "string", "required": true, "description": "标题。" },
      "primaryValue": { "type": "string", "required": true, "description": "主指标（已格式化）。" },
      "subLeftLabel": { "type": "string", "required": true, "description": "左下标签。" },
      "subLeftValue": { "type": "string", "required": true, "description": "左下值。" },
      "subRightLabel": { "type": "string", "required": true, "description": "右下标签。" },
      "subRightValue": { "type": "string", "required": true, "description": "右下值。" },
      "trendUp": { "type": "boolean", "required": true, "description": "环比是否上升。" },
      "trendPercentText": { "type": "string", "required": true, "description": "环比文案。" },
      "spark": {
        "type": "number[]",
        "required": true,
        "description": "迷你趋势序列（近 7 点等）。"
      },
      "accent": {
        "type": "string",
        "required": true,
        "enum": ["blue", "teal", "purple", "amber", "green", "indigo"],
        "description": "主题色键。"
      }
    }
  },
