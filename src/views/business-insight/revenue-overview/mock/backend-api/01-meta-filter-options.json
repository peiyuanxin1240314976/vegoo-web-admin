        "type": "SelectOption[]",
        "required": true,
        "description": "终端平台：all / android / ios。"
      },
      "countryOptions": {
        "type": "SelectOption[]",
        "required": true,
        "description": "国家；首项 all，其余 value 为 ISO 3166-1 alpha-2。"
      },
      "versionOptions": {
        "type": "SelectOption[]",
        "required": true,
        "description": "应用版本；首项 all。"
      }
    },
    "SelectOption": {
