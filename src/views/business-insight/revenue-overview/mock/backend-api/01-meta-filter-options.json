{
  "_comment": "收入总览 — 筛选下拉选项。页面当前在 index.vue 内写死选项，接入后改为远程。",
  "fieldDescription": {
    "request": {},
    "response": {
      "appOptions": {
        "type": "SelectOption[]",
        "required": true,
        "description": "应用下拉，value 为 s_app_id。"
      },
