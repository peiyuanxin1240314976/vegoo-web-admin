{
  "_comment": "收入概览-近7天 IAA vs IAP 收入趋势：用于右上折线图数据源。",
  "fieldDescription": {
    "request": {
      "t_date": {
        "type": "string",
        "required": true,
        "description": "查询结束日期（YYYY-MM-DD）。近7天范围由后端计算。"
      },
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用。\"all\" 表示全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["all", "android", "ios"],
        "description": "终端平台。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码。\"all\" 表示全部。"
      },
      "app_version": {
        "type": "string",
        "required": false,
        "description": "应用版本。\"all\" 表示全部。"
      }
    },
    "response": {
      "trend7d": {
        "type": "RevenueOverviewTrend7d",
        "required": true,
        "description": "近7天趋势。"
      }
    },
    "RevenueOverviewTrend7d": {
      "s_dates_list": { "type": "string[]", "required": true, "description": "近7天日期标签。" },
      "money_iaa_revenue_list": {
        "type": "number[]",
        "required": true,
        "description": "IAA 收入序列（金额）。"
      },
      "money_iap_revenue_list": {
        "type": "number[]",
        "required": true,
        "description": "IAP 收入序列（金额）。"
      }
    }
  },
  "sampleRequest": {
    "t_date": "2026-03-05",
    "s_app_id": "weather5",
    "platform": "all",
    "s_country_code": "all",
    "app_version": "all"
  },
  "sampleResponse": {
    "trend7d": {
      "s_dates_list": ["Feb27", "Feb28", "Mar1", "Mar2", "Mar3", "Mar4", "Mar5"],
      "money_iaa_revenue_list": [1820, 2100, 1950, 2300, 2500, 2768, 2855],
      "money_iap_revenue_list": [72, 85, 68, 92, 78, 95, 86]
    }
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/revenue-overview/trend7d",
    "method": "POST",
    "priority": "P0",
    "requestBody": "t_date, s_app_id, platform, s_country_code, app_version（均为 body 字段）",
    "responseBody": "trend7d (RevenueOverviewTrend7d)"
  },
  "apiSuggestion": {
    "notes": ["money_* 序列建议保持同一币种与同一口径（未去平台抽成）。"]
  }
}
