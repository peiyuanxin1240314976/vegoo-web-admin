{
  "_comment": "收入总览 — IAA 构成国家维度。对应 mock.ts: MOCK_REVENUE_OVERVIEW_IAA_COUNTRY_ROWS。不含国旗 URL，仅 s_country_code。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": true, "description": "应用 ID。" },
      "platform": { "type": "string", "required": true, "description": "终端平台。" },
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "筛选国家；分析表仍返回多国时可传 all。"
      },
      "app_version": { "type": "string", "required": true, "description": "版本。" },
      "t_date": { "type": "string", "required": true, "description": "统计日。" }
    },
    "response": {
      "rows": {
        "type": "RevenueOverviewIaaCountryRow[]",
        "required": true,
        "description": "国家行；ZZ/Other 表示其余汇总。"
      }
    },
    "RevenueOverviewIaaCountryRow": {
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "ISO 3166-1 alpha-2。"
      },
      "s_country_name": { "type": "string", "required": true, "description": "展示用国家名。" },
      "revenue": { "type": "number", "required": true, "description": "收入 USD。" },
      "percent": { "type": "number", "required": true, "description": "占比 %。" },
      "n_impression": { "type": "number", "required": true, "description": "展示次数。" },
      "d_ecpm": { "type": "number", "required": true, "description": "eCPM。" },
      "n_users": { "type": "number", "required": true, "description": "用户数。" },
      "d_mom_pct": { "type": "number", "required": true, "description": "环比 %，可负。" }
    }
  },
