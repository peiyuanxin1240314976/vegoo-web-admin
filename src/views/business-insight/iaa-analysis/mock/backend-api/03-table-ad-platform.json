{
  "_comment": "IAA 分析 - 广告平台 Tab 平台详细对比表（独立接口，若与 overview/platform-tab 合并可废弃）。对应 types.ts: IaaPlatformTableRow。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID。" },
      "platform": { "type": "string", "required": false, "description": "终端平台。" },
      "s_country_code": { "type": "string", "required": false, "description": "国家代码。" },
      "t_date": { "type": "string", "required": true, "description": "日期 YYYY-MM-DD。" }
    },
    "response": {
      "list": {
        "type": "IaaPlatformTableRow[]",
        "required": true,
        "description": "平台对比行列表，建议按 revenue 降序。"
      }
    },
    "IaaPlatformTableRow": {
      "sourceName": {
        "type": "string",
        "required": true,
        "description": "广告平台名称，如 Admob。"
      },
      "source": { "type": "number", "required": true, "description": "广告平台枚举 n_source。" },
      "revenue": { "type": "number", "required": true, "description": "广告收入（USD）。" },
      "revenueShare": { "type": "number", "required": true, "description": "收入占比 0–100。" },
      "impressions": { "type": "number", "required": true, "description": "展示次数。" },
      "impressionShare": { "type": "number", "required": true, "description": "展示占比 0–100。" },
      "adUsers": { "type": "number", "required": true, "description": "广告用户数。" },
      "userShare": { "type": "number", "required": true, "description": "用户占比 0–100。" },
      "ecpmEst": { "type": "number", "required": true, "description": "预估 ECPM（USD）。" },
      "ecpmReal": { "type": "number", "required": true, "description": "真实 ECPM（USD）。" },
      "variance": { "type": "number", "required": true, "description": "预估相对真实偏差百分比。" },
      "fillRate": { "type": "number", "required": true, "description": "充填率 0–100。" },
      "trend": {
        "type": "string",
        "required": true,
        "enum": ["up", "flat", "down"],
        "description": "趋势：上/平/下。"
      }
    }
  },
