{
  "_comment": "IAA 分析 - 广告平台 Tab 平台详细对比表。对应 types.ts: IaaPlatformTableRow。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID。" },
      "platform": { "type": "string", "required": false, "description": "终端平台。" },
      "s_country_code": { "type": "string", "required": false, "description": "国家代码。" },
      "t_date": { "type": "string", "required": true, "description": "日期 YYYY-MM-DD。" }
    },
    "response": {
      "list": {
        "type": "IaaPlatformTableRow[]",
        "required": true,
        "description": "平台对比行列表。"
      }
    },
    "IaaPlatformTableRow": {
      "sourceName": {
        "type": "string",
        "required": true,
        "description": "广告平台名称，如 Admob。"
      },
      "source": { "type": "number", "required": true, "description": "广告平台枚举 n_source。" },
      "revenue": { "type": "number", "required": true, "description": "广告收入。" },
      "revenueShare": { "type": "number", "required": true, "description": "收入占比%。" },
      "impressions": { "type": "number", "required": true, "description": "展示次数。" },
      "impressionShare": { "type": "number", "required": true, "description": "展示占比%。" },
      "adUsers": { "type": "number", "required": true, "description": "广告用户数。" },
      "userShare": { "type": "number", "required": true, "description": "用户占比%。" },
      "ecpmEst": { "type": "number", "required": true, "description": "预估 ECPM。" },
      "ecpmReal": { "type": "number", "required": true, "description": "真实 ECPM。" },
      "variance": { "type": "number", "required": true, "description": "偏差%。" },
      "fillRate": { "type": "number", "required": true, "description": "充填率%。" },
      "trend": {
        "type": "string",
        "required": true,
        "enum": ["up", "flat", "down"],
        "description": "趋势：上/平/下。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "platform": "all",
    "s_country_code": "all",
    "t_date": "2026-03-05"
  },
  "sampleResponse": {
    "list": [
      {
        "sourceName": "Admob",
        "source": 1,
        "revenue": 1985.86,
        "revenueShare": 71.7,
        "impressions": 520000,
        "impressionShare": 62.4,
        "adUsers": 85000,
        "userShare": 72.4,
        "ecpmEst": 18.54,
        "ecpmReal": 17.2,
        "variance": 7.8,
        "fillRate": 96.2,
        "trend": "up"
      },
      {
        "sourceName": "Facebook",
        "source": 2,
        "revenue": 257.5,
        "revenueShare": 9.3,
        "impressions": 120000,
        "impressionShare": 14.4,
        "adUsers": 22000,
        "userShare": 18.7,
        "ecpmEst": 2.14,
        "ecpmReal": 2.0,
        "variance": 7.0,
        "fillRate": 92,
        "trend": "flat"
      }
    ]
  },
  "api": {
    "url": "POST /api/business-insight/iaa-analysis/table/ad-platform",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, platform?, s_country_code?, t_date",
    "responseBody": "list (IaaPlatformTableRow[])"
  }
}
