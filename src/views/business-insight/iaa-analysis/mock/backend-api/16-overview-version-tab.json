  },
  "api": {
    "url": "POST /api/business-insight/iaa-analysis/overview/version-tab",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, platform?, s_country_code?, t_date",
    "responseBody": "IaaVersionTabData"
  },
  "apiSuggestion": {
    "notes": [
      "tableRows 按 revenue 降序返回，isCurrent 标记当前最新版本（仅一条）",
      "revenueComparison 与 tableRows 同源，前端用于横向柱图展示，后端可复用同一查询",
      "ecpmTrend.versions 与 penetrationCrash.versions 数组顺序一致（均按版本升序），前端直接映射 X 轴",
      "upgradeProgress.series 颜色由后端返回固定色值，前端不做映射",
      "aiInsight.bullets 为 3~5 条 AI 生成洞察，若 AI 服务不可用则返回空数组 []"
    ]
  }
}
