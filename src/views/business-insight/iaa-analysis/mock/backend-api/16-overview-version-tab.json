{
  "_comment": "IAA 分析 - 版本 Tab 整页数据（KPI/收入对比/版本表/ECPM趋势/升级进度/渗透率/AI洞察）。对应 types.ts: IaaVersionTabData。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" }
    },
    "response": {
      "data": {
        "type": "IaaVersionTabData",
        "required": true,
        "description": "版本 Tab 全模块数据。"
      }
    },
    "IaaVersionTabData": {
      "kpis": {
        "type": "IaaKpiCard[]",
        "required": true,
        "description": "顶部4个KPI：版本数/最高收入版本/平均ECPM/最新版用户占比。"
      },
      "tableRows": {
        "type": "IaaVersionTableRow[]",
        "required": true,
        "description": "版本详细数据表，含 app_version/releaseDate/userShare/revenue/ecpmEst/ecpmReal/impressions/adPenetration/crashRate/versionRating/isCurrent。"
      },
      "revenueComparison": {
        "type": "IaaVersionRevenueItem[]",
        "required": true,
        "description": "版本收入对比横向柱图，含 app_version/revenue/userShare，按 revenue 降序。"
      },
      "versionInsight": { "type": "string", "required": true, "description": "版本数据洞察文案。" },
      "ecpmTrend": {
        "type": "object",
        "required": true,
        "description": "各版本 ECPM 趋势，fields: versions(string[])/est(number[])/real(number[])，与 versions 数组一一对应。"
      },
      "upgradeProgress": {
        "type": "object",
        "required": true,
        "description": "版本升级进度（按日堆叠面积图）。dates: string[], series: {version, color, data}[]。"
      },
      "penetrationCrash": {
        "type": "object",
        "required": true,
        "description": "各版本广告渗透率与崩溃率对比（双轴：柱+线）。versions: string[], penetration: number[], crash: number[]。"
      },
      "aiInsight": {
        "type": "IaaVersionInsight",
        "required": true,
        "description": "AI 版本洞察，bullets: string[]（3~5条）。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "platform": "all",
    "s_country_code": "all",
    "t_date": "2026-03-05"
  },
