  },
  "api": {
    "url": "POST /api/business-insight/iaa-analysis/overview/ad-type-tab",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, platform?, s_country_code?, t_date",
    "responseBody": "IaaAdTypeTabData"
  },
  "apiSuggestion": {
    "notes": [
      "kpi 为单对象（非数组），与其他 Tab 的 kpis[] 结构不同，请注意区分",
      "compareRows 与 radar.indicatorNames 顺序须一致，前端直接按序映射雷达图",
      "radar.maxByMetric 为各维度的坐标轴最大值，由后端计算（通常为该维度最大值的 1.2 倍取整），前端不做计算",
      "placementTop10.rank 从1开始，percent 为该广告位收入占总收入的百分比",
      "trend7d.series 颜色建议由后端返回固定色值（广告类型枚举固定），前端按 name 映射",
      "userBreakdown.highlightRevenueSharePct 为最后一个安装天数桶（360+天）贡献的广告收入占比，用于 tooltip 强调展示"
    ]
  }
}
