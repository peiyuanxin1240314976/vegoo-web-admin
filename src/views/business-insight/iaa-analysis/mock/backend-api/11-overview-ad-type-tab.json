{
  "_comment": "IAA 分析 - 广告类型 Tab 整页数据（KPI/类型对比表/雷达/平台排行/广告位Top10/近7天趋势/用户拆分）。对应 types.ts: IaaAdTypeTabData。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" }
    },
    "response": {
      "data": {
        "type": "IaaAdTypeTabData",
        "required": true,
        "description": "广告类型 Tab 全模块数据。"
      }
    },
    "IaaAdTypeTabData": {
      "kpi": {
        "type": "IaaAdTypeKpiSummary",
        "required": true,
        "description": "顶部 KPI 区使用的聚合指标（单对象），前端由此拼出 4 张卡片文案。"
      },
      "compareRows": {
        "type": "IaaAdTypeCompareRow[]",
        "required": true,
        "description": "广告类型详细对比表，含 adTypeName/revenue/revenueShare/users/ecpm/impressions。"
      },
      "radar": {
        "type": "object",
        "required": true,
        "description": "雷达图数据：indicatorNames(string[])/maxByMetric({revenue,users,impressions,avgRevenue})/values({revenue[],users[],impressions[],avgRevenue[]})。各数组顺序与 indicatorNames 一致。"
      },
      "platformRanking": {
        "type": "IaaPlatformRankItem[]",
        "required": true,
        "description": "广告平台效果排行柱图，含 sourceName/revenue/ecpm，按 revenue 降序。"
      },
      "platformInsight": {
        "type": "string",
        "required": true,
        "description": "平台排行下方洞察文案。"
      },
      "placementTop10": {
        "type": "IaaPlacementTopItem[]",
        "required": true,
        "description": "广告位 Top10 收入列表，含 rank/placementName/revenue/percent。"
      },
      "trend7d": {
        "type": "object",
        "required": true,
        "description": "近7天广告类型收入趋势（按广告类型拆线）。dates: string[], series: {name,color,data}[]。"
      },
      "userBreakdown": {
        "type": "object",
        "required": true,
        "description": "用户拆分（安装天数）双轴图。buckets: {installDays,revenue,activeUsers}[], insight: string, highlightRevenueSharePct?: number。"
      }
    },
    "IaaAdTypeKpiSummary": {
      "revenueTotal": {
        "type": "number",
        "required": true,
        "description": "广告总收入（预估/上报，USD）。"
      },
      "revenueReal": {
        "type": "number",
        "required": true,
        "description": "Firebase/真实收入（USD）。"
      },
      "penetrationPct": {
        "type": "number",
        "required": true,
        "description": "广告用户渗透率 0–100。"
      },
      "adUsers": { "type": "number", "required": true, "description": "广告用户数。" },
      "dau": { "type": "number", "required": true, "description": "日活。" },
      "impressions": { "type": "number", "required": true, "description": "展示次数。" },
      "impressionsPerUser": { "type": "number", "required": true, "description": "人均展示次数。" },
      "ecpmEst": { "type": "number", "required": true, "description": "预估 ECPM（USD）。" },
      "ecpmReal": { "type": "number", "required": true, "description": "真实 ECPM（USD）。" },
      "ecpmVariancePct": {
        "type": "number",
        "required": true,
        "description": "ECPM 偏差百分比（预估相对真实，正数表示预估偏高）。"
      }
    },
    "IaaAdTypeCompareRow": {
      "adTypeName": {
        "type": "string",
        "required": true,
        "description": "广告类型名：插页式/原生/横幅/开屏/激励视频。"
      },
      "revenue": { "type": "number", "required": true, "description": "该类型广告收入（USD）。" },
      "revenueShare": { "type": "number", "required": true, "description": "收入占比（0-100）。" },
      "users": { "type": "number", "required": true, "description": "广告用户数。" },
      "ecpm": { "type": "number", "required": true, "description": "预估 ECPM（USD）。" },
      "impressions": { "type": "number", "required": true, "description": "广告展示次数。" }
    },
    "IaaPlatformRankItem": {
      "sourceName": { "type": "string", "required": true, "description": "广告平台名称。" },
      "revenue": { "type": "number", "required": true, "description": "收入（USD）。" },
      "ecpm": { "type": "number", "required": true, "description": "ECPM（USD）。" }
    },
    "IaaPlacementTopItem": {
      "rank": { "type": "number", "required": true, "description": "排名，从 1 开始。" },
      "placementName": {
        "type": "string",
        "required": true,
        "description": "广告位名称/ID 展示名。"
      },
      "revenue": { "type": "number", "required": true, "description": "该广告位收入（USD）。" },
      "percent": { "type": "number", "required": true, "description": "占广告总收入百分比 0–100。" }
    },
    "IaaAdTypeTrend7dSeries": {
      "name": { "type": "string", "required": true, "description": "系列名（广告类型名）。" },
      "color": { "type": "string", "required": true, "description": "折线颜色 HEX。" },
      "data": {
        "type": "number[]",
        "required": true,
        "description": "与 trend7d.dates 等长的数据点。"
      }
    },
    "IaaUserBreakdownItem": {
      "installDays": {
        "type": "string",
        "required": true,
        "description": "安装天数分桶文案，如 1-7天。"
      },
      "revenue": { "type": "number", "required": true, "description": "该桶广告收入（USD）。" },
      "activeUsers": { "type": "number", "required": true, "description": "该桶活跃用户数。" }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "platform": "all",
    "s_country_code": "all",
    "t_date": "2026-03-05"
  },
