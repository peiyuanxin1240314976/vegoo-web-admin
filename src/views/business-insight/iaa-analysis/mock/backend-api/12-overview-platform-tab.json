  "api": {
    "url": "POST /api/business-insight/iaa-analysis/overview/platform-tab",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, platform?, s_country_code?, t_date",
    "responseBody": "IaaPlatformTabData"
  },
  "apiSuggestion": {
    "notes": [
      "donut 与 tableRows 的 revenue、percent 须自洽，percent 之和建议为 100（允许末位四舍五入误差）。",
      "tableRows 中的 revenueShare/impressionShare/userShare 由后端汇总计算，前端仅展示。",
      "trend7d 每条 series 的 data 长度必须等于 dates 长度；颜色可由后端返回或与前端按平台名映射二选一。",
      "ecpmComparison 与 tableRows 中同名的 ecpmEst/ecpmReal 应一致，可同源查询。"
    ]
  }
}
