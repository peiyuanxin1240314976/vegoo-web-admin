{
  "_comment": "IAA 分析 - 广告平台 Tab 整页数据（KPI/平台排行/对比表/收入占比环图/ECPM对比/7天趋势）。对应 types.ts: IaaPlatformTabData。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" }
    },
    "response": {
      "data": {
        "type": "IaaPlatformTabData",
        "required": true,
        "description": "广告平台 Tab 全模块数据。"
      }
    },
    "IaaPlatformTabData": {
      "kpis": { "type": "IaaKpiCard[]", "required": true, "description": "顶部 4 个 KPI 卡片。" },
      "platformRanking": {
        "type": "IaaPlatformRankItem[]",
        "required": true,
        "description": "广告平台效果排行，柱状图数据，按 revenue 降序。"
      },
      "platformInsight": {
        "type": "string",
        "required": true,
        "description": "平台排行洞察文案。"
      },
      "tableRows": {
        "type": "IaaPlatformTableRow[]",
        "required": true,
        "description": "平台详细对比表行，含收入/展示/用户/ECPM/充填率/趋势。"
      },
      "donut": {
        "type": "IaaRevenueDonutItem[]",
        "required": true,
        "description": "各广告平台收入占比环形图，name/value/percent 与 tableRows 汇总一致。"
      },
      "ecpmComparison": {
        "type": "object[]",
        "required": true,
        "description": "各平台预估与真实 ECPM 对比（水平柱状图）。fields: name, ecpmEst, ecpmReal，与 tableRows 同平台对齐。"
      },
      "trend7d": {
        "type": "object",
        "required": true,
        "description": "近 7 天按广告平台拆线的收入趋势。dates: string[]（7 个刻度）, series: IaaAdTypeTrend7dSeries[]（name/color/data[]）。"
      }
    },
    "IaaKpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片唯一标识。" },
      "title": { "type": "string", "required": true, "description": "卡片标题。" },
      "primaryValue": {
        "type": "string",
        "required": true,
        "description": "主数值展示，如 $2,768.58。"
      },
      "subText": {
        "type": "string",
        "required": false,
        "description": "副文案，如 广告平台上报 ↑12.3%。"
      },
      "trendUp": {
        "type": "boolean",
        "required": false,
        "description": "趋势是否上升（用于样式）。"
      },
      "accent": {
        "type": "string",
        "required": false,
        "enum": ["teal", "blue", "amber", "green", "default"],
        "description": "强调色。"
      }
    },
    "IaaPlatformRankItem": {
      "sourceName": { "type": "string", "required": true, "description": "广告平台名称。" },
      "revenue": { "type": "number", "required": true, "description": "该平台收入（USD）。" },
      "ecpm": {
        "type": "number",
        "required": true,
        "description": "该平台 ECPM（USD，可与预估或真实口径一致，需与前端约定）。"
      }
    },
    "IaaPlatformTableRow": {
      "sourceName": { "type": "string", "required": true, "description": "广告平台名称。" },
      "source": { "type": "number", "required": true, "description": "广告平台枚举 n_source。" },
      "revenue": { "type": "number", "required": true, "description": "广告收入（USD）。" },
      "revenueShare": { "type": "number", "required": true, "description": "收入占比 0–100。" },
      "impressions": { "type": "number", "required": true, "description": "展示次数。" },
      "impressionShare": { "type": "number", "required": true, "description": "展示占比 0–100。" },
      "adUsers": { "type": "number", "required": true, "description": "广告用户数。" },
      "userShare": { "type": "number", "required": true, "description": "用户占比 0–100。" },
      "ecpmEst": { "type": "number", "required": true, "description": "预估 ECPM（USD）。" },
      "ecpmReal": { "type": "number", "required": true, "description": "真实 ECPM（USD）。" },
      "variance": {
        "type": "number",
        "required": true,
        "description": "预估相对真实的偏差百分比。"
      },
      "fillRate": { "type": "number", "required": true, "description": "充填率 0–100。" },
      "trend": {
        "type": "string",
        "required": true,
        "enum": ["up", "flat", "down"],
        "description": "环比趋势。"
      }
    },
    "IaaRevenueDonutItem": {
      "name": {
        "type": "string",
        "required": true,
        "description": "平台名称，与 sourceName 一致。"
      },
      "value": { "type": "number", "required": true, "description": "收入金额（USD）。" },
      "percent": { "type": "number", "required": true, "description": "占总收入百分比 0–100。" }
    },
    "IaaAdTypeTrend7dSeries": {
      "name": { "type": "string", "required": true, "description": "系列名，与广告平台名称一致。" },
      "color": {
        "type": "string",
        "required": true,
        "description": "折线颜色 HEX，建议按平台固定映射。"
      },
      "data": {
        "type": "number[]",
        "required": true,
        "description": "7 个点，与 trend7d.dates 一一对应，单位为收入或与前端约定的度量。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "platform": "all",
    "s_country_code": "all",
    "t_date": "2026-03-05"
  },
