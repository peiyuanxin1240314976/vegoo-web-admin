  "api": {
    "url": "POST /api/business-insight/iaa-analysis/overview/ad-unit-tab",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, platform?, s_country_code?, t_date",
    "responseBody": "IaaAdUnitTabData"
  },
  "apiSuggestion": {
    "notes": [
      "tableRows 应按 revenue 降序返回前 15 条，前端直接展示。",
      "fillRateBuckets 的 range 枚举固定为 ['<70%','70-80%','80-90%','90-95%','>95%']，count 之和应等于开启单元数（或与产品约定一致）。",
      "status：fillRate < 80 时为 low，否则为 normal。",
      "trend7d.series 建议取当日收入最高的 3～5 个单元，避免折线过多。"
    ]
  }
