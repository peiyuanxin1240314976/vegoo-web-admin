{
  "_comment": "IAA 分析 - 广告单元 Tab 整页数据（KPI/单元表/充填率分布/ECPM散点/趋势）。对应 types.ts: IaaAdUnitTabData。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" }
    },
    "response": {
      "data": {
        "type": "IaaAdUnitTabData",
        "required": true,
        "description": "广告单元 Tab 全模块数据。"
      }
    },
    "IaaAdUnitTabData": {
      "kpis": {
        "type": "IaaKpiCard[]",
        "required": true,
        "description": "顶部 4 个 KPI：总数/总收入/平均 ECPM/充填率；充填率偏低时 accent=amber。"
      },
      "tableRows": {
        "type": "IaaAdUnitTableRow[]",
        "required": true,
        "description": "广告单元收入表，建议按 revenue 降序返回前 15 条。"
      },
      "fillRateBuckets": {
        "type": "IaaFillRateBucket[]",
        "required": true,
        "description": "充填率区间分布，range 枚举固定见 apiSuggestion。"
      },
      "fillRateInsight": {
        "type": "string",
        "required": true,
        "description": "充填率异常洞察文案。"
      },
      "scatterData": {
        "type": "IaaEcpmFillPoint[]",
        "required": true,
        "description": "ECPM vs 充填率散点。"
      },
      "trend7d": {
        "type": "object",
        "required": true,
        "description": "近 7 天收入趋势，按 Top 单元拆线。dates 长度 7，series[].data 同长度。"
      }
    },
    "IaaKpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片 ID。" },
      "title": { "type": "string", "required": true, "description": "标题。" },
      "primaryValue": { "type": "string", "required": true, "description": "主展示值。" },
      "subText": { "type": "string", "required": false, "description": "副文案。" },
      "trendUp": { "type": "boolean", "required": false, "description": "趋势。" },
      "accent": {
        "type": "string",
        "required": false,
        "enum": ["teal", "blue", "amber", "green", "default"],
        "description": "强调色。"
      }
    },
    "IaaAdUnitTableRow": {
      "s_ad_unit_id": { "type": "string", "required": true, "description": "广告单元 ID。" },
      "placementName": { "type": "string", "required": true, "description": "所属广告位名。" },
      "adTypeName": { "type": "string", "required": true, "description": "广告类型。" },
      "sourceName": { "type": "string", "required": true, "description": "广告平台。" },
      "revenue": { "type": "number", "required": true, "description": "收入（USD）。" },
      "ecpmEst": { "type": "number", "required": true, "description": "预估 ECPM。" },
      "ecpmReal": { "type": "number", "required": true, "description": "真实 ECPM。" },
      "impressions": { "type": "number", "required": true, "description": "展示次数。" },
      "fillRate": { "type": "number", "required": true, "description": "充填率 0–100。" },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["normal", "low"],
        "description": "fillRate < 80 为 low。"
      }
    },
    "IaaFillRateBucket": {
      "range": { "type": "string", "required": true, "description": "区间标签。" },
      "count": { "type": "number", "required": true, "description": "该区间单元数量。" }
    },
    "IaaEcpmFillPoint": {
      "unitId": {
        "type": "string",
        "required": true,
        "description": "单元短名或 ID 后缀，用于散点标签。"
      },
      "ecpm": { "type": "number", "required": true, "description": "ECPM（USD）。" },
      "fillRate": { "type": "number", "required": true, "description": "充填率。" },
      "adType": { "type": "string", "required": true, "description": "广告类型。" }
    },
    "IaaAdTypeTrend7dSeries": {
      "name": { "type": "string", "required": true, "description": "系列名（单元标识）。" },
      "color": { "type": "string", "required": true, "description": "颜色 HEX。" },
      "data": { "type": "number[]", "required": true, "description": "7 日数据点。" }
    }
  },
  "sampleRequest": {
