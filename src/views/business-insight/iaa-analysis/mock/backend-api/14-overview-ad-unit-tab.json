{
  "_comment": "IAA 分析 - 广告单元 Tab 整页数据（KPI/单元表/充填率分布/ECPM散点/趋势）。对应 types.ts: IaaAdUnitTabData。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" }
    },
    "response": {
      "data": {
        "type": "IaaAdUnitTabData",
        "required": true,
        "description": "广告单元 Tab 全模块数据。"
      }
    },
    "IaaAdUnitTabData": {
      "kpis": {
        "type": "IaaKpiCard[]",
        "required": true,
        "description": "顶部4个KPI：总数/总收入/平均ECPM/充填率。accent=amber时充填率KPI高亮警告。"
      },
      "tableRows": {
        "type": "IaaAdUnitTableRow[]",
        "required": true,
        "description": "广告单元 Top15 收入表行，含 s_ad_unit_id/placementName/adTypeName/sourceName/revenue/ecpmEst/ecpmReal/impressions/fillRate/status。"
      },
      "fillRateBuckets": {
        "type": "IaaFillRateBucket[]",
        "required": true,
        "description": "充填率区间分布，fields: range/count。如 '<70%'/10。"
      },
      "fillRateInsight": {
        "type": "string",
        "required": true,
        "description": "充填率异常洞察文案。"
      },
      "scatterData": {
        "type": "IaaEcpmFillPoint[]",
        "required": true,
        "description": "ECPM vs 充填率散点，fields: unitId/ecpm/fillRate/adType。"
      },
      "trend7d": {
        "type": "object",
        "required": true,
        "description": "近7天收入趋势（按 Top 广告单元拆线）。dates: string[], series: {name,color,data}[]。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "platform": "all",
    "s_country_code": "all",
    "t_date": "2026-03-05"
  },
  "sampleResponse": {
    "data": {
      "kpis": [
        {
          "id": "1",
          "title": "广告单元总数",
          "primaryValue": "284个",
          "subText": "已开启256个 | 关闭28个"
        }
      ],
      "tableRows": [
        {
          "s_ad_unit_id": "ca-app-pub-xxx/Splash_001",
          "placementName": "Splash",
          "adTypeName": "开屏",
          "sourceName": "Admob",
          "revenue": 488.2,
          "ecpmEst": 19.2,
          "ecpmReal": 18.56,
          "impressions": 27335,
          "fillRate": 97.6,
          "status": "normal"
        }
      ],
      "fillRateBuckets": [
        { "range": "<70%", "count": 2 },
        { "range": ">95%", "count": 107 }
      ],
      "fillRateInsight": "12个单元充填率<80%，建议检查广告位配置",
      "scatterData": [{ "unitId": "Splash_001", "ecpm": 19.2, "fillRate": 97.6, "adType": "开屏" }],
      "trend7d": {
        "dates": ["Feb27", "Mar5"],
        "series": [{ "name": "Splash_001", "color": "#26C2AD", "data": [480, 488] }]
      }
    }
  },
  "api": {
    "url": "POST /api/business-insight/iaa-analysis/overview/ad-unit-tab",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, platform?, s_country_code?, t_date",
    "responseBody": "IaaAdUnitTabData"
  },
  "apiSuggestion": {
    "notes": [
      "tableRows 应按 revenue 降序返回前15条，前端直接展示",
      "fillRateBuckets 的 range 枚举固定为 ['<70%','70-80%','80-90%','90-95%','>95%']",
      "status 字段：fillRate < 80 时为 low，否则为 normal"
    ]
  }
}
