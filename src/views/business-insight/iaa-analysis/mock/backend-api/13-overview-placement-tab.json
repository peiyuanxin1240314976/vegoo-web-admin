  "api": {
    "url": "POST /api/business-insight/iaa-analysis/overview/placement-tab",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, platform?, s_country_code?, t_date",
    "responseBody": "IaaPlacementTabData"
  },
  "apiSuggestion": {
    "notes": [
      "donut 可与 top10 同源：前 N 项展开，其余合并为「其他」，percent 合计 100（允许四舍五入误差）。",
      "tableRows 建议按 revenue 降序，status=low 通常表示 fillRate < 80（与广告单元 Tab 约定一致时可复用）。",
      "scatterData 与 tableRows 可同源裁剪列，便于联调对照。"
    ]
  }
}
