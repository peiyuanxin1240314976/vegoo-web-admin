{
  "_comment": "IAA 分析 - 广告位 Tab 整页数据（KPI/Top10/详表/收入占比/ECPM排行/洞察/散点）。对应 types.ts: IaaPlacementTabData。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" }
    },
    "response": {
      "data": {
        "type": "IaaPlacementTabData",
        "required": true,
        "description": "广告位 Tab 全模块数据。"
      }
    },
    "IaaPlacementTabData": {
      "kpis": {
        "type": "IaaKpiCard[]",
        "required": true,
        "description": "顶部 4 个 KPI：总数/总收入/平均 ECPM/展示总次等。"
      },
      "top10": {
        "type": "IaaPlacementTop10Item[]",
        "required": true,
        "description": "Top10 广告位，含 revenue/impressions/ecpm/users/percent。"
      },
      "tableRows": {
        "type": "IaaPlacementTableRow[]",
        "required": true,
        "description": "广告位详细数据表（可多于 Top10，供表格滚动）。"
      },
      "donut": {
        "type": "IaaRevenueDonutItem[]",
        "required": true,
        "description": "收入占比环形图，name/value/percent 与总收入自洽。"
      },
      "ecpmRanking": {
        "type": "object[]",
        "required": true,
        "description": "ECPM 排行水平柱图，fields: name, ecpm（USD）。"
      },
      "placementInsight": { "type": "string", "required": true, "description": "广告位洞察文案。" },
      "scatterData": {
        "type": "object[]",
        "required": true,
        "description": "展示次数 vs 收入散点，fields: name, impressions, revenue。"
      }
    },
    "IaaKpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片 ID。" },
      "title": { "type": "string", "required": true, "description": "标题。" },
      "primaryValue": {
        "type": "string",
        "required": true,
        "description": "主展示值（可预格式化）。"
      },
      "subText": { "type": "string", "required": false, "description": "副文案。" },
      "trendUp": { "type": "boolean", "required": false, "description": "趋势向上。" },
      "accent": {
        "type": "string",
        "required": false,
        "enum": ["teal", "blue", "amber", "green", "default"],
        "description": "强调色。"
      }
    },
    "IaaPlacementTop10Item": {
      "name": { "type": "string", "required": true, "description": "广告位名称。" },
      "revenue": { "type": "number", "required": true, "description": "收入（USD）。" },
      "impressions": { "type": "number", "required": true, "description": "展示次数。" },
      "ecpm": { "type": "number", "required": true, "description": "ECPM（USD）。" },
      "users": { "type": "number", "required": true, "description": "触达用户数。" },
      "percent": { "type": "number", "required": true, "description": "收入占比 0–100。" }
    },
    "IaaPlacementTableRow": {
      "placementName": { "type": "string", "required": true, "description": "广告位名称。" },
      "adTypeName": { "type": "string", "required": true, "description": "广告类型中文名。" },
      "sourceName": { "type": "string", "required": true, "description": "广告平台名称。" },
      "revenue": { "type": "number", "required": true, "description": "收入（USD）。" },
      "impressions": { "type": "number", "required": true, "description": "展示次数。" },
      "ecpmEst": { "type": "number", "required": true, "description": "预估 ECPM（USD）。" },
      "ecpmReal": { "type": "number", "required": true, "description": "真实 ECPM（USD）。" },
      "impressionUsers": { "type": "number", "required": true, "description": "有展示的用户数。" },
      "fillRate": { "type": "number", "required": true, "description": "充填率 0–100。" },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["normal", "low"],
        "description": "充填率偏低等为 low。"
      }
    },
    "IaaRevenueDonutItem": {
      "name": { "type": "string", "required": true, "description": "图例名称（广告位或聚合项）。" },
      "value": { "type": "number", "required": true, "description": "收入（USD）。" },
      "percent": { "type": "number", "required": true, "description": "占比 0–100。" }
    }
  },
