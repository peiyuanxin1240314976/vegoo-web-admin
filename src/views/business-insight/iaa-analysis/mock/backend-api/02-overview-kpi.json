{
  "_comment": "IAA 分析 - 当前 Tab 顶部 4 个 KPI 卡片。对应 types.ts: IaaKpiCard。",
  "fieldDescription": {
    "request": {
      "tab": {
        "type": "string",
        "required": true,
        "enum": ["adType", "adPlatform", "adPlacement", "adUnit", "country", "version"],
        "description": "当前选中的 Tab，用于返回该 Tab 的 4 个 KPI。"
      },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" }
    },
    "response": {
      "kpis": {
        "type": "IaaKpiCard[]",
        "required": true,
        "description": "当前 Tab 的 4 个 KPI 卡片数据。"
      }
    },
    "IaaKpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片唯一标识。" },
      "title": { "type": "string", "required": true, "description": "卡片标题。" },
      "primaryValue": {
        "type": "string",
        "required": true,
        "description": "主数值展示，如 $2,768.58、68.6%。"
      },
      "subText": {
        "type": "string",
        "required": false,
        "description": "副文案，如 广告平台上报 ↑12.3%。"
      },
      "trendUp": {
        "type": "boolean",
        "required": false,
        "description": "趋势是否上升（绿色/红色）。"
      },
      "accent": {
        "type": "string",
        "required": false,
        "enum": ["teal", "blue", "amber", "green", "default"],
        "description": "强调色类型。"
      }
    }
  },
  "sampleRequest": {
    "tab": "adPlatform",
    "s_app_id": "all",
    "platform": "all",
    "s_country_code": "all",
    "t_date": "2026-03-05"
  },
  "sampleResponse": {
    "kpis": [
      {
        "id": "kpi_1",
        "title": "广告总收入",
        "primaryValue": "$2,768.58",
        "subText": "广告平台上报 ↑12.3%",
        "trendUp": true,
        "accent": "teal"
      },
      {
        "id": "kpi_2",
        "title": "平均ECPM",
        "primaryValue": "3.32 / 3.06",
        "subText": "预估/真实 | 偏差 +8.5%",
        "accent": "default"
      },
      {
        "id": "kpi_3",
        "title": "广告展示次数",
        "primaryValue": "833,607",
        "subText": "人均展示4.9次",
        "accent": "default"
      },
      {
        "id": "kpi_4",
        "title": "广告用户",
        "primaryValue": "117,483",
        "subText": "渗透率68.6%",
        "accent": "default"
      }
    ]
  },
  "api": {
    "url": "POST /api/business-insight/iaa-analysis/overview-kpi",
    "method": "POST",
    "priority": "P0",
    "requestBody": "tab, s_app_id?, platform?, s_country_code?, t_date",
    "responseBody": "kpis (IaaKpiCard[])"
  },
  "apiSuggestion": {
    "notes": [
      "须固定返回 4 条 KPI，顺序与前端卡片占位一致；tab 切换时仅文案与数值变化。",
      "若与各 Tab 的 overview/*-tab 整页接口合并，本接口可下线，但 IaaKpiCard 结构仍与整页中的 kpis[] 一致。"
    ]
  }
}
