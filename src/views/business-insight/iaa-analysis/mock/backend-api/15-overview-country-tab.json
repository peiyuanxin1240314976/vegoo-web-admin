{
  "_comment": "IAA 分析 - 国家 Tab 整页数据（KPI/地图热力/Top10表/ECPM对比/7天趋势/渗透率）。对应 types.ts: IaaCountryTabData。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台：all/android/ios。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" }
    },
    "response": {
      "data": {
        "type": "IaaCountryTabData",
        "required": true,
        "description": "国家 Tab 全模块数据。"
      }
    },
    "IaaCountryTabData": {
      "kpis": {
        "type": "IaaKpiCard[]",
        "required": true,
        "description": "顶部4个KPI：覆盖国家数/Top1收入/平均ECPM/ARPDAU差异倍数。"
      },
      "mapData": {
        "type": "IaaCountryMapItem[]",
        "required": true,
        "description": "国家收入地图热力数据，按 ECPM 着色。name 必须与 /geo/world.json GeoJSON 的 properties.name 一致（英文）。"
      },
      "tableRows": {
        "type": "IaaCountryTableRow[]",
        "required": true,
        "description": "国家收入 Top10 表行，含 rank/s_country_code/s_country_name/revenue/revenueShare/ecpmEst/ecpmReal/impressions/adUsers/arpdau/trend/trendPercent。"
      },
      "ecpmComparison": {
        "type": "object[]",
        "required": true,
        "description": "国家 ECPM 水平柱状图，fields: name(中文)/ecpm，按 ecpm 降序。"
      },
      "trend7d": {
        "type": "object",
        "required": true,
        "description": "近7天国家收入趋势（Top3国家拆线）。dates: string[], series: {name,color,data}[]。"
      },
      "penetrationData": {
        "type": "object[]",
        "required": true,
        "description": "国家广告用户渗透率，fields: name(中文)/penetration（0-100）。"
      }
    },
    "IaaKpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片 ID。" },
      "title": { "type": "string", "required": true, "description": "标题。" },
      "primaryValue": {
        "type": "string",
        "required": true,
        "description": "主展示值（可含国家名、倍数等）。"
      },
      "subText": { "type": "string", "required": false, "description": "副文案。" },
      "trendUp": { "type": "boolean", "required": false, "description": "趋势向上。" },
      "accent": {
        "type": "string",
        "required": false,
        "enum": ["teal", "blue", "amber", "green", "default"],
        "description": "强调色。"
      }
    },
    "IaaCountryMapItem": {
      "name": {
        "type": "string",
        "required": true,
        "description": "英文国家名，与 world.json GeoJSON properties.name 完全一致，用于地图高亮映射。特殊值：美国→United States，韩国→Korea，英国→United Kingdom。"
      },
      "value": {
        "type": "number",
        "required": true,
        "description": "ECPM 值，用于热力着色（颜色梯度：低→深蓝，高→青色 #26C2AD）。"
      },
      "cnName": {
        "type": "string",
        "required": false,
        "description": "中文国家名，用于地图标签和 tooltip 展示。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "ISO 3166-1 alpha-2 国家代码，如 US/KR/JP。"
      }
    },
    "IaaCountryTableRow": {
      "rank": { "type": "number", "required": true, "description": "收入排名，从1开始。" },
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "ISO 3166-1 alpha-2 国家代码，用于显示国旗（flag-icons）。"
      },
      "s_country_name": { "type": "string", "required": true, "description": "国家中文名。" },
      "revenue": { "type": "number", "required": true, "description": "广告收入（USD）。" },
      "revenueShare": { "type": "number", "required": true, "description": "收入占比（0-100）。" },
      "ecpmEst": { "type": "number", "required": true, "description": "预估 ECPM（USD）。" },
      "ecpmReal": { "type": "number", "required": true, "description": "真实 ECPM（USD）。" },
      "impressions": { "type": "number", "required": true, "description": "广告展示次数。" },
      "adUsers": { "type": "number", "required": true, "description": "广告用户数。" },
      "arpdau": {
        "type": "number",
        "required": true,
        "description": "每日活跃用户广告收入（USD），精度4位小数，如 0.0228。"
      },
      "trend": { "type": "string", "required": true, "description": "环比趋势：up/flat/down。" },
      "trendPercent": {
        "type": "number",
        "required": false,
        "description": "环比变化百分比（绝对值），trend=flat时可不传。"
      }
    }
  },
