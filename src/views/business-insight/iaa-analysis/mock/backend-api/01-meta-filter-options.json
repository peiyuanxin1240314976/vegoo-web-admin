{
  "_comment": "IAA 分析 - 全局筛选下拉选项。对应 types.ts: IaaFilterOptions。",
  "fieldDescription": {
    "request": {},
    "response": {
      "appOptions": {
        "type": "IaaSelectOption[]",
        "required": true,
        "description": "应用下拉选项，首项建议固定为「全部」value=all。"
      },
      "platformOptions": {
        "type": "IaaSelectOption[]",
        "required": true,
        "description": "终端平台下拉选项（Android/iOS/全部）。"
      },
      "countryOptions": {
        "type": "IaaSelectOption[]",
        "required": true,
        "description": "国家下拉选项，首项建议固定为「全部」value=all；其余 value 为 ISO 3166-1 alpha-2。"
      }
    },
    "IaaSelectOption": {
      "label": { "type": "string", "required": true, "description": "展示文案。" },
      "value": {
        "type": "string",
        "required": true,
        "description": "选项值：应用为 all 或 s_app_id；平台为 all/android/ios；国家为 all 或两位国家码。"
      }
    }
  },
