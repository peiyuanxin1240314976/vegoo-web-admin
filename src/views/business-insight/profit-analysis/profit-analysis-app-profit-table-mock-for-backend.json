{
  "_comment": "利润分析（国家）-应用利润详情：用于左侧表格 + 趋势小折线。",
  "fieldDescription": {
    "request": {
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用筛选。all 表示全部。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家筛选。all 表示全部。"
      },
      "t_date_start": {
        "type": "string",
        "required": true,
        "description": "开始日期（YYYY-MM-DD）。"
      },
      "t_date_end": {
        "type": "string",
        "required": true,
        "description": "结束日期（YYYY-MM-DD）。"
      }
    },
    "response": {
      "list": { "type": "AppProfitRow[]", "required": true, "description": "应用利润行数据。" }
    },
    "AppProfitRow": {
      "s_app_name": { "type": "string", "required": true, "description": "应用名称。" },
      "d_ad_revenue": { "type": "decimal", "required": true, "description": "广告收入（金额）。" },
      "d_iap_revenue": { "type": "decimal", "required": true, "description": "付费收入（金额）。" },
      "d_total_revenue": { "type": "decimal", "required": true, "description": "总收入（金额）。" },
      "d_ad_spend": { "type": "decimal", "required": true, "description": "广告支出（金额）。" },
      "d_est_profit": {
        "type": "decimal",
        "required": true,
        "description": "预估利润（金额，可为负）。"
      },
      "d_profit_rate": {
        "type": "decimal",
        "required": true,
        "description": "利润率（百分比，0~100，可为负）。"
      },
      "trend": {
        "type": "decimal[]",
        "required": true,
        "description": "趋势点（用于小折线，建议 7~14 点）。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "s_country_code": "all",
    "t_date_start": "2026-03-01",
    "t_date_end": "2026-03-05"
  },
  "sampleResponse": {
    "list": [
      {
        "s_app_name": "Weather5",
        "d_ad_revenue": 45200,
        "d_iap_revenue": 12100,
        "d_total_revenue": 57300,
        "d_ad_spend": 38500,
        "d_est_profit": 18800,
        "d_profit_rate": 32.8,
        "trend": [120, 260, 180, 310, 280, 360, 420]
      }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/profit-analysis/app-profit-table",
    "method": "POST",
    "priority": "P1",
    "requestBody": "s_app_id, s_country_code, t_date_start, t_date_end",
    "responseBody": "list"
  }
}
