      "name": { "type": "string", "required": true, "description": "节点名称。" },
      "itemStyle": { "type": "object", "required": false, "description": "如 { color }。" }
    },
    "ProfitSankeyLinkDto": {
      "source": { "type": "string", "required": true, "description": "源节点 name。" },
      "target": { "type": "string", "required": true, "description": "目标节点 name。" },
      "value": { "type": "number", "required": true, "description": "流量数值。" }
    }
  },
  "sampleRequest": {
