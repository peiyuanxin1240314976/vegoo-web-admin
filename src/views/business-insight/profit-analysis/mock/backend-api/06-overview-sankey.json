  "_comment": "利润分析 - 利润构成桑基图。对应 types：ProfitSankeyDto（nodes + links）。",
  "fieldDescription": {
    "request": {
      "dateRange": {
        "type": "string",
        "required": true,
        "description": "日期范围，如 2026-03-01,2026-03-05。"
      },
      "currentPage": { "type": "integer", "required": false, "description": "分页。" },
      "pageSize": { "type": "integer", "required": false, "description": "分页。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台 all/android/ios。"
      },
