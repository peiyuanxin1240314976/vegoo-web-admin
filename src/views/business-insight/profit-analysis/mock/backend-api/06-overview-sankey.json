      "sCountryCode": { "type": "string", "required": false, "description": "国家代码，全部 all。" }
    },
    "response": {
      "data": {
        "type": "ProfitSankeyDto",
        "required": true,
        "description": "网关 data 内结构；前端 http 解包后为 nodes + links。"
      }
    },
    "ProfitSankeyDto": {
      "nodes": { "type": "ProfitSankeyNodeDto[]", "required": true, "description": "节点列表。" },
