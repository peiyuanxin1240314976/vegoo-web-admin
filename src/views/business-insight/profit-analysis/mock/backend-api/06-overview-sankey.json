{
  "_comment": "利润分析 - 利润构成桑基图（节点与连线）。对应 types.ts: ProfitSankeyNode[], ProfitSankeyLink[]。",
  "fieldDescription": {
    "request": {
      "dateRange": { "type": "string", "required": true, "description": "日期范围。" },
      "s_app_id": { "type": "string", "required": false, "description": "应用 ID，全部传 all。" },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家代码，全部传 all。"
      },
      "platform": { "type": "string", "required": false, "description": "终端平台。" }
    },
    "response": {
      "nodes": {
        "type": "ProfitSankeyNode[]",
        "required": true,
        "description": "桑基图节点，name 可含换行与金额展示。"
      },
      "links": {
        "type": "ProfitSankeyLink[]",
        "required": true,
        "description": "连线，source/target 与 nodes[].name 一致，value 为数值。"
      }
    },
    "ProfitSankeyNode": {
      "name": {
        "type": "string",
        "required": true,
        "description": "节点名称，如 广告收入(IAA)\\n$98,240。"
      },
      "itemStyle": {
        "type": "object",
        "required": false,
        "description": "节点样式，如 { color: '#38bdf8' }。"
      }
    },
    "ProfitSankeyLink": {
      "source": { "type": "string", "required": true, "description": "源节点 name。" },
      "target": { "type": "string", "required": true, "description": "目标节点 name。" },
      "value": { "type": "number", "required": true, "description": "流量/金额数值。" }
    }
  },
  "sampleRequest": {
    "dateRange": "2026-03-01,2026-03-05",
    "s_app_id": "all",
    "s_country_code": "all",
    "platform": "all"
  },
  "sampleResponse": {
    "nodes": [
      { "name": "广告收入(IAA)\n$98,240", "itemStyle": { "color": "#38bdf8" } },
      { "name": "付费收入(IAP)\n$27,440", "itemStyle": { "color": "#2dd4bf" } },
      { "name": "总收入\n$125,680", "itemStyle": { "color": "#818cf8" } },
      { "name": "广告支出\n$89,240", "itemStyle": { "color": "#fb923c" } },
      { "name": "预估利润\n$36,440", "itemStyle": { "color": "#a855f7" } }
    ],
    "links": [
      { "source": "广告收入(IAA)\n$98,240", "target": "总收入\n$125,680", "value": 98240 },
      { "source": "付费收入(IAP)\n$27,440", "target": "总收入\n$125,680", "value": 27440 },
      { "source": "总收入\n$125,680", "target": "广告支出\n$89,240", "value": 89240 },
      { "source": "总收入\n$125,680", "target": "预估利润\n$36,440", "value": 36440 }
    ]
  },
  "api": {
    "url": "POST /api/business-insight/profit-analysis/overview/sankey",
    "method": "POST",
    "priority": "P0",
    "requestBody": "dateRange, s_app_id?, s_country_code?, platform",
    "responseBody": "nodes (ProfitSankeyNode[]), links (ProfitSankeyLink[])"
  }
}
