    }
  },
  "api": {
    "url": "POST /api/business-insight/profit-analysis/table/app-profit",
    "method": "POST",
    "priority": "P0",
    "requestBody": "扁平 ProfitAnalysisQueryParams（列表带 currentPage、pageSize）",
    "responseBody": "rows (ProfitAppRow[]), total (ProfitAppTotal)"
  }
}
