{
  "_comment": "利润分析 - 应用利润详情（树表）：单根节点「全部应用、全部国家」+ children 为国家行。前端展开后首屏仅渲染 20 条，滚动到底每次追加 10 条，并使用虚拟列表避免一次性渲染 200+ 国家行。对应 types.ts: ProfitAppProfitTreeNode, ProfitAppProfitResponseDto。",
  "fieldDescription": {
    "request": {
      "dateRange": { "type": "string", "required": true, "description": "日期范围。" },
      "currentPage": { "type": "integer", "required": false, "description": "当前页。" },
      "pageSize": { "type": "integer", "required": false, "description": "每页条数。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台 all/android/ios。"
      },
      "sAppId": { "type": "string", "required": false, "description": "应用 ID，全部 all。" },
      "sCountryCode": { "type": "string", "required": false, "description": "国家代码，全部 all。" }
    },
    "response": {
      "root": { "type": "ProfitAppProfitTreeNode", "required": true, "description": "树表根节点。" }
    },
    "ProfitAppProfitTreeNode": {
      "id": {
        "type": "string",
        "required": true,
        "description": "稳定主键。根固定为 root；国家行可用 countryCode 或拼接。"
      },
      "name": {
        "type": "string",
        "required": true,
        "description": "首列展示名。根为「全部应用、全部国家」；子节点为国家名。"
      },
      "appName": {
        "type": "string",
        "required": false,
        "description": "应用展示名。根行可为「全部应用」；子行用于表格「应用」列展示具体应用。"
      },
      "countryCode": {
        "type": "string",
        "required": false,
        "description": "国家代码（ISO 3166-1 alpha-2 小写）。根节点可省略或为空串。"
      },
      "adRev": {
        "type": "string",
        "required": true,
        "description": "广告收入(预) 展示值，如 $45,200。"
      },
      "paidRev": { "type": "string", "required": true, "description": "付费收入展示值。" },
      "adSpend": { "type": "string", "required": true, "description": "广告支出展示值。" },
      "profit": { "type": "string", "required": true, "description": "预估利润，如 +$18,800。" },
      "profitColor": { "type": "string", "required": true, "description": "利润颜色 HEX。" },
      "roi1d": {
        "type": "string",
        "required": true,
        "description": "首日ROI（百分比展示值，如 86.52%）。"
      },
      "avgDau": { "type": "string", "required": true, "description": "平均DAU（整数展示值）。" },
      "newUsers": { "type": "string", "required": true, "description": "新用户（整数展示值）。" },
      "paidUsers": {
        "type": "string",
        "required": true,
        "description": "买量用户（整数展示值）。"
      },
      "organicUsers": {
        "type": "string",
        "required": true,
        "description": "自然量（整数展示值）。"
      },
      "profitTrend": {
        "type": "ProfitTrendPoint[]",
        "required": true,
        "description": "按筛选日期范围返回的利润趋势点，前端据此绘制趋势图。"
      },
      "children": {
        "type": "ProfitAppProfitTreeNode[]",
        "required": false,
        "description": "子节点数组。当前业务：根节点 children 为国家行。无数据返回 []。"
      }
    },
    "ProfitTrendPoint": {
      "date": { "type": "string", "required": true, "description": "日期（YYYY-MM-DD）。" },
      "profit": {
        "type": "number",
        "required": true,
        "description": "当日利润数值（USD，可正可负）。"
      }
    }
  },
  "sampleRequest": {
    "currentPage": 1,
    "dateRange": "2026-03-01,2026-03-05",
    "pageSize": 20,
    "platform": "",
    "sAppId": [],
    "sCountryCode": ""
  },
