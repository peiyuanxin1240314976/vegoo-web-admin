{
  "_comment": "利润分析 - 应用利润详情表 + 合计行。趋势改为按筛选日期范围返回利润序列。对应 types.ts: ProfitAppRow[], ProfitAppTotal。",
  "fieldDescription": {
    "request": {
      "dateRange": { "type": "string", "required": true, "description": "日期范围。" },
      "currentPage": { "type": "integer", "required": false, "description": "当前页。" },
      "pageSize": { "type": "integer", "required": false, "description": "每页条数。" },
      "platform": {
        "type": "string",
        "required": false,
        "description": "终端平台 all/android/ios。"
      },
      "sAppId": { "type": "string", "required": false, "description": "应用 ID，全部 all。" },
      "sCountryCode": { "type": "string", "required": false, "description": "国家代码，全部 all。" }
    },
    "response": {
      "rows": {
        "type": "ProfitAppRow[]",
        "required": true,
        "description": "应用维度利润表行。"
      },
      "total": {
        "type": "ProfitAppTotal",
        "required": true,
        "description": "合计行。"
      }
    },
    "ProfitAppRow": {
      "app": { "type": "string", "required": true, "description": "应用名称或 s_app_id 展示名。" },
      "adRev": {
        "type": "string",
        "required": true,
        "description": "广告收入(预) 展示值，如 $45,200。"
      },
      "paidRev": { "type": "string", "required": true, "description": "付费收入展示值。" },
      "total": { "type": "string", "required": true, "description": "总收入展示值。" },
      "adSpend": { "type": "string", "required": true, "description": "广告支出展示值。" },
      "profit": { "type": "string", "required": true, "description": "预估利润，如 +$18,800。" },
      "profitColor": { "type": "string", "required": true, "description": "利润颜色 HEX。" },
      "rate": { "type": "string", "required": true, "description": "利润率，如 32.8% 或 N/A。" },
      "rateColor": { "type": "string", "required": true, "description": "利润率颜色 HEX。" },
      "profitTrend": {
        "type": "ProfitTrendPoint[]",
        "required": true,
        "description": "按筛选日期范围返回的利润趋势点，前端据此绘制趋势图。"
      }
    },
    "ProfitTrendPoint": {
      "date": { "type": "string", "required": true, "description": "日期（YYYY-MM-DD）。" },
      "profit": {
        "type": "number",
        "required": true,
        "description": "当日利润数值（USD，可正可负）。"
      }
    },
    "ProfitAppTotal": {
      "adRev": { "type": "string", "required": true, "description": "广告收入合计。" },
      "paidRev": { "type": "string", "required": true, "description": "付费收入合计。" },
      "total": { "type": "string", "required": true, "description": "总收入合计。" },
      "adSpend": { "type": "string", "required": true, "description": "广告支出合计。" },
      "profit": { "type": "string", "required": true, "description": "预估利润合计。" },
      "rate": { "type": "string", "required": true, "description": "利润率合计。" }
    }
  },
  "sampleRequest": {
    "currentPage": 1,
    "dateRange": "2026-03-01,2026-03-05",
    "pageSize": 20,
    "platform": "all",
    "sAppId": "all",
    "sCountryCode": "all"
  },
  "sampleResponse": {
    "rows": [
