{
  "_comment": "利润分析 - 顶部 5 个 KPI 卡片。对应 types.ts: ProfitKpiCard[]。",
  "fieldDescription": {
    "request": {
      "dateRange": {
        "type": "string",
        "required": true,
        "description": "日期范围，如 2026-03-01,2026-03-05。"
      },
      "currentPage": { "type": "integer", "required": false, "description": "分页。" },
      "pageSize": { "type": "integer", "required": false, "description": "分页。" },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["all", "android", "ios"],
        "description": "终端平台。"
      },
      "sAppId": { "type": "string", "required": false, "description": "应用 ID，全部 all。" },
      "sCountryCode": { "type": "string", "required": false, "description": "国家代码，全部 all。" }
    },
    "response": {
      "kpis": {
        "type": "ProfitKpiCard[]",
        "required": true,
        "description": "5 个 KPI 卡片。"
      }
    },
    "ProfitKpiCard": {
      "label": {
        "type": "string",
        "required": true,
        "description": "卡片标题，如 预估利润、总收入。"
      },
      "badge": { "type": "string", "required": false, "description": "角标文案，如 ⚠ 预估值。" },
      "badgeColor": { "type": "string", "required": false, "description": "角标颜色 HEX。" },
      "value": {
        "type": "string",
        "required": true,
        "description": "主数值展示，如 +$36,440、40.8%。"
      },
      "valueColor": { "type": "string", "required": true, "description": "主值颜色 HEX。" },
      "sub": { "type": "string", "required": true, "description": "副文案说明。" },
      "border": { "type": "string", "required": true, "description": "卡片边框渐变 CSS。" },
      "bg": { "type": "string", "required": true, "description": "卡片背景色 CSS。" }
    }
  },
  "sampleRequest": {
    "currentPage": 0,
    "dateRange": "2026-03-01,2026-03-05",
    "pageSize": 0,
    "platform": "all",
    "sAppId": "all",
    "sCountryCode": "all"
  },
