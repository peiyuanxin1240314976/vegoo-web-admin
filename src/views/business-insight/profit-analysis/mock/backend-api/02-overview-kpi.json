  "api": {
    "url": "POST /api/business-insight/profit-analysis/overview/kpi",
    "method": "POST",
    "priority": "P0",
    "requestBody": "扁平 ProfitAnalysisQueryParams（dateRange 必填，余可选）",
    "responseBody": "kpis (ProfitKpiCard[])"
  },
  "apiSuggestion": {
    "notes": ["value 可为后端算好后格式化的字符串，或传数值由前端格式化。"]
