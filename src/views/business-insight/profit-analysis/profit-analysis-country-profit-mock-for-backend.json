{
  "_comment": "利润分析（国家）-国家利润分布：用于右上地图与 Top10 表格。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用。all 表示全部。" },
      "t_date_start": {
        "type": "string",
        "required": true,
        "description": "开始日期（YYYY-MM-DD）。"
      },
      "t_date_end": {
        "type": "string",
        "required": true,
        "description": "结束日期（YYYY-MM-DD）。"
      }
    },
    "response": {
      "map_points": {
        "type": "CountryProfitPoint[]",
        "required": true,
        "description": "地图标注点。"
      },
      "top10": { "type": "CountryTopRow[]", "required": true, "description": "国家利润 Top10。" }
    },
    "CountryProfitPoint": {
      "s_country_name_en": {
        "type": "string",
        "required": true,
        "description": "GeoJSON 国家英文名（需与 world.json 的 name 对齐）。"
      },
      "s_country_name_cn": { "type": "string", "required": true, "description": "国家中文名。" },
      "s_country_code": { "type": "string", "required": true, "description": "国家代码（ISO2）。" },
      "d_profit": { "type": "decimal", "required": true, "description": "利润金额（可为负）。" },
      "s_profit_text": {
        "type": "string",
        "required": true,
        "description": "用于标注显示的文本（如 +$18,200）。"
      },
      "d_lng": { "type": "decimal", "required": true, "description": "经度。" },
      "d_lat": { "type": "decimal", "required": true, "description": "纬度。" }
    },
    "CountryTopRow": {
      "s_country_code": { "type": "string", "required": true, "description": "国家代码（ISO2）。" },
      "s_country_name_cn": { "type": "string", "required": true, "description": "国家中文名。" },
      "d_ad_revenue": { "type": "decimal", "required": true, "description": "广告收入。" },
      "d_iap_revenue": { "type": "decimal", "required": true, "description": "付费收入。" },
      "d_ad_spend": { "type": "decimal", "required": true, "description": "广告支出。" },
      "d_profit": { "type": "decimal", "required": true, "description": "利润。" },
      "d_profit_rate": { "type": "decimal", "required": true, "description": "利润率（百分比）。" }
    }
  },
  "sampleRequest": { "s_app_id": "all", "t_date_start": "2026-03-01", "t_date_end": "2026-03-05" },
  "sampleResponse": {
    "map_points": [
      {
        "s_country_name_en": "United States of America",
        "s_country_name_cn": "美国",
        "s_country_code": "US",
        "d_profit": 18200,
        "s_profit_text": "+$18,200",
        "d_lng": -98.5,
        "d_lat": 39.8
      }
    ],
    "top10": [
      {
        "s_country_code": "US",
        "s_country_name_cn": "美国",
        "d_ad_revenue": 52000,
        "d_iap_revenue": 14200,
        "d_ad_spend": 38500,
        "d_profit": 27700,
        "d_profit_rate": 53.3
      }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/profit-analysis/country-profit",
    "method": "POST",
    "priority": "P1",
    "requestBody": "s_app_id, t_date_start, t_date_end",
    "responseBody": "map_points, top10"
  }
}
