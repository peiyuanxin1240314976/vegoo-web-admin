{
  "_comment": "利润分析（国家）-利润构成分析：用于右下桑基图。",
  "fieldDescription": {
    "request": {
      "s_app_id": { "type": "string", "required": false, "description": "应用。all 表示全部。" },
      "s_country_code": {
        "type": "string",
        "required": false,
        "description": "国家。all 表示全部。"
      },
      "t_date_start": {
        "type": "string",
        "required": true,
        "description": "开始日期（YYYY-MM-DD）。"
      },
      "t_date_end": {
        "type": "string",
        "required": true,
        "description": "结束日期（YYYY-MM-DD）。"
      }
    },
    "response": {
      "nodes": { "type": "SankeyNode[]", "required": true, "description": "节点。" },
      "links": { "type": "SankeyLink[]", "required": true, "description": "连线。" }
    },
    "SankeyNode": {
      "name": { "type": "string", "required": true, "description": "节点名称（需全局唯一）。" },
      "s_value_display": {
        "type": "string",
        "required": false,
        "description": "节点显示的金额文本（可选）。"
      },
      "itemStyle": { "type": "object", "required": false, "description": "节点样式（如 color）。" }
    },
    "SankeyLink": {
      "source": { "type": "string", "required": true, "description": "来源节点 name。" },
      "target": { "type": "string", "required": true, "description": "目标节点 name。" },
      "value": { "type": "decimal", "required": true, "description": "流量值（金额）。" }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "s_country_code": "all",
    "t_date_start": "2026-03-01",
    "t_date_end": "2026-03-05"
  },
  "sampleResponse": {
    "nodes": [
      {
        "name": "广告收入(IAA)",
        "s_value_display": "$98,240",
        "itemStyle": { "color": "#22c55e" }
      },
      {
        "name": "付费收入(IAP)",
        "s_value_display": "$27,440",
        "itemStyle": { "color": "#38bdf8" }
      },
      { "name": "总收入", "s_value_display": "$125,680", "itemStyle": { "color": "#10b981" } },
      { "name": "广告支出", "s_value_display": "$89,240", "itemStyle": { "color": "#f59e0b" } },
      { "name": "预估利润", "s_value_display": "$36,440", "itemStyle": { "color": "#a78bfa" } }
    ],
    "links": [
      { "source": "广告收入(IAA)", "target": "总收入", "value": 98240 },
      { "source": "付费收入(IAP)", "target": "总收入", "value": 27440 },
      { "source": "总收入", "target": "广告支出", "value": 89240 },
      { "source": "总收入", "target": "预估利润", "value": 36440 }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/profit-analysis/sankey",
    "method": "POST",
    "priority": "P2",
    "requestBody": "s_app_id, s_country_code, t_date_start, t_date_end",
    "responseBody": "nodes, links"
  }
}
