{
  "_comment": "代投分析 - 国家消耗分布 Top 8。对应 types.ts: CountryDistributionItem[]。",
  "fieldDescription": {
    "request": {
      "t_date": { "type": "string", "required": true, "description": "查询日期 YYYY-MM-DD。" },
      "s_app_id": {
        "type": "string",
        "required": false,
        "default": "all",
        "description": "应用筛选（all=全部）。"
      },
      "agency_id": {
        "type": "string",
        "required": false,
        "default": "all",
        "description": "代投方筛选（all=全部）。"
      },
      "source": {
        "type": "string",
        "required": false,
        "default": "all",
        "description": "广告平台筛选（all=全部；值来自 meta/filter-options）。"
      }
    },
    "response": {
      "countryTop8": {
        "type": "CountryDistributionItem[]",
        "required": true,
        "description": "国家维度消耗及占比。"
      }
    }
  },
  "sampleRequest": {
    "t_date": "2026-03-07",
    "s_app_id": "all",
    "agency_id": "all",
    "source": "all"
  },
  "sampleResponse": {
    "countryTop8": [
      { "s_country_code": "US", "spend": 98420, "sharePct": 34.6 },
      { "s_country_code": "UK", "spend": 68180, "sharePct": 24.0 }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/business-insight/agency-analysis/chart/country-top8",
    "method": "POST",
    "priority": "P1",
    "requestBody": "t_date, s_app_id?, agency_id?, source?",
    "responseBody": "countryTop8"
  }
}
