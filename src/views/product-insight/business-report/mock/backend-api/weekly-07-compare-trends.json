{
  "_comment": "周报-对比模式-趋势图数据。",
  "api": {
    "url": "POST /api/v1/datacenter/analysis/report/weekly/compare-trends",
    "method": "POST",
    "priority": "P0"
  },
  "interaction": {
    "triggers": [
      { "moment": "周报对比卡片后并行", "detail": "加载近8周趋势" },
      {
        "moment": "对比模式右上角切换日期/开关",
        "detail": "独立于顶部筛选栏，参数变化后重拉趋势图"
      }
    ]
  },
  "sampleRequest": {
    "startDate": "2026-04-06",
    "endDate": "2026-04-12",
    "appId": "",
    "appIds": [],
    "platformList": [],
    "sourceList": [],
    "countryCodeList": [],
    "account": "",
    "compareAppIds": ["overall", "health", "ai"],
    "compareEnabled": true,
    "compareStartDate": "2026-03-30",
    "compareEndDate": "2026-04-05"
  },
  "sampleResponse": {
