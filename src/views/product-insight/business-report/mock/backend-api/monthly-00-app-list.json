{
  "_comment": "月报-侧栏应用列表。与 monthly overview 等详情解耦；startDate/endDate 为自然月首尾日。app-list 设计说明见 README「侧栏 app-list 接口设计说明（给后端）」。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "月起始日（含），YYYY-MM-DD，一般为当月 1 日。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "月结束日（含），YYYY-MM-DD，与 natural 月末日一致。"
      },
      "appId": {
        "type": "string",
        "required": true,
        "description": "须为空串 \"\"；顶栏应用见 filterAppIds。与详情接口统一 POST 形态，非旧版兼容。"
      },
      "filterAppIds": {
        "type": "string[]",
        "required": true,
        "description": "顶栏应用多选；[] 不限。"
      },
      "platformList": {
        "type": "string[]",
        "required": true,
        "description": "顶栏终端平台多选；[] 不限。"
      },
      "sourceList": {
        "type": "string[]",
        "required": true,
        "description": "顶栏广告平台多选；[] 不限。"
      },
      "countryCodeList": {
        "type": "string[]",
        "required": true,
        "description": "顶栏国家多选；[] 不限。"
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "广告账户，空串不限；与全局维度键名对齐，当前页恒传空串。非旧版兼容。"
      },
      "tab": {
        "type": "string",
        "required": true,
        "enum": ["summary", "adPlatform", "byCountry", "platformCountry", "campaigns"]
      }
    },
    "response": {
      "items": {
        "type": "AppListItem[]",
        "required": true,
        "description": "月报侧栏可突出 mau 等字段。"
      }
    }
  },
  "sampleRequest": {
    "startDate": "2026-04-01",
    "endDate": "2026-04-30",
    "appId": "",
    "filterAppIds": [],
    "platformList": [],
    "sourceList": [],
    "countryCodeList": [],
    "account": "",
    "tab": "summary"
  },
  "sampleResponse": {
