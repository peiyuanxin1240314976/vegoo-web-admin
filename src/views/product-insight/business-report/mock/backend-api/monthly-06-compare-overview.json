{
  "_comment": "月报-对比模式-卡片数据。",
  "api": {
    "url": "POST /api/v1/datacenter/analysis/report/monthly/compare-overview",
    "method": "POST",
    "priority": "P0"
  },
  "interaction": {
    "triggers": [
      { "moment": "进入月报对比模式", "detail": "应用变化时刷新卡片" },
      {
        "moment": "对比模式右上角切换日期/开关",
        "detail": "独立于顶部筛选栏，变更 compareEnabled 与对比日期后刷新卡片"
      }
    ]
  },
  "sampleRequest": {
    "startDate": "2026-04-01",
    "endDate": "2026-04-30",
    "appId": "",
    "platform": "",
    "source": "",
    "countryCode": "",
    "account": "",
    "appIds": ["overall", "health", "ai"],
    "compareEnabled": true,
    "compareStartDate": "2026-03-01",
    "compareEndDate": "2026-03-31"
  },
  "sampleResponse": {
    "apps": [
      {
        "id": "overall",
        "name": "整体",
        "color": "#00D4A1",
        "revenue": "$4,521,000",
        "revenueChange": 9.7,
        "metrics": [
          { "label": "MAU", "value": "8,234万", "change": "+4.4%", "changeType": "positive" }
        ]
      },
      {
        "id": "health",
        "name": "健康",
        "color": "#FF6B9D",
        "revenue": "$1,234,000",
        "revenueChange": 12.3,
        "metrics": [
          { "label": "MAU", "value": "2,456万", "change": "+8.1%", "changeType": "positive" }
        ]
      },
      {
        "id": "ai",
        "name": "AI应用",
        "color": "#8B5CF6",
        "revenue": "$876,000",
        "revenueChange": 5.6,
        "metrics": [
          { "label": "MAU", "value": "1,654万", "change": "+3.2%", "changeType": "positive" }
        ]
      }
    ]
  },
  "apiSuggestion": {
    "notes": [
      "对比模式右上角日期与开关为独立控制，勿复用顶部筛选栏日期状态。",
      "compareEnabled=false 时，卡片涨跌字段建议返回 0 或占位文案（与前端开关关闭态一致）。"
    ]
  }
}
