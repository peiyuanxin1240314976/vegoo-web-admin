{
  "_comment": "周报-侧栏应用列表。与 weekly overview 等详情解耦；契约字段同 daily-00-app-list，仅路径 period=weekly。app-list 设计说明见 README「侧栏 app-list 接口设计说明（给后端）」。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "周起始日（含），YYYY-MM-DD，一般为周一。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "周结束日（含），YYYY-MM-DD，一般为周日。"
      },
      "appId": {
        "type": "string",
        "required": true,
        "description": "须为空串 \"\"。顶栏应用范围见 appIds（与 daily-00-app-list 一致）。与详情接口统一 POST 形态，非旧版兼容。"
      },
      "appIds": {
        "type": "string[]",
        "required": true,
        "description": "顶栏应用多选；[] 不限。"
      },
      "platformList": {
        "type": "string[]",
        "required": true,
        "description": "顶栏终端平台多选；[] 不限。"
      },
      "sourceList": {
        "type": "string[]",
        "required": true,
        "description": "顶栏广告平台多选；[] 不限。"
      },
      "countryCodeList": {
        "type": "string[]",
        "required": true,
        "description": "顶栏国家多选；[] 不限。"
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "广告账户，空串不限；与全局维度键名对齐，当前页恒传空串。非旧版兼容。"
      },
      "tab": {
        "type": "string",
        "required": true,
        "enum": ["summary", "adPlatform", "byCountry", "platformCountry", "campaigns"]
      }
    },
    "response": {
      "items": { "type": "AppListItem[]", "required": true, "description": "同日报侧栏结构。" }
    }
  },
  "sampleRequest": {
    "startDate": "2026-04-06",
    "endDate": "2026-04-12",
    "appId": "",
    "appIds": [],
    "platformList": [],
    "sourceList": [],
    "countryCodeList": [],
    "account": "",
    "tab": "summary"
  },
  "sampleResponse": {
