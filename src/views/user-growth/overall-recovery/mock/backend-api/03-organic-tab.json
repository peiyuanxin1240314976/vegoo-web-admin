{
  "_comment": "整体回收 - Tab2 自然量分析数据。对应 types.ts: OrganicTabData。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "统计起始日 YYYY-MM-DD（含）。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "统计结束日 YYYY-MM-DD（含）。"
      },
      "appId": { "type": "string", "required": true, "description": "应用；全部 `''`。" },
      "source": { "type": "string", "required": true, "description": "广告平台；全部 `''`。" },
      "countryCode": {
        "type": "string",
        "required": true,
        "description": "国家小写码；全部 `''`。"
      }
    },
    "response": {
      "data": {
        "type": "OrganicTabData",
        "required": true,
        "description": "kpis / trendData / trafficSources / radarData / kfactorTrend / kfactorChannels / countryTop8。"
      }
    },
    "OrganicTabData": {
      "kpis": {
        "type": "OrganicKpiCard[]",
        "description": "顶部 KPI（id/title/primaryValue/trendText?/trendUp?）。"
      },
      "trendData": {
        "type": "OrganicVsPaidTrendItem[]",
        "description": "自然量 vs 付费量趋势（date/organic/paid/organicRatio）。"
      },
      "trafficSources": {
        "type": "TrafficSourceItem[]",
        "description": "流量来源饼图（name/value/color）。"
      },
      "radarData": {
        "type": "{ indicators; organicValues; paidValues }",
        "description": "雷达图（指标/自然量值/付费值）。"
      },
      "kfactorTrend": { "type": "{ dates; values }", "description": "K-factor 趋势折线。" },
      "kfactorChannels": {
        "type": "KfactorChannelRow[]",
        "description": "K-factor 渠道表（source/paidInstall/organicDriven/total/kfactor/roiBoost/trend）。注意字段名为 source 而非 channel。"
      },
      "countryTop8": {
        "type": "CountryOrganicItem[]",
        "description": "国家自然量分布 Top8（countryCode/countryName/organicInstall/paidInstall/kfactor/roiBoost/organicRatio）。"
      }
    }
  },
