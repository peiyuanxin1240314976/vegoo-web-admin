{
  "_comment": "整体回收 - Tab1 整体回收数据。对应 types.ts: OverallTabData。",
  "fieldDescription": {
    "request": {
      "date_start": { "type": "string", "required": true, "description": "开始日期 YYYY-MM-DD。" },
      "date_end": { "type": "string", "required": true, "description": "结束日期 YYYY-MM-DD。" },
      "s_app_id": { "type": "string", "required": true, "description": "应用 ID；'' 全部。" },
      "source": { "type": "string", "required": true, "description": "广告平台；'' 全部。" },
      "s_country_code": { "type": "string", "required": true, "description": "国家代码；'' 全部。" }
    },
    "response": {
      "data": {
        "type": "OverallTabData",
        "required": true,
        "description": "kpis / recoveryCurve / dailyVolume / roiCompare / detailRows。"
      }
    },
    "OverallTabData": {
      "kpis": {
        "type": "OverallKpiCard[]",
        "description": "顶部 KPI 卡片（id/title/primaryValue/subLabel?/subValue?/trendText?/trendUp?）。"
      },
      "recoveryCurve": {
        "type": "RecoveryCurveData",
        "description": "回收曲线（days 数组 + series 折线）。"
      },
      "dailyVolume": {
        "type": "DailyVolumeItem[]",
        "description": "日均量构成（date/paid/organic）。"
      },
      "roiCompare": {
        "type": "RoiCompareRow[]",
        "description": "ROI 对比表（label/day1/day14/day30/day60/day90/isHighlight?）。"
      },
      "detailRows": {
        "type": "RecoveryDetailRow[]",
        "description": "明细数据表（date/adSpend/cpi/paidUsers/totalUsers/organicUsers/roiDayN/rush/threeStar/sevenStar/retDayN）；可选 detailApp/detailChannel 与页内子筛选 value 对齐，未返回时该行不受子筛选约束。"
      }
    }
  },
