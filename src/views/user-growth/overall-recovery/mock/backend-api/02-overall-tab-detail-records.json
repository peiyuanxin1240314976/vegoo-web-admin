{
  "_comment": "整体回收 Tab1 - 明细数据表（含卡片内子筛选）。对应 types.ts: Pick<OverallTabData,'detailRows'>。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "统计起始日 YYYY-MM-DD（含）；与顶栏统计周期一致。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "统计结束日 YYYY-MM-DD（含）。"
      },
      "appId": { "type": "string", "required": true, "description": "顶栏应用；全部 `''`。" },
      "source": { "type": "string", "required": true, "description": "顶栏广告平台；全部 `''`。" },
      "countryCode": { "type": "string", "required": true, "description": "顶栏国家；全部 `''`。" },
      "detailApp": {
        "type": "string",
        "required": true,
        "description": "明细卡片内「应用」子筛。UI 选「全部」映射 `''`；否则与行字段 detailApp、下拉的 value 一致（如 weather5）。服务端按此过滤或聚合。"
      },
      "detailChannel": {
        "type": "string",
        "required": true,
        "description": "明细卡片内「广告平台」子筛。UI 选「全部」映射 `''`；否则与行字段 detailChannel、下拉 value 一致（如 google、facebook）。"
      }
    },
    "response": {
      "data": {
        "type": "RecoveryDetailRow[]",
        "required": true,
        "description": "键名 detailRows；行内 detailApp/detailChannel 可选，与明细子筛 value 对齐。"
      },
      "RecoveryDetailRow": {
        "detailApp": {
          "type": "string",
          "required": false,
          "description": "拆应用维度时与请求 detailApp 对齐。"
        },
        "detailChannel": {
          "type": "string",
          "required": false,
          "description": "拆广告平台维度时与请求 detailChannel、下拉的 value（如 google、facebook）对齐。"
        },
        "date": { "type": "string", "required": true },
        "adSpend": { "type": "number", "required": true },
        "cpi": { "type": "number", "required": true },
        "paidUsers": { "type": "number", "required": true },
        "totalUsers": { "type": "number", "required": true },
        "organicUsers": { "type": "number", "required": true },
        "roiDay0": { "type": "number", "required": true },
        "roiDay1": { "type": "number", "required": true },
        "roiDay2": { "type": "number", "required": true },
        "roiDay3": { "type": "number", "required": true },
        "roiDay5": { "type": "number", "required": true },
        "roiDay7": { "type": "number", "required": true },
        "rush": { "type": "number", "required": true },
        "threeStar": { "type": "number", "required": true },
        "sevenStar": { "type": "number", "required": true },
        "retDay1": { "type": "number", "required": true },
        "retDay3": { "type": "number", "required": true },
        "retDay7": { "type": "number", "required": true }
      }
    }
  },
