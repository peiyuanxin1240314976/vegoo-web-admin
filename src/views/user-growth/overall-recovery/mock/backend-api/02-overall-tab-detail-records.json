  "api": {
    "url": "POST /api/user-growth/overall-recovery/overall-tab/detail-records",
    "method": "POST",
    "priority": "P0",
    "requestBody": "公共筛选 + detailApp + detailChannel",
    "responseBody": "{ detailRows: RecoveryDetailRow[] }"
  },
  "apiSuggestion": {
    "notes": [
      "明细「检索」应触发本接口重拉：子筛从 UI 的 all 映射为 `''`，勿传字面量 all。",
      "若后端在 detailApp/detailChannel 均为 `''` 时返回汇总行，可不返回行级 detailApp/detailChannel；用户再选子筛后应返回匹配行或聚合行。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "Tab1 首屏 / 顶栏检索",
        "detail": "与其它 Tab1 接口并行，`detailApp`/`detailChannel` 均为 `''`（全部）。",
        "prerequisite": "同 kpis。"
      },
      {
        "moment": "明细卡片内点击「检索」",
        "detail": "`tab-overall.vue` 仅请求本接口，入参带上当前子筛（全部则 `''`）；**不应**只做前端过滤若后端已支持服务端筛选。",
        "prerequisite": "已有 Tab1 其它数据或至少已应用顶栏筛选。"
      }
    ],
    "defaultSelection": "子筛默认「全部」→ `detailApp: ''`, `detailChannel: ''`。",
    "dedupe": "明细检索可单独 debounce；与首屏批量请求分开取消键。"
  }
