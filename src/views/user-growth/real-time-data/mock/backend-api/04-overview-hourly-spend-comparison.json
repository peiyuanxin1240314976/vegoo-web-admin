{
  "_comment": "实时数据 - 底部多应用小时花费对比 + 全局 ROI 折线。对应 types.ts: RealtimeHourlySpendComparison。",
  "fieldDescription": {
    "request": {
      "appId": {
        "type": "string",
        "required": true,
        "description": "与 cockpit appOptions[].value 同源；空字符串时返回默认对比集（如头部多应用）；传单个 ID 可只返回该应用柱序列 + ROI。勿传字面量 all。"
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "按广告平台过滤；与 sourceOptions[].value 同源；空字符串表示不限。"
      }
    },
    "response": {
      "hourLabels": {
        "type": "string[]",
        "required": true,
        "description": "横轴时间标签，与每条 costSeries 长度一致。"
      },
      "series": {
        "type": "RealtimeHourlyBarSeriesItem[]",
        "required": true,
        "description": "各应用柱状序列；每项一条 stackable/group bar 数据。"
      },
      "roiPercentSeries": {
        "type": "number[]",
        "required": true,
        "description": "与 hourLabels 等长的 ROI 折线，百分比数值（0-100 展示口径）。"
      }
    },
    "RealtimeHourlyBarSeriesItem": {
      "s_app_id": {
        "type": "string",
        "required": true,
        "description": "应用 ID。"
      },
      "name": { "type": "string", "required": true, "description": "图例名称。" },
      "color": {
        "type": "string",
        "required": true,
        "description": "柱状主色（与前端图例一致）。"
      },
      "costSeries": {
        "type": "number[]",
        "required": true,
        "description": "各时段花费 USD，与 hourLabels 一一对应。"
      }
    }
  },
  "sampleRequest": {
    "appId": "",
    "source": ""
  },
  "sampleResponse": {
    "hourLabels": ["0:00", "2:00", "4:00", "6:00", "8:00", "10:00", "12:00", "14:00"],
    "series": [
      {
        "s_app_id": "weather5",
        "name": "Weather5",
        "color": "#00cfc0",
        "costSeries": [45, 80, 120, 280, 420, 680, 520, 720]
      },
      {
        "s_app_id": "phonetracker",
        "name": "PhoneTracker",
        "color": "#ffa040",
        "costSeries": [20, 40, 80, 150, 280, 420, 380, 460]
      },
      {
        "s_app_id": "bloodsugar2",
        "name": "BloodSugar2",
        "color": "#4d9eff",
        "costSeries": [60, 100, 180, 320, 480, 750, 600, 680]
      },
      {
        "s_app_id": "phonetracker2",
        "name": "PhoneTracker2",
        "color": "#a855f7",
        "costSeries": [10, 20, 40, 80, 120, 180, 160, 200]
      }
    ],
    "roiPercentSeries": [20, 28, 42, 60, 78, 94, 96, 100]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "底部「实时小时消耗对比」柱状 + ROI 折线图请求 hourLabels、series、roiPercentSeries。",
        "prerequisite": "无"
      },
      {
        "moment": "筛选或刷新",
        "detail": "与 01/02 同步刷新；图表横轴标签切换若仅格式化可前端本地处理，不重拉接口。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "appId 为空字符串时返回约定对比应用集合（如头部多应用）；响应 series[].s_app_id 仍为应用维度主键字段名。",
    "dedupe": "可并行 01/02；大数据量时保持独立接口避免拖慢首屏。"
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/real-time-data/overview-hourly-spend-comparison",
    "method": "POST",
    "priority": "P0",
    "requestBody": "appId, source",
    "responseBody": "RealtimeHourlySpendComparison"
  },
  "apiSuggestion": {
    "notes": [
      "当前前端仍使用 RealtimeBottomSeries 固定键名；接入本接口时请在 composable 中把 series[] 映射为图表 option。",
      "参考 mock/data.ts 中 mockRealtimeHourlySpendComparison 与 mockRealtimeBottomSeries 的对应关系。"
    ]
  }
}
