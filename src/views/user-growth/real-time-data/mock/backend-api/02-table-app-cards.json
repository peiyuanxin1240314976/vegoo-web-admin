{
  "_comment": "实时数据 - 应用卡片列表（不含详情）。对应 types.ts: RealtimeAppCardRow[]。sampleResponse.items 需覆盖列表形态：多应用、可选环比字段缺失、roiGood=false、actionTagType 四枚举；前 7 条与 mock/data.ts 卡片行一致，riskdemo 为 red 联调样例。",
  "fieldDescription": {
    "request": {
      "appId": {
        "type": "string",
        "required": true,
        "description": "应用 ID；与 cockpit appOptions[].value 同源；空字符串表示「全部应用」；勿传字面量 all。"
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "广告平台枚举字符串；与 sourceOptions[].value 同源；空字符串表示不限；勿用 JSON number。"
      }
    },
    "response": {
      "items": {
        "type": "RealtimeAppCardRow[]",
        "required": true,
        "description": "卡片行列表，顺序即展示顺序。"
      }
    },
    "RealtimeAppCardRow": {
      "id": {
        "type": "string",
        "required": true,
        "description": "应用标识（与 appId 筛选、详情 appId 及响应体 series[].s_app_id 同值语义；前端卡片 key）。"
      },
      "name": { "type": "string", "required": true, "description": "应用名称。" },
      "iconText": {
        "type": "string",
        "required": true,
        "description": "图标区展示字符（如 emoji）；纯前端展示，非接口国旗资源。"
      },
      "iconBg": {
        "type": "string",
        "required": true,
        "description": "图标背景色（CSS 颜色字符串）。"
      },
      "isLive": {
        "type": "boolean",
        "required": true,
        "description": "是否实时刷新状态（影响角标样式）。"
      },
      "hasWarning": {
        "type": "boolean",
        "required": true,
        "description": "是否存在预警。"
      },
      "warningBadge": {
        "type": "string",
        "required": false,
        "description": "预警文案，如超额、低活跃。"
      },
      "launchLabel": {
        "type": "string",
        "required": true,
        "description": "状态区文案，如「实时」「展开明细」。"
      },
      "spend": {
        "type": "number",
        "required": true,
        "description": "今日花费 USD；与 cost 同语义。"
      },
      "spendChange": {
        "type": "string",
        "required": false,
        "description": "花费环比展示，如 8.5%。"
      },
      "spendUp": {
        "type": "boolean",
        "required": false,
        "description": "花费环比是否上升。"
      },
      "installs": {
        "type": "number",
        "required": true,
        "description": "今日安装量 installs。"
      },
      "cpi": {
        "type": "number",
        "required": true,
        "description": "实时 CPI，USD。"
      },
      "cpiChange": {
        "type": "string",
        "required": false,
        "description": "CPI 环比展示。"
      },
      "cpiUp": {
        "type": "boolean",
        "required": false,
        "description": "CPI 环比是否上升。"
      },
      "activeSeries": {
        "type": "number",
        "required": true,
        "description": "活跃广告系列数量。"
      },
      "roi": {
        "type": "number",
        "required": true,
        "description": "当前 ROI 百分比数值（如 94）。"
      },
      "roiGood": {
        "type": "boolean",
        "required": true,
        "description": "是否高于业务阈值（用于样式）。"
      },
      "roiColor": {
        "type": "string",
        "required": true,
        "description": "ROI 数字展示色。"
      },
      "chartData": {
        "type": "number[]",
        "required": true,
        "description": "火花图序列；可为今日按固定间隔点的花费或得分，长度由产品约定。"
      },
      "chartColor": {
        "type": "string",
        "required": true,
        "description": "火花图主色。"
      },
      "actionTag": {
        "type": "string",
        "required": false,
        "description": "右下角标签文案。"
      },
      "actionTagType": {
        "type": "string",
        "required": false,
        "enum": ["cyan", "orange", "gray", "red"],
        "description": "标签配色类型。"
      }
    }
  },
