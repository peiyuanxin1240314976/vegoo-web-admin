  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "加载应用卡片栅格（火花图数据在 items[].chartData）；与 01 同筛选项。",
        "prerequisite": "无"
      },
      {
        "moment": "筛选或刷新",
        "detail": "用户变更应用/广告平台或触发整页刷新时重拉；切换卡片内展示维度若仅前端本地切换则不触发（本页火花图为接口字段，非多 Tab 另请求）。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "与 01-overview-kpi-summary 使用相同默认筛选。",
    "dedupe": "打开详情 03 不重复拉取列表；列表不含弹窗大字段。"
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/real-time-data/table/app-cards",
    "method": "POST",
    "priority": "P0",
    "requestBody": "appId, source",
    "responseBody": "items: RealtimeAppCardRow[]"
  },
  "apiSuggestion": {
    "notes": [
      "禁止在本接口返回弹窗级大字段（小时序列、分广告平台明细）；请走 03-app-detail。",
      "若后端统一使用 cost 命名字段，可在映射层写入 spend 以兼容当前 UI。",
      "`sampleResponse.items` 前 7 条与 `mock/data.ts` 导出的卡片行一致；最后一条 `riskdemo` 仅用于联调覆盖 `actionTagType: \"red\"`，生产可不返回。"
    ]
  }
