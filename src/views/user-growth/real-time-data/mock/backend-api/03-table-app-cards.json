{
  "_comment": "实时数据 - 应用卡片列表（不含详情）。对应 types.ts: RealtimeAppCardRow[]。",
  "fieldDescription": {
    "request": {
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用 ID；all 或不传表示全部。"
      },
      "n_source": {
        "type": "number",
        "required": false,
        "description": "广告平台枚举；筛选卡片所基于的投放维度。"
      },
      "t_date": {
        "type": "string",
        "required": false,
        "description": "业务日 YYYY-MM-DD。"
      }
    },
    "response": {
      "items": {
        "type": "RealtimeAppCardRow[]",
        "required": true,
        "description": "卡片行列表，顺序即展示顺序。"
      }
    },
    "RealtimeAppCardRow": {
      "id": {
        "type": "string",
        "required": true,
        "description": "与 s_app_id 对齐的应用标识（前端卡片 key）。"
      },
      "name": { "type": "string", "required": true, "description": "应用名称。" },
      "iconText": {
        "type": "string",
        "required": true,
        "description": "图标区展示字符（如 emoji）；纯前端展示，非接口国旗资源。"
      },
      "iconBg": {
        "type": "string",
        "required": true,
        "description": "图标背景色（CSS 颜色字符串）。"
      },
      "isLive": {
        "type": "boolean",
        "required": true,
        "description": "是否实时刷新状态（影响角标样式）。"
      },
      "hasWarning": {
        "type": "boolean",
        "required": true,
        "description": "是否存在预警。"
      },
      "warningBadge": {
        "type": "string",
        "required": false,
        "description": "预警文案，如超额、低活跃。"
      },
      "launchLabel": {
        "type": "string",
        "required": true,
        "description": "状态区文案，如「实时」「展开明细」。"
      },
      "spend": {
        "type": "number",
        "required": true,
        "description": "今日花费 USD；与 cost 同语义。"
      },
      "spendChange": {
        "type": "string",
        "required": false,
        "description": "花费环比展示，如 8.5%。"
      },
      "spendUp": {
        "type": "boolean",
        "required": false,
        "description": "花费环比是否上升。"
      },
      "installs": {
        "type": "number",
        "required": true,
        "description": "今日安装量 installs。"
      },
      "cpi": {
        "type": "number",
        "required": true,
        "description": "实时 CPI，USD。"
      },
      "cpiChange": {
        "type": "string",
        "required": false,
        "description": "CPI 环比展示。"
      },
      "cpiUp": {
        "type": "boolean",
        "required": false,
        "description": "CPI 环比是否上升。"
      },
      "activeSeries": {
        "type": "number",
        "required": true,
        "description": "活跃广告系列数量。"
      },
      "roi": {
        "type": "number",
        "required": true,
        "description": "当前 ROI 百分比数值（如 94）。"
      },
      "roiGood": {
        "type": "boolean",
        "required": true,
        "description": "是否高于业务阈值（用于样式）。"
      },
      "roiColor": {
        "type": "string",
        "required": true,
        "description": "ROI 数字展示色。"
      },
      "chartData": {
        "type": "number[]",
        "required": true,
        "description": "火花图序列；可为今日按固定间隔点的花费或得分，长度由产品约定。"
      },
      "chartColor": {
        "type": "string",
        "required": true,
        "description": "火花图主色。"
      },
      "actionTag": {
        "type": "string",
        "required": false,
        "description": "右下角标签文案。"
      },
      "actionTagType": {
        "type": "string",
        "required": false,
        "enum": ["cyan", "orange", "gray", "red"],
        "description": "标签配色类型。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "t_date": "2026-03-21"
  },
  "sampleResponse": {
    "items": [
      {
        "id": "weather5",
        "name": "Weather5",
        "iconText": "⛅",
        "iconBg": "#0d3d5a",
        "isLive": false,
        "hasWarning": false,
        "launchLabel": "展开明细",
        "spend": 8372,
        "spendChange": "8.5%",
        "spendUp": true,
        "installs": 3518,
        "cpi": 2.38,
        "cpiChange": "3.2%",
        "cpiUp": false,
        "activeSeries": 185,
        "roi": 94,
        "roiGood": true,
        "roiColor": "#00cfc0",
        "chartData": [120, 160, 200, 280, 360, 520, 640, 720, 780, 760],
        "chartColor": "#00cfc0",
        "actionTag": "选择",
        "actionTagType": "cyan"
      },
      {
        "id": "phonetracker",
        "name": "PhoneTracker",
        "iconText": "📱",
        "iconBg": "#3d2800",
        "isLive": true,
        "hasWarning": true,
        "warningBadge": "超额",
        "launchLabel": "实时",
        "spend": 2886,
        "installs": 1013,
        "cpi": 2.85,
        "cpiChange": "3.2%",
        "cpiUp": true,
        "activeSeries": 98,
        "roi": 108,
        "roiGood": true,
        "roiColor": "#00cfc0",
        "chartData": [40, 70, 110, 170, 240, 360, 490, 540, 590, 630],
        "chartColor": "#ffa040",
        "actionTag": "鼠标",
        "actionTagType": "orange"
      }
    ]
  },
  "api": {
    "url": "POST /api/user-growth/real-time-data/table/app-cards",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, n_source?, t_date?",
    "responseBody": "items: RealtimeAppCardRow[]"
  },
  "apiSuggestion": {
    "notes": [
      "禁止在本接口返回弹窗级大字段（小时序列、分广告平台明细）；请走 04-app-detail。",
      "若后端统一使用 cost 命名字段，可在映射层写入 spend 以兼容当前 UI。"
    ]
  }
}
