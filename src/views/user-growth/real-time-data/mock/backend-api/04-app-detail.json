{
  "_comment": "实时数据 - 应用详情弹窗。对应 types.ts: AppDetailData。",
  "fieldDescription": {
    "request": {
      "s_app_id": {
        "type": "string",
        "required": true,
        "description": "应用 ID。"
      },
      "startDate": {
        "type": "string",
        "required": false,
        "description": "查询起始日（含），YYYY-MM-DD。"
      },
      "endDate": {
        "type": "string",
        "required": false,
        "description": "查询结束日（含），YYYY-MM-DD。"
      },
      "n_source": {
        "type": "number",
        "required": false,
        "description": "若弹窗内需按单一广告平台过滤，可选；默认全平台汇总。"
      }
    },
    "response": {
      "detail": {
        "type": "AppDetailData",
        "required": true,
        "description": "详情主体。"
      }
    },
    "AppDetailData": {
      "id": { "type": "string", "required": true, "description": "应用 ID。" },
      "name": { "type": "string", "required": true, "description": "应用名称。" },
      "iconText": { "type": "string", "required": true, "description": "图标展示字符。" },
      "iconBg": { "type": "string", "required": true, "description": "图标背景色。" },
      "spend": {
        "type": "number",
        "required": true,
        "description": "今日花费 USD（cost 语义）。"
      },
      "installs": { "type": "number", "required": true, "description": "今日安装量。" },
      "cpi": { "type": "number", "required": true, "description": "实时 CPI。" },
      "roi1d": {
        "type": "number",
        "required": true,
        "description": "首日 ROI 百分比数值（如 94 表示 94%）。"
      },
      "roi3d": {
        "type": "number",
        "required": true,
        "description": "3 日 ROI 百分比数值。"
      },
      "estimatedProfit": {
        "type": "number",
        "required": true,
        "description": "预估利润 USD，可为负。"
      },
      "activeSeries": { "type": "number", "required": true, "description": "活跃系列数。" },
      "balance": { "type": "number", "required": true, "description": "账户余额 USD。" },
      "ctr": {
        "type": "number",
        "required": true,
        "description": "点击率，百分比数值（如 3.2 表示 3.2%）。"
      },
      "cvr": {
        "type": "number",
        "required": true,
        "description": "转化率，百分比数值。"
      },
      "budgetProgress": {
        "type": "number",
        "required": true,
        "description": "预算进度 0-100。"
      },
      "budgetDaysLeft": {
        "type": "string",
        "required": true,
        "description": "预算耗尽预估文案，如「~5天后」。"
      },
      "channels": {
        "type": "RealtimeAppDetailChannelRow[]",
        "required": true,
        "description": "按广告平台拆分的数据行（UI 文案用「广告平台」）。"
      },
      "hourlyData": {
        "type": "number[]",
        "required": true,
        "description": "与图表横轴等长的各时段花费（cost），USD。"
      },
      "hourlyRoi": {
        "type": "number[]",
        "required": true,
        "description": "与 hourlyData 等长的 ROI 百分比数值序列。"
      }
    },
    "RealtimeAppDetailChannelRow": {
      "name": {
        "type": "string",
        "required": true,
        "description": "广告平台展示名。"
      },
      "iconColor": {
        "type": "string",
        "required": true,
        "description": "列表圆点颜色。"
      },
      "spend": {
        "type": "number",
        "required": true,
        "description": "该平台花费 USD。"
      },
      "cpi": { "type": "number", "required": true, "description": "该平台 CPI。" },
      "roi": {
        "type": "number",
        "required": true,
        "description": "该平台 ROI 百分比数值。"
      },
      "n_source": {
        "type": "number",
        "required": false,
        "description": "可选，对应数据字典广告平台枚举，便于下钻。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "weather5",
    "startDate": "2026-03-21",
    "endDate": "2026-03-21"
  },
  "sampleResponse": {
    "detail": {
      "id": "weather5",
      "name": "Weather5",
      "iconText": "⛅",
      "iconBg": "#0d3d5a",
      "spend": 8372,
      "installs": 3518,
      "cpi": 2.38,
      "roi1d": 94,
      "roi3d": 108,
      "estimatedProfit": 1820,
      "activeSeries": 185,
      "balance": 6200,
      "ctr": 3.2,
      "cvr": 28.5,
      "budgetProgress": 68,
      "budgetDaysLeft": "~5天后",
      "channels": [
        {
          "name": "Google Ads",
          "iconColor": "#ea4335",
          "spend": 4800,
          "cpi": 2.25,
          "roi": 96,
          "n_source": 1
        },
        {
          "name": "Meta Ads",
          "iconColor": "#1877f2",
          "spend": 2500,
          "cpi": 2.48,
          "roi": 91,
          "n_source": 2
        },
        {
          "name": "Pangle",
          "iconColor": "#000000",
          "spend": 1072,
          "cpi": 2.61,
          "roi": 89,
          "n_source": 7
        }
      ],
      "hourlyData": [30, 60, 100, 220, 380, 620, 520, 650],
      "hourlyRoi": [18, 22, 38, 55, 72, 90, 92, 96]
    }
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户打开详情",
        "detail": "点击卡片「展开明细」等，`AppDetailModal` 打开时按当前卡片的 s_app_id 请求；不依赖 03 列表内嵌详情。",
        "prerequisite": "s_app_id 有效"
      }
    ],
    "defaultSelection": "继承列表当前筛选的 n_source（可选）与业务日 startDate/endDate；弹窗内若仅展示不触发新维度则不再请求。",
    "dedupe": "同一 s_app_id 短缓存可选；关闭弹窗可丢弃。"
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/real-time-data/app-detail",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id, startDate?, endDate?, n_source?",
    "responseBody": "detail: AppDetailData"
  },
  "apiSuggestion": {
    "notes": [
      "弹窗打开时请求；关闭可丢弃缓存或按 s_app_id 短缓存。",
      "channels 内 name 为展示用；统计口径以 n_source 为准。"
    ]
  }
}
