{
  "_comment": "实时数据 - 顶部 KPI 四卡。对应 types.ts: RealtimeKpiSummary。",
  "fieldDescription": {
    "request": {
      "s_app_id": {
        "type": "string",
        "required": false,
        "description": "应用 ID；不传或 all 表示全应用汇总。"
      },
      "n_source": {
        "type": "number",
        "required": false,
        "description": "广告平台枚举；不传表示不限平台。"
      },
      "t_date": {
        "type": "string",
        "required": false,
        "description": "业务日 YYYY-MM-DD；不传为当日。"
      }
    },
    "response": {
      "onlineApps": {
        "type": "number",
        "required": true,
        "description": "在线应用数（展示用整数）。"
      },
      "totalApps": {
        "type": "number",
        "required": true,
        "description": "应用总数。"
      },
      "todaySpend": {
        "type": "number",
        "required": true,
        "description": "全应用（或筛选范围内）今日花费，单位 USD；与数据字典 cost 语义一致。"
      },
      "spendChange": {
        "type": "string",
        "required": true,
        "description": "周环比展示文案，如 +8.3%（已含符号，前端可直接展示）。"
      },
      "roiAvg": {
        "type": "number",
        "required": true,
        "description": "实时 ROI 均值，百分比数值（如 97 表示 97%）。"
      },
      "roiTarget": {
        "type": "number",
        "required": true,
        "description": "达标线 ROI，同左，百分比数值。"
      },
      "warningApps": {
        "type": "number",
        "required": true,
        "description": "处于预警状态的应用数量（如超预算、低活跃等）。"
      }
    }
  },
  "sampleRequest": {
    "s_app_id": "all",
    "t_date": "2026-03-21"
  },
  "sampleResponse": {
    "onlineApps": 8,
    "totalApps": 12,
    "todaySpend": 34858,
    "spendChange": "+8.3%",
    "roiAvg": 97,
    "roiTarget": 85,
    "warningApps": 2
  },
  "api": {
    "url": "POST /api/user-growth/real-time-data/overview-kpi-summary",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_app_id?, n_source?, t_date?",
    "responseBody": "RealtimeKpiSummary"
  },
  "apiSuggestion": {
    "notes": [
      "与 03 使用相同筛选维度，便于并行请求后一次性渲染首屏。",
      "若后端字段名为 cost_today，请在 Api 层映射为前端 todaySpend 或统一改类型命名。"
    ]
  }
}
