      "kpiMetrics": {
        "spend": { "type": "number", "description": "消耗，单位美元。" },
        "impressions": { "type": "number", "description": "展示次数。" },
        "clicks": { "type": "number", "description": "点击次数。" },
        "installs": { "type": "number", "description": "安装量。" },
        "ctr": { "type": "number", "description": "点击率，百分比值，如 12.14。" },
        "cpi": { "type": "number", "description": "CPI，单位美元，两位小数。" },
        "roi": { "type": "number", "description": "ROI，百分比值，如 142 表示 142%。" }
      },
      "trendData": {
        "type": "AdTrendPoint[]",
        "description": "按日趋势数据，含 date/spend/installs/cpi/roi。"
      },
      "creatives": {
        "type": "AdCreativeItem[]",
        "description": "素材列表，含 id/type/name/impressions/clicks/ctr/installs/cpi/roi/status。"
      },
      "creativeSuggestion": { "type": "string", "description": "AI 素材优化建议文案。" }
    }
  },
