{
  "_comment": "广告成效 - 广告系列详情（抽屉）：顶部 KPI + ROI 汇总 + 三维度 tabs（广告组/日期/国家）。对应 types.ts: AdPerformanceCampaignDetail。",
  "interaction": {
    "triggers": [
      {
        "moment": "用户打开系列详情抽屉",
        "detail": "`AdPerformanceDetailDrawer` 打开且传入 `campaignId` 时请求；可带主列表当前 dateRange。",
        "prerequisite": "有效的 `campaignId`。"
      },
      {
        "moment": "抽屉内切换子 tab（若未拆子接口）",
        "detail": "若仍由本聚合接口返回多 tab 数据，仅需首屏一次；若后续拆分为子接口则按子契约触发。",
        "prerequisite": "抽屉仍打开。"
      }
    ],
    "defaultSelection": "dateRange 可与主列表筛选同步或后端默认。",
    "dedupe": "同一 `campaignId` 快速重复打开可缓存短 TTL（可选）。"
  },
  "fieldDescription": {
    "request": {
      "campaignId": {
        "type": "string",
        "required": true,
        "description": "广告系列 ID（对应表格 campaign 行 id）。"
      },
      "dateRange": {
        "type": "string",
        "required": false,
        "enum": ["today", "yesterday", "last7d", "month"],
        "description": "可选：与主页面筛选同步的日期范围；若不传，后端可用默认值。"
      }
    },
    "response": {
      "header": {
        "type": "AdPerformanceDetailHeader",
        "required": true,
        "description": "抽屉头部信息。"
      },
      "topKpi": {
        "type": "AdPerformanceDetailTopKpi",
        "required": true,
        "description": "抽屉顶部 KPI（总消耗/CPI/首日ROI/预算进度）。"
      },
      "roiSummary": {
        "type": "AdPerformanceDetailRoiSummary",
        "required": true,
        "description": "ROI 汇总与预估利润。"
      },
      "tabs": {
        "type": "{ adGroup: AdPerformanceDetailAdGroupTabData, date: AdPerformanceDetailDateTabData, country: AdPerformanceDetailCountryTabData }",
        "required": true,
        "description": "三维度数据集合。"
      }
    },
    "AdPerformanceDetailAdGroupTabData": {
      "marketSummaryText": { "type": "string", "required": true, "description": "顶部提示文案。" },
      "sortHintText": { "type": "string", "required": true, "description": "排序提示文案。" },
      "adGroups": {
        "type": "AdPerformanceDetailAdGroupRow[]",
        "required": true,
        "description": "广告组明细列表。"
      },
      "spendDistribution": {
        "type": "AdPerformanceDetailSpendDistributionItem[]",
        "required": true,
        "description": "广告组消耗占比（0-100）。"
      },
      "quickCards": {
        "type": "AdPerformanceDetailQuickMetricCard[]",
        "required": true,
        "description": "右侧快捷指标卡。"
      },
      "insightTitle": { "type": "string", "required": true, "description": "洞察标题。" },
      "insightText": { "type": "string", "required": true, "description": "洞察内容。" }
    },
    "AdPerformanceDetailDateTabData": {
      "range": {
        "type": "string",
        "required": true,
        "enum": ["last7d", "last14d", "month"],
        "description": "日期维度范围（抽屉内部 tab）。"
      },
      "spendRoiTrend": {
        "type": "AdPerformanceDetailTrendPoint[]",
        "required": true,
        "description": "消耗/首日ROI 双轴趋势。"
      },
      "cpiTrend": {
        "type": "AdPerformanceDetailTrendPoint[]",
        "required": true,
        "description": "CPI 趋势。"
      },
      "dailyRows": {
        "type": "AdPerformanceDetailDailyRow[]",
        "required": true,
        "description": "每日明细表格。"
      },
      "roiTarget": { "type": "number", "required": true, "description": "ROI 目标线（百分比）。" },
      "cpiTarget": { "type": "number", "required": true, "description": "CPI 目标线（数值）。" }
    },
    "AdPerformanceDetailCountryTabData": {
      "marketSummaryText": { "type": "string", "required": true, "description": "顶部提示文案。" },
      "sortHintText": { "type": "string", "required": true, "description": "排序提示文案。" },
      "spendRows": {
        "type": "AdPerformanceDetailCountrySpendRow[]",
        "required": true,
        "description": "各市场广告支出分布条。"
      },
      "marketRows": {
        "type": "AdPerformanceDetailMarketRow[]",
        "required": true,
        "description": "市场详情表格行（含 sparkline 趋势点可选）。"
      },
      "insightTitle": { "type": "string", "required": true, "description": "洞察标题。" },
      "insightText": { "type": "string", "required": true, "description": "洞察内容。" }
    }
  },
  "sampleRequest": { "campaignId": "c1", "dateRange": "today" },
