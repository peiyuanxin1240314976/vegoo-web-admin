  "api": {
    "url": "POST /api/v1/datacenter/analysis/ad-performance/campaign-detail",
    "method": "POST",
    "priority": "P0",
    "requestBody": "campaignId (必填), dateRange?",
    "responseBody": "AdPerformanceCampaignDetail（header/topKpi/roiSummary/tabs）"
  },
  "apiSuggestion": {
    "notes": [
      "tabs.date.dailyRows 的 date 使用 YYYY-MM-DD，趋势点可用短日期（如 2/22）或同样用 YYYY-MM-DD，但需前后端统一。",
      "roiTarget/cpiTarget 建议由后端按业务规则下发（不同应用/平台/国家可能不同）。",
      "country.marketRows.trendPoints 可选；为空时前端会按 trendDirection 生成占位趋势线。"
    ]
  }
}
