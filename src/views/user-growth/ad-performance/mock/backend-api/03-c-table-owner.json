  },
  "api": {
    "url": "POST /api/user-growth/ad-performance/table/owner",
    "method": "POST",
    "priority": "P0",
    "requestBody": "keyword?, current?, size?, dateRange, app?, adPlatform?, account?, country?",
    "responseBody": "rows, summary, pagination"
  }
}
