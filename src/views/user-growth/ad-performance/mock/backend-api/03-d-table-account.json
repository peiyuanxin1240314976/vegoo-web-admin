{
  "_comment": "广告成效 - 主表格（Account tab）。由原 03 的 tab=account 拆分而来。",
  "interaction": {
    "triggers": [
      {
        "moment": "用户切换到 Account tab",
        "detail": "首进该 tab、分页、关键字与筛选变化时请求。",
        "prerequisite": "dateRange 必填。"
      }
    ],
    "defaultSelection": "current=1, size=10。",
    "dedupe": "同其他 tab 策略。"
  },
  "fieldDescription": {
    "request": {
      "keyword": {
        "type": "string",
        "required": false,
        "description": "关键字搜索（accountName/platform/campaignName/channel/country 等）。空字符串表示不筛选。"
      },
      "current": {
        "type": "number",
        "required": false,
        "default": 1,
        "description": "页码，从 1 开始。"
      },
      "size": { "type": "number", "required": false, "default": 10, "description": "每页条数。" },
      "dateRange": {
        "type": "string",
        "required": true,
        "enum": ["today", "yesterday", "last7d", "month"],
        "description": "日期范围（与 overview 一致）。"
      },
      "app": { "type": "string", "required": false, "description": "应用筛选。空字符串表示全部。" },
      "adPlatform": {
        "type": "string",
        "required": false,
        "description": "广告平台筛选。空字符串表示全部。"
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "账户筛选。空字符串表示全部。"
      },
      "country": {
        "type": "string",
        "required": false,
        "description": "国家筛选。空字符串表示全部。"
      }
    },
    "response": {
      "rows": {
        "type": "AdPerformanceAccountRow[]",
        "required": true,
        "description": "账户维度明细。支持树表 children（账户下的 campaign）。"
      },
      "summary": { "type": "AccountSummary", "required": true, "description": "账户汇总。" },
      "pagination": {
        "type": "AdPerformancePagination",
        "required": true,
        "description": "分页信息。建议只对顶层 account 行分页。"
      }
    }
  },
  "sampleRequest": {
    "keyword": "",
    "current": 1,
    "size": 10,
    "dateRange": "today",
    "app": "",
    "adPlatform": "",
    "account": "",
    "country": ""
  },
  "sampleResponse": {
    "rows": [
      {
        "id": "ac1",
        "accountName": "523-793-2262",
        "platform": "google",
        "balance": 2380,
        "status": "sufficient",
        "spend": 15686,
        "budgetProgressPercent": 65,
        "activeCampaignCount": 3,
        "avgCpi": 2.37,
        "avgCtr": 3.1,
        "avgCvr": 31.2,
        "roi1": 85,
        "roi7": 94,
        "estimatedProfit": 2130,
        "children": [
          {
            "id": "ac1-c1",
            "campaignName": "Weather5_US_Google_CRE001",
            "channel": "google",
            "country": "US",
            "status": "active",
            "spend": 12450,
            "cpi": 2.37,
            "ctr": 3.1,
            "cvr": 31.2,
            "roi1": 85,
            "roi7": 94,
            "estimatedProfit": 1240
          }
        ]
      }
    ],
    "summary": {
      "totalSpend": 34858,
      "avgCpi": 2.38,
      "lowBalanceAccountCount": 2,
      "overBudgetAccountCount": 1,
      "estimatedProfit": 2205
    },
    "pagination": { "current": 1, "size": 10, "total": 12 }
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/ad-performance/table/account",
    "method": "POST",
    "priority": "P0",
    "requestBody": "keyword?, current?, size?, dateRange, app?, adPlatform?, account?, country?",
    "responseBody": "rows, summary, pagination"
  }
}
