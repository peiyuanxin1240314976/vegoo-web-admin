{
  "_comment": "广告成效 - 页面概览数据：顶部 KPI、趋势图、右侧分布、异常预警、数据时间。建议首屏与筛选变化时调用。",
  "fieldDescription": {
    "request": {
      "dateRange": {
        "type": "string",
        "required": true,
        "enum": ["today", "yesterday", "last7d", "month"],
        "description": "日期范围（当前 UI 为枚举）。"
      },
      "app": {
        "type": "string",
        "required": false,
        "description": "应用筛选。空字符串表示全部。"
      },
      "adPlatform": {
        "type": "string",
        "required": false,
        "description": "广告平台筛选。空字符串表示全部。"
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "账户筛选。空字符串表示全部。"
      },
      "country": {
        "type": "string",
        "required": false,
        "description": "国家筛选。空字符串表示全部。"
      }
    },
    "response": {
      "dataTime": {
        "type": "string",
        "required": true,
        "description": "数据更新时间（展示用），格式 HH:mm:ss。"
      },
      "kpi": {
        "type": "AdPerformanceKpi[]",
        "required": true,
        "description": "顶部 KPI 卡片列表（建议固定 6 张卡）。"
      },
      "spendTrend": {
        "type": "SpendTrendItem[]",
        "required": true,
        "description": "花费趋势（折线）。"
      },
      "roi7dTrend": {
        "type": "Roi7dTrendItem[]",
        "required": true,
        "description": "7日 ROI 趋势（折线）。"
      },
      "channelDistribution": {
        "type": "ChannelDistributionItem[]",
        "required": true,
        "description": "广告平台分布（环形图）。percent 用于图表值，value 用于金额汇总。"
      },
      "appDistribution": {
        "type": "AppDistributionItem[]",
        "required": true,
        "description": "应用分布（列表条形）。"
      },
      "ownerShareDistribution": {
        "type": "OwnerShareDistributionItem[]",
        "required": true,
        "description": "投放师占比分布（列表条形）。"
      },
      "alerts": {
        "type": "AdPerformanceAlertItem[]",
        "required": true,
        "description": "异常预警列表。"
      }
    }
  },
  "sampleRequest": {
    "dateRange": "today",
    "app": "",
    "adPlatform": "",
    "account": "",
    "country": ""
  },
  "sampleResponse": {
