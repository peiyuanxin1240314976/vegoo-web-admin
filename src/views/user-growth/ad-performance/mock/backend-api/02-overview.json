  "api": {
    "url": "POST /api/user-growth/ad-performance/overview",
    "method": "POST",
    "priority": "P0",
    "requestBody": "dateRange, app?, adPlatform?, account?, country?",
    "responseBody": "dataTime, kpi, spendTrend, roi7dTrend, channelDistribution, appDistribution, ownerShareDistribution, alerts"
  },
  "apiSuggestion": {
    "notes": [
      "kpi.value/compare 为展示字符串，若后端希望返回数值型（spend/cpi/roi/profit），建议新增 valueNumber/compareNumber 字段或改为数值并由前端格式化。",
      "channelDistribution.percent 建议总和≈100（允许四舍五入误差），value 口径建议与“总花费”一致。",
      "alerts.actionType 建议只允许枚举 pause/view/optimize，便于前端按钮样式与行为绑定。"
    ]
  }
}
