{
  "_comment": "广告成效 - 主表格（Campaign tab）。由原 03 的 tab=campaign 拆分而来。",
  "interaction": {
    "triggers": [
      {
        "moment": "主列表 tab 为 Campaign",
        "detail": "首屏、分页、关键字、筛选变化时请求；可与 overview 并行。",
        "prerequisite": "startDate/endDate 必填；其余筛选项与主筛选一致。"
      },
      {
        "moment": "数据变更后刷新",
        "detail": "抽屉内暂停系列、alert-action 等成功后，父组件可 `refreshAll` 再次请求本接口。",
        "prerequisite": "仍停留在 Campaign tab。"
      }
    ],
    "defaultSelection": "current=1, size=10。",
    "dedupe": "相同 query 连续触发可防抖（可选）。"
  },
  "fieldDescription": {
    "request": {
      "keyword": {
        "type": "string",
        "required": false,
        "description": "关键字搜索（name/appName/channel/country 等）。空字符串表示不筛选。"
      },
      "current": {
        "type": "number",
        "required": false,
        "default": 1,
        "description": "页码，从 1 开始。"
      },
      "size": { "type": "number", "required": false, "default": 10, "description": "每页条数。" },
      "startDate": {
        "type": "string",
        "required": true,
        "description": "开始日期（YYYY-MM-DD，闭区间）。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "结束日期（YYYY-MM-DD，闭区间）。"
      },
      "app": { "type": "string", "required": false, "description": "应用筛选。空字符串表示全部。" },
      "adPlatform": {
        "type": "string",
        "required": false,
        "description": "广告平台筛选。空字符串表示全部。"
      },
      "account": {
        "type": "string",
        "required": false,
        "description": "账户筛选。空字符串表示全部。"
      },
      "country": {
        "type": "string",
        "required": false,
        "description": "国家筛选。空字符串表示全部。"
      }
    },
    "response": {
      "rows": {
        "type": "AdPerformanceCampaignRow[]",
        "required": true,
        "description": "系列维度明细。支持树表 children（AdGroup 行）。"
      },
      "pagination": {
        "type": "AdPerformancePagination",
        "required": true,
        "description": "分页信息。建议只对顶层 campaign 行分页。"
      }
    }
  },
  "sampleRequest": {
    "keyword": "",
    "current": 1,
    "size": 10,
    "startDate": "2026-03-05",
    "endDate": "2026-03-05",
    "app": "",
    "adPlatform": "",
    "account": "",
    "country": ""
  },
  "sampleResponse": {
    "rows": [
      {
        "id": "c1",
        "appName": "Weather5",
        "name": "Weather5_US_Google_CRE001",
        "channel": "google",
        "country": "US",
        "status": "active",
        "spend": 12450,
        "budget": 13000,
        "spendBudgetPercent": 83,
        "cpi": 2.37,
        "ctr": 3.1,
        "cvr": 31.2,
        "roi1": 85,
        "roi7": 94,
        "estimatedProfit": 1240,
        "children": [
          {
            "id": "c1-1",
            "appName": "Weather5",
            "name": "AdGroup_US_Interest_Broad",
            "channel": "google",
            "country": "US",
            "status": "active",
            "spend": 4200,
            "budget": 4500,
            "spendBudgetPercent": 93,
            "cpi": 2.2,
            "ctr": 3.2,
            "cvr": 32,
            "roi1": 86,
            "roi7": 95,
            "estimatedProfit": 420
          }
        ]
      }
    ],
    "pagination": { "current": 1, "size": 10, "total": 604 }
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/ad-performance/table/campaign",
    "method": "POST",
    "priority": "P0",
    "requestBody": "keyword?, current?, size?, startDate, endDate, app?, adPlatform?, account?, country?",
    "responseBody": "rows, pagination"
  }
}
