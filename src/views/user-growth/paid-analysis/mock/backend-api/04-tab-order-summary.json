        "type": "string",
        "required": false,
        "default": "",
        "description": "终端平台。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "国家。"
      },
      "n_source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台。"
      }
    },
    "response": {
      "kpis": { "type": "array", "required": true, "description": "订单 KPI 卡片。" },
      "appPlatformRows": {
        "type": "array",
        "required": true,
        "description": "应用×平台汇总主表。"
      },
      "dailyRows": { "type": "array", "required": true, "description": "按日汇总。" },
      "hourAmounts": {
        "type": "array",
        "required": true,
        "description": "24 小时金额序列（USD，与整点区间对齐）。"
      },
      "productTypeShare": { "type": "array", "required": true, "description": "商品类型订单占比。" }
    },
    "AppPlatformRow": {
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["iOS", "Android", "--"],
        "description": "终端展示；汇总行用 --。"
      }
    }
  },
