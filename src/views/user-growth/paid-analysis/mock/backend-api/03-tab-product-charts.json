{
  "_comment": "付费分析 - 商品分析 Tab · 图例与图表。契约文件：03-tab-product-charts.json。types: PaidAnalysisProductTabChartsData。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "起始日 YYYY-MM-DD（含）。"
      },
      "endDate": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD（含）。" },
      "app": { "type": "string", "required": false, "default": "", "description": "应用筛选。" },
      "platform": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "终端平台。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "国家。"
      },
      "n_source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台。"
      },
      "productRankingMode": {
        "type": "string",
        "required": false,
        "default": "",
        "enum": ["", "revenue", "orders", "retention", "country"],
        "description": "与 overview、ranking 一致；图表一般忽略，可为空。"
      }
    },
    "response": {
      "mixLegend": { "type": "array", "required": true, "description": "收入构成图例。" },
      "paidDateSummaryRows": {
        "type": "array",
        "required": true,
        "description": "按付费日订单汇总。"
      },
      "revenueTrend30d": {
        "type": "array",
        "required": true,
        "description": "近 30 日收入趋势点（t_date + revenue）。"
      },
      "subscriptionRetentionMatrix": {
        "type": "array",
        "required": true,
        "description": "订阅续费矩阵（m1–m5）。"
      },
      "countryBarTop": {
        "type": "array",
        "required": true,
        "description": "国家 Top 分段柱（s_country_code + segments）。"
      }
    }
  },
