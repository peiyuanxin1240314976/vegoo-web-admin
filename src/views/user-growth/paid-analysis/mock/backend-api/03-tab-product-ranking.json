{
  "_comment": "付费分析 - 商品分析 Tab · 商品收入排行。契约文件：03-tab-product-ranking.json。types: PaidAnalysisProductTabRankingData。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "起始日 YYYY-MM-DD（含）。"
      },
      "endDate": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD（含）。" },
      "appId": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "应用 ID；与 meta appOptions.value 一致；空为全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "终端平台。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "国家。"
      },
      "n_source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台。"
      },
      "productRankingMode": {
        "type": "string",
        "required": false,
        "default": "",
        "enum": ["", "revenue", "orders", "retention", "country"],
        "description": "可选：服务端接管排序时传入；空则返回默认序，由前端子 Tab 本地重排。"
      }
    },
    "response": {
      "productRows": { "type": "array", "required": true, "description": "商品收入排行主表。" }
    },
    "PaidAnalysisProductRankingRow": {
      "skuName": { "type": "string", "required": true, "description": "SKU 展示名。" },
      "priceUsd": { "type": "number", "required": true, "description": "标价 USD。" },
      "productKind": { "type": "string", "required": true, "description": "商品类型展示文案。" },
      "productKindKey": {
        "type": "string",
        "required": true,
        "enum": ["year_sub", "month_sub", "lifetime", "coin", "other"],
        "description": "商品类型键，用于标签样式。"
      },
      "revenueUsd": { "type": "number", "required": true, "description": "收入 USD。" },
      "sharePercent": { "type": "number", "required": true, "description": "占比 0–100。" },
      "orderCount": { "type": "number", "required": true, "description": "订单数。" },
      "arppuUsd": { "type": "number", "required": true, "description": "ARPPU USD。" },
      "retentionPercent": {
        "type": "number",
        "required": false,
        "description": "续订率 0–100；无则 null。"
      },
      "topCountries": { "type": "array", "required": true, "description": "Top 国家小写码。" },
      "trendPoints": { "type": "array", "required": true, "description": "迷你趋势序列。" }
    }
  },
