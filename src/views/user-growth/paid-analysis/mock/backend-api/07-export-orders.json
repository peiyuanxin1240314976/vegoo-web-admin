    "platform": "",
    "s_country_code": "",
    "n_source": "",
    "keyword": "",
    "format": "xlsx"
  },
  "sampleResponse": {
    "downloadUrl": "https://example-cdn.internal/export/paid-orders-20260305.xlsx",
    "fileId": ""
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/paid-analysis/export/orders",
    "method": "POST",
    "priority": "P2",
    "requestBody": "startDate, endDate, 筛选, keyword?, format?",
    "responseBody": "export result"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户点击导出",
