{
  "_comment": "付费分析 - 导出订单（顶栏或订单 Tab）。P2。",
  "fieldDescription": {
    "request": {
      "startDate": { "type": "string", "required": true, "description": "导出范围起。" },
      "endDate": { "type": "string", "required": true, "description": "导出范围止。" },
      "app": { "type": "string", "required": false, "default": "", "description": "应用。" },
      "platform": { "type": "string", "required": false, "default": "", "description": "终端。" },
      "s_country_code": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "国家。"
      },
      "n_source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台。"
      },
      "keyword": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "与列表一致。"
      },
      "format": {
        "type": "string",
        "required": false,
        "default": "xlsx",
        "enum": ["xlsx", "csv"],
        "description": "导出格式。"
      }
    },
    "response": {
      "downloadUrl": {
        "type": "string",
        "required": true,
        "description": "短时有效下载地址；或二者之一见 fileId。"
      },
      "fileId": {
        "type": "string",
        "required": false,
        "description": "异步导出任务 id（若走任务制）。"
      }
    }
  },
  "sampleRequest": {
    "startDate": "2026-02-05",
    "endDate": "2026-03-05",
