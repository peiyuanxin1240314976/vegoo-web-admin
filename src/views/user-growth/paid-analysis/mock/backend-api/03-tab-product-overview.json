{
  "_comment": "付费分析 - 商品分析 Tab · KPI。契约文件：03-tab-product-overview.json。types: PaidAnalysisProductTabOverviewData。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "起始日 YYYY-MM-DD（含）。"
      },
      "endDate": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD（含）。" },
      "appId": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "应用 ID；与 meta appOptions.value 一致；空为全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "终端平台。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "国家。"
      },
      "n_source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台。"
      },
      "productRankingMode": {
        "type": "string",
        "required": false,
        "default": "",
        "enum": ["", "revenue", "orders", "retention", "country"],
        "description": "可选：服务端排序时传入；空表示前端本地排序（当前 UI）。"
      }
    },
    "response": {
      "kpis": {
        "type": "array",
        "required": true,
        "description": "KPI 卡片（结构同 channel 概览 kpis）。"
      }
    }
  },
  "sampleRequest": {
    "startDate": "2026-04-01",
    "endDate": "2026-04-03",
    "appId": "",
    "platform": "",
    "s_country_code": "",
    "n_source": "",
    "productRankingMode": ""
  },
  "sampleResponse": {
    "kpis": [
      {
