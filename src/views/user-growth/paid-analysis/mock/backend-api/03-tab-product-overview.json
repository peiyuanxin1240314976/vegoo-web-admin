        "sparkData": [68, 69, 70, 69, 71, 70, 70],
        "sparkType": "line"
      },
      {
        "label": "活跃商品数",
        "value": "7个",
        "trendUp": false,
        "trendVal": "",
        "sub": "共5类型",
        "color": "#3b82f6",
