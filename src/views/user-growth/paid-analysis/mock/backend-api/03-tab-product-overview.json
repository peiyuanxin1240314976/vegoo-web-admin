  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/paid-analysis/tab-product/overview",
    "method": "POST",
    "priority": "P0",
    "requestBody": "startDate, endDate, appId?, platform?, s_country_code?, n_source?, productRankingMode?",
    "responseBody": "PaidAnalysisProductTabOverviewData"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "商品分析 Tab 首屏 / 顶栏检索",
        "detail": "与 ranking、charts 可并行请求。",
        "prerequisite": "登录态"
      }
    ],
    "defaultSelection": "productRankingMode 默认 \"\" 由前端本地排序。"
  }
}
