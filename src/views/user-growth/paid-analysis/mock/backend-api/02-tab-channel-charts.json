{
  "_comment": "付费分析 - 广告平台 IAP 转化 Tab · 图表。契约文件：02-tab-channel-charts.json。types: PaidAnalysisChannelTabChartsData。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "起始日 YYYY-MM-DD（含）。"
      },
      "endDate": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD（含）。" },
      "app": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "应用；空为全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "终端平台；空为不限。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "国家小写码；空为全部。"
      },
      "n_source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台枚举 string；空为全部。"
      }
    },
    "response": {
      "trendSeries": {
        "type": "array",
        "required": true,
        "description": "IAP 收入趋势多序列（含 points.t_date / revenue）。"
      },
      "arppuBar": {
        "type": "array",
        "required": true,
        "description": "ARPPU 横向条（percentOfMax、arppu）。"
      },
      "productMixDonut": {
        "type": "array",
        "required": true,
        "description": "商品类型占比（name/value/color）。"
      },
      "donutCenterRevenueUsd": {
        "type": "number",
        "required": true,
        "description": "环形图中心总 IAP（USD）。"
      }
    }
  },
  "sampleRequest": {
    "startDate": "2026-04-01",
    "endDate": "2026-04-03",
