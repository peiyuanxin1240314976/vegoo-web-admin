{
  "_comment": "付费分析 - 广告平台 IAP 转化 Tab · 表格。契约文件：02-tab-channel-tables.json。types: PaidAnalysisChannelTabTablesData。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "起始日 YYYY-MM-DD（含）。"
      },
      "endDate": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD（含）。" },
      "appId": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "应用 ID；与公用 meta appOptions.value 一致；空为全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "终端平台；空为不限。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "国家小写码；空为全部。"
      },
      "n_source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台枚举 string；空为全部。"
      }
    },
    "response": {
      "channelRows": { "type": "array", "required": true, "description": "广告平台对比主表。" },
      "roiCohortRows": { "type": "array", "required": true, "description": "ROI 区间表。" },
      "retentionRows": {
        "type": "array",
        "required": true,
        "description": "续订热力档位（按渠道）。"
      }
    },
    "PaidAnalysisChannelRow": {
      "channelName": { "type": "string", "required": true, "description": "广告平台名称。" },
      "iapRevenue": { "type": "number", "required": true, "description": "IAP 收入 USD。" },
      "revenueSharePercent": {
        "type": "number",
        "required": true,
        "description": "收入占比 0–100。"
      },
      "payingUsers": { "type": "number", "required": true, "description": "付费人数。" },
      "arppu": { "type": "number", "required": true, "description": "ARPPU USD。" },
      "firstPayPeriodDays": {
        "type": "number",
        "required": true,
        "description": "首次付费周期天。"
      },
      "retentionPercent": { "type": "number", "required": true, "description": "续订率 0–100。" },
      "qualityScore": {
        "type": "string",
        "required": true,
        "enum": ["★A+", "★A", "★B-", "★B+"],
        "description": "质量评分展示文案。"
      }
    },
    "PaidAnalysisRoiCohortRow": {
      "periodLabel": {
        "type": "string",
        "required": true,
        "description": "区间标签（如首日、7日）。"
      },
      "roiPercent": { "type": "number", "required": true, "description": "ROI 百分比数值。" },
      "cpaPercent": { "type": "number", "required": true, "description": "CPA 相关占比。" },
      "paidRevenue": { "type": "number", "required": true, "description": "付费收入。" },
      "paidUsers": { "type": "number", "required": true, "description": "付费用户数。" },
      "renewRatePercent": { "type": "number", "required": true, "description": "续订率。" },
      "iapRevenue": { "type": "number", "required": true, "description": "IAP 收入。" },
      "iapSharePercent": { "type": "number", "required": true, "description": "IAP 占比。" },
      "iapOrders": { "type": "number", "required": true, "description": "IAP 订单数。" },
      "iapUsers": { "type": "number", "required": true, "description": "IAP 用户数。" }
    },
    "PaidAnalysisChannelRetentionRow": {
      "channelName": { "type": "string", "required": true, "description": "渠道名。" },
      "month1Bucket": { "type": "string", "required": true, "description": "第 1 档展示桶。" },
      "month2Bucket": { "type": "string", "required": true, "description": "第 2 档展示桶。" },
      "month5Bucket": { "type": "string", "required": true, "description": "第 5 档展示桶。" }
    }
  },
