{
  "_comment": "付费分析 - 广告平台 IAP 转化 Tab · 概览。契约文件：本目录 02-tab-channel-overview.json（与 tables/charts 契约并列，无子文件夹）。types: PaidAnalysisChannelTabOverviewData。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "起始日 YYYY-MM-DD（含）。"
      },
      "endDate": { "type": "string", "required": true, "description": "结束日 YYYY-MM-DD（含）。" },
      "appId": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "应用 ID；与公用 meta appOptions.value 一致；空为全部。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "终端平台；空为不限。"
      },
      "s_country_code": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "国家小写码；空为全部。"
      },
      "n_source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台枚举 string；空为全部。"
      }
    },
    "response": {
      "kpis": {
        "type": "array",
        "required": true,
        "description": "KPI 卡片（含 sparkData、sparkType）。"
      },
      "aiTips": {
        "type": "array",
        "required": true,
        "description": "AI 洞察条目（id/color/text）。"
      }
    },
    "PaidAnalysisChannelKpiItem": {
      "label": { "type": "string", "required": true, "description": "KPI 标题。" },
      "value": { "type": "string", "required": true, "description": "主展示值（可预格式化）。" },
      "trendUp": { "type": "boolean", "required": true, "description": "趋势方向。" },
      "trendVal": { "type": "string", "required": true, "description": "环比等文案。" },
      "sub": { "type": "string", "required": true, "description": "副文案。" },
      "color": { "type": "string", "required": true, "description": "主题色 CSS。" },
      "sparkData": { "type": "array", "required": true, "description": "迷你序列数值。" },
      "sparkType": {
        "type": "string",
        "required": true,
        "enum": ["line", "bar"],
        "description": "迷你图类型。"
      }
    }
  },
  "sampleRequest": {
    "startDate": "2026-04-01",
    "endDate": "2026-04-03",
    "appId": "",
    "platform": "",
    "s_country_code": "",
    "n_source": ""
  },
