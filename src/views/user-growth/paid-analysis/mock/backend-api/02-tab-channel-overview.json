  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/paid-analysis/tab-channel/overview",
    "method": "POST",
    "priority": "P0",
    "requestBody": "startDate, endDate, appId?, platform?, s_country_code?, n_source?",
    "responseBody": "PaidAnalysisChannelTabOverviewData"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "进入 channel Tab 或点击检索",
        "detail": "与 tables、charts 可并行请求；首屏优先渲染本段。",
        "prerequisite": "日期合法；筛选「全部」映射空串"
      }
    ],
    "defaultSelection": "与顶栏 filters 一致；单日筛选时 startDate=endDate。",
    "dedupe": "kpis 与 aiTips 仅随筛选变更；可单独缓存 TTL。"
  }
}
