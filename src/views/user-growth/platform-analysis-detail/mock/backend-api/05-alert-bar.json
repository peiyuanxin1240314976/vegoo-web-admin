{
  "_comment": "综合分析应用详情 - 底部智能预警条。响应 data 可为 AlertBarItem[]，或 { alertBar: AlertBarItem[] }（前端 asAlertBarPayload 兼容）。",
  "fieldDescription": {
    "request": {
      "name": { "type": "string", "required": true, "description": "钻取实体名称。" },
      "startDate": {
        "type": "string",
        "required": true,
        "description": "查询起始日期（含），YYYY-MM-DD。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "查询结束日期（含），YYYY-MM-DD。"
      },
      "appId": {
        "type": "string",
        "required": true,
        "description": "应用筛选；空字符串表示全部。"
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "广告平台筛选；空字符串表示全部。"
      },
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "国家代码筛选；空字符串表示全部。"
      }
    },
    "response": {
      "data": {
        "type": "AlertBarItem[] | { alertBar: AlertBarItem[] }",
        "required": true,
        "description": "预警列表；推荐直接返回数组。"
      }
    },
    "AlertBarItem": {
      "id": { "type": "string", "required": true, "description": "项 id。" },
      "level": {
        "type": "string",
        "required": true,
        "enum": ["danger", "warning", "info", "good"],
        "description": "样式级别；示例须覆盖各枚举至少一次。"
      },
      "text": { "type": "string", "required": true, "description": "展示文案。" }
    }
  },
  "sampleRequest": {
    "name": "PhoneTracker",
    "startDate": "2026-02-27",
    "endDate": "2026-03-05",
    "appId": "",
    "source": "",
    "s_country_code": ""
  },
  "sampleResponse": {
    "data": [
      {
        "id": "alert-1",
        "level": "danger",
        "text": "PhoneTracker × Google Ads × US：CPI 高于目标 22%，建议收紧定向"
      },
      {
        "id": "alert-2",
        "level": "warning",
        "text": "TikTok × DE：预算已用 89%，关注次日回收"
      },
      {
        "id": "alert-3",
        "level": "info",
        "text": "来自综合分析钻取（Mock）"
      },
      {
        "id": "alert-4",
        "level": "good",
        "text": "Facebook × IN：ROI 达标，可适度扩量"
      }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/comprehensive-analysis/platform-analysis-detail/alert-bar",
    "method": "POST",
    "priority": "P1",
    "requestBody": "name, startDate, endDate, appId, source, s_country_code",
    "responseBody": "AlertBarItem[]"
  },
  "apiSuggestion": {
    "notes": [
      "若网关统一包裹为 { data: { alertBar: [...] } }，前端 unwrap 后仍须得到数组或含 alertBar 的对象。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "首屏并行加载",
        "detail": "与矩阵表等同时请求；仅展示无二次交互。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "与 summary 共用请求体。",
    "dedupe": "无"
  }
}
