        "description": "钻取实体名称，与路由 query `name` 一致。"
      },
      "from": {
        "type": "string",
        "required": false,
        "description": "来源页面标识，如 comprehensive-analysis。"
      }
    },
    "response": {
      "data": {
        "type": "PlatformAnalysisDetailData",
        "required": true,
        "description": "KPI、平台卡片、矩阵表、CPI/ECPM 趋势、预警条等。"
      }
    }
  },
  "sampleRequest": {
