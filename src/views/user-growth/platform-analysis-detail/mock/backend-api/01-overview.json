      "ecpmTrend": { "dates": [], "series": [] },
      "ecpmMetrics": {},
      "alertBar": []
    }
  },
  "api": {
    "url": "POST /api/user-growth/platform-analysis-detail/overview",
    "method": "POST",
    "priority": "P0",
    "requestBody": "name (必填), from?",
    "responseBody": "PlatformAnalysisDetailData"
  },
  "apiSuggestion": {
    "notes": ["完整字段结构以 `platform-analysis-detail/types.ts` 为准；此处为占位示例。"]
