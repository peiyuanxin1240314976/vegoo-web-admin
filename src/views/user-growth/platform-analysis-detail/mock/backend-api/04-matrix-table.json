  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/comprehensive-analysis/platform-analysis-detail/matrix-table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "name (必填), from?",
    "responseBody": "MatrixTableData"
  },
  "apiSuggestion": {
    "notes": [
      "主表格数组至少 3 个完整节点（含跨层）；示例含 3 个平台根行 + 多国子行。",
      "cpiLevel、roiD1Level 闭合枚举须在示例中各至少出现一次。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "首屏并行加载",
        "detail": "右侧 ElTable 树形数据；展开/收起不调接口。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "与 summary 共用 name/from。",
    "dedupe": "数据量大时可后续拆懒加载子节点（另契约）；当前为整表返回。"
  }
}
