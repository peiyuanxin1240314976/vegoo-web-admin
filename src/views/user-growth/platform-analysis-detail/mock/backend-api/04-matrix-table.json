{
  "_comment": "综合分析应用详情 - 广告平台×国家树形表及表脚合计。对应 types: MatrixTableData。国家子行须含 s_country_code（ISO 3166-1 alpha-2）；勿返回国旗 emoji。",
  "fieldDescription": {
    "request": {
      "name": { "type": "string", "required": true, "description": "钻取实体名称。" },
      "from": { "type": "string", "required": false, "description": "来源页标识。" }
    },
    "response": {
      "data": {
        "type": "MatrixTableData",
        "required": true,
        "description": "树形表数据 + 合计行。"
      }
    },
    "MatrixTableData": {
      "rows": {
        "type": "PlatformRow[]",
        "required": true,
        "description": "一级平台行 isCountry:false，children 为国家行 isCountry:true。"
      },
      "total": {
        "type": "object",
        "required": true,
        "description": "与表列对齐：adSpend, cpi, cpm, cpc, roiD1, roiD3, roiD7, profit（走势列为前端 sparkline，合计行可占位或与业务约定）。"
      }
    },
    "PlatformRow": {
      "id": { "type": "string", "required": true, "description": "行唯一 id。" },
      "isCountry": {
        "type": "boolean",
        "required": true,
        "description": "平台根行固定 false。"
      },
      "platform": { "type": "string", "required": true, "description": "广告平台名称。" },
      "countryCount": {
        "type": "string",
        "required": true,
        "description": "下属国家数，预格式化展示。"
      },
      "adSpend": { "type": "string", "required": true, "description": "广告支出。" },
      "cpi": { "type": "string", "required": true, "description": "CPI 展示。" },
      "cpiLevel": {
        "type": "string",
        "required": true,
        "enum": ["good", "near", "over"],
        "description": "CPI 档位，驱动标签色。"
      },
      "cpm": { "type": "string", "required": true, "description": "CPM。" },
      "cpc": { "type": "string", "required": true, "description": "CPC。" },
      "roiD1": { "type": "string", "required": true, "description": "首日 ROI。" },
      "roiD1Level": {
        "type": "string",
        "required": true,
        "enum": ["good", "warn", "danger"],
        "description": "首日 ROI 档位。"
      },
      "roiD3": { "type": "string", "required": true, "description": "3 日 ROI。" },
      "roiD7": { "type": "string", "required": true, "description": "7 日 ROI。" },
      "profit": { "type": "string", "required": true, "description": "预估利润。" },
      "profitNeg": {
        "type": "boolean",
        "required": false,
        "description": "是否负利润样式（平台汇总行可选用）。"
      },
      "sparkline": {
        "type": "number[]",
        "required": true,
        "description": "迷你走势序列，长度由产品约定（示例 7 点）。"
      },
      "children": {
        "type": "CountryRow[]",
        "required": true,
        "description": "国家明细行。"
      }
    },
    "CountryRow": {
      "id": { "type": "string", "required": true, "description": "行唯一 id。" },
      "isCountry": {
        "type": "boolean",
        "required": true,
        "description": "国家行固定 true。"
      },
      "platform": {
        "type": "string",
        "required": true,
        "description": "所属广告平台名（与父行一致）。"
      },
      "country": { "type": "string", "required": true, "description": "国家中文/展示名。" },
      "s_country_code": {
        "type": "string",
        "required": true,
        "description": "ISO 3166-1 alpha-2，大写；前端映射 fi-xx 展示国旗。"
      },
      "adSpend": { "type": "string", "required": true, "description": "广告支出。" },
      "cpi": { "type": "string", "required": true, "description": "CPI。" },
      "cpiLevel": {
        "type": "string",
        "required": true,
        "enum": ["good", "near", "over"],
        "description": "CPI 档位。"
      },
      "cpm": { "type": "string", "required": true, "description": "CPM。" },
      "cpc": { "type": "string", "required": true, "description": "CPC。" },
      "roiD1": { "type": "string", "required": true, "description": "首日 ROI。" },
      "roiD1Level": {
        "type": "string",
        "required": true,
        "enum": ["good", "warn", "danger"],
        "description": "首日 ROI 档位。"
      },
      "roiD3": { "type": "string", "required": true, "description": "3 日 ROI。" },
      "roiD7": { "type": "string", "required": true, "description": "7 日 ROI。" },
      "profit": { "type": "string", "required": true, "description": "预估利润。" },
      "profitNeg": {
        "type": "boolean",
        "required": false,
        "description": "负利润高亮。"
      },
      "sparkline": { "type": "number[]", "required": true, "description": "迷你走势。" }
    }
  },
