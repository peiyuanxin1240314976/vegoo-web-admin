{
  "_comment": "综合分析应用详情 - ECPM 双折线 + 卡片区四指标。对应 types: PlatformAnalysisDetailEcpmBlock（ecpmTrend + ecpmMetrics）。",
  "fieldDescription": {
    "request": {
      "name": { "type": "string", "required": true, "description": "钻取实体名称。" },
      "from": { "type": "string", "required": false, "description": "来源页标识。" }
    },
    "response": {
      "data": {
        "type": "PlatformAnalysisDetailEcpmBlock",
        "required": true,
        "description": "趋势与摘要指标一并返回。"
      }
    },
    "PlatformAnalysisDetailEcpmBlock": {
      "ecpmTrend": {
        "type": "ChartTrend",
        "required": true,
        "description": "预估 vs 真实 ECPM 两条线；结构同 02-cpi-trend 中 ChartTrend。"
      },
      "ecpmMetrics": {
        "type": "EcpmTrendMetrics",
        "required": true,
        "description": "预估ECPM、真实ECPM、偏差率、偏差金额；预格式化字符串，度量两位小数见 sampleResponse。"
      }
    },
    "EcpmTrendMetrics": {
      "estimatedEcpm": {
        "type": "string",
        "required": true,
        "description": "预估 ECPM 展示文案（两位小数）。"
      },
      "actualEcpm": {
        "type": "string",
        "required": true,
        "description": "真实 ECPM 展示文案（两位小数）。"
      },
      "biasRate": {
        "type": "string",
        "required": true,
        "description": "偏差率，预格式化（如 +7.90%）。"
      },
      "biasAmount": {
        "type": "string",
        "required": true,
        "description": "偏差金额，预格式化（如 +$284.00）。"
      }
    }
  },
  "sampleRequest": {
    "name": "PhoneTracker",
    "from": "comprehensive-analysis"
  },
  "sampleResponse": {
    "data": {
      "ecpmTrend": {
        "dates": ["02-27", "02-28", "03-01", "03-02", "03-03", "03-04", "03-05"],
        "series": [
          {
            "name": "预估ECPM",
            "color": "#F59E0B",
            "data": [17.2, 17.45, 17.7, 17.95, 18.2, 18.45, 18.7]
          },
          {
            "name": "真实ECPM",
            "color": "#14B8A6",
            "data": [16.85, 17.0, 17.15, 17.3, 17.45, 17.6, 17.75]
          }
        ]
      },
      "ecpmMetrics": {
        "estimatedEcpm": "19.20",
        "actualEcpm": "17.80",
        "biasRate": "+7.90%",
        "biasAmount": "+$284.00"
      }
    }
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/comprehensive-analysis/platform-analysis-detail/ecpm-trend",
    "method": "POST",
    "priority": "P0",
    "requestBody": "name (必填), from?",
    "responseBody": "PlatformAnalysisDetailEcpmBlock"
  },
  "apiSuggestion": {
    "notes": [
      "ecpmTrend.dates 与两条 series.data 须等长。",
      "四指标为展示用预格式化字符串，与图表 tooltip 口径一致即可。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "首屏并行加载",
        "detail": "与 CPI 图同屏展示，一次请求返回趋势+四卡指标。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "与 summary 共用 name/from。",
    "dedupe": "整页重拉时与其它分片并行。"
  }
}
