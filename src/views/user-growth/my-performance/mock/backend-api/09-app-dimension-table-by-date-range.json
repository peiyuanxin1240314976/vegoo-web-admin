    "requestBody": "personId, startDate, endDate",
    "responseBody": "title, list, summary, excelTables"
  },
  "apiSuggestion": {
    "notes": [
      "此接口用于替代原 app-dimension-table 的 periodType/periodValue 入参；统计周期由 startDate/endDate 明确指定。",
      "无数据时返回 list: []，summary 保持结构完整（数值字段返回 0），保证页面主流程不阻塞。"
    ]
  }
