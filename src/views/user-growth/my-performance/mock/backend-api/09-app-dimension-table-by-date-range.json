{
  "_comment": "我的绩效 - 应用维度绩效评估表（固定近 7 天）。对应 types.ts: MyPerformanceAppDimensionTableQueryBody, MyPerformanceAppTreeRow, MyPerformanceAppTableSummary。",
  "fieldDescription": {
    "request": {
      "personId": { "type": "string", "required": true, "description": "人员 ID。" },
      "startDate": {
        "type": "string",
        "required": true,
        "description": "开始日期，YYYY-MM-DD；由前端按应用当前时间往前推 7 天计算。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "结束日期，YYYY-MM-DD；由前端按应用当前时间计算“今天”。"
      }
    },
    "response": {
      "title": { "type": "string", "required": true, "description": "表格标题。" },
      "list": {
        "type": "MyPerformanceAppTreeRow[]",
        "required": true,
        "description": "树形表格数据：顶层为应用行(type=app)，children 为广告平台行(type=source)。"
      },
      "summary": {
        "type": "MyPerformanceAppTableSummary",
        "required": true,
        "description": "底部汇总（合计/均值）。"
      },
      "excelTables": {
        "type": "object",
        "required": true,
        "description": "用于页面两张 Excel 风格表格的完整示例数据（上方汇总表 + 下方明细表）。"
      }
    }
  },
