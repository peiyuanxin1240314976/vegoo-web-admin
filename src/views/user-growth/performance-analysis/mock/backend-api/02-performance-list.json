{
  "_comment": "人员绩效列表页 - 主表格分页数据 + 合计行。对应 PerformanceList 表格与表尾合计（服务端汇总当前筛选全量，非仅当前页）。",
  "fieldDescription": {
    "request": {
      "startDate": {
        "type": "string",
        "required": true,
        "description": "开始日期，YYYY-MM-DD（含）。"
      },
      "endDate": {
        "type": "string",
        "required": true,
        "description": "结束日期，YYYY-MM-DD（含）。"
      },
      "personFilter": {
        "type": "string",
        "required": false,
        "description": "人员筛选；\"\" 表示全部；非空与 list-filter-options 及行 id/姓名口径一致。"
      },
      "appFilter": {
        "type": "string",
        "required": false,
        "description": "应用分类；\"\" 表示全部；与 appCategoryOptions 的 value 对齐。"
      },
      "statusFilter": {
        "type": "string",
        "required": false,
        "enum": ["", "达标", "未达标"],
        "description": "达标状态；\"\" 全部；「达标」含超标+达标；「未达标」含接近达标+未达标（与当前列表筛选逻辑一致）。"
      },
      "keyword": {
        "type": "string",
        "required": false,
        "description": "姓名模糊搜索，空表示不限。"
      },
      "sortField": {
        "type": "string",
        "required": false,
        "enum": ["", "adSpend"],
        "description": "排序字段；空表示默认顺序（如后端定序）；adSpend 为广告支出。"
      },
      "sortAsc": {
        "type": "boolean",
        "required": false,
        "description": "与 sortField 同时有效；true 升序 false 降序。"
      },
      "current": { "type": "number", "required": true, "description": "页码，从 1 开始。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" }
    },
    "response": {
      "list": { "type": "PerformanceRow[]", "required": true, "description": "当前页行数据。" },
      "total": { "type": "number", "required": true, "description": "符合筛选的总行数。" },
      "totals": {
        "type": "PerformanceListTotals",
        "required": true,
        "description": "当前筛选条件下全量汇总（表尾合计行），非仅当前页。"
      }
    },
    "PerformanceRow": {
      "id": { "type": "string", "required": true, "description": "人员唯一 ID。" },
      "surname": { "type": "string", "required": true, "description": "姓氏（头像旁单字）。" },
      "name": { "type": "string", "required": true, "description": "姓名。" },
      "avatarBg": { "type": "string", "required": true, "description": "头像背景 CSS 颜色。" },
      "level": {
        "type": "string",
        "required": true,
        "description": "职级展示文案（如 高级优化师）。"
      },
      "levelClass": {
        "type": "string",
        "required": true,
        "enum": ["senior", "mid", "junior"],
        "description": "职级样式：senior 高级、mid 中级、junior 初级。"
      },
      "adSpend": { "type": "number", "required": true, "description": "广告支出（USD）。" },
      "budget": {
        "type": "number",
        "required": true,
        "description": "预算（USD；列表列「预算」）。"
      },
      "roi1": {
        "type": "number",
        "required": true,
        "description": "首日 ROI，百分比数值（如 93 表示 93%）。"
      },
      "roi3": { "type": "number", "required": true, "description": "3 日 ROI，百分比数值。" },
      "roi7": { "type": "number", "required": true, "description": "7 日 ROI，百分比数值。" },
      "agentCost": { "type": "number", "required": true, "description": "代投消耗（USD）。" },
      "minCost": { "type": "number", "required": true, "description": "最低消耗（USD）。" },
      "estProfit": { "type": "number", "required": true, "description": "预估利润（USD，可负）。" },
      "minProfit": { "type": "number", "required": true, "description": "最低利润（USD，可负）。" },
      "score": { "type": "number", "required": true, "description": "绩效得分。" },
      "status": {
        "type": "string",
        "required": true,
        "description": "达标状态文案（超标/达标/接近达标/未达标）。"
      },
      "statusClass": {
        "type": "string",
        "required": true,
        "enum": ["over", "pass", "near", "fail"],
        "description": "状态样式：over 超标、pass 达标、near 接近达标、fail 未达标。"
      },
      "reportDate": {
        "type": "string",
        "required": true,
        "description": "数据归属日期 YYYY-MM-DD。"
      }
    },
    "PerformanceListTotals": {
      "adSpend": { "type": "number", "required": true, "description": "广告支出合计（USD）。" },
      "budget": { "type": "number", "required": true, "description": "预算合计（USD）。" },
      "roi1": {
        "type": "number",
        "required": true,
        "description": "首日 ROI 展示用汇总值（百分比数值，口径由后端约定，可为加权或行均）。"
      },
      "roi3": { "type": "number", "required": true, "description": "3 日 ROI 汇总展示值。" },
      "roi7": { "type": "number", "required": true, "description": "7 日 ROI 汇总展示值。" },
      "agentCost": { "type": "number", "required": true, "description": "代投消耗合计（USD）。" },
      "estProfit": { "type": "number", "required": true, "description": "预估利润合计（USD）。" },
      "minProfit": { "type": "number", "required": true, "description": "最低利润合计（USD）。" },
      "score": {
        "type": "number",
        "required": true,
        "description": "得分汇总或均值（百分比数值或分，口径由后端约定）。"
      }
    }
  },
  "sampleRequest": {
    "startDate": "2026-03-28",
    "endDate": "2026-04-04",
    "personFilter": "",
    "appFilter": "",
    "statusFilter": "",
    "keyword": "",
    "sortField": "adSpend",
    "sortAsc": false,
    "current": 1,
    "size": 20
  },
