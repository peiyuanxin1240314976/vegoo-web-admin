  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/performance-analysis/performance-list",
    "method": "POST",
    "priority": "P0",
    "requestBody": "startDate, endDate, personFilter?, appFilter?, statusFilter?, keyword?, sortField?, sortAsc?, current, size",
    "responseBody": "list, total, totals"
  },
  "apiSuggestion": {
    "notes": [
      "列表行 statusClass 四类须在联调样例中均可出现；levelClass 三类建议覆盖。",
      "表尾 totals 与 list 的聚合口径须在实现文档中写清（如 ROI 是否为加权）。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "列表页首屏 / 筛选变更",
        "detail": "日期范围、人员、应用分类、达标状态、关键字、排序或分页变化后重新请求；切换页码只改 current。",
        "prerequisite": "startDate/endDate 已确定（含自定义区间确认后）。"
      }
    ],
    "defaultSelection": "personFilter、appFilter、statusFilter 默认 \"\"；sortField 默认 \"\" 或后端约定；current=1、size=20。",
    "dedupe": "建议对相同参数请求防抖或取消上一次 in-flight，避免快速切换筛选时乱序回填。"
  }
}
