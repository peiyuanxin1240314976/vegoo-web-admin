{
  "_comment": "综合分析 - ECPM 分析（预估 vs 真实）。对应 types.ts: EcpmAnalysis。",
  "interaction": {
    "route": "/user-growth/comprehensive-analysis",
    "surface": "底部右「ECPM 分析」面积/折线图 + 四格指标",
    "trigger": "fetchComprehensiveAnalysisData 内并发 POST。"
  },
  "fieldDescription": {
    "request": {
      "date_start": {
        "type": "string",
        "required": true,
        "description": "统计区间开始 YYYY-MM-DD（含）。"
      },
      "date_end": {
        "type": "string",
        "required": true,
        "description": "统计区间结束 YYYY-MM-DD（含）。"
      },
      "s_app_id": { "type": "string", "required": true, "description": "应用 ID；'' 全部。" },
      "source": { "type": "string", "required": true, "description": "广告平台；'' 全部。" },
      "s_country_code": { "type": "string", "required": true, "description": "国家代码；'' 全部。" }
    },
    "response": {
      "data": {
        "type": "EcpmAnalysis",
        "required": true,
        "description": "序列 + 汇总 metrics（预格式化字符串）。"
      }
    },
    "EcpmAnalysis": {
      "dates": {
        "type": "string[]",
        "required": true,
        "description": "横轴标签，与 estimated/actual 等长。"
      },
      "estimated": {
        "type": "number[]",
        "required": true,
        "description": "预估 ECPM 序列（数值；图表 tooltip 可格式化为两位小数）。"
      },
      "actual": {
        "type": "number[]",
        "required": true,
        "description": "真实 ECPM 序列。"
      },
      "metrics": {
        "type": "object",
        "required": true,
        "description": "卡片区展示用预格式化字符串。"
      }
    },
    "EcpmAnalysisMetrics": {
      "estimatedEcpm": {
        "type": "string",
        "required": true,
        "description": "预估 ECPM 汇总展示。"
      },
      "actualEcpm": { "type": "string", "required": true, "description": "真实 ECPM 汇总展示。" },
      "biasRate": { "type": "string", "required": true, "description": "偏差率（如 -6.10%）。" },
      "biasAmount": { "type": "string", "required": true, "description": "偏差金额展示。" }
    }
  },
  "sampleRequest": {
    "date_start": "2026-03-14",
    "date_end": "2026-03-20",
    "s_app_id": "",
    "source": "",
    "s_country_code": ""
  },
  "sampleResponse": {
    "data": {
      "dates": ["03-14", "03-15", "03-16", "03-17", "03-18", "03-19", "03-20"],
      "estimated": [18.2, 18.5, 18.8, 19.0, 19.2, 19.5, 19.8],
      "actual": [17.9, 18.1, 18.3, 18.0, 18.4, 18.5, 18.6],
      "metrics": {
        "estimatedEcpm": "$19.80",
        "actualEcpm": "$18.60",
        "biasRate": "-6.10%",
        "biasAmount": "-$1.20"
      }
    }
  },
  "api": {
    "url": "POST /api/user-growth/comprehensive-analysis/ecpm-analysis",
    "method": "POST",
    "priority": "P1",
    "requestBody": "date_start, date_end, s_app_id, source, s_country_code",
    "responseBody": "EcpmAnalysis"
  },
  "apiSuggestion": {
    "notes": [
      "metrics 为预格式化字符串时可不按两位小数强制；若与图表数值同源，建议偏差类也保留两位小数。"
    ]
  }
}
