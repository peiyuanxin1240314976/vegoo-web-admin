{
  "_comment": "综合分析 - 顶部 KPI 卡片。对应 types.ts: KpiCard[]。",
  "interaction": {
    "route": "/user-growth/comprehensive-analysis",
    "surface": "KPI 卡片行（5 列栅格）",
    "trigger": "筛选后点击「查询」或 onMounted 与 fetchComprehensiveAnalysisData 聚合内并发请求。"
  },
  "fieldDescription": {
    "request": {
      "date_start": { "type": "string", "required": true, "description": "开始日期 YYYY-MM-DD。" },
      "date_end": { "type": "string", "required": true, "description": "结束日期 YYYY-MM-DD。" },
      "s_app_id": { "type": "string", "required": true, "description": "应用 ID；'' 全部。" },
      "source": { "type": "string", "required": true, "description": "广告平台；'' 全部。" },
      "s_country_code": { "type": "string", "required": true, "description": "国家代码；'' 全部。" }
    },
    "response": {
      "data": {
        "type": "KpiCard[]",
        "required": true,
        "description": "顶部 KPI 卡片列表，字段见 KpiCard。"
      }
    },
    "KpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片唯一标识。" },
      "title": { "type": "string", "required": true, "description": "KPI 标题。" },
      "subTitle": {
        "type": "string",
        "required": true,
        "description": "副标题/口径说明（如安装成本）。"
      },
      "primaryValue": {
        "type": "string",
        "required": true,
        "description": "主指标预格式化展示文案。"
      },
      "trendText": {
        "type": "string",
        "required": true,
        "description": "趋势幅度，不含箭头；百分比建议两位小数。"
      },
      "trendUp": { "type": "boolean", "required": true, "description": "true 上升，false 下降。" },
      "trendCompareLabel": {
        "type": "string",
        "required": false,
        "description": "对比期文案（如 vs昨日）；可选。"
      }
    }
  },
  "sampleRequest": {
    "date_start": "2026-03-14",
    "date_end": "2026-03-20",
    "s_app_id": "",
    "source": "",
    "s_country_code": ""
  },
  "sampleResponse": {
    "data": [
      {
        "id": "cpiToday",
        "title": "今日CPI（综合）",
        "subTitle": "安装成本",
        "primaryValue": "$2.38",
        "trendText": "5.20%",
        "trendUp": true,
        "trendCompareLabel": "vs昨日"
      },
      {
        "id": "installsToday",
        "title": "今日安装数",
        "subTitle": "买量用户",
        "primaryValue": "42,156",
        "trendText": "2.30%",
        "trendUp": true
      },
      {
        "id": "ecpmKpi",
        "title": "ECPM",
        "subTitle": "广告变现效率",
        "primaryValue": "19.20",
        "trendText": "5.20%",
        "trendUp": true
      },
      {
        "id": "roiD1Comprehensive",
        "title": "首日ROI（综合）",
        "subTitle": "回收率",
        "primaryValue": "87%",
        "trendText": "2.10%",
        "trendUp": true
      },
      {
        "id": "estProfit",
        "title": "预估利润",
        "subTitle": "今日",
        "primaryValue": "$3,358",
        "trendText": "8.40%",
        "trendUp": true
      }
    ]
  },
  "api": {
    "url": "POST /api/user-growth/comprehensive-analysis/kpi",
    "method": "POST",
    "priority": "P0",
    "requestBody": "date_start, date_end, s_app_id, source, s_country_code",
    "responseBody": "KpiCard[]"
  },
  "apiSuggestion": {
    "notes": [
      "primaryValue、trendText 为预格式化字符串；度量类百分比建议保留两位小数。",
      "trendUp 仅表示方向，trendText 不含箭头前缀。"
    ]
  }
}
