{
  "_comment": "账户成效页（Account Performance）接口结构说明文件：用于后端快速理解前端所需字段、返回结构与枚举口径。后端按 sampleResponse 的结构返回，即可与当前页面 mock 对齐并直接渲染：顶部 KPI、左侧应用×平台×账户树表、右侧渠道分布/预算使用率分布/首日ROI趋势/预警事项/今日消耗节奏。",
  "fieldDescription": {
    "root": {
      "dateRange": "默认日期范围（前端日期选择器回显用），格式：['YYYY-MM-DD','YYYY-MM-DD']",
      "summaryText": "表格底部汇总文案（可由后端计算后直接返回，或前端拼接）",
      "kpi": "顶部 KPI 卡片数组",
      "tableTree": "左侧树形表格数据：应用（一级）→ 平台（二级）→ 账户（三级）",
      "channelSpend": "右侧「渠道消耗分布」环形图数据（percent 可选）",
      "budgetUsageBuckets": "右侧「账户预算使用率分布」条形图分桶数据",
      "day1RoiTrend": "右侧「首日ROI趋势（7天）」折线图数据（按日/按点）",
      "alerts": "右侧「预警事项」列表",
      "todaySpendPace": "右侧「今日消耗节奏」面积折线图数据（按时间段）"
    },
    "kpiItem": {
      "type": "KPI 类型标识（前端用于选择图标/中间圆环取 spend）",
      "label": "KPI 标题（中文）",
      "value": "KPI 主值（已格式化字符串，如 '$17,022' / '97个' / '97%'）",
      "sub": "KPI 副文案（可选）",
      "detail": "KPI 详情说明（可选）",
      "compare": "对比文案（可选，如 '周环比 +8.5%'）",
      "compareUp": "对比方向（可选，true=上升/绿色；false=下降/红色）",
      "alert": "是否为预警类 KPI（可选，true 会高亮）"
    },
    "tableRow": {
      "id": "行唯一 id（树表 row-key）",
      "type": "行类型：'app' | 'platform' | 'account'",
      "name": "名称：应用名 / 平台名 / 账户名",
      "spend": "广告支出（数值，前端会 formatMoney 加 '$' 与千分位）",
      "budget": "预算（数值）",
      "usageRate": "预算使用率（数值百分比，例如 18.7 表示 18.7%）",
      "cpi": "CPI（数值）",
      "installs": "安装数（数值）",
      "roi1": "首日 ROI（百分比数值，例如 108 表示 108%）",
      "roi3": "3日 ROI（百分比数值）",
      "roi7": "7日 ROI（百分比数值）",
      "status": "状态：'normal' | 'warning' | 'roi_low'（当前前端用来渲染状态颜色/文案）",
      "statusText": "状态文案（可选，status 非 normal 时优先展示，如 'ROI偏低'）",
      "children": "子节点数组（可选，app 下是 platform；platform 下是 account）"
    },
    "channelSpendItem": {
      "name": "渠道名称（如 TikTok / Facebook / Google）",
      "value": "占比数值（当前 mock 里直接为百分比值）",
      "percent": "占比（可选；与 value 同口径时可省略）"
    },
    "budgetUsageBucket": {
      "range": "分桶区间（如 '0-20%'）",
      "count": "落在该分桶的账户数量"
    },
    "day1RoiTrendItem": {
      "date": "横轴点（当前 mock 为 '2/26' 这种展示文案；也可以用 'YYYY-MM-DD' 由前端格式化）",
      "roi": "首日 ROI（百分比数值，例如 95 表示 95%）"
    },
    "alertItem": {
      "id": "预警唯一 id",
      "type": "预警类型：'over_budget' | 'low_roi' | 'low_usage' | 'insufficient_balance' | 'roi_drop'",
      "title": "预警标题（中文）",
      "desc": "预警描述（中文）",
      "targetName": "命中对象名称（可选，如应用名/账户名）"
    },
    "todaySpendPaceItem": {
      "time": "时间段（如 '0-5h' / '14h' / '20-24h'）",
      "value": "该时间段消耗值（数值，单位由业务决定）"
    }
  },
