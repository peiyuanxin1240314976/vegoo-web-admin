{
  "_comment": "账户成效页 - 平台维度占位表（对应 modules/platform-performance-placeholder.vue）。",
  "fieldDescription": {
    "request": {
      "currentPage": {
        "type": "number",
        "required": true,
        "description": "当前页码，从 0 起算（与后端分页约定一致）。"
      },
      "dateStart": {
        "type": "string",
        "required": true,
        "description": "开始日期（YYYY-MM-DD）。"
      },
      "dateEnd": {
        "type": "string",
        "required": true,
        "description": "结束日期（YYYY-MM-DD）。"
      },
      "kw": {
        "type": "string",
        "required": false,
        "description": "关键词，可为空字符串。"
      },
      "ownerId": {
        "type": "string",
        "required": false,
        "description": "广告账户/负责人筛选，对应前端 ownerId。空字符串表示全部。"
      },
      "pageSize": {
        "type": "number",
        "required": true,
        "description": "每页条数。"
      },
      "appIds": {
        "type": "string[]",
        "required": false,
        "description": "应用筛选：不限为 []，单选为 [\"应用ID\"]（与账户成效页顶部应用筛选联动）。"
      },
      "source": {
        "type": "string",
        "required": false,
        "description": "广告平台筛选。空字符串表示全部。"
      }
    },
    "response": {
      "code": {
        "type": "number",
        "required": true,
        "description": "业务状态码，200 表示成功。"
      },
      "message": {
        "type": "string | null",
        "required": false,
        "description": "提示信息，成功时可为 null。"
      },
      "data": {
        "type": "object",
        "required": true,
        "description": "业务数据载体。"
      },
      "data.platformTotal": {
        "type": "number",
        "required": true,
        "description": "广告平台总数。"
      },
      "data.accountTotal": {
        "type": "number",
        "required": true,
        "description": "广告账户总数（用于底部文案）。"
      },
      "data.platforms": {
        "type": "PlatformPerformancePlatformRow[]",
        "required": true,
        "description": "表格平台行数据。"
      }
    },
    "PlatformPerformancePlatformRow": {
      "id": {
        "type": "string",
        "required": true,
        "description": "表格行唯一标识（前端 row-key）。"
      },
      "name": {
        "type": "string",
        "required": true,
        "description": "广告平台名称（如 Google、Facebook、Other 等）。"
      },
      "iconBg": {
        "type": "string",
        "required": true,
        "description": "平台图标背景色（hex）。"
      },
      "iconColor": {
        "type": "string",
        "required": true,
        "description": "平台图标文字颜色（hex）。"
      },
      "iconChar": {
        "type": "string",
        "required": true,
        "description": "平台图标字符（展示在圆形徽章中）。"
      },
      "accountCount": {
        "type": "number",
        "required": true,
        "description": "该平台广告账户数。"
      },
      "spend": {
        "type": "number",
        "required": true,
        "description": "广告支出花费（数值）。"
      },
      "budget": {
        "type": "number",
        "required": true,
        "description": "预算（数值）。"
      },
      "usageRate": {
        "type": "number",
        "required": true,
        "description": "预算使用率百分比（可超过 100）。"
      },
      "cpi": {
        "type": "number",
        "required": true,
        "description": "CPI（展示到合适小数位）。"
      },
      "installs": {
        "type": "number",
        "required": true,
        "description": "安装数。"
      },
      "firstThreeDayRoi": {
        "type": "FirstThreeDayRoi",
        "required": true,
        "description": "近三日每日一条 ROI：dates[i] 与 data[i] 一一对应，一条折线（一日一点）；表头由前端对 date 做本地化。"
      },
      "roi3": {
        "type": "number",
        "required": true,
        "description": "3 日 ROI（汇总百分比数值，可与折线并存）。"
      },
      "roi7": {
        "type": "number",
        "required": true,
        "description": "7 日 ROI（百分比数值）。"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["normal", "warning", "roi_low"],
        "description": "平台状态：normal=正常，warning=注意，roi_low=ROI 偏低。"
      }
    },
    "FirstThreeDayRoi": {
      "dates": {
        "type": "string[]",
        "required": true,
        "description": "近 N 日横轴（通常为 3 日），YYYY-MM-DD；与 data 等长、按下标对齐；顺序由产品决定（如新→旧）。"
      },
      "data": {
        "type": "number[]",
        "required": true,
        "description": "与 dates 等长的 ROI（百分比数值，如 94 表示 94%）；第 i 项为 dates[i] 当日值；可带小数。"
      }
    }
  },
  "sampleRequest": {
    "currentPage": 0,
