{
  "_comment": "账户成效页 - 平台维度占位表（对应 modules/platform-performance-placeholder.vue）。",
  "fieldDescription": {
    "request": {
      "dateRangeStart": {
        "type": "string",
        "required": true,
        "description": "开始日期（YYYY-MM-DD）。"
      },
      "dateRangeEnd": {
        "type": "string",
        "required": true,
        "description": "结束日期（YYYY-MM-DD）。"
      },
      "source": {
        "type": "string",
        "required": false,
        "description": "广告平台筛选。空字符串表示全部。"
      },
      "app": {
        "type": "string",
        "required": false,
        "description": "应用筛选。空字符串表示全部。"
      },
      "owner": {
        "type": "string",
        "required": false,
        "description": "负责人筛选。空字符串表示全部。"
      }
    },
    "response": {
      "platformTotal": {
        "type": "number",
        "required": true,
        "description": "广告平台总数。"
      },
      "accountTotal": {
        "type": "number",
        "required": true,
        "description": "广告账户总数（用于底部文案）。"
      },
      "platforms": {
        "type": "PlatformPerformancePlatformRow[]",
        "required": true,
        "description": "表格平台行数据。"
      }
    },
    "PlatformPerformancePlatformRow": {
      "id": {
        "type": "string",
        "required": true,
        "description": "表格行唯一标识（前端仅用于 key）。"
      },
      "name": {
        "type": "string",
        "required": true,
        "description": "广告平台名称（TikTok/Facebook/Google/Mintegral/Kwai/NewsBreak）。"
      },
      "iconBg": {
        "type": "string",
        "required": true,
        "description": "平台图标背景色（hex）。"
      },
      "iconColor": {
        "type": "string",
        "required": true,
        "description": "平台图标文字颜色（hex）。"
      },
      "iconChar": {
        "type": "string",
        "required": true,
        "description": "平台图标字符（展示在圆形徽章中）。"
      },
      "accountCount": {
        "type": "number",
        "required": true,
        "description": "该平台广告账户数。"
      },
      "spend": {
        "type": "number",
        "required": true,
        "description": "广告支出花费（数值）。"
      },
      "budget": {
        "type": "number",
        "required": true,
        "description": "预算（数值）。"
      },
      "usageRate": {
        "type": "number",
        "required": true,
        "description": "预算使用率百分比（0-100）。"
      },
      "cpi": {
        "type": "number",
        "required": true,
        "description": "CPI（展示到 2 位小数）。"
      },
      "installs": {
        "type": "number",
        "required": true,
        "description": "安装数。"
      },
      "roi1": {
        "type": "number",
        "required": true,
        "description": "首日 ROI（百分比数值）。"
      },
      "roi3": {
        "type": "number",
        "required": true,
        "description": "3 日 ROI（百分比数值）。"
      },
      "roi7": {
        "type": "number",
        "required": true,
        "description": "7 日 ROI（百分比数值）。"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["normal", "warning", "roi_low"],
        "description": "平台状态：normal=正常，warning=注意，roi_low=ROI 偏低。"
      }
    }
  },
  "sampleRequest": {
    "dateRangeStart": "2026-02-26",
    "dateRangeEnd": "2026-03-04",
    "source": "",
    "app": "",
    "owner": ""
  },
