{
  "_comment": "账户成效页 - 应用/账户 tab 占位表（对应 modules/app-performance-placeholder.vue）。广告账户维度指标集中在 adAccount 对象内，与 UI「广告账户」多级表头分组一致；筛选入参见 fieldDescription.request。sampleResponse 为节选页示例。",
  "fieldDescription": {
    "request": {
      "currentPage": {
        "type": "number",
        "required": true,
        "description": "当前页码（从 0 开始）。"
      },
      "pageSize": {
        "type": "number",
        "required": true,
        "description": "每页条数；若为 0 则由后端按约定使用默认条数（与前端分页组件联动时以实际约定为准）。"
      },
      "dateStart": {
        "type": "string",
        "required": true,
        "description": "开始日期（YYYY-MM-DD）。"
      },
      "dateEnd": {
        "type": "string",
        "required": true,
        "description": "结束日期（YYYY-MM-DD）。"
      },
      "keys": {
        "type": "string",
        "required": false,
        "description": "关键词搜索。应用层级关键词过滤。"
      },
      "kw": {
        "type": "string",
        "required": false,
        "description": "关键词搜索。空字符串表示不按关键词过滤。"
      },
      "ownerId": {
        "type": "string",
        "required": false,
        "description": "负责人 ID。空字符串表示全部。"
      },
      "appIds": {
        "type": "string[]",
        "required": false,
        "description": "应用 ID 列表（包名/业务 ID 等，与顶栏应用筛选一致）。空数组表示不按应用过滤；非空表示仅查询所选应用下账户。"
      },
      "source": {
        "type": "string",
        "required": false,
        "description": "广告平台筛选。空字符串表示全部。"
      }
    },
    "response": {
      "code": {
        "type": "number",
        "required": true,
        "description": "业务状态码，成功为 200。"
      },
      "message": {
        "type": "string | null",
        "required": false,
        "description": "提示信息，成功时可为 null。"
      },
      "data": {
        "type": "AppPerformanceTableData",
        "required": true,
        "description": "表格分页数据。"
      }
    },
    "AppPerformanceTableData": {
      "total": {
        "type": "number",
        "required": true,
        "description": "符合条件的广告账户总数（用于分页/底部文案，不必等于当前页条数）。"
      },
      "accounts": {
        "type": "AppPerformanceAccountRow[]",
        "required": true,
        "description": "当前页表格账户行数据。"
      }
    },
    "AppPerformanceAccountRow": {
      "appId": {
        "type": "string",
        "required": true,
        "description": "应用 ID（与顶栏/应用维度一致）。"
      },
      "appName": {
        "type": "string",
        "required": true,
        "description": "应用名称（展示用）。"
      },
      "platform": {
        "type": "string",
        "required": true,
        "description": "终端/系统平台展示文案（如 安卓、iOS），仅列表行字段；非请求筛选字段，亦非广告渠道名。"
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "广告平台/渠道（如 Facebook、Google、TikTok），与请求体 source 筛选语义一致。"
      },
      "adAccount": {
        "type": "AppPerformanceAdAccountMetrics",
        "required": true,
        "description": "广告账户分组：与 UI「广告账户」多级表头下子列一一对应（ID、名称、支出、预算、CPA、CPI、安装数）。"
      },
      "usageRate": {
        "type": "number",
        "required": true,
        "description": "预算使用率（百分比数值，通常 0–100，极端可大于 100）；一般可由 spend/budget 推导；无预算时可为 0。"
      },
      "firstThreeDayRoi": {
        "type": "FirstThreeDayRoi",
        "required": true,
        "description": "近三日每日一条 ROI：dates[i] 与 data[i] 一一对应；表头由前端对 date 做本地化（可与「广告账户」并列作为另一组多级表头）。"
      },
      "roi3": {
        "type": "number",
        "required": true,
        "description": "3 日 ROI 汇总指标（可与 firstThreeDayRoi 折线并存；口径由后端定义）。"
      },
      "roi7": {
        "type": "number",
        "required": true,
        "description": "7 日 ROI 汇总指标（口径由后端定义）。"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["normal", "warning", "roi_low"],
        "description": "账户状态：normal=正常，warning=注意，roi_low=ROI 偏低。"
      }
    },
    "AppPerformanceAdAccountMetrics": {
      "id": {
        "type": "string",
        "required": true,
        "description": "广告账户 ID（与 accountId 通常相同；前端 row-key 建议使用 adAccount.id）。"
      },
      "name": {
        "type": "string | null",
        "required": false,
        "description": "广告账户名称；无名称时可为 null，前端可回退展示 id。"
      },
      "accountId": {
        "type": "string",
        "required": true,
        "description": "广告账户 ID 展示用（可与 id 相同；允许空字符串）。"
      },
      "spend": {
        "type": "number",
        "required": true,
        "description": "广告支出花费（数值）。"
      },
      "budget": {
        "type": "number | null",
        "required": false,
        "description": "预算（数值）；无预算或未配置时可为 null。"
      },
      "cpa": {
        "type": "number | null",
        "required": false,
        "description": "CPA；无数据或未接入时可为 null。"
      },
      "cpi": {
        "type": "number",
        "required": true,
        "description": "CPI（展示到合适小数位）。"
      },
      "installs": {
        "type": "number",
        "required": true,
        "description": "安装数。"
      }
    },
    "FirstThreeDayRoi": {
      "dates": {
        "type": "string[]",
        "required": true,
        "description": "近 N 日横轴（通常为 3 日），YYYY-MM-DD；与 data 等长、按下标对齐；顺序由产品决定（如新→旧）。"
      },
      "data": {
        "type": "(number | null)[]",
        "required": true,
        "description": "与 dates 等长；第 i 项为 dates[i] 当日 ROI（百分比数值，如 94 表示 94%）；缺数或未统计用 null（如展示「-」）。"
      }
    }
  },
  "sampleRequest": {
    "currentPage": 0,
    "dateEnd": "2026-02-10",
    "dateStart": "2026-02-10",
    "kw": "",
    "keys": "",
    "ownerId": "",
    "pageSize": 0,
    "appIds": ["com.photo.ai.art.agecam.fx"],
    "source": ""
  },
