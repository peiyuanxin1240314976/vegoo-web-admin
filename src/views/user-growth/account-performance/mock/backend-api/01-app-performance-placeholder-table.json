{
  "_comment": "账户成效页 - 应用/账户 tab 占位表（对应 modules/app-performance-placeholder.vue）。",
  "fieldDescription": {
    "request": {
      "currentPage": {
        "type": "number",
        "required": true,
        "description": "当前页码（从 0 开始）。"
      },
      "pageSize": {
        "type": "number",
        "required": true,
        "description": "每页条数。"
      },
      "dateStart": {
        "type": "string",
        "required": true,
        "description": "开始日期（YYYY-MM-DD）。"
      },
      "dateEnd": {
        "type": "string",
        "required": true,
        "description": "结束日期（YYYY-MM-DD）。"
      },
      "kw": {
        "type": "string",
        "required": false,
        "description": "关键词搜索。空字符串表示不按关键词过滤。"
      },
      "ownerId": {
        "type": "string",
        "required": false,
        "description": "负责人 ID。空字符串表示全部。"
      },
      "appIds": {
        "type": "string[]",
        "required": false,
        "description": "应用筛选：不限为 []，单选为 [\"应用ID\"]。"
      },
      "source": {
        "type": "string",
        "required": false,
        "description": "广告平台筛选。空字符串表示全部。"
      }
    },
    "response": {
      "code": {
        "type": "number",
        "required": true,
        "description": "业务状态码，成功为 200。"
      },
      "message": {
        "type": "string | null",
        "required": false,
        "description": "提示信息，成功时可为 null。"
      },
      "data": {
        "type": "AppPerformanceTableData",
        "required": true,
        "description": "表格分页数据。"
      }
    },
    "AppPerformanceTableData": {
      "total": {
        "type": "number",
        "required": true,
        "description": "广告账户总数（用于分页/底部文案）。"
      },
      "accounts": {
        "type": "AppPerformanceAccountRow[]",
        "required": true,
        "description": "当前页表格账户行数据。"
      }
    },
    "AppPerformanceAccountRow": {
      "id": {
        "type": "string",
        "required": true,
        "description": "表格行唯一标识（前端仅用于 key）。"
      },
      "name": {
        "type": "string | null",
        "required": false,
        "description": "账户名称（用于展示）；无名称时可为 null，前端可回退展示 accountId。"
      },
      "accountId": {
        "type": "string",
        "required": true,
        "description": "账户 ID（展示在名称后缀，允许空字符串）。"
      },
      "platform": {
        "type": "string",
        "required": true,
        "description": "广告平台名称（如 TikTok/Facebook/Google/Mintegral/Kwai/NewsBreak）。"
      },
      "spend": {
        "type": "number",
        "required": true,
        "description": "广告支出花费（数值）。"
      },
      "budget": {
        "type": "number",
        "required": true,
        "description": "预算（数值）。"
      },
      "usageRate": {
        "type": "number",
        "required": true,
        "description": "预算使用率（百分比数值，通常 0–100，极端情况可大于 100）。"
      },
      "cpi": {
        "type": "number",
        "required": true,
        "description": "CPI（展示到合适小数位）。"
      },
      "installs": {
        "type": "number",
        "required": true,
        "description": "安装数。"
      },
      "roi1": {
        "type": "number",
        "required": true,
        "description": "首日 ROI（数值；后端口径可能为放大后的指标，不限于 0–100）。"
      },
      "roi3": {
        "type": "number",
        "required": true,
        "description": "3 日 ROI（数值）。"
      },
      "roi7": {
        "type": "number",
        "required": true,
        "description": "7 日 ROI（数值）。"
      },
      "status": {
        "type": "string",
        "required": true,
        "enum": ["normal", "warning", "roi_low"],
        "description": "账户状态：normal=正常，warning=注意，roi_low=ROI 偏低。"
      }
    }
  },
  "sampleRequest": {
    "currentPage": 0,
