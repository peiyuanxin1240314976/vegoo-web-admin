  "api": {
    "url": "POST /api/user-growth/account-performance/app-performance-placeholder-table",
    "method": "POST",
    "priority": "P1",
    "requestBody": "dateRangeStart, dateRangeEnd, source?, app?, owner?",
    "responseBody": "total, accounts"
  },
  "apiSuggestion": {
    "notes": [
      "status 枚举建议与前端展示逻辑一致：normal=正常，warning=注意，roi_low=ROI偏低。",
      "若后端返回真实 accountId，可直接替换 accountId 字段并确保为空值用空字符串（避免 null 处理）。"
    ]
  }
}
