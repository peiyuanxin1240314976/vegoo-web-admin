  "api": {
    "url": "POST /api/v1/datacenter/analysis/account-performance/app-performance-placeholder-table",
    "method": "POST",
    "priority": "P1",
    "requestBody": "currentPage, pageSize, dateStart, dateEnd, kw?, ownerId?, appIds?, source?",
    "responseBody": "code, message, data: { total, accounts }"
  },
  "apiSuggestion": {
    "notes": [
      "status 枚举建议与前端展示逻辑一致：normal=正常，warning=注意，roi_low=ROI偏低。",
      "name 可为 null：前端展示名称时建议回退为 accountId 或占位文案。",
      "roi1/roi3/roi7 为后端口径数值，可能与「百分比 0–100」不同；usageRate 在超支等场景可能大于 100。",
      "无数据时 data.accounts 返回 []，data.total 为 0；message 可为 null。"
    ]
  }
}
