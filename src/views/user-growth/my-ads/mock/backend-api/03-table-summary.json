{
  "_comment": "我的广告页 - 汇总 Tab：统计卡、趋势序列、广告平台分布、应用支出占比条、消耗进度表。对应 types.ts: MyAdsSummaryTabMock。",
  "fieldDescription": {
    "request": {
      "staff_id": { "type": "string", "required": true, "description": "优化师 ID。" },
      "start_date": { "type": "string", "required": true, "description": "YYYY-MM-DD。" },
      "end_date": { "type": "string", "required": true, "description": "YYYY-MM-DD。" }
    },
    "response": {
      "data": {
        "type": "MyAdsSummaryTabMock",
        "required": true,
        "description": "汇总 Tab 全量展示数据。"
      },
      "trend": {
        "days": { "type": "string[]", "required": true, "description": "横轴标签，如 M/D。" },
        "spend": {
          "type": "number[]",
          "required": true,
          "description": "广告支出序列（与货币轴一致）。"
        },
        "profit": { "type": "number[]", "required": true, "description": "预估利润序列。" },
        "roiPct": {
          "type": "number[]",
          "required": true,
          "description": "首日 ROI 百分比数值（非 0-1）；与右侧 Y 轴一致。"
        }
      },
      "sourcePie": {
        "type": "array",
        "required": true,
        "description": "广告平台分布；value 为金额，name 为展示名，color 为图表色。"
      },
      "statCards": {
        "type": "object",
        "required": true,
        "description": "四张统计卡的文案与强调色，值为已格式化或待绑定的展示串。"
      },
      "progressList": {
        "type": "array",
        "required": true,
        "description": "消耗进度表行。progress 可为超出 100 的百分比。statusType: ok|warn|inactive|null。roi 为预格式化文案；无 roi 时用 roi1（数值，百分比非 0-1）由前端格式化为两位小数 + %。"
      }
    }
  },
