{
  "_comment": "广告平台信息 - KPI 卡片栅格（含 spark）。对应 types: AdPlatformInfoKpiCard[]。",
  "fieldDescription": {
    "request": {
      "s_campaign_id": {
        "type": "string",
        "required": true,
        "description": "广告系列 ID。"
      },
      "date_range": {
        "type": "string",
        "required": false,
        "enum": ["7d", "30d", "90d"],
        "default": "30d",
        "description": "统计周期。"
      },
      "t_start_date": {
        "type": "string",
        "required": false,
        "description": "区间开始 YYYY-MM-DD。"
      },
      "t_end_date": { "type": "string", "required": false, "description": "区间结束 YYYY-MM-DD。" }
    },
    "response": {
      "kpis": {
        "type": "AdPlatformInfoKpiCard[]",
        "required": true,
        "description": "KPI 卡片列表。"
      }
    },
    "AdPlatformInfoKpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片 id。" },
      "title": { "type": "string", "required": true, "description": "标题。" },
      "metricKey": {
        "type": "string",
        "required": true,
        "description": "指标键，见 types AdPlatformInfoMetricKey。"
      },
      "valueText": { "type": "string", "required": true, "description": "主数值展示字符串。" },
      "deltaPct": { "type": "number", "required": true, "description": "环比变化 %。" },
      "accent": {
        "type": "string",
        "required": true,
        "enum": ["blue", "green", "amber", "red", "purple", "teal"],
        "description": "主题色。"
      },
      "spark": { "type": "number[]", "required": true, "description": "迷你序列。" },
      "variant": { "type": "string", "required": false, "enum": ["top", "stat", "retention"] },
      "noteText": { "type": "string", "required": false },
      "icon": { "type": "string", "required": false }
    }
  },
  "sampleRequest": {
    "s_campaign_id": "s_cmp_mock_001",
    "date_range": "30d",
    "t_start_date": "2026-03-01",
    "t_end_date": "2026-03-29"
  },
  "sampleResponse": {
    "kpis": [
      {
        "id": "spend",
        "title": "总支出",
        "metricKey": "spend",
        "valueText": "$120,500.00",
        "deltaPct": 12.3,
        "accent": "blue",
        "variant": "top",
        "spark": [82, 88, 84, 90, 96, 94, 102, 98, 112, 108, 116, 120.5]
      },
      {
        "id": "roi",
        "title": "平均 ROI",
        "metricKey": "roi",
        "valueText": "200.00%",
        "deltaPct": 12.3,
        "accent": "amber",
        "variant": "top",
        "spark": [150, 158, 162, 170, 178, 185, 192, 188, 195, 198, 202, 200]
      }
    ]
  },
  "api": {
    "url": "POST /api/user-growth/ad-platform-analysis/ad-platform-info/kpi-cards",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_campaign_id (必填), date_range?, t_start_date?, t_end_date?",
    "responseBody": "{ kpis }"
  },
  "apiSuggestion": {
    "notes": ["卡片较多时仍可单接口返回；若单卡独立刷新可再拆（一般不推荐）。"]
  }
}
