{
  "_comment": "广告平台信息 - KPI 卡片栅格（含 spark）。对应 types: AdPlatformInfoKpiCard[]。",
  "fieldDescription": {
    "request": {
      "s_campaign_id": {
        "type": "string",
        "required": true,
        "description": "广告系列 ID。"
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "广告平台编码（与大屏筛选 `source` 口径一致，如 google/facebook）。"
      },
      "date_range": {
        "type": "string",
        "required": false,
        "enum": ["7d", "30d", "90d"],
        "default": "30d",
        "description": "统计周期。"
      },
      "t_start_date": {
        "type": "string",
        "required": false,
        "description": "区间开始 YYYY-MM-DD。"
      },
      "t_end_date": { "type": "string", "required": false, "description": "区间结束 YYYY-MM-DD。" }
    },
    "response": {
      "kpis": {
        "type": "AdPlatformInfoKpiCard[]",
        "required": true,
        "description": "KPI 卡片列表。"
      }
    },
    "AdPlatformInfoKpiCard": {
      "id": { "type": "string", "required": true, "description": "卡片 id。" },
      "title": { "type": "string", "required": true, "description": "标题。" },
      "metricKey": {
        "type": "string",
        "required": true,
        "description": "指标键，见 types AdPlatformInfoMetricKey。"
      },
      "valueText": { "type": "string", "required": true, "description": "主数值展示字符串。" },
      "deltaPct": { "type": "number", "required": true, "description": "环比变化 %。" },
      "accent": {
        "type": "string",
        "required": true,
        "enum": ["blue", "green", "amber", "red", "purple", "teal"],
        "description": "主题色。"
      },
      "spark": { "type": "number[]", "required": true, "description": "迷你序列。" },
      "variant": { "type": "string", "required": false, "enum": ["top", "stat", "retention"] },
      "noteText": { "type": "string", "required": false },
      "icon": { "type": "string", "required": false }
    }
  },
  "sampleRequest": {
    "s_campaign_id": "s_cmp_mock_001",
    "source": "google",
    "date_range": "30d",
    "t_start_date": "2026-03-01",
    "t_end_date": "2026-03-29"
  },
  "sampleResponse": {
    "kpis": [
      {
        "id": "spend",
        "title": "总支出",
        "metricKey": "spend",
        "valueText": "$120,500.00",
        "deltaPct": 12.3,
        "accent": "blue",
        "variant": "top",
        "spark": [82, 88, 84, 90, 96, 94, 102, 98, 112, 108, 116, 120.5]
      },
      {
        "id": "roi",
        "title": "平均 ROI",
        "metricKey": "roi",
        "valueText": "200.00%",
        "deltaPct": 12.3,
        "accent": "amber",
        "variant": "top",
        "spark": [150, 158, 162, 170, 178, 185, 192, 188, 195, 198, 202, 200]
      }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/ad-platform/ad-platform-info/kpi-cards",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_campaign_id (必填), source (必填), date_range?, t_start_date?, t_end_date?",
    "responseBody": "{ kpis }（位于网关 BaseResponse.data）"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`useAdPlatformInfo` 首屏 `Promise.all` 之一；渲染 `modules/kpi-grid.vue`。",
        "prerequisite": "需有效 `s_campaign_id`。"
      },
      {
        "moment": "用户点击顶栏「查询」",
        "detail": "`load()` 全量重拉，本接口随批次更新 KPI。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "`date_range` 默认 `30d`；`s_campaign_id` 取自路由 `?id=`。",
    "dedupe": "与同页其他 7 个 POST 同次触发。"
  },
  "apiSuggestion": {
    "notes": [
      "卡片较多时仍可单接口返回；若单卡独立刷新可再拆（一般不推荐）。",
      "联调 URL 以 `src/api/user-growth/ad-platform-info.ts` 为准。"
    ]
  }
}
