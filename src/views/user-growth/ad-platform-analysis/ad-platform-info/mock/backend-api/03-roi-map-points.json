{
  "_comment": "广告平台信息 - ROI 地图/区域散点。对应 types: AdPlatformInfoMapPoint[]。",
  "fieldDescription": {
    "request": {
      "s_campaign_id": { "type": "string", "required": true, "description": "广告系列 ID。" },
      "source": {
        "type": "string",
        "required": true,
        "description": "广告平台编码（与大屏筛选 `source` 口径一致，如 google/facebook）。"
      },
      "date_range": {
        "type": "string",
        "required": false,
        "enum": ["7d", "30d", "90d"],
        "default": "30d"
      },
      "t_start_date": { "type": "string", "required": false },
      "t_end_date": { "type": "string", "required": false }
    },
    "response": {
      "mapPoints": {
        "type": "AdPlatformInfoMapPoint[]",
        "required": true,
        "description": "国家/区域点位。"
      }
    },
    "AdPlatformInfoMapPoint": {
      "name": { "type": "string", "required": true, "description": "英文地名。" },
      "cnName": { "type": "string", "required": false, "description": "中文名。" },
      "value": { "type": "number", "required": true, "description": "指标值（与图表语义一致）。" }
    }
  },
  "sampleRequest": {
    "s_campaign_id": "s_cmp_mock_001",
    "source": "google",
    "date_range": "30d"
  },
  "sampleResponse": {
    "mapPoints": [
      { "name": "United States", "cnName": "美国", "value": 86.2 },
      { "name": "Germany", "cnName": "德国", "value": 78.3 }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/ad-platform/ad-platform-info/roi-map-points",
    "method": "POST",
    "priority": "P0",
    "requestBody": "s_campaign_id (必填), source (必填), date_range?, t_start_date?, t_end_date?",
    "responseBody": "{ mapPoints }（位于网关 BaseResponse.data）"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`useAdPlatformInfo` 首屏 `Promise.all` 之一；渲染 `modules/roi-map-panel.vue`。",
        "prerequisite": "需有效 `s_campaign_id`。"
      },
      {
        "moment": "用户点击顶栏「查询」",
        "detail": "`load()` 全量重拉地图散点。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "`date_range` 默认 `30d`；`s_campaign_id` 取自路由 `?id=`。",
    "dedupe": "与同页其他 7 个 POST 同次触发。"
  },
  "apiSuggestion": {
    "notes": [
      "点位数量大时可按 zoom/视口分页，本契约为全量示例。",
      "联调 URL 以 `src/api/user-growth/ad-platform-info.ts` 为准。"
    ]
  }
}
