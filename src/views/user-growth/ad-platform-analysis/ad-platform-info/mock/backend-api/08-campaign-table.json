{
  "_comment": "广告平台信息 - 广告系列明细表。对应 types: AdPlatformInfoCampaignRow[]。",
  "fieldDescription": {
    "request": {
      "s_campaign_id": {
        "type": "string",
        "required": true,
        "description": "主广告系列 ID（详情主体）；若表内为子系列，仍按该筛选维度返回。"
      },
      "source": {
        "type": "string",
        "required": true,
        "description": "广告平台编码（与大屏筛选 `source` 口径一致，如 google/facebook）。"
      },
      "date_range": {
        "type": "string",
        "required": false,
        "enum": ["7d", "30d", "90d"],
        "default": "30d"
      },
      "t_start_date": { "type": "string", "required": false },
      "t_end_date": { "type": "string", "required": false }
    },
    "response": {
      "campaigns": {
        "type": "AdPlatformInfoCampaignRow[]",
        "required": true,
        "description": "明细行。"
      }
    },
    "AdPlatformInfoCampaignRow": {
      "id": { "type": "string", "required": true, "description": "行 id / 子系列 id。" },
      "campaign": { "type": "string", "required": true, "description": "广告系列名称。" },
      "spend": { "type": "number", "required": true, "description": "花费 USD。" },
      "revenue": { "type": "number", "required": true },
      "profit": { "type": "number", "required": true },
      "roi": { "type": "number", "required": true },
      "cpi": { "type": "number", "required": true },
      "installs": { "type": "number", "required": true },
      "status": { "type": "string", "required": true, "enum": ["active", "paused"] }
    }
  },
  "sampleRequest": {
    "s_campaign_id": "s_cmp_mock_001",
    "source": "google",
    "date_range": "30d"
  },
  "sampleResponse": {
    "campaigns": [
      {
        "id": "cmp_1",
        "campaign": "P7262_a_3_17geo_09",
        "spend": 5720.0,
        "revenue": 8008.0,
        "profit": 2288.0,
        "roi": 140.0,
        "cpi": 0.78,
        "installs": 7320,
        "status": "active"
      },
      {
        "id": "cmp_2",
        "campaign": "P7263_a_4_17geo_10",
        "spend": 6440.0,
        "revenue": 9016.0,
        "profit": 2576.0,
        "roi": 140.0,
        "cpi": 0.84,
        "installs": 7840,
        "status": "paused"
      }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/ad-platform/ad-platform-info/campaign-table",
    "method": "POST",
    "priority": "P1",
    "requestBody": "s_campaign_id (必填), source (必填), date_range?, t_start_date?, t_end_date?",
    "responseBody": "{ campaigns }（位于网关 BaseResponse.data）"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`useAdPlatformInfo` 首屏 `Promise.all` 之一；渲染 `modules/campaign-table.vue`。",
        "prerequisite": "需有效 `s_campaign_id`。"
      },
      {
        "moment": "用户点击顶栏「查询」",
        "detail": "`load()` 全量重拉系列明细表。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "`date_range` 默认 `30d`；`s_campaign_id` 取自路由 `?id=`。",
    "dedupe": "与同页其他 7 个 POST 同次触发。"
  },
  "apiSuggestion": {
    "notes": [
      "后续若需分页，增加 pageNum/pageSize 与 total，本契约为全量示例。",
      "联调 URL 以 `src/api/user-growth/ad-platform-info.ts` 为准。"
    ]
  }
}
