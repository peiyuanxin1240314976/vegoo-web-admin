{
  "_comment": "广告平台分析大屏 - Top10 广告系列。对应 Api.UserGrowth.AdPlatformCampaignTop10RowDto[]。",
  "fieldDescription": {
    "request": {
      "appId": { "type": "string", "required": false },
      "platform": { "type": "string", "required": false },
