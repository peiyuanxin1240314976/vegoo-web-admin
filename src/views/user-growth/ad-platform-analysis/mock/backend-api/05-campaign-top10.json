        "type": "string",
        "required": false,
        "description": "可选：筛选某平台的 Top10。"
      },
      "dateStart": { "type": "string", "required": true },
      "dateEnd": { "type": "string", "required": true },
      "currentPage": { "type": "number", "required": true },
      "pageSize": { "type": "number", "required": true },
      "groupBy": { "type": "string", "required": false },
      "userId": { "type": "string", "required": false }
    },
    "response": {
      "data": {
        "type": "AdPlatformCampaignTop10RowDto[]",
        "required": true,
        "description": "网关 unwrap 后即为数组。"
      }
    },
    "AdPlatformCampaignTop10RowDto": {
      "campaignId": {
        "type": "string",
        "required": true,
        "description": "广告系列主键，用于跳转系列详情。"
      },
      "campaignName": { "type": "string", "required": true },
      "cost": { "type": "number", "required": true, "description": "花费（USD）。" },
      "cpi": { "type": "number", "required": true, "description": "CPI（USD）。" },
      "roi": { "type": "number", "required": true, "description": "ROI 数值。" },
      "source": { "type": "string", "required": true, "description": "广告平台展示名。" },
      "appId": {
        "type": "string",
        "required": false,
        "description": "可选：应用 ID（用于跳转系列详情 query）。"
      },
      "appName": { "type": "string", "required": false, "description": "可选：应用名称。" }
    }
  },
  "sampleRequest": {
    "appId": "",
    "platform": "",
    "source": "",
    "dateStart": "2026-03-01",
    "dateEnd": "2026-03-30",
