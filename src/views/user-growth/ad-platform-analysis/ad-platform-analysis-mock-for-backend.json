{
  "_comment": "广告平台分析大屏（Ad Platform Analysis）接口结构说明文件：用于后端快速理解前端所需字段、返回结构与枚举口径。后端按 sampleResponse 的结构返回，即可与当前页面 mock 对齐并直接渲染：顶部渠道 KPI 卡片、渠道 ROI 趋势（最近30天，折线面积图，图例隐藏）、用户质量热力图、渠道指标对比详情表（支持全字段排序与分页）。注意：当前前端 mock 仅包含「渠道维度」，App/平台筛选目前是入口占位；后端接入后可根据 appId/platform/channelKey 返回对应维度数据。",
  "fieldDescription": {
    "root": {
      "groupBy": "聚合维度（建议：'channel' | 'platform' | 'app'），当前页面主要按渠道展示",
      "viewDesc": "视图描述（便于排查/对齐口径，例如：'最近30天，按渠道汇总'）",
      "filtersMeta": "筛选项元数据（可选；用于前端下拉选项渲染）",
      "kpiCards": "顶部 KPI 卡片（渠道维度）",
      "roiTrend": "渠道 ROI 趋势（最近30天）",
      "qualityHeatmap": "用户质量热力图（行=渠道，列=D1/D7/D30留存、付费率、ARPU）",
      "metricsTable": "渠道指标对比详情表（表格行数据）",
      "footer": "底部汇总（可选，用于后续扩展或全局校验）"
    },
    "filtersMeta": {
      "apps": "App 下拉选项数组（label/value），value 建议用 appId",
      "platforms": "平台下拉选项数组（label/value），value 建议用 'ios'/'android'/'all' 等",
      "channels": "渠道下拉选项数组（label/value），value 建议用规范化 channelKey，如 google/facebook/tiktok"
    },
    "kpiCard": {
      "id": "卡片唯一 id（建议同 channelKey）",
      "name": "渠道展示名（如 Google Ads / Facebook）",
      "logo": "渠道 logo（可选）",
      "roi": "ROI 数值（例如 1.52）",
      "roiChange": "ROI 环比变化百分比（例如 8.5 表示 +8.5%）",
      "roiChangeUp": "ROI 是否上升（true=上升，false=下降）",
      "cost": "花费展示值（如 '$850K'；也可改为数值 + 货币，由前端格式化）",
      "revenue": "收入展示值（如 '$1.29M'）",
      "cpi": "CPI 展示值（如 '$2.15'）",
      "trendData": "迷你趋势数组（number[]，用于卡片小折线面积图）"
    },
    "roiTrend": {
      "dates": "横轴日期数组（string[]，展示用，可为 'YYYY-MM-DD' 由前端格式化）",
      "series": "折线序列数组（每个渠道一条线）"
    },
    "roiTrendSeries": {
      "name": "序列名（渠道名）",
      "data": "与 dates 对齐的 ROI 数值数组（number[]）"
    },
    "qualityHeatmapRow": {
      "channel": "渠道名称（行名）",
      "d1Retention": "D1 留存（百分比数值，例如 58 表示 58%）",
      "d7Retention": "D7 留存（百分比数值）",
      "d30Retention": "D30 留存（百分比数值）",
      "payRate": "付费率（百分比数值）",
      "arpu": "ARPU（数值，例如 3.28；单位可约定为 USD）"
    },
    "metricRow": {
      "channel": "渠道名称（表格行 key）",
      "cost": "花费（展示值，如 '$850K'）",
      "revenue": "收入（展示值，如 '$1.29M'）",
      "roi": "ROI（数值）",
      "roiTrendUp": "ROI 趋势是否上升（用于小条颜色）",
      "roas": "ROAS（数值）",
      "cpi": "CPI（数值）",
      "cpiTrendUp": "CPI 趋势是否上升（用于小条颜色）",
      "installs": "安装量（展示值，如 '395K'）",
      "userQualityD7": "User Quality (D7)（百分比数值）",
      "userQualityD7TrendUp": "User Quality (D7) 趋势是否上升",
      "userQualityPay": "User Quality(Pay%)（百分比数值）",
      "userQualityPayTrendUp": "User Quality(Pay%) 趋势是否上升",
      "ltv7": "LTV_7（数值）",
      "ltv30": "LTV_30（数值）",
      "status": "状态枚举：excellent / average / poor",
      "statusText": "状态中文（可选；也可由前端映射）"
    },
    "footer": {
      "channelCount": "渠道数量",
      "totalSpend": "总花费（数值，建议最小单位：美元）",
      "avgRoi": "平均 ROI（数值）",
      "generatedAt": "数据生成时间（ISO 字符串，可选）"
    }
