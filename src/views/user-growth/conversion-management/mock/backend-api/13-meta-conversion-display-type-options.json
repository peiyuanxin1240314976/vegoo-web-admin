{
  "_comment": "转化管理（name Tab 弹窗）- 转化展示分类选项（付费/激活/行为/收入）。当前前端写死常量；若后端希望统一配置或按权限控制，可提供该接口。",
  "fieldDescription": {
    "response": {
      "options": {
        "type": "Option[]",
        "required": true,
        "description": "转化展示分类选项列表。"
      }
    },
    "Option": {
      "label": {
        "type": "string",
        "required": true,
        "description": "展示文案。也可返回 i18nKey 让前端翻译。"
      },
      "value": {
        "type": "string",
        "required": true,
        "enum": ["paid", "activation", "behavior", "revenue"],
        "description": "展示分类值（入库值）。"
      }
    },
    "usageNote": {
      "description": "该字段对应表单 ConversionMappingForm.conversionDisplayType；用于把不同平台转化归类展示（与平台侧 platformConversionType 不同）。"
    }
  },
  "sampleRequest": {},
  "sampleResponse": {
    "options": [
      { "label": "付费转化", "value": "paid" },
      { "label": "激活转化", "value": "activation" },
      { "label": "行为转化", "value": "behavior" },
      { "label": "收入转化", "value": "revenue" }
    ]
  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/conversion-management/meta-conversion-display-type-options",
    "method": "POST",
    "priority": "P1",
    "requestBody": "无（或 {}）",
    "responseBody": "options: { label, value }[]，value 为 paid|activation|behavior|revenue"
  },
  "apiSuggestion": {
    "notes": [
      "若后端不提供该接口，前端可继续写死枚举，不影响主流程。",
      "若需要 i18n，建议返回 i18nKey（例如 conversionManagement.conversionTypePaid）。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "弹窗加载（可选）",
        "detail": "编辑/新增映射弹窗中「转化展示分类」下拉；当前前端写死枚举，未请求本接口。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "空 body；返回四类 paid/activation/behavior/revenue。",
    "dedupe": "可缓存。"
  }
}
