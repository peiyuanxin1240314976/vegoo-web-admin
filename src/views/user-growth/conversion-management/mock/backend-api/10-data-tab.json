  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/conversion-management/data-tab",
    "method": "POST",
    "priority": "P0",
    "requestBody": "startDate?, endDate?, platform, appPackage|app, source|adPlatform, conversionType",
    "responseBody": "kpi (conversionCount/conversionValue/averageValue/activeTypeCount), tableRows (树表), sidePanels (typeDistribution, top10, valueTrend30d, accountShare)"
  },
  "apiSuggestion": {
    "notes": [
      "日期范围入参须使用 startDate/endDate（YYYY-MM-DD），禁止再用 dateRange 数组作为契约主字段。",
      "页面会每 30s 刷新：建议接口支持缓存或增量计算，避免高频全量聚合压力。",
      "tree 表格层级固定 3 层；若后端返回更多层级，前端当前展示不支持。",
      "「转化数据明细」树表：`tableRows` 根级示例 ≥3 组；`level=conversion` 行须覆盖广告平台转化类型六类（与 README、`01-mappings-list` 一致）；`sidePanels.typeDistribution.name` 亦须六类写全以便与环形图/表格列联动验收。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面初始化",
        "detail": "路由 `conversion-management/index.vue` 在 `activeTab === 'data'` 时 `watch(..., { immediate: true })` 触发首次 `loadDataTab`。",
        "prerequisite": "依赖登录态；默认 startDate/endDate 为最近 7 天（应用当前日，见 app-now）。"
      },
      {
        "moment": "用户操作",
        "detail": "组件 `conversion-data-filters.vue` 变更日期/平台/应用/转化类型或点击「查询」时 `emit('search')` → `handleDataSearch` → `loadDataTab`。"
      },
      {
        "moment": "定时刷新",
        "detail": "仅 data Tab 激活时每 30s `useIntervalFn` 调用 `loadDataTab`（与筛选条件一致）；切换回 name Tab 时暂停。"
      }
    ],
    "defaultSelection": "platform/app/conversionType 默认空字符串表示全部；日期默认最近 7 天映射为 startDate、endDate。",
    "dedupe": "使用 dataLoadSeq 丢弃过期响应；刷新中跳过新一轮定时任务避免重叠。"
  }
}
