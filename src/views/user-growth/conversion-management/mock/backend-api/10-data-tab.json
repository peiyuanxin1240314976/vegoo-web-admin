            "accountGroupName": "ACCOUNT GROUP 1",
            "accountName": "PT_262__bgeoo_0903_b",
            "conversionCount": 56789,
            "conversionValue": 321000,
            "share": 19.8,
            "trendPoints": [20, 22, 21, 25, 24, 23, 26, 27, 26, 28, 29, 30, 31, 32],
            "children": [
              {
                "id": "g-1-a-1-c-1",
                "level": "conversion",
                "accountGroupName": "ACCOUNT GROUP 1",
                "accountName": "PT_262__bgeoo_0903_b",
                "appPackage": "com.locate.phone.track",
                "conversionName": "PT_262__bgeoo_0903_b | DOWNLOAD | main",
                "platformConversionType": "DOWNLOAD",
                "conversionCount": 12000,
                "conversionValue": 98000,
                "share": 4.2,
                "trendPoints": [10, 12, 11, 13, 14, 13, 15, 16, 15, 17, 18, 18, 19, 20]
              }
