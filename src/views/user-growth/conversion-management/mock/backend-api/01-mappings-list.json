  },
  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/conversion-management/mappings-list",
    "method": "POST",
    "priority": "P0",
    "requestBody": "current, size, platform, appPackage|app, conversionType, status, keyword（均为 body 字段）",
    "responseBody": "records (ConversionMappingItem[]), current, size, total"
  },
  "apiSuggestion": {
    "notes": [
      "前端兼容字段：appPackage 与 app 语义相同；后端优先取 appPackage。",
      "conversionId 必须返回 string（不要返回 number）。",
      "sampleResponse.records：platform/status/billingType 闭合 enum 写全；platformConversionType 六类写全；systemDisplayName 与 `mock/data.ts` 一致覆盖「订阅转化、首次安装、IAP购买、加购、页面浏览、发起结账」，与六类 platform 转化一一对应。"
    ]
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面初始化",
        "detail": "`index.vue` name Tab 下 `useTable` 挂载后首次 `getData()`，api 当前为 `fetchConversionMappingListMock`，接真接口后改为 `fetch*`。",
        "prerequisite": "无"
      },
      {
        "moment": "用户操作",
        "detail": "`conversion-filters.vue` 点搜索 → `handleSearch` 合并筛选到 `searchParams` 后 `getData()`；表格换页 `handleSizeChange` / `handleCurrentChange`。",
        "prerequisite": "无"
      }
    ],
    "defaultSelection": "current=1,size=20；platform/app/conversionType/status/keyword 默认空或空串表示全部。",
    "dedupe": "与 mappings-stats 建议使用相同筛选快照；列表与统计可并行请求。"
  }
}
