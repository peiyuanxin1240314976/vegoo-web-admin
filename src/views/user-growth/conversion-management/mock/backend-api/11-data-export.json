{
  "_comment": "转化管理（data Tab）- 导出（可选）。按筛选条件导出 data tab 的树表与关键指标。",
  "fieldDescription": {
    "request": {
      "dateRange": {
        "type": "[string,string]",
        "required": false,
        "description": "日期范围（YYYY-MM-DD）。"
      },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["", "android", "ios"],
        "description": "终端平台筛选。"
      },
      "appPackage": {
        "type": "string",
        "required": false,
        "description": "应用包名筛选（推荐字段）。"
      },
      "app": {
        "type": "string",
        "required": false,
        "description": "历史兼容字段，语义同 appPackage。"
      },
      "source": {
        "type": "string",
        "required": false,
        "enum": ["", "google", "meta", "tiktok", "mintegral"],
        "description": "广告平台筛选（推荐字段）。"
      },
      "adPlatform": {
        "type": "string",
        "required": false,
        "description": "历史兼容字段，语义同 source。"
      },
      "conversionType": {
        "type": "string",
        "required": false,
        "description": "平台转化类型筛选。"
      },
      "format": {
        "type": "string",
        "required": false,
        "default": "xlsx",
        "enum": ["xlsx", "csv"],
        "description": "导出格式。"
      }
    },
    "responseOptionA_fileStream": {
      "contentType": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet 或 text/csv",
      "contentDisposition": "attachment; filename=conversion-data.xlsx",
      "description": "方案 A：直接返回文件流。"
    },
    "responseOptionB_downloadUrl": {
      "type": "object",
      "description": "方案 B：返回下载链接。",
      "fields": {
        "downloadUrl": { "type": "string", "required": true, "description": "可下载链接。" },
        "expireAt": {
          "type": "string",
          "required": false,
          "description": "过期时间（ISO 字符串）。"
        }
      }
    },
    "exportContentSuggestion": {
      "description": "建议导出内容包含：KPI（4项）、树表明细（group/account/conversion 三层摊平或保留层级列）、Top10、30天趋势（可选）。"
    }
  },
  "sampleRequest": {
    "dateRange": ["2026-03-11", "2026-03-17"],
    "platform": "",
    "appPackage": "",
    "app": "",
    "source": "",
    "adPlatform": "",
    "conversionType": "",
    "format": "xlsx"
  },
  "sampleResponse": {
    "downloadUrl": "https://files.example.com/download/conversion-data.xlsx?sign=yyy",
    "expireAt": "2026-03-17T12:00:00Z"
  },
  "apiSuggestion": {
    "method": "GET",
    "path": "/ugc/conversion/data/export",
    "queryParams": [
      "dateRangeStart",
      "dateRangeEnd",
      "platform",
      "appPackage|app",
      "source|adPlatform",
      "conversionType",
      "format"
    ],
    "notes": [
      "若导出生成耗时较长，建议异步任务导出并返回 taskId。",
      "导出树表时建议增加 level 字段列（group/account/conversion），便于数据透视分析。"
    ]
  }
}
