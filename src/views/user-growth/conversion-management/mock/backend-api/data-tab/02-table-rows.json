  "api": {
    "url": "POST /api/v1/datacenter/analysis/user-growth/conversion-management/data-tab/table-rows",
    "method": "POST",
    "priority": "P0",
    "requestBody": "同 01-overview-kpi",
    "responseBody": "tableRows: ConversionDataRow[]"
  },
  "apiSuggestion": {
    "notes": [
      "根级 tableRows ≥3 条 group；conversion 行 platformConversionType 六类须在示例中写全（跨行覆盖即可）。"
    ]
  },
  "interaction": {
    "triggers": [
