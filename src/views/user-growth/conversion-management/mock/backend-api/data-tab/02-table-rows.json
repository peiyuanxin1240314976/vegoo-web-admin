{
  "_comment": "转化管理 data Tab — 三层树表主数据。与 `01-overview-kpi`、`03-side-panels` 共用 request。",
  "fieldDescription": {
    "request": {
      "startDate": { "type": "string", "required": false, "description": "起始日 YYYY-MM-DD。" },
      "endDate": { "type": "string", "required": false, "description": "结束日 YYYY-MM-DD。" },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["", "android", "ios"],
        "description": "终端平台；空串全部。"
      },
      "appId": {
        "type": "string",
        "required": false,
        "description": "应用筛选（自有应用 ID）。空字符串表示全部。见 backend-fields「接口请求 · 应用筛选（appId）」。"
      },
      "source": {
        "type": "string",
        "required": false,
        "enum": ["", "google", "meta", "tiktok", "mintegral"],
        "description": "广告平台。"
      },
      "adPlatform": { "type": "string", "required": false, "description": "兼容 source。" },
      "conversionType": {
        "type": "string",
        "required": false,
        "description": "转化类型筛选；空串全部。"
      }
    },
    "response": {
      "tableRows": {
        "type": "ConversionDataRow[]",
        "required": true,
        "description": "树根数组：group → account → conversion。"
      }
    },
    "ConversionDataRow": {
      "id": { "type": "string", "required": true, "description": "行 ID。" },
      "level": {
        "type": "string",
        "required": true,
        "enum": ["group", "account", "conversion"],
        "description": "层级。"
      },
      "accountGroupName": { "type": "string", "required": false, "description": "账户组。" },
      "accountName": { "type": "string", "required": false, "description": "账户。" },
      "appId": {
        "type": "string",
        "required": false,
        "description": "自有应用 ID（conversion 行；与 `01-mappings-list` 的 `appId` 语义一致）。"
      },
      "conversionName": { "type": "string", "required": false, "description": "转化名。" },
      "platformConversionType": {
        "type": "string",
        "required": false,
        "enum": [
          "PHONE_CALL_LEAD",
          "DOWNLOAD",
          "PURCHASE",
          "ADD_TO_CART",
          "PAGE_VIEW",
          "BEGIN_CHECKOUT"
        ],
        "description": "广告平台转化类型（conversion 行色条）。"
      },
      "conversionCount": { "type": "number", "required": true, "description": "转化次数。" },
      "conversionValue": { "type": "number", "required": true, "description": "转化价值。" },
      "share": { "type": "number", "required": true, "description": "占比 0-100。" },
      "trendPoints": {
        "type": "number[]",
        "required": true,
        "description": "火花线点数（现网 14）。"
      },
      "children": { "type": "ConversionDataRow[]", "required": false, "description": "子节点。" }
    }
  },
  "sampleRequest": {
    "startDate": "2026-03-11",
    "endDate": "2026-03-17",
