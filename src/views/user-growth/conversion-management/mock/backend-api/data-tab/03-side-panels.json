{
  "_comment": "转化管理 data Tab — 右侧四块：类型分布、Top10、30 日趋势、账户分段占比。与 `01`、`02` 共用 request。",
  "fieldDescription": {
    "request": {
      "startDate": { "type": "string", "required": false, "description": "起始日 YYYY-MM-DD。" },
      "endDate": { "type": "string", "required": false, "description": "结束日 YYYY-MM-DD。" },
      "platform": {
        "type": "string",
        "required": false,
        "enum": ["", "android", "ios"],
        "description": "终端平台。"
      },
      "appId": {
        "type": "string",
        "required": false,
        "description": "应用筛选（自有应用 ID）。空字符串表示全部。见 backend-fields「接口请求 · 应用筛选（appId）」。"
      },
      "source": {
        "type": "string",
        "required": false,
        "enum": ["", "google", "meta", "tiktok", "mintegral"],
        "description": "广告平台。"
      },
      "adPlatform": { "type": "string", "required": false, "description": "兼容 source。" },
      "conversionType": { "type": "string", "required": false, "description": "转化类型。" }
    },
    "response": {
      "sidePanels": {
        "type": "ConversionDataSidePanels",
        "required": true,
        "description": "右侧面板聚合。"
      }
    },
    "ConversionDataSidePanels": {
      "typeDistribution": {
        "type": "ConversionTypeDistributionItem[]",
        "required": true,
        "description": "环形图：六类转化类型占比。"
      },
      "top10": { "type": "ConversionTop10Item[]", "required": true, "description": "Top10。" },
      "valueTrend30d": {
        "type": "ConversionValueTrendPoint[]",
        "required": true,
        "description": "近 30 日趋势（示例可截断，联调宜满 30 点）。"
      },
      "accountShare": {
        "type": "ConversionAccountShareItem[]",
        "required": true,
        "description": "账户分段占比。"
      }
    },
    "ConversionTypeDistributionItem": {
      "name": { "type": "string", "required": true, "description": "类型名（与六类枚举一致）。" },
      "value": { "type": "number", "required": true, "description": "占比 0-100。" },
      "count": { "type": "number", "required": false, "description": "可选条数。" }
    },
    "ConversionTop10Item": {
      "name": { "type": "string", "required": true, "description": "名称。" },
      "value": { "type": "number", "required": true, "description": "指标值。" }
    },
    "ConversionValueTrendPoint": {
      "date": { "type": "string", "required": true, "description": "YYYY-MM-DD。" },
      "value": { "type": "number", "required": true, "description": "当日值。" }
    },
    "ConversionAccountShareItem": {
      "accountName": { "type": "string", "required": true, "description": "账户名。" },
      "segments": {
        "type": "{type:string,percent:number}[]",
        "required": true,
        "description": "各转化类型占比，合计约 100。"
      }
    }
  },
