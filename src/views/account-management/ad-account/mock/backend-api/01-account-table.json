{
  "_comment": "账户管理 · 广告账户 — 分页列表。对应 types.ts: AccountTableQuery / AdAccountItem。网关若统一包裹，业务体为 data 内对象；与 Api.Common.PaginatedResponse 对齐时使用 records、current、size、total。",
  "fieldDescription": {
    "request": {
      "current": {
        "type": "number",
        "required": true,
        "description": "当前页码，从 1 开始。",
        "default": 1
      },
      "size": { "type": "number", "required": true, "description": "每页条数。", "default": 20 },
      "keyword": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "关键词，匹配账户名或 ID。"
      },
      "source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台筛选，空为全部。"
      },
      "accountType": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "账户类型：直投 / 代投，空为全部。"
      },
      "status": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "状态筛选，空为全部。"
      },
      "appId": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "应用筛选，空字符串表示全部。"
      }
    },
    "response": {
      "records": { "type": "AdAccountItem[]", "required": true, "description": "当前页记录。" },
      "total": { "type": "number", "required": true, "description": "总条数。" },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" }
    }
  },
  "sampleRequest": {
    "current": 1,
    "size": 20,
    "keyword": "",
    "source": "",
    "accountType": "",
    "status": "",
    "appId": ""
  },
  "sampleResponse": {
    "code": 200,
    "message": "success",
    "data": {
      "records": [
        {
          "id": "ACC-001",
          "accountName": "Google-US-Main",
          "source": "Google Ads",
          "agency": "直投",
          "accountType": "直投",
          "balance": 12450,
          "monthSpend": 85420,
          "status": "正常",
          "bcBm": "Vegoo Google BM",
          "apps": ["BloodSugar2", "WeatherApp"],
          "platform": ["安卓"],
          "purposes": ["广告投放", "用户获取"],
          "credential": "AdCost",
          "spendLimit": 200000,
          "spendProgress": 42.7,
          "currency": "USD",
          "lastRechargeTime": "2024-01-25",
          "lastRechargeAmount": 2000,
          "createTime": "2023-01-15",
          "remark": "美国主力投放账户"
        }
      ],
      "total": 248,
      "current": 1,
      "size": 20
    }
  },
  "api": {
    "url": "POST /api/config-management/account/table",
    "method": "POST",
    "priority": "P0",
    "requestBody": "AccountTableQuery",
    "responseBody": "PaginatedResponse<AdAccountItem>"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "页面首屏初始化",
        "detail": "`/config-management/account-management` 进入后切换至「广告账户」Tab，`ad-account-tab.vue` onMounted 拉取列表。",
        "prerequisite": "`AccountApiSource.accountTable === true` 时走本地 mock，不调用网关；为 false 时发起本 POST。"
      },
      {
        "moment": "用户操作",
        "detail": "父级搜索词变更、`reloadList`；行点击打开详情侧边栏不改变列表数据源。"
      }
    ],
    "defaultSelection": "current=1，size=20，筛选默认空串表示不限。",
    "dedupe": "与 Tab 切换互不取消；按页面实现可能全量拉取后前端分页。"
  }
}
