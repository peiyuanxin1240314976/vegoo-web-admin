{
  "_comment": "账户管理 - 导出广告账户列表。后端返回文件流，前端需在 http 层处理 responseType: blob。",
  "fieldDescription": {
    "request": {
      "keyword": { "type": "string", "required": false, "description": "关键词搜索。" },
      "source": { "type": "string", "required": false, "description": "广告平台筛选。" },
      "accountType": { "type": "string", "required": false, "description": "账户类型筛选。" },
      "status": { "type": "string", "required": false, "description": "状态筛选。" },
      "appId": {
        "type": "string",
        "required": false,
        "description": "应用筛选，空字符串表示全部。"
      }
    },
    "response": {
      "note": "后端返回二进制文件流，响应头 Content-Disposition: attachment; filename=accounts_xxx.csv"
    }
  },
  "sampleRequest": {
    "keyword": "",
    "source": "",
    "accountType": "",
    "status": "",
    "appId": ""
  },
  "sampleResponse": {
    "code": 200,
    "message": "success",
    "data": {
      "downloadUrl": "https://example.com/exports/account_20260327.csv",
      "taskId": "export_account_20260327_001",
      "_note": "若网关直接返回 blob，可无 JSON body；此处为异步导出任务示例。"
    }
  },
  "api": {
    "url": "POST /api/config-management/account/export",
    "method": "POST",
    "priority": "P1",
    "requestBody": "Partial<AccountTableQuery>",
    "responseBody": "blob | { downloadUrl?, taskId? }"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "页头导出按钮，`exportAccountList`；`AccountApiSource.exportAccount === true` 时可仅提示不请求。"
      }
    ],
    "defaultSelection": "导出条件与当前列表筛选一致（若实现）。",
    "dedupe": "无"
  }
}
