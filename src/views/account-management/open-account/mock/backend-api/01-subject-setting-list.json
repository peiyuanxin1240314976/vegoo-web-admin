  "api": {
    "url": "POST /api/account-management/open-account/subject-settings/list",
    "method": "POST",
    "priority": "P0",
    "requestBody": "keyword?, platformStatus?, hasBusinessLicense?, sortOrder?, current?, size?",
    "responseBody": "records: SubjectSettingItem[], current, size, total"
  },
  "apiSuggestion": {
    "notes": [
      "后端按 updateTime 排序并返回稳定结构；空数据仍返回 records: []。",
      "keyword 建议同时支持 subjectId/subjectName 模糊匹配，大小写不敏感。"
    ]
  }
}
