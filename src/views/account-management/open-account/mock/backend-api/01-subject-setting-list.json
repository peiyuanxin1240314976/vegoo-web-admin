{
  "_comment": "开户主体配置-分页列表查询。仅返回列表，不包含顶部卡片统计。",
  "interaction": {
    "entry": "页面进入后自动加载；筛选栏与分页参数变化后重新请求。",
    "uiBinding": [
      "index.vue -> loadList()",
      "modules/subject-setting-toolbar.vue -> 4 个筛选项",
      "列表分页器 -> current / size"
    ],
    "emptyState": "返回 records=[] 时展示表格空态，不阻塞新建主体。"
  },
  "fieldDescription": {
    "request": {
      "keyword": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "关键字，匹配 subjectId 或 subjectName；空字符串表示不过滤。"
      },
      "platformStatus": {
        "type": "string",
        "required": false,
        "enum": ["all", "facebook", "tiktok", "both", "none"],
        "default": "all",
        "description": "平台状态筛选：all 全部、facebook 仅 Facebook 可用、tiktok 仅 TikTok 可用、both 双平台可用、none 双平台均不可用。"
      },
      "hasBusinessLicense": {
        "type": "string",
        "required": false,
        "enum": ["all", "yes", "no"],
        "default": "all",
        "description": "营业执照筛选：all 全部、yes 有执照、no 无执照。"
      },
      "sortOrder": {
        "type": "string",
        "required": false,
        "enum": ["updated_desc", "updated_asc"],
        "default": "updated_desc",
        "description": "按更新时间排序：updated_desc 最近更新优先，updated_asc 最早更新优先。"
      },
      "current": {
        "type": "number",
        "required": false,
        "default": 1,
        "description": "当前页码，从 1 开始。"
      },
      "size": {
        "type": "number",
        "required": false,
        "default": 10,
        "description": "每页条数。"
      }
    },
    "response": {
      "records": {
        "type": "SubjectSettingItem[]",
        "required": true,
        "description": "主体配置列表。无数据时返回空数组 []。"
      },
      "current": {
        "type": "number",
        "required": true,
        "description": "当前页码。"
      },
      "size": {
        "type": "number",
        "required": true,
        "description": "每页条数。"
      },
      "total": {
        "type": "number",
        "required": true,
        "description": "总条数。"
      }
    },
    "SubjectSettingItem": {
      "subjectId": {
        "type": "string",
        "required": true,
        "description": "主体唯一标识。"
      },
      "subjectName": {
        "type": "string",
        "required": true,
        "description": "主体名称。"
      },
      "businessLicense": {
        "type": "string",
        "required": true,
        "description": "营业执照地址或文件标识；空字符串表示未上传。"
      },
      "facebookEnabled": {
        "type": "boolean",
        "required": true,
        "description": "Facebook 是否可用。"
      },
      "facebookRemark": {
        "type": "string",
        "required": true,
        "description": "Facebook 备注。"
      },
      "tiktokEnabled": {
        "type": "boolean",
        "required": true,
        "description": "TikTok 是否可用。"
      },
      "tiktokRemark": {
        "type": "string",
        "required": true,
        "description": "TikTok 备注。"
      },
      "inputTime": {
        "type": "string",
        "required": true,
        "description": "录入时间，格式 YYYY-MM-DD HH:mm:ss。"
      },
      "creatorId": {
        "type": "number | null",
        "required": true,
        "description": "创建人 ID。"
      },
      "createTime": {
        "type": "string",
        "required": true,
        "description": "创建时间，格式 YYYY-MM-DD HH:mm:ss。"
      },
      "updaterId": {
        "type": "number | null",
        "required": true,
        "description": "更新人 ID。"
      },
      "updateTime": {
        "type": "string",
        "required": true,
        "description": "更新时间，格式 YYYY-MM-DD HH:mm:ss。"
      }
    }
  },
  "sampleRequest": {
    "keyword": "",
    "platformStatus": "all",
    "hasBusinessLicense": "all",
    "sortOrder": "updated_desc",
    "current": 1,
    "size": 10
  },
