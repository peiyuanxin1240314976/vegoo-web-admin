{
  "_comment": "开户页面 - 导出开户记录。",
  "fieldDescription": {
    "request": {
      "keyword": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "关键词筛选。"
      },
      "source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台筛选。"
      },
      "status": {
        "type": "string",
        "required": false,
        "default": "",
        "enum": ["", "待分配", "已激活", "开户失败"],
        "description": "状态筛选。"
      },
      "agency": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "代理商筛选。"
      },
      "appIds": {
        "type": "string[]",
        "required": false,
        "default": [],
        "description": "应用筛选 ID 列表（当前页面仅支持单选，最多传 1 个）。"
      }
    },
    "response": {
      "fileStream": {
        "type": "binary",
        "required": true,
        "description": "HTTP 响应体为原始文件二进制流（blob），不是 JSON 业务体。"
      },
      "contentType": {
        "type": "string",
        "required": true,
        "description": "响应头 Content-Type，推荐 xlsx/csv 对应 MIME。"
      },
      "contentDisposition": {
        "type": "string",
        "required": true,
        "description": "响应头 Content-Disposition，需包含 attachment 与文件名。"
      }
    }
  },
  "sampleRequest": {
    "keyword": "",
    "source": "",
    "status": "",
    "agency": "",
    "appIds": []
  },
  "sampleResponse": {
    "_note": "该接口返回二进制文件流，无法用 JSON 展示 sampleResponse 业务体。联调以 Content-Type/Content-Disposition + blob 为准。"
  },
  "api": {
    "url": "POST /api/account-management/open-account/export",
    "method": "POST",
    "priority": "P1",
    "requestBody": "Partial<OpenAccountTableQuery>",
    "responseBody": "binary file stream (blob) + Content-Type + Content-Disposition"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "点击导出按钮时触发，筛选条件与列表保持一致。",
        "prerequisite": "无。"
      }
    ],
    "defaultSelection": "筛选为空时导出全部。",
    "dedupe": "允许同条件重复触发，每次请求直接返回文件流下载。"
  },
  "apiSuggestion": {
    "notes": [
      "前端使用 requestBlob/responseType='blob' 接收并下载文件。",
      "后端不得返回 taskId/downloadUrl JSON 作为该接口主响应。",
      "无数据时仍返回合法空文件（可仅含表头），保持文件流语义不变。"
    ]
  }
}
