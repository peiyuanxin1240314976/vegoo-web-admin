{
  "_comment": "开户页面 - 新建开户记录。",
  "fieldDescription": {
    "request": {
      "source": { "type": "string", "required": true, "description": "广告平台。" },
      "app": { "type": "string", "required": true, "description": "应用名称。" },
      "platform": {
        "type": "string",
        "required": true,
        "enum": ["安卓", "iOS", "网页"],
        "description": "投放平台。"
      },
      "accountType": {
        "type": "string",
        "required": true,
        "enum": ["企业户", "个人户", "小额广告户"],
        "description": "开户类型。"
      },
      "agency": { "type": "string", "required": true, "description": "归属代理商。" },
      "amount": { "type": "string", "required": true, "description": "开户金额（字符串输入）。" },
      "applicant": { "type": "string", "required": true, "description": "申请人。" },
      "adAccountId": { "type": "string", "required": false, "description": "广告账户 ID。" },
      "adAccountName": { "type": "string", "required": false, "description": "广告账户名称。" },
      "credential": { "type": "string", "required": false, "description": "凭据名称。" },
      "remark": { "type": "string", "required": false, "description": "备注。" }
    },
    "response": {
      "data": { "type": "OpenAccountItem", "required": true, "description": "创建后的开户记录。" }
    }
  },
  "sampleRequest": {
