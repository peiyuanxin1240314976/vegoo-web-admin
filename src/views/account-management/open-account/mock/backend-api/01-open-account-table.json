{
  "_comment": "开户页面 - 开户记录分页列表。对应 OpenAccountTableQuery / OpenAccountItem。",
  "fieldDescription": {
    "request": {
      "current": {
        "type": "number",
        "required": true,
        "default": 1,
        "description": "当前页码，从 1 开始。"
      },
      "size": { "type": "number", "required": true, "default": 20, "description": "每页条数。" },
      "keyword": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "关键词（申请ID/应用）。"
      },
      "source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台筛选，空字符串表示全部。"
      },
      "status": {
        "type": "string",
        "required": false,
        "default": "",
        "enum": ["", "待分配", "已激活", "开户失败"],
        "description": "开户状态筛选。"
      },
      "agency": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "代理商筛选。"
      },
      "appIds": {
        "type": "string[]",
        "required": false,
        "default": [],
        "description": "应用筛选 ID 列表（当前页面仅支持单选，最多传 1 个）。"
      }
    },
    "response": {
      "records": { "type": "OpenAccountItem[]", "required": true, "description": "当前页记录。" },
      "total": { "type": "number", "required": true, "description": "总条数。" },
      "current": { "type": "number", "required": true, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "description": "每页条数。" }
    }
  },
