{
  "_comment": "BC 管理页面 - BC 分页列表。对应 BcTableQuery / BcItem。",
  "fieldDescription": {
    "request": {
      "current": { "type": "number", "required": true, "default": 1, "description": "当前页码。" },
      "size": { "type": "number", "required": true, "default": 10, "description": "每页条数。" },
      "keyword": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "关键词（BM ID / 名称）。"
      },
      "source": {
        "type": "string",
        "required": false,
        "default": "",
        "description": "广告平台筛选。"
      },
      "status": {
        "type": "string",
        "required": false,
        "default": "",
        "enum": ["", "健康", "可用", "不再使用", "封禁", "其他"],
        "description": "状态筛选。"
      },
      "ownerType": {
        "type": "string",
        "required": false,
        "default": "",
        "enum": ["", "企业户", "个人户", "小额广告户"],
        "description": "开户主体筛选。"
      },
      "banRecord": {
        "type": "string",
        "required": false,
        "default": "",
        "enum": ["", "有", "无"],
        "description": "封户记录筛选。"
      }
    },
    "response": {
      "records": { "type": "BcItem[]", "required": true, "description": "当前页记录。" },
      "total": { "type": "number", "required": true, "description": "总条数。" },
      "current": { "type": "number", "required": true, "description": "当前页。" },
      "size": { "type": "number", "required": true, "description": "页大小。" }
    }
  },
