  "api": {
    "url": "POST /api/config-management/agency",
    "method": "POST",
    "priority": "P0",
    "requestBody": "AgencyFormModel",
    "responseBody": "AgencyItem"
  },
  "interaction": {
    "triggers": [
      {
        "moment": "用户操作",
        "detail": "页头「新建代理商」按钮打开弹窗，提交后调用 `createAgency`。"
      }
    ],
    "defaultSelection": "无",
    "dedupe": "提交按钮防重复。"
  }
}
