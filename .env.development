# 【开发】环境变量

# 应用部署基础路径（如部署在子目录 /admin，则设置为 /admin/）
VITE_BASE_URL = /

# API 请求基础路径（开发环境设置为 / 使用代理，生产环境设置为完整后端地址）
VITE_API_URL = /

# 代理目标地址（开发环境通过 Vite 代理转发请求到此地址，解决跨域问题）
# VITE_API_PROXY_URL = http://dev.hoovog.com
VITE_API_PROXY_URL = http://7036d27c.r38.cpolar.top

# Delete console
VITE_DROP_CONSOLE = false

# 为 true 且 getUser 返回的 permissionConfig.routePermissions.routeNames 非空时，前端菜单按路由 name 过滤（后端未就绪前勿开）
# VITE_USE_ROUTE_NAMES_MENU = true